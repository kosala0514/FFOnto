    rdfs:domain ffonto:Vegetation ;
    rdfs:range ffonto:ForestEcosystem .

ffonto:triggeredByFire
    a owl:ObjectProperty ;
    rdfs:label "triggered by fire" ;
    rdfs:comment "Indicates that a seed release mechanism is activated by wildfire heat or fire conditions." ;
    rdfs:domain ffonto:SeedReleaseMechanism ;
    rdfs:range ffonto:ForestFire.

ffonto:triggeredByFireOf
    a owl:ObjectProperty ;
    rdfs:label "triggered by fire of" ;
    rdfs:comment "Inverse - Indicates that a seed release mechanism is activated by wildfire heat or fire conditions." ;
    rdfs:range ffonto:SeedReleaseMechanism ;
    rdfs:domain ffonto:ForestFire.

ffonto:triggeredByFire owl:inverseOf ffonto:triggeredByFireOf .

ffonto:modifiesSoilCondition
    a owl:ObjectProperty ;
    rdfs:label "modifies soil condition" ;
    rdfs:comment "Indicates that a wildfire alters the condition of soil, such as reducing infiltration or increasing hydrophobicity." ;
    rdfs:domain ffonto:ForestFire;
    rdfs:range ffonto:SoilCondition .

ffonto:modifiesSoilConditionOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:label "inverse of modifies soil condition"@en  .

ffonto:modifiesSoilConditionOf owl:inverseOf ffonto:modifiesSoilCondition .

ffonto:affectsGroundwaterRecharge
    a owl:ObjectProperty ;
    rdfs:label "affects groundwater recharge" ;
    rdfs:comment "Indicates that a wildfire influences groundwater recharge rates by altering soil permeability and vegetation cover." ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Groundwater .

ffonto:affectsGroundwaterRechargeOf
    a owl:ObjectProperty ;
