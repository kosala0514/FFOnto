ffonto:PlantSpecies
    a owl:Class ;
    rdfs:label "Plant Species" ;
    rdfs:comment "Represents specific species of plants that may regrow after a wildfire." .

ffonto:SeedReleaseMechanism rdf:type owl:Class ;
