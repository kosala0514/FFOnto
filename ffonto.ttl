ffonto:waterSafeToDrink rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WellWater ;
    rdfs:range xsd:boolean .

ffonto:particulateLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:AirPollution ;
    rdfs:range xsd:float .

ffonto:coversSmokeDamage rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:InsurancePolicy ;
    rdfs:range xsd:boolean .

ffonto:buildingBurned
    a owl:DatatypeProperty ;
    rdfs:label "building burned" ;
    rdfs:comment "Indicates whether the building was burned in the wildfire." ;
    rdfs:domain ffonto:Building ;
    rdfs:range xsd:boolean .

ffonto:buildingDestroyed
    a owl:DatatypeProperty ;
    rdfs:label "building destroyed" ;
    rdfs:comment "Indicates whether the building was completely destroyed." ;
    rdfs:domain ffonto:Building ;
    rdfs:range xsd:boolean .

ffonto:vehicleDamaged
    a owl:DatatypeProperty ;
    rdfs:label "vehicle damaged" ;
    rdfs:comment "Indicates whether a vehicle suffered wildfire damage." ;
    rdfs:domain ffonto:Vehicle ;
    rdfs:range xsd:boolean .

ffonto:roofCollapsed
    a owl:DatatypeProperty ;
    rdfs:label "roof collapsed" ;
    rdfs:comment "Indicates whether the roof of a building collapsed due to wildfire." ;
    rdfs:domain ffonto:Roof ;
    rdfs:range xsd:boolean .

ffonto:windowsBroken
    a owl:DatatypeProperty ;
    rdfs:label "windows broken" ;
    rdfs:comment "Indicates whether windows were broken due to heat or impact." ;
    rdfs:domain ffonto:Window ;
    rdfs:range xsd:boolean .

ffonto:coveredWithAsh
    a owl:DatatypeProperty ;
    rdfs:label "covered with ash" ;
    rdfs:comment "Indicates whether a vehicle is covered with ash from wildfire smoke." ;
    rdfs:domain ffonto:Vehicle ;
    rdfs:range xsd:boolean .

ffonto:vehicleWindowsMelted
    a owl:DatatypeProperty ;
    rdfs:label "vehicle windows melted" ;
    rdfs:comment "Indicates whether the windows of a vehicle melted due to extreme heat." ;
    rdfs:domain ffonto:Vehicle ;
    rdfs:range xsd:boolean .

ffonto:chimneyStanding
    a owl:DatatypeProperty ;
    rdfs:label "chimney standing" ;
    rdfs:comment "Indicates whether a chimney remains standing after the wildfire." ;
    rdfs:domain ffonto:Chimney ;
    rdfs:range xsd:boolean .

ffonto:smokeRising
    a owl:DatatypeProperty ;
    rdfs:label "smoke rising" ;
    rdfs:comment "Indicates whether smoke is still rising from a building after a wildfire." ;
    rdfs:domain ffonto:Building ;
    rdfs:range xsd:boolean .

ffonto:solarPanelDamaged
    a owl:DatatypeProperty ;
    rdfs:label "solar panel damaged" ;
    rdfs:comment "Indicates whether solar panels installed on a building are damaged." ;
    rdfs:domain ffonto:SolarPanel ;
    rdfs:range xsd:boolean .

ffonto:produceSafeToEat
    a owl:DatatypeProperty ;
    rdfs:label "produce safe to eat"@en ;
    rdfs:comment "Indicates whether the agricultural produce is considered safe for consumption (true/false) after contamination assessment."@en ;
    rdfs:domain ffonto:AgriculturalProduce ;
    rdfs:range  xsd:boolean .

ffonto:ashContaminationLevel
    a owl:DatatypeProperty ;
    rdfs:label "ash contamination level"@en ;
    rdfs:comment "A human-readable or coded value describing the level of ash contamination (e.g. 'low', 'moderate', 'high', or measurement notes)."@en ;
    rdfs:domain ffonto:AgriculturalProduce ;
    rdfs:range  xsd:string .

ffonto:removalByProfessionals
    a owl:DatatypeProperty ;
    rdfs:label "removal by professionals required" ;
    rdfs:comment "Specifies whether the hazardous waste must be removed by trained professionals." ;
    rdfs:domain ffonto:HazardousWasteGuideline ;
    rdfs:range xsd:boolean .

ffonto:disposalInstruction
    a owl:DatatypeProperty ;
    rdfs:label "disposal instruction" ;
    rdfs:comment "Provides instructions for safely disposing of hazardous waste after a wildfire." ;
    rdfs:domain ffonto:HazardousWasteGuideline ;
    rdfs:range xsd:string .

ffonto:coverageAvailable
    a owl:DatatypeProperty ;
    rdfs:label "coverage available" ;
    rdfs:comment "Indicates whether coverage is available under the insurance policy." ;
    rdfs:domain ffonto:InsurancePolicy ;
    rdfs:range xsd:boolean .
 
ffonto:claimRequired
    a owl:DatatypeProperty ;
    rdfs:label "claim required" ;
    rdfs:comment "Specifies whether a formal insurance claim must be submitted to receive compensation for the damage." ;
    rdfs:domain ffonto:InsurancePolicy ;
    rdfs:range xsd:boolean .

ffonto:particulateConcentration
    a owl:DatatypeProperty ;
    rdfs:label "particulate concentration" ;
    rdfs:comment "Represents the concentration of particulate matter in the air pollution measurement." ;
    rdfs:domain ffonto:AirPollution ;
    rdfs:range xsd:float .

ffonto:exposureDuration
    a owl:DatatypeProperty ;
    rdfs:label "exposure duration" ;
    rdfs:comment "Represents the length of time individuals are exposed to air pollution." ;
    rdfs:domain ffonto:AirPollution ;
    rdfs:range xsd:duration .

ffonto:healthRiskLevel
    a owl:DatatypeProperty ;
    rdfs:label "health risk level" ;
    rdfs:comment "Describes the level of health risk associated with exposure to air pollution (e.g., low, moderate, high)." ;
    rdfs:domain ffonto:AirPollution ;
    rdfs:range xsd:string .

ffonto:speciesDiversityIncrease
    a owl:DatatypeProperty ;
    rdfs:label "species diversity increase" ;
    rdfs:comment "Indicates whether plant species diversity increases after vegetation regrowth." ;
    rdfs:domain ffonto:VegetationRegrowth ;
    rdfs:range xsd:boolean .

ffonto:regrowthDensity
    a owl:DatatypeProperty ;
    rdfs:label "regrowth density" ;
    rdfs:comment "Describes the density level of vegetation regrowth (e.g., sparse, moderate, dense)." ;
    rdfs:domain ffonto:VegetationRegrowth ;
    rdfs:range xsd:string .

ffonto:infiltrationRate
    a owl:DatatypeProperty ;
    rdfs:label "infiltration rate" ;
    rdfs:comment "Represents the rate at which water infiltrates into the soil." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:float .

ffonto:groundwaterRechargeRate
    a owl:DatatypeProperty ;
    rdfs:label "groundwater recharge rate" ;
    rdfs:comment "Represents the rate at which groundwater is replenished after infiltration." ;
    rdfs:domain ffonto:Groundwater ;
    rdfs:range xsd:float .

ffonto:runoffIntensity
    a owl:DatatypeProperty ;
    rdfs:label "runoff intensity" ;
    rdfs:comment "Describes the intensity of surface runoff (e.g., low, moderate, high)." ;
    rdfs:domain ffonto:Runoff ;
    rdfs:range xsd:string .

ffonto:fireConfidenceLevel
    a owl:DatatypeProperty ;
    rdfs:label "fire confidence level" ;
    rdfs:comment "Represents the confidence level of fire detection, often derived from satellite observations." ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range xsd:string .

ffonto:fireRadiativePower
    a owl:DatatypeProperty ;
    rdfs:label "fire radiative power" ;
    rdfs:comment "Represents the radiative power of a fire event, indicating its intensity." ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range xsd:float .

ffonto:firePersistence
    a owl:DatatypeProperty ;
    rdfs:label "fire persistence" ;
    rdfs:comment "Represents the duration or persistence of a fire event over time." ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range xsd:float .


