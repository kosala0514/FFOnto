    rdfs:domain ffonto:Runoff ;
    rdfs:range ffonto:Watershed .

ffonto:occursInWatershedOf
    a owl:ObjectProperty ;
    rdfs:label "occurs in watershed of" ;
    rdfs:comment "Inverse - Indicates the watershed where runoff flows and accumulates." ;
    rdfs:range ffonto:Runoff ;
    rdfs:domain ffonto:Watershed .

ffonto:occursInWatershedOf owl:inverseOf ffonto:occursInWatershed .

ffonto:removesVegetation
    a owl:ObjectProperty ;
    rdfs:label "removes vegetation" ;
    rdfs:comment "Indicates that wildfire removes or destroys vegetation cover." ;
    rdfs:domain ffonto:ForestFire;
    rdfs:range ffonto:Vegetation .

ffonto:removesVegetationOf
    a owl:ObjectProperty ;
    rdfs:label "removes vegetation of" ;
    rdfs:comment "Inverse - Indicates that wildfire removes or destroys vegetation cover." ;
    rdfs:range ffonto:ForestFire;
    rdfs:domain ffonto:Vegetation .

ffonto:removesVegetationOf owl:inverseOf ffonto:removesVegetation .

ffonto:hasDamage
    a owl:ObjectProperty ;
    rdfs:label "has damage" ;
    rdfs:comment "Indicates that a building has suffered structural damage." ;
    rdfs:domain ffonto:Building ;
    rdfs:range ffonto:StructuralDamage .

ffonto:isDamageOf a owl:ObjectProperty ;
    rdfs:range ffonto:Building ;
    rdfs:domain ffonto:StructuralDamage ;
    rdfs:label "inverse of is damage"@en .

ffonto:isDamageOf owl:inverseOf ffonto:hasDamage .

ffonto:hasVehicleDamage
    a owl:ObjectProperty ;
    rdfs:label "has vehicle damage" ;
    rdfs:comment "Indicates that a vehicle has suffered structural damage." ;
    rdfs:domain ffonto:Vehicle ;
    rdfs:range ffonto:StructuralDamage .

ffonto:isVehicleDamageOf a owl:ObjectProperty ;
    rdfs:label "inverse of is vehicle damage"@en ;
    rdfs:range ffonto:Vehicle ;
    rdfs:domain ffonto:StructuralDamage  .

ffonto:isVehicleDamageOf owl:inverseOf ffonto:hasVehicleDamage .

ffonto:partOfBuilding
    a owl:ObjectProperty ;
    rdfs:label "part of building" ;
    rdfs:comment "Indicates an element (roof, gutter, chimney, meterbox) is part of a building." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( ffonto:Chimney ffonto:MeterBox ) ] ;
    rdfs:range ffonto:Building .

