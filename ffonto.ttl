    rdfs:label "Cigarette Smoke" ;
    rdfs:comment "Smoke produced by burning tobacco products." .

ffonto:ParticulateMatter
    a owl:Class ;
    rdfs:label "Particulate Matter" ;
    rdfs:comment "Tiny particles or droplets in the air such as dust, soot, or smoke that can affect air quality and health." .

ffonto:HumanHealth
    a owl:Class ;
    rdfs:label "Human Health" ;
    rdfs:comment "Represents the respiratory or overall health condition of humans affected by environmental factors like air pollution." .

ffonto:VegetationRegrowth rdf:type owl:Class ;
    rdfs:label "Vegetation Regrowth" ;
