ffonto:Culvert
    a owl:Class ;
    rdfs:subClassOf ffonto:TransportationInfrastructure ;
    rdfs:label "Culvert" ;
    rdfs:comment "Culvert inlets/outlets along roadways." .

ffonto:VehicleDamage rdf:type owl:Class ;
    rdfs:label "Vehicle Damage" ;
    rdfs:comment "Damage to vehicles caused by wildfire heat or smoke." .

ffonto:StructuralDamage rdf:type owl:Class ;
    rdfs:label "Structural Damage" ;
    rdfs:comment "Damage affecting buildings after wildfire." .

ffonto:Roof rdf:type owl:Class ;
    rdfs:subClassOf ffonto:BuildingComponent ;
    rdfs:label "Roof" ;
    rdfs:comment "The upper covering of a building." .

ffonto:Window rdf:type owl:Class ;
    rdfs:subClassOf ffonto:BuildingComponent ;
    rdfs:label "Window" ;
    rdfs:comment "Glass openings in a building or vehicle." .

ffonto:Garage
    a owl:Class ;
    rdfs:subClassOf ffonto:Building ;
    rdfs:label "Garage" ;
    rdfs:comment "Represents a garage building used to store vehicles." .

ffonto:Trailer
    a owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "Trailer" ;
    rdfs:comment "Represents a towable vehicle such as a travel trailer or utility trailer." .

ffonto:ExteriorSiding
    a owl:Class ;
    rdfs:label "Exterior Siding" ;
    rdfs:comment "Represents the exterior covering or material attached to the outside walls of buildings." .

ffonto:Chimney rdf:type owl:Class ;
    rdfs:label "Chimney" ;
    rdfs:comment "A vertical structure that vents smoke from buildings." .

ffonto:SolarPanel rdf:type owl:Class ;
    rdfs:label "Solar Panel" ;
    rdfs:comment "Photovoltaic panels installed on rooftops." .

ffonto:FarmEquipment rdf:type owl:Class ;
    rdfs:label "Farm Equipment" ;
    rdfs:comment "Agricultural machines such as tractors or ATVs." ;
    rdfs:subClassOf ffonto:Equipment .

ffonto:mayIgnite rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FarmEquipment ;
    rdfs:range ffonto:IgnitionSource .

ffonto:mayIgniteOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FarmEquipment ;
    rdfs:domain ffonto:IgnitionSource .

ffonto:mayIgniteOf owl:inverseOf ffonto:mayIgnite .

ffonto:HeavyEquipment rdf:type owl:Class ;
    rdfs:label "Heavy Equipment" ;
    rdfs:comment "Large machines such as bulldozers or excavators." .

ffonto:InsurancePolicy rdf:type owl:Class ;
    rdfs:label "Insurance Policy" .

ffonto:HomeInsurance
    a owl:Class ;
    rdfs:subClassOf ffonto:InsurancePolicy ;
    rdfs:label "Home Insurance" ;
    rdfs:comment "An insurance policy designed to cover damages to a privately owned home and its contents." .

ffonto:RentersInsurance
    a owl:Class ;
    rdfs:subClassOf ffonto:InsurancePolicy ;
    rdfs:label "Renters Insurance" ;
    rdfs:comment "An insurance policy that protects renters against damage to personal belongings and liability within a rented property." .

ffonto:SmokeDamage
    a owl:Class ;
    rdfs:label "Smoke Damage" ;
    rdfs:comment "Damage caused by smoke, often resulting from wildfires, house fires, or other combustion events." .

ffonto:AshFall
    a owl:Class ;
    rdfs:label "Ash Fall"@en ;
    rdfs:comment "Represents ash deposition events or ash material resulting from fires."@en .

ffonto:Location
    a owl:Class ;
    rdfs:subClassOf ffonto:ObservableProperty ;
    rdfs:label "Location"@en ;
    rdfs:comment "Generic geographic area or site (field, orchard, region, coordinate) where produce is produced."@en .

ffonto:HazardousWasteGuideline
    a owl:Class ;
    rdfs:label "Hazardous Waste Guideline" ;
    rdfs:comment "Guidelines or instructions for safely handling and disposing of hazardous waste after a wildfire." .

ffonto:FireType
    a owl:Class ;
    rdfs:label "Fire Type" ;
    rdfs:comment "Represents categories used to classify fire events." .

ffonto:LandClearing
    a owl:Class ;
    rdfs:label "Land Clearing" ;
    rdfs:comment "Represents the purpose of clearing land for agriculture, development, or other uses." .

ffonto:Observation
    a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "An observation or record about conditions at a wildfire scene." .

ffonto:ObservableProperty a owl:Class ;
    rdfs:label "ObservableProperty" ;
    rdfs:comment "Observable Property." .

ffonto:smoke a ffonto:ObservableProperty .
ffonto:fire a ffonto:ObservableProperty .
ffonto:temperature a ffonto:ObservableProperty .
ffonto:humidity a ffonto:ObservableProperty .

ffonto:Result
    a owl:Class ;
    rdfs:label "Result" ;
    rdfs:comment "Results got from observation at a wildfire scene." .

ffonto:Annotation a owl:Class ;
    rdfs:label "Annotation" ;
    rdfs:comment "Additional information derived from data, not a direct physical observation." .

ffonto:TextAnnotation a owl:Class ;
    rdfs:subClassOf ffonto:Annotation ;
    rdfs:label "Text Annotation" ;
    rdfs:comment "Textual annotation such as captions or descriptions." .

ffonto:MLModel a owl:Class ;
    rdfs:label "Machine Learning Model" ;
    rdfs:comment "A model used to generate annotations or results." .

ffonto:ModelExecution a owl:Class ;
    rdfs:label "Model Execution" ;
    rdfs:comment "A specific run of a model on data." .

ffonto:DetectionResult
    a owl:Class ;
    rdfs:subClassOf ffonto:Result ;
    rdfs:subClassOf ffonto:ModelOutput ;
    rdfs:label "DetectionResult" ;
    rdfs:comment "Classification or detection outputs (e.g., smoke, fire)." .

ffonto:MeasurementResult
    a owl:Class ;
    rdfs:subClassOf ffonto:Result ;
    rdfs:label "MeasurementResult" ;
    rdfs:comment "Numeric or measured values (e.g., temperature, humidity)." .

ffonto:UtilityInfrastructure
    a owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Utility Infrastructure" ;
    rdfs:comment "Infrastructure related to utilities (power poles, lines, transformers, insulators, meters)." .

ffonto:TransportationInfrastructure
    a owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Transportation Infrastructure" ;
    rdfs:comment "Infrastructure related to transport (roads, bridges, guardrails, culverts, parking lots)." .

ffonto:BurnEvidence
    a owl:Class ;
    rdfs:label "Burn Evidence" ;
    rdfs:comment "Observable evidence of burning such as ash, charring, scorch, smoldering." .

ffonto:OutdoorItems
    a owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Outdoor Items" ;
    rdfs:comment "Patio furniture, tools, trailers, etc., located outside buildings." .

ffonto:RockSurface
    a owl:Class ;
    rdfs:label "Rock Surface" ;
    rdfs:comment "Represents rocks or exposed mineral surfaces affected by wildfire heat." .

ffonto:ErosionFeature
    a owl:Class ;
    rdfs:label "Erosion Feature" ;
    rdfs:comment "Represents erosion indicators such as rills, exposed soil, and denuded banks." .

ffonto:SmokeCondition
    a owl:Class ;
    rdfs:label "Smoke Condition" ;
    rdfs:comment "Represents characteristics of smoke present at the wildfire scene." .

ffonto:EcosystemImpact
    a owl:Class ;
    rdfs:label "Ecosystem Impact" ;
    rdfs:comment "Represents ecological impacts of wildfire including biodiversity changes, habitat loss, and ecosystem disruption." .

ffonto:RestorationStrategy
    a owl:Class ;
    rdfs:label "Restoration Strategy" ;
    rdfs:comment "Represents strategies or actions that may be applied to restore ecosystems after wildfire disturbance." .

#################################################################
# Object Properties
#################################################################

ffonto:performsOperation rdf:type owl:ObjectProperty ;
    rdfs:label "performs operation" ;
    rdfs:domain ffonto:EmergencyResponder ;
    rdfs:range ffonto:EmergencyOperation ;
    rdfs:comment "Relates a firefighter to an operation they perform." .

ffonto:performsOperationOf rdf:type owl:ObjectProperty ;
    rdfs:label "performs operation of" ;
    rdfs:range ffonto:EmergencyResponder ;
    rdfs:domain ffonto:EmergencyOperation ;
    rdfs:comment "Inverse - Relates a firefighter to an operation they perform." .

ffonto:performsOperationOf owl:inverseOf ffonto:performsOperation .

ffonto:usesEquipment rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:EmergencyResponder ;
    rdfs:range ffonto:ProtectiveEquipment ;
    rdfs:label "uses equipment" .

ffonto:usesEquipmentOf a owl:ObjectProperty ;
    rdfs:range ffonto:EmergencyResponder ;
    rdfs:domain ffonto:ProtectiveEquipment ;
    rdfs:label "inverse of uses equipment"@en .

ffonto:usesEquipmentOf owl:inverseOf ffonto:usesEquipment .

ffonto:protectsStructure rdf:type owl:ObjectProperty ;
    rdfs:label "firefighter protects structure" ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range ffonto:House ;
    rdfs:comment "Indicates firefighters protecting a structure from fire." .

ffonto:protectsStructureOf a owl:ObjectProperty ;
    rdfs:label "inverse of protects structure"@en ;
    rdfs:range ffonto:Firefighter ;
    rdfs:domain ffonto:House .

ffonto:protectsStructureOf owl:inverseOf ffonto:protectsStructure .

ffonto:occursInScene rdf:type owl:ObjectProperty ;
    rdfs:label "occurs in scene" ;
    rdfs:domain ffonto:FirefightingOperation ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:comment "Indicates that an operation occurs in a wildfire scene." .

ffonto:occursInSceneOf a owl:ObjectProperty ;
    rdfs:range ffonto:FirefightingOperation ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:label "inverse of occurs in scene"@en .

ffonto:occursInSceneOf owl:inverseOf ffonto:occursInScene .

ffonto:involvesFirefighter rdf:type owl:ObjectProperty ;
    rdfs:label "involves firefighter" ;
    rdfs:domain ffonto:FirefightingOperation ;
    rdfs:range ffonto:Firefighter ;
    rdfs:comment "Indicates firefighters participating in an operation." .

ffonto:involvesFirefighterOf a owl:ObjectProperty ;
    rdfs:label "inverse of involves firefighter"@en ;
    rdfs:range ffonto:FirefightingOperation ;
    rdfs:domain ffonto:Firefighter .

ffonto:involvesFirefighterOf owl:inverseOf ffonto:involvesFirefighter .

ffonto:usesWaterSource rdf:type owl:ObjectProperty ;
    rdfs:label "uses water source" ;
    rdfs:domain ffonto:FirefightingOperation ;
    rdfs:range ffonto:WaterSource ;
    rdfs:comment "Indicates that a firefighting operation uses a water source." .

ffonto:usesWaterSourceOf a owl:ObjectProperty ;
    rdfs:range ffonto:FirefightingOperation ;
    rdfs:domain ffonto:WaterSource ;
    rdfs:label "inverse of uses water source"@en .

ffonto:usesWaterSourceOf owl:inverseOf ffonto:usesWaterSource .

ffonto:hasCommandPost rdf:type owl:ObjectProperty ;
    rdfs:label "has command post" ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:IncidentCommandPost ;
    rdfs:comment "Indicates that a wildfire scene includes an incident command post." .

ffonto:isCommandPostOf rdf:type owl:ObjectProperty ;
    rdfs:label "is command post of" ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:domain ffonto:IncidentCommandPost ;
    rdfs:comment "Inverse - Indicates that a wildfire scene includes an incident command post." .

ffonto:isCommandPostOf owl:inverseOf ffonto:hasCommandPost .

ffonto:hasRehabArea rdf:type owl:ObjectProperty ;
    rdfs:label "has rehab area" ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:RehabArea ;
    rdfs:comment "Indicates a firefighter rest area at the wildfire scene." .

ffonto:isRehabAreaOf a owl:ObjectProperty ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:domain ffonto:RehabArea ;
    rdfs:label "inverse of is rehab area"@en .

ffonto:isRehabAreaOf owl:inverseOf ffonto:hasRehabArea .

ffonto:hasBriefingArea rdf:type owl:ObjectProperty ;
    rdfs:label "has briefing area" ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:BriefingArea ;
    rdfs:comment "Indicates a briefing area at the wildfire scene." .

ffonto:isBriefingAreaOf a owl:ObjectProperty ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:domain ffonto:BriefingArea ;
    rdfs:label "inverse of is briefing area"@en .

ffonto:isBriefingAreaOf owl:inverseOf ffonto:hasBriefingArea .

ffonto:hasHazard rdf:type owl:ObjectProperty ;
    rdfs:domain [
        rdf:type owl:Class ;
        owl:unionOf (ffonto:Road ffonto:WildfireScene ffonto:ForestFire)
    ] ;
    rdfs:range ffonto:Hazard ;
    rdfs:label "has hazard" ;
    rdfs:comment "Indicates hazards affecting roads or wildfire scenes." .

ffonto:isHazardOf rdf:type owl:ObjectProperty ;
    rdfs:range [
        rdf:type owl:Class ;
        owl:unionOf (ffonto:Road ffonto:WildfireScene ffonto:ForestFire)
    ] ;
    rdfs:domain ffonto:Hazard ;
    rdfs:label "is hazard of" ;
    rdfs:comment "Inverse - Indicates hazards affecting roads or wildfire scenes." .

ffonto:isHazardOf owl:inverseOf ffonto:hasHazard .

ffonto:hasRecoveryGuideline rdf:type owl:ObjectProperty ;
    rdfs:label "has recovery guideline" ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:RecoveryGuideline ;
    rdfs:comment "Links wildfire scenes with recovery guidelines." .

ffonto:isRecoveryGuidelineOf a owl:ObjectProperty ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:domain ffonto:RecoveryGuideline ;
    rdfs:label "inverse of is recovery guideline"@en .

ffonto:isRecoveryGuidelineOf owl:inverseOf ffonto:hasRecoveryGuideline .

ffonto:appliesToUtility rdf:type owl:ObjectProperty ;
    rdfs:label "applies to utility" ;
    rdfs:domain ffonto:RecoveryGuideline ;
    rdfs:range ffonto:UtilitySystem ;
    rdfs:comment "Indicates that a recovery guideline applies to a utility system." .

ffonto:appliesToUtilityOf a owl:ObjectProperty ;
    rdfs:label "inverse of applies to utility"@en ;
    rdfs:range ffonto:RecoveryGuideline ;
    rdfs:domain ffonto:UtilitySystem .

ffonto:appliesToUtilityOf owl:inverseOf ffonto:appliesToUtility .

ffonto:usesVehicle rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range ffonto:Vehicle ;
    rdfs:label "uses vehicle" ;
    rdfs:comment "Indicates that firefighters operate or use a vehicle during firefighting." .

ffonto:usesVehicleOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Firefighter ;
    rdfs:domain ffonto:Vehicle ;
    rdfs:label "uses vehicle of" ;
    rdfs:comment "Inverse - Indicates that firefighters operate or use a vehicle during firefighting." .

ffonto:usesVehicleOf owl:inverseOf ffonto:usesVehicle .

ffonto:usesHose rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range ffonto:FireHose ;
    rdfs:label "uses hose" ;
    rdfs:comment "Indicates firefighters using hoses to apply water to fire." .

ffonto:usesHoseof a owl:ObjectProperty ;
    rdfs:label "inverse of uses hose"@en ;
    rdfs:range ffonto:Firefighter ;
    rdfs:domain ffonto:FireHose .

ffonto:usesHoseof owl:inverseOf ffonto:usesHose .

ffonto:locatedNearStructure rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:PortableTank ;
    rdfs:range ffonto:House ;
    rdfs:label "located near structure" ;
    rdfs:comment "Indicates portable tanks positioned near buildings for firefighting." .

ffonto:locatedNearStructureOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:PortableTank ;
    rdfs:domain ffonto:House ;
    rdfs:label "located near structure of" ;
    rdfs:comment "Inverse - Indicates portable tanks positioned near buildings for firefighting." .

ffonto:locatedNearStructureOf owl:inverseOf ffonto:locatedNearStructure .

ffonto:hasWaterTank rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:House ;
    rdfs:range ffonto:WaterTank ;
    rdfs:label "has water tank" ;
    rdfs:comment "Indicates a house having a rooftop water tank or cistern." .

ffonto:isWaterTankOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:House ;
    rdfs:domain ffonto:WaterTank ;
    rdfs:label "is water tank of" ;
    rdfs:comment "Inverse - Indicates a house having a rooftop water tank or cistern." .

ffonto:isWaterTankOf owl:inverseOf ffonto:hasWaterTank .

ffonto:usesMapBoard rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:BriefingArea ;
    rdfs:range ffonto:MapBoard ;
    rdfs:label "uses map board" ;
    rdfs:comment "Indicates a map board used during operational briefings." .

ffonto:usesMapBoardOf a owl:ObjectProperty ;
    rdfs:range ffonto:BriefingArea ;
    rdfs:domain ffonto:MapBoard ;
    rdfs:label "inverse of uses map board"@en .

ffonto:usesMapBoardOf owl:inverseOf ffonto:usesMapBoard .

ffonto:managesPropaneTank rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:RecoveryGuideline ;
    rdfs:range ffonto:PropaneTank ;
    rdfs:label "manages propane tank" ;
    rdfs:comment "Indicates recommended management procedures for propane tanks." .

ffonto:managesPropaneTankOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:RecoveryGuideline ;
    rdfs:domain ffonto:PropaneTank ;
    rdfs:label "manages propane tank of" ;
    rdfs:comment "Inverse - Indicates recommended management procedures for propane tanks." .

ffonto:managesPropaneTankOf owl:inverseOf ffonto:managesPropaneTank .

ffonto:usedAsWaterSource rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:WaterBody ;
    rdfs:range ffonto:WaterSource .

ffonto:usedAsWaterSourceOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:WaterBody ;
    rdfs:domain ffonto:WaterSource .

ffonto:usedAsWaterSource owl:inverseOf ffonto:usedAsWaterSourceOf .

ffonto:extractedFrom rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:WellWater ;
    rdfs:range ffonto:Groundwater ;
    rdfs:label "extracted from" ;
