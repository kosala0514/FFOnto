    rdfs:range ffonto:WildfireScene ;
    rdfs:domain ffonto:WaterBody .

ffonto:affectsWaterBodyOf owl:inverseOf ffonto:affectsWaterBody .

ffonto:hasEcosystemImpact
    a owl:ObjectProperty ;
    rdfs:label "has ecosystem impact" ;
    rdfs:comment "Links wildfire scenes to ecosystem impacts." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:EcosystemImpact .

ffonto:isEcosystemImpactOf a owl:ObjectProperty ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:domain ffonto:EcosystemImpact ;
    rdfs:label "inverse of has ecosystem impact"@en .

