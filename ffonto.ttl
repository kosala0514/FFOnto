ffonto:Runoff rdf:type owl:Class ;
    rdfs:label "Runoff" ;
    rdfs:comment "Water flow occurring when soil cannot absorb rainfall." .

ffonto:Watershed
    a owl:Class ;
    rdfs:label "Watershed" ;
