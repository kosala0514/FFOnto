ffonto:RightFlank rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireFlank ;
    rdfs:label "Right Flank" .

ffonto:LeftFlank rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireFlank ;
    rdfs:label "Left Flank" .

ffonto:FireFront rdf:type owl:Class ;
