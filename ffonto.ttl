ffonto:appliesAfterFire
    a owl:ObjectProperty ;
    rdfs:label "applies after fire" ;
    rdfs:comment "Indicates that a hazardous waste guideline is applicable after a wildfire event in a specific wildfire scene." ;
    rdfs:domain ffonto:HazardousWasteGuideline ;
    rdfs:range ffonto:WildfireScene .

ffonto:appliesAfterFireOf a owl:ObjectProperty ;
    rdfs:range ffonto:HazardousWasteGuideline ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:label "inverse of applies after fire"@en .

ffonto:appliesAfterFireOf owl:inverseOf ffonto:appliesAfterFire .

ffonto:coversDamage
    a owl:ObjectProperty ;
    rdfs:label "covers damage" ;
    rdfs:comment "Indicates that an insurance policy provides coverage for smoke damage." ;
    rdfs:domain ffonto:InsurancePolicy ;
    rdfs:range ffonto:SmokeDamage .

ffonto:coversDamageOf a owl:ObjectProperty ;
    rdfs:range ffonto:InsurancePolicy ;
    rdfs:domain ffonto:SmokeDamage ;
    rdfs:label "inverse of covers damage"@en .

ffonto:coversDamageOf owl:inverseOf ffonto:coversDamage .

ffonto:producesPollution
    a owl:ObjectProperty ;
    rdfs:label "produces pollution" ;
    rdfs:comment "Indicates that a wildfire produces wildfire smoke pollution." ;
