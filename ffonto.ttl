#################################################################
# Datatype property
#################################################################

ffonto:incidentName rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEvent;
    rdfs:range xsd:string ;
    rdfs:label "incident name" .

ffonto:incidentSizeAcres rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEvent;
    rdfs:range xsd:decimal ;
    rdfs:label "incident size in acres" .

ffonto:containmentPercent rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEvent;
    rdfs:range xsd:decimal ;
    rdfs:label "containment percent" .

ffonto:rainMm rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "rain mm" .

ffonto:fireOccurred rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "fire occurred" .

ffonto:areaHa rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "area ha" .

ffonto:rowIndex rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "rowI index" .

ffonto:areaAcres rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:PerimeterSnapshot ;
    rdfs:range xsd:decimal ;
    rdfs:label "area (acres)" ;
    rdfs:comment "Perimeter-derived area in acres." .

ffonto:fireTypeValue rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehavior ;
    rdfs:range xsd:string ;
    rdfs:label "fire type (string)" ;
    rdfs:comment "Textual description of fire type (e.g., 'Primarily surface/ground with intermittent torching')." .

ffonto:flameFrontsVisible rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "flame fronts visible" ;
    rdfs:comment "Indicates whether flame fronts are visible from the camera." .

ffonto:numberOfFlameFronts rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "number of flame fronts" ;
    rdfs:comment "Count of distinct flame fronts visible in the frame." .

ffonto:spotFiresVisible rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "spot fires visible" ;
    rdfs:comment "Indicates visible spot fires ahead of main flame." .

ffonto:fireScore rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:VisionModelScores ;
    rdfs:range xsd:decimal ;
    rdfs:label "fire score" .

ffonto:smokeScore rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:VisionModelScores ;
    rdfs:range xsd:decimal ;
    rdfs:label "smoke score" .

ffonto:fireProbabilityScore rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireProbabilityModel ;
    rdfs:range xsd:decimal ;
    rdfs:label "fire probability" ;
    rdfs:comment "Model-provided fire probability score (0.0-1.0)." .

ffonto:smokeColorLiteral rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range xsd:string ;
    rdfs:label "smoke color description" ;
    rdfs:comment "Literal description of smoke color (e.g., 'dark-gray with a brown tinge')." .

ffonto:smokePlumeOrientation rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range xsd:string ;
    rdfs:label "smoke plume orientation" ;
    rdfs:comment "Whether plume is rising vertically or drifting horizontally (plus direction)." .

ffonto:smokePlumeHeight rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range xsd:string ;
    rdfs:label "smoke plume height (descriptive)" ;
    rdfs:comment "Descriptive height of the smoke plume (e.g., 'very tall, extending high into the atmosphere')." .

ffonto:smokeThickness rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range xsd:string ;
    rdfs:label "smoke thickness (descriptive)" ;
    rdfs:comment "Descriptive thickness of smoke (e.g., 'extremely thick')." .

ffonto:visibilityKm rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "visibility (km)" ;
    rdfs:comment "Numeric visibility estimate in kilometers." .

ffonto:visibilityCategory rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range xsd:string ;
    rdfs:label "visibility category (low/medium/high)" ;
    rdfs:comment "Categorical visibility derived from smoke observations." .

ffonto:cameraObscuredBySmoke rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "camera obscured by smoke" ;
    rdfs:comment "Indicates camera view is partially or fully obscured by smoke/haze." .

ffonto:smolderingPresent rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "smoldering present" ;
    rdfs:comment "Indicates smoldering patches are visible without open flames." .

ffonto:retardantVisible rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "retardant visible" ;
    rdfs:comment "Indicates whether foam or retardant staining is visible." .

ffonto:weatherRow rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:string ;
    rdfs:label "weather row raw" ;
    rdfs:comment "Optional raw CSV row or JSON serialization for audit." .

ffonto:hasRecordConfidence rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range xsd:decimal ;
    rdfs:label "record confidence" .

ffonto:hasObservationSource rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range xsd:string ;
    rdfs:label "observation source" .

ffonto:temperatureC rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "air temperature (C)" ;
    rdfs:comment "Air temperature at the incident site in degrees Celsius." .

ffonto:relativeHumidity rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "relative humidity (%)" ;
    rdfs:comment "Relative humidity as percentage." .

ffonto:windSpeedKmh rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "wind speed (km/h)" ;
    rdfs:comment "Sustained wind speed in km/h." .

ffonto:windGustKmh rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "wind gust (km/h)" ;
    rdfs:comment "Peak gust speed in km/h." .

ffonto:precipitationMm rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "precipitation (mm)" ;
    rdfs:comment "Precipitation recorded for the day in millimetres." .

ffonto:windEffectOnAerial rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:string ;
    rdfs:label "wind effect on aerial drops (yes/no/qualifier)" ;
    rdfs:comment "Assessment whether wind reduces aerial drop effectiveness." .

ffonto:directAttackFavored rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range xsd:boolean ;
    rdfs:label "direct attack favored (hand tools)" ;
    rdfs:comment "Indicates if current RH/conditions favor direct hand-tool attack." .

ffonto:FFMC rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range xsd:decimal ;
    rdfs:label "FFMC" ;
    rdfs:comment "Fine Fuel Moisture Code." .

ffonto:ISI rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range xsd:decimal ;
    rdfs:label "ISI" ;
