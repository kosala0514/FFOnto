    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:Groundwater .

ffonto:affectsGroundwaterRechargeOf owl:inverseOf ffonto:affectsGroundwaterRecharge .

ffonto:increasesRunoff
    a owl:ObjectProperty ;
    rdfs:label "increases runoff" ;
    rdfs:comment "Indicates that a wildfire increases surface water runoff due to reduced vegetation and altered soil conditions." ;
    rdfs:domain ffonto:ForestFire;
    rdfs:range ffonto:Runoff .

ffonto:increasesRunoffOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire;
    rdfs:domain ffonto:Runoff ;
    rdfs:label "inverse of increases runoff"@en .

ffonto:increasesRunoffOf owl:inverseOf ffonto:increasesRunoff .

