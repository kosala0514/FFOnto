ffonto:CautionTape rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TrafficControlDevice ;
    rdfs:label "Caution Tape" .

ffonto:Barricade rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TrafficControlDevice ;
    rdfs:label "Barricade / Road-closure Sign" .

ffonto:ResourcePlacement rdf:type owl:Class ;
    rdfs:label "Resource Placement" ;
    rdfs:comment "Location/orientation of resources relative to assets and terrain." .

ffonto:ProtectionMeasure rdf:type owl:Class ;
    rdfs:label "Protection Measure" ;
    rdfs:comment "Hose lines, sprinklers, foam, pumps and other structure-protection measures." .

ffonto:Tool rdf:type owl:Class ;
