ffonto:mayRequireRestoration
    a owl:ObjectProperty ;
    rdfs:label "may require restoration strategy" ;
    rdfs:comment "Links wildfire scenes to recommended restoration strategies." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:RestorationStrategy .

ffonto:mayRequireRestorationInverse a owl:ObjectProperty ;
    rdfs:label "inverse of may require restoration"@en ;
