    rdfs:domain geo:SpatialObject .

ffonto:affectsForestAreaOf owl:inverseOf ffonto:affectsForestArea .

ffonto:InsectInfestation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ForestDisturbance ;
    rdfs:label "Insect Infestation" ;
    rdfs:comment "Damage to forests caused by insect outbreaks." .

ffonto:MountainPineBeetle rdf:type ffonto:InsectInfestation ;
    rdfs:label "Mountain Pine Beetle" ;
    rdfs:comment "A destructive insect responsible for widespread forest mortality." .


