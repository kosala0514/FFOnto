ffonto:requiresHandlingGuidelineOf a owl:ObjectProperty ;
    rdfs:range ffonto:HazardousMaterial ;
    rdfs:domain ffonto:HazardousWasteGuideline ;
    rdfs:label "inverse of requires handling guideline"@en .

