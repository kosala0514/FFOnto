    rdfs:label "Fire Emergency Service Sri Lanka" ;
    ffonto:hasPhoneNumber "110" ;
    ffonto:hasWebsite "https://www.gov.lk"^^xsd:anyURI .

ffonto:LocalCommunityPlan rdf:type ffonto:CommunityPreparedness ;
    rdfs:label "Neighborhood Evacuation & Preparedness Plan" ;
    ffonto:hasEvacuationPlan ffonto:RouteAPlan ;
    ffonto:hasEmergencyKit ffonto:StandardKit .

ffonto:RouteAPlan rdf:type ffonto:EvacuationPlan ;
    rdfs:label "Primary Evacuation Route A" ;
    ffonto:recommendedAction "Designate primary and alternate routes and practice quarterly." .

ffonto:StandardKit rdf:type ffonto:EmergencyKit ;
    rdfs:label "72-Hour Emergency Kit" ;
    ffonto:recommendedAction "3 days of water, food, medications, documents, first-aid supplies." .

ffonto:NationalPrescribedBurnPolicy rdf:type ffonto:PrescribedBurnPolicy ;
    rdfs:label "National Prescribed Burn Policy Example" ;
    ffonto:recommendedAction "Specifies permit process, notification and monitoring requirements." .

ffonto:LocalBuildingCode rdf:type ffonto:BuildingCode ;
    rdfs:label "Local WUI Building Code" ;
    ffonto:recommendedAction "Requires ember-resistant vents and non-combustible siding." .

ffonto:StandardICS rdf:type ffonto:IncidentCommandSystem ;
    rdfs:label "Standard ICS Model" ;
    ffonto:hasICSFunction ffonto:CommandFunction , ffonto:OperationsFunction , ffonto:PlanningFunction , ffonto:LogisticsFunction , ffonto:FinanceFunction ;
    ffonto:hasCommunicationMethod ffonto:RadioComms , ffonto:PublicAlert .

ffonto:CommandFunction rdf:type ffonto:ICSFunction ;
    rdfs:label "Command" .

ffonto:OperationsFunction rdf:type ffonto:ICSFunction ;
    rdfs:label "Operations" .

ffonto:PlanningFunction rdf:type ffonto:ICSFunction ;
    rdfs:label "Planning" .

ffonto:LogisticsFunction rdf:type ffonto:ICSFunction ;
    rdfs:label "Logistics" .

ffonto:FinanceFunction rdf:type ffonto:ICSFunction ;
    rdfs:label "Finance / Administration" .

ffonto:FuelMapGISApp rdf:type ffonto:GISApplication ;
    rdfs:label "Fuel Mapping GIS Application" ;
    ffonto:recommendedAction "Used for hazard mapping, evacuation planning, and modeling fire spread." .

ffonto:DefaultPrioritization rdf:type ffonto:ResourcePrioritization ;
    rdfs:label "Default Prioritization Rule" ;
    ffonto:prioritizes ffonto:LifeSafety , ffonto:IncidentStabilization , ffonto:PropertyProtection .

ffonto:LifeSafety rdf:type owl:NamedIndividual ;
    rdfs:label "Life Safety" .

ffonto:IncidentStabilization rdf:type owl:NamedIndividual ;
    rdfs:label "Incident Stabilization" .

ffonto:PropertyProtection rdf:type owl:NamedIndividual ;
    rdfs:label "Property Protection" .

ffonto:ClimateChangeChallenge rdf:type ffonto:ChallengeOpportunity ;
    rdfs:label "Climate Change" ;
    ffonto:recommendedAction "Longer seasons, increased drought; requires strategic adaptation." .

ffonto:TechOpportunity rdf:type ffonto:ChallengeOpportunity ;
    rdfs:label "Technology Opportunity" ;
    ffonto:recommendedAction "Improved detection, modeling and communications." .

ffonto:ErosionSeedMix rdf:type ffonto:ErosionControl ;
    rdfs:label "Erosion Control Seed Mix" ;
    ffonto:recommendedAction "Use native grass species for rapid slope stabilization." .

ffonto:StandardDeployableShelter rdf:type ffonto:DeployableShelter ;
    rdfs:label "Standard Deployable Fire Shelter" ;
    ffonto:hasLimitation "Intended as last-resort; limited protection from direct flame and extreme radiant heat." .

ffonto:HardenedVehicleShelter rdf:type ffonto:StructureShelter ;
    rdfs:label "Hardened Vehicle Shelter" ;
    ffonto:hasLimitation "Requires pre-positioning and may not be available in all incidents." .

ffonto:RadioComms rdf:type ffonto:RadioComms ;
    rdfs:label "Operational Radio Communications" .

ffonto:SMSAlert rdf:type ffonto:PublicAlert ;
    rdfs:label "SMS Public Alert" ;
    ffonto:recommendedAction "Used to deliver evacuation notices and situational updates to residents." .

ffonto:FARSITE rdf:type ffonto:FireSimulationSoftware ;
    rdfs:label "FARSITE Fire Spread Model" ;
    ffonto:hasDescription "Simulation system used to predict wildfire spread." .

ffonto:FlamMap rdf:type ffonto:FireSimulationSoftware ;
    rdfs:label "FlamMap Fire Behavior Model" ;
    ffonto:hasDescription "Software used to map potential fire behavior." .

ffonto:SatelliteMonitoring rdf:type ffonto:SatelliteObservation ;
    rdfs:label "Satellite Fire Monitoring System" .

ffonto:DroneFireMonitoring rdf:type ffonto:DroneMonitoring ;
    rdfs:label "ForestFire Drone Surveillance System" .

ffonto:SmokeyBearCampaign rdf:type ffonto:AwarenessCampaign ;
    rdfs:label "Smokey Bear ForestFire Prevention Campaign" ;
    ffonto:hasDescription "Public campaign promoting wildfire prevention." .

ffonto:CaliforniaForestFireCount rdf:type ffonto:CaliforniaForestFireStatistic ;
    rdfs:label "Annual California ForestFire Count" ;
    ffonto:hasStatisticValue 10000 ;
    ffonto:hasDescription "Approximate number of wildfires occurring annually in California." .

ffonto:USFS rdf:type owl:NamedIndividual ;
    rdfs:label "United States Forest Service (USFS)" ;
    ffonto:infoURL "https://www.fs.usda.gov"^^xsd:anyURI ;
    ffonto:phone "+1-202-205-8333" .

ffonto:FEMA rdf:type owl:NamedIndividual ;
    rdfs:label "Federal Emergency Management Agency (FEMA)" ;
    ffonto:infoURL "https://www.fema.gov"^^xsd:anyURI ;
    ffonto:phone "+1-800-621-3362" .

ffonto:CDC rdf:type owl:NamedIndividual ;
    rdfs:label "Centers for Disease Control and Prevention (CDC)" ;
    ffonto:infoURL "https://www.cdc.gov"^^xsd:anyURI ;
    ffonto:phone "+1-800-232-4636" .

ffonto:OGC rdf:type owl:NamedIndividual ;
    rdfs:label "Open Geospatial Consortium" ;
    ffonto:hasWebsite "https://www.ogc.org"^^xsd:anyURI .

ffonto:PGEUtility rdf:type owl:NamedIndividual ;
    rdfs:label "Pacific Gas and Electric Company (Example utility)" ;
    ffonto:infoURL "https://www.pge.com"^^xsd:anyURI ;
    ffonto:phone "+1-800-743-5002" ;
    rdfs:comment "Utility often associated with pre-emptive de-energization programs (PSPS) in extreme fire weather." .

ffonto:Headache rdf:type ffonto:HealthSymptom ;
    rdfs:label "Headache" ;
    rdfs:comment "Common symptom from smoke inhalation." .

ffonto:SoreThroat rdf:type ffonto:HealthSymptom ;
    rdfs:label "Sore throat" .

ffonto:Nausea rdf:type ffonto:HealthSymptom ;
    rdfs:label "Nausea" .

ffonto:ShortnessOfBreath rdf:type ffonto:HealthSymptom ;
    rdfs:label "Shortness of breath" .

ffonto:SmokeExposureRespiratory rdf:type ffonto:RespiratoryEffect ;
    rdfs:label "Respiratory irritation & exacerbation" ;
    ffonto:hasSymptom ffonto:SoreThroat , ffonto:ShortnessOfBreath , ffonto:Headache .

ffonto:SmokeExposureSystemic rdf:type ffonto:CardiovascularEffect ;
    rdfs:label "Cardiovascular stress" ;
    ffonto:hasSymptom ffonto:Headache , ffonto:Nausea .

ffonto:GeneralEvacuationGuidance rdf:type ffonto:SurvivalGuidance ;
    rdfs:label "General Evacuation Guidance" ;
    ffonto:recommendedBy "FEMA / Local Fire Authority" ;
    ffonto:recommendsAction ffonto:EvacuateNow , ffonto:HaveEmergencyKit , ffonto:FollowAlerts .

ffonto:EvacuateNow rdf:type ffonto:EvacuationAction ;
    rdfs:label "Evacuate immediately when ordered" ;
    rdfs:comment "Primary recommended action to maximize survival." .

ffonto:HaveEmergencyKit rdf:type ffonto:EvacuationAction ;
    rdfs:label "Maintain emergency kit (72-hour supply)" .

ffonto:FollowAlerts rdf:type ffonto:EvacuationAction ;
    rdfs:label "Subscribe to & follow official alerts (EAS, Wireless Emergency Alerts, agency apps)" .

ffonto:SamplePSPS rdf:type ffonto:UtilityPowerShutoff ;
    rdfs:label "Planned PSPS example" ;
    ffonto:utilityImplementsPSPS ffonto:PGEUtility ;
    rdfs:comment "Planned de-energization to reduce ignition risk during extreme wind and dry fuel conditions." .

ffonto:ExtremeWindLimit rdf:type ffonto:Limitations ;
    rdfs:label "Extreme wind limitation" ;
    rdfs:comment "High winds may ground air tankers, increase ember transport, and reduce effectiveness of line construction." .

ffonto:AccessTerrainLimit rdf:type ffonto:Limitations ;
    rdfs:label "Inaccessible terrain limitation" ;
    rdfs:comment "Rugged terrain limits crew access and safe line construction." .

ffonto:AirTankerDrops rdf:type ffonto:FireSuppressionAction ;
    rdfs:label "Air tanker retardant/water drops" ;
    ffonto:hasSuppressionLimit ffonto:ExtremeWindLimit .

ffonto:HandCrewLineConstruction rdf:type ffonto:FireSuppressionAction ;
    rdfs:label "Hand crew line construction" ;
    ffonto:hasSuppressionLimit ffonto:AccessTerrainLimit .


ffonto:NationalInteragencyFireCenter rdf:type owl:NamedIndividual ;
    rdfs:label "National Interagency Fire Center (NIFC)" ;
    rdfs:comment "Interagency coordinating center for wildland fire response (US)." ;
    ffonto:infoURL "https://www.nifc.gov"^^xsd:anyURI .

ffonto:UCDavis rdf:type owl:NamedIndividual ;
    rdfs:label "University of California, Davis (UC Davis)" ;
    ffonto:infoURL "https://www.ucdavis.edu"^^xsd:anyURI .

ffonto:CNPRC rdf:type owl:NamedIndividual ;
    rdfs:label "California National Primate Research Center (CNPRC)" ;
    ffonto:infoURL "https://cnprc.ucdavis.edu"^^xsd:anyURI .

ffonto:VIIRSInstrument rdf:type ffonto:VIIRS ;
    rdfs:label "VIIRS satellite instrument" .

ffonto:GOESInstrument rdf:type ffonto:GOES ;
    rdfs:label "GOES geostationary satellite" .

ffonto:SARSystem rdf:type ffonto:SAR ;
    rdfs:label "SAR satellite system" .

ffonto:ThermalUAV rdf:type ffonto:UAV ;
    rdfs:label "Thermal UAV with thermal camera and edge device" ;
    ffonto:enables ffonto:SmokeDetection .

ffonto:EdgeInferenceDevice rdf:type ffonto:EdgeDevice ;
    rdfs:label "Edge Inference Device" ;
    rdfs:comment "Performs onboard CV filtering and alerts." .

ffonto:StateForestFireStatistic
    rdfs:label "State forest fire statistic"@en ;
    rdfs:comment "A wildfire statistic aggregated at a state or regional level."@en .

ffonto:CaliforniaForestFireAnnualCount rdf:type ffonto:StateForestFireStatistic ;
    rdfs:label "California annual wildfire count (approx)" ;
    ffonto:hasStatisticValue "10000"^^xsd:decimal ;
    ffonto:statisticDate "2021-01-01"^^xsd:date ;
    rdfs:comment "Illustrative: counts vary year-to-year; used to answer 'which state has most wildfires' CQ." .

ffonto:CardiacIssue
    rdfs:label "Cardiac issue"@en ;
    rdfs:comment "A heart-related health condition potentially triggered or worsened by wildfire smoke exposure."@en .

ffonto:RespiratoryIssue
    rdfs:label "Respiratory issue"@en ;
    rdfs:comment "A breathing or lung-related health condition influenced by wildfire smoke or air pollution."@en .

ffonto:AirPollutantProperty rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AirQualityIndex ;
    rdfs:label "Air Pollutant Property" .

ffonto:affectsHealth rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:AirPollutantProperty ;
    rdfs:range ffonto:RespiratoryIssue .

ffonto:affectsHealthOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:AirPollutantProperty ;
    rdfs:domain ffonto:RespiratoryIssue .

ffonto:affectsHealthOf owl:inverseOf ffonto:affectsHealth .


ffonto:Headache rdf:type ffonto:HealthSymptom ; rdfs:label "Headache" .
ffonto:SoreThroat rdf:type ffonto:HealthSymptom ; rdfs:label "Sore Throat" .
ffonto:Nausea rdf:type ffonto:HealthSymptom ; rdfs:label "Nausea" .
ffonto:LungDamage rdf:type ffonto:RespiratoryIssue ; rdfs:comment "ForestFire smoke can cause inflammation, COPD-like outcomes; observed in primate studies from CNPRC / UC Davis." ; rdfs:label "Lung Damage / COPD risk" .
ffonto:CardiacStress rdf:type ffonto:CardiacIssue ; rdfs:label "Cardiac stress / thrombotic risk" .
ffonto:FetalNeuroEffect rdf:type ffonto:NeurologicalDevelopmentIssue ; rdfs:label "Prenatal neurodevelopmental risk" .

ffonto:ForestFireSpreadGNN rdf:type ffonto:GraphNeuralNetwork ;
    rdfs:label "ForestFire Spread Graph Neural Network Model" ;
    ffonto:performsTask ffonto:HotspotLocalization ;
    ffonto:trainedWith ffonto:SelfSupervisedLearning ;
    ffonto:evaluatedBy ffonto:F1Score .

ffonto:FireRiskMLModel rdf:type ffonto:MachineLearningModel ;
    rdfs:label "Fire Risk Prediction ML Model" ;
    ffonto:usesSensor ffonto:ThermalSensor ;
    ffonto:trainedWith ffonto:DataAugmentation ;
    ffonto:evaluatedBy ffonto:Precision .

ffonto:RemoteSensingSensor
    rdfs:label "Remote sensing sensor"@en ;
    rdfs:comment "A sensor used to capture environmental data remotely, such as from satellites, drones, or aircraft."@en .

ffonto:MODISSensor rdf:type ffonto:RemoteSensingSensor ;
    rdfs:label "MODIS Satellite Sensor" .

ffonto:VIIRSSensor rdf:type ffonto:RemoteSensingSensor ;
    rdfs:label "VIIRS Satellite Sensor" .

ffonto:ControlledBurn rdf:type ffonto:PreventionMethod ;
    rdfs:label "Controlled Burn" ;
    rdfs:comment "Intentional burning of vegetation to reduce fuel accumulation." .

ffonto:Firebreak rdf:type ffonto:PreventionMethod ;
    rdfs:label "Firebreak" ;
    rdfs:comment "Cleared strips of land used to stop or slow wildfire spread." .

ffonto:PublicEducation rdf:type ffonto:PreventionMethod ;
    rdfs:label "Public Education" ;
    rdfs:comment "Awareness campaigns aimed at reducing accidental fire ignition." .

ffonto:Drought rdf:type ffonto:EnvironmentalFactor ;
    rdfs:label "Drought Condition" ;
    rdfs:comment "Extended periods without rainfall increasing vegetation flammability." .

ffonto:Topography rdf:type ffonto:EnvironmentalFactor ;
    rdfs:label "Topography" ;
    rdfs:comment "Landscape features such as slopes and valleys affecting fire spread." .

ffonto:UrbanDevelopment rdf:type ffonto:EnvironmentalFactor ;
    rdfs:label "Urban Development Near Forests" ;
    rdfs:comment "Human settlements near forests increasing ignition risk." .

ffonto:EarlyDetectionSystem rdf:type ffonto:MonitoringSystem ;
    rdfs:label "Early Fire Detection System" ;
    rdfs:comment "Technology that detects wildfires early to enable rapid response." .

ffonto:TemperatureSensor rdf:type ffonto:Sensor ;
    rdfs:label "Temperature Sensor" .

ffonto:HumiditySensor rdf:type ffonto:Sensor ;
    rdfs:label "Humidity Sensor" .

ffonto:WindSensor rdf:type ffonto:Sensor ;
    rdfs:label "Wind Sensor" .

ffonto:SmokeSensor rdf:type ffonto:Sensor ;
    rdfs:label "Smoke Sensor" .

ffonto:EarlyDetectionSystem ffonto:usesSensor ffonto:TemperatureSensor ;
    ffonto:usesSensor ffonto:HumiditySensor ;
    ffonto:usesSensor ffonto:WindSensor ;
    ffonto:usesSensor ffonto:SmokeSensor .

ffonto:NationalFireRiskMap rdf:type ffonto:FireRiskMap ;
    rdfs:label "National Wildfire Risk Map" ;
    ffonto:mapUpdateFrequency "Updated daily during fire season" .

ffonto:Helicopter rdf:type ffonto:FirefightingResource ;
    rdfs:label "Firefighting Helicopter" ;
    rdfs:comment "Aircraft used to drop water or fire retardant in remote areas." .

ffonto:FireEngine rdf:type ffonto:FirefightingResource ;
    rdfs:label "Fire Engine" ;
    rdfs:comment "Ground vehicle used for transporting firefighters and equipment." .

ffonto:Drone rdf:type ffonto:FirefightingResource ;
    rdfs:label "Fire Monitoring Drone" ;
    rdfs:comment "Drone used to monitor wildfire spread and fuel conditions." .

ffonto:ICSTraining rdf:type ffonto:TrainingProgram ;
    rdfs:label "Incident Command System Training" ;
    rdfs:comment "Standardized emergency management training for wildfire coordination." .

ffonto:SimulationTraining rdf:type ffonto:TrainingProgram ;
    rdfs:label "Wildfire Simulation Training" ;
    rdfs:comment "Use of VR and computer simulation to train firefighters." .

ffonto:Water rdf:type ffonto:PreparednessItem ;
    rdfs:label "Emergency Water Supply" .

ffonto:FirstAidKit rdf:type ffonto:PreparednessItem ;
    rdfs:label "First Aid Kit" .

ffonto:Medication rdf:type ffonto:PreparednessItem ;
    rdfs:label "Medication" .

ffonto:WildfireEvacuation rdf:type ffonto:EvacuationProcedure ;
    rdfs:label "Wildfire Evacuation Procedure" ;
    rdfs:comment "Procedures residents should follow during wildfire emergencies." ;
    ffonto:requiresItem ffonto:Water ;
    ffonto:requiresItem ffonto:FirstAidKit ;
    ffonto:requiresItem ffonto:ImportantDocuments ;
    ffonto:requiresItem ffonto:Medication .

ffonto:FamilyGoKit rdf:type ffonto:PreparednessKit ;
    rdfs:label "Family Disaster Supply Kit" ;
    rdfs:comment "Kit to sustain a household through evacuation and temporary displacement." ;
    ffonto:kitDurationDays "5"^^xsd:integer ;
    ffonto:hasRequiredItem ffonto:WaterOnePersonPerDay ;
    ffonto:hasRequiredItem ffonto:ThreeDayFoodSupply ;
    ffonto:hasRequiredItem ffonto:FirstAidKitItem ;
    ffonto:hasRequiredItem ffonto:PrescriptionMedications ;
    ffonto:hasRequiredItem ffonto:ImportantDocsContainer .

ffonto:WaterOnePersonPerDay rdf:type ffonto:PreparednessItem ;
    rdfs:label "Water (1 gallon per person per day)" ;
    rdfs:comment "Recommended potable water per person per day." .

ffonto:ThreeDayFoodSupply rdf:type ffonto:PreparednessItem ;
    rdfs:label "Three-day nonperishable food supply" ;
    rdfs:comment "Ready-to-eat and nonperishable foods for at least 3 days (extendable to 5-7 days as advised)." .

ffonto:FirstAidKitItem rdf:type ffonto:PreparednessItem ;
    rdfs:label "First Aid Kit Item" ;
    rdfs:comment "Includes basic medical supplies and family prescription medications." .

ffonto:PrescriptionMedications rdf:type ffonto:PreparednessItem ;
    rdfs:label "Prescription Medications" ;
    rdfs:comment "Prescriptions (original or up-to-date list) and supplies needed for continuity of care." .

ffonto:ImportantDocsContainer rdf:type ffonto:ImportantDocument ;
    rdfs:label "Important Documents Container - waterproof/fireproof container + cloud backup" ;
    rdfs:comment "Birth certificates, wills, insurance policies, property deeds; store offline and in cloud backup." ;
    ffonto:documentStorageMethod "fire-resistant safe; waterproof pouch; encrypted cloud backup" .

ffonto:CashAndCards rdf:type ffonto:PreparednessItem ;
    rdfs:label "Cash and Payment Cards" ;
    rdfs:comment "Small cash reserve and credit/debit card for emergency purchases." .

ffonto:ExtraCarKeys rdf:type ffonto:PreparednessItem ;
    rdfs:label "Extra Car Keys" ;
    rdfs:comment "Spare set of vehicle keys kept with go-kit." .

ffonto:PetGoKit rdf:type ffonto:PreparednessKit ;
    rdfs:label "Pet Go-Kit" ;
    rdfs:comment "Supplies for pets: food, water, vaccination records, carrier, leash." ;
    ffonto:hasRequiredItem ffonto:PetFood ;
    ffonto:hasRequiredItem ffonto:PetVaccineRecord ;
    ffonto:hasRequiredItem ffonto:PetCarrier .

ffonto:PetFood rdf:type ffonto:PreparednessItem ;
    rdfs:label "Pet Food & Water" ;
    rdfs:comment "Sufficient pet food and water for evacuation duration." .

ffonto:PetVaccineRecord rdf:type ffonto:PreparednessItem ;
    rdfs:label "Pet Vaccination Record" ;
    rdfs:comment "Proof of vaccinations for pet shelter admission." .

ffonto:PetCarrier rdf:type ffonto:PreparednessItem ;
    rdfs:label "Pet Carrier / Crate" ;
    rdfs:comment "Secure carrier for transporting pets safely." .

ffonto:SturdyBoots rdf:type ffonto:ClothingRecommendation ;
    rdfs:label "Sturdy Boots" ;
    rdfs:comment "Closed-toe, durable footwear to protect feet from heat and debris." ;
    ffonto:clothingMaterial "leather or heavy canvas; avoid meltable synthetics" .

ffonto:LongSleevesAndPants rdf:type ffonto:ClothingRecommendation ;
    rdfs:label "Long Sleeves and Long Pants" ;
    rdfs:comment "Natural fiber clothing such as cotton or wool to resist brief heat exposure." ;
    ffonto:clothingMaterial "cotton or wool; avoid polyester or nylon" .

ffonto:GlovesAndEyeProtection rdf:type ffonto:ClothingRecommendation ;
    rdfs:label "Gloves and Eye Protection" ;
    rdfs:comment "Leather or heavy gloves and goggles or safety glasses." .

ffonto:N95Respirator rdf:type ffonto:ClothingRecommendation ;
    rdfs:label "N95 Respirator" ;
    rdfs:comment "Respirator for particulate smoke protection (not a substitute for medical advice)." ;
    ffonto:clothingMaterial "filter media; single-person use recommended and fit-checked" .

ffonto:ParkFacingEscapeDirection rdf:type ffonto:VehiclePreparation ;
    rdfs:label "Park Vehicle Facing Escape Direction" ;
    rdfs:comment "Back vehicle into garage or park facing escape direction for quick departure." ;
    ffonto:vehicleFuelLevel "Keep fuel above half tank when in fire season" .

ffonto:LockHomeBeforeLeaving rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Lock Home Before Leaving" ;
    rdfs:comment "Close and lock main doors and windows prior to evacuation but leave garage unlocked for responders if advised." .

ffonto:DisconnectGarageOpener rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Disconnect Automatic Garage Door Opener" ;
    rdfs:comment "Prevent garage doors from opening unexpectedly during fire and allow manual operation if needed." .

ffonto:ConfinePets rdf:type ffonto:PetPreparation ;
    rdfs:label "Confine Pets to One Room" ;
    rdfs:comment "Temporarily confining pets to a single room prior to evacuation may simplify gathering them quickly." .

ffonto:WetRoofAndNearby rdf:type ffonto:HomeProtectionMeasure ;
    rdfs:label "Wet Roof and Nearby Vegetation" ;
    rdfs:comment "If time allows, wet roof and nearby shrubs to reduce ember ignition — note this is not a guaranteed defense." ;
    ffonto:usesProtectionMethod ffonto:WetRoofAction .

ffonto:WetRoofAction rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Wet Roof Action" ;
    rdfs:comment "Use hose or sprinklers to wet roof and vulnerable vegetation; prioritize ember-blocking measures." .

ffonto:SealVents rdf:type ffonto:HomeProtectionMeasure ;
    rdfs:label "Seal Vents" ;
    rdfs:comment "Seal attic and ground vents with pre-cut plywood or commercial vent seals to reduce ember entry." ;
    ffonto:usesProtectionMethod ffonto:SealVentsAction .

ffonto:SealVentsAction rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Seal Vents Action" ;
    rdfs:comment "Install pre-cut plywood or commercial seals over vents when time permits." .

ffonto:MoveFlammableInside rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Move Flammable Items Inside" ;
    rdfs:comment "Move patio furniture, firewood, and other combustibles away from structure or inside." .

ffonto:TurnOffPropane rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Turn Off Propane Tanks" ;
    rdfs:comment "Shut off external propane tanks to reduce explosion risk if advised and safe to do so." .

ffonto:ShutOffGas rdf:type ffonto:HomeProtectionMeasure ;
    rdfs:label "Shut Off Gas at Meter" ;
    rdfs:comment "Turn off natural gas at the meter and extinguish pilot lights if told to and safe to do so." ;
    ffonto:usesProtectionMethod ffonto:ShutOffGasAction .

ffonto:ShutOffGasAction rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Shut Off Gas Action" ;
    rdfs:comment "Procedure for turning off gas; only performed if instructed and safe." .

ffonto:PortableGeneratorSafety rdf:type ffonto:GeneratorSafety ;
    rdfs:label "Portable Generator Safety" ;
    rdfs:comment "Guidance: operate generators outdoors, away from doors/windows/balconies; never backfeed into household wiring; use CO alarms." ;
    ffonto:generatorUsage "Outdoors only; keep >20 feet from openings; never operate in enclosed spaces; use CO monitor" .

ffonto:StandardCommunicationPlan rdf:type ffonto:CommunicationPlan ;
    rdfs:label "Standard Communication Plan" ;
    rdfs:comment "Tell someone where you're going; share rendezvous points and alternate contacts." ;
    ffonto:contacts ffonto:NationalFireAgency .

ffonto:AlternateRoutes rdf:type ffonto:EvacuationRoute ;
    rdfs:label "Alternate Evacuation Route" ;
    rdfs:comment "Have multiple routes planned to avoid blocked roads and reduce gridlock." .

ffonto:LeaveEarlyAdvice rdf:type ffonto:ImmediateEvacuationAction ;
    rdfs:label "Leave Early Advice" ;
    rdfs:comment "Recommendation to leave early to avoid traffic congestion and rapidly changing fire/smoke." .

ffonto:ReadySetGoPlan rdf:type owl:Class ;
    rdfs:label "Ready–Set–Go Plan" ;
    rdfs:comment "Three-stage public guidance: Ready (prepare), Set (be packed), Go (leave immediately)." .

ffonto:StageReady rdf:type owl:NamedIndividual, ffonto:ReadySetGoPlan ;
    rdfs:label "Ready Stage" ;
    rdfs:comment "Prepare home and kit; plan routes; maintain vehicle fuel; safeguard important documents." .

ffonto:StageSet rdf:type owl:NamedIndividual, ffonto:ReadySetGoPlan ;
    rdfs:label "Set Stage" ;
    rdfs:comment "Be packed and prepared to leave at short notice; move family and pets to central location; load car if safe to do so." .

ffonto:StageGo rdf:type owl:NamedIndividual, ffonto:ReadySetGoPlan ;
    rdfs:label "Go Stage" ;
    rdfs:comment "Leave immediately when ordered or when conditions are unsafe; follow official routes." .

ffonto:SpecialNeedsForHousehold rdf:type ffonto:SpecialNeedsPlan ;
    rdfs:label "Household Special Needs Plan" ;
    rdfs:comment "Arrangements for transport, backup power, medication continuity, and accessible shelter; coordinate with local agencies." .

ffonto:NeighborhoodCoordination rdf:type ffonto:NeighborSupportPlan ;
    rdfs:label "Neighborhood Coordination Plan" ;
    rdfs:comment "Plan to identify neighbors with special needs, pool resources, and coordinate evacuation assistance." .

ffonto:ActionPrepareCar rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Prepare Vehicle" ;
    rdfs:comment "Back vehicle into garage or park facing escape direction; ensure fuel and keys ready; roll up windows." .

ffonto:ActionPackKit rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Pack Disaster Supply Kit" ;
    rdfs:comment "Gather family kit, medications, documents, pet supplies, cash, and chargers." .

ffonto:ActionArrangeHousing rdf:type ffonto:BeforeEvacuationAction ;
    rdfs:label "Arrange Temporary Housing" ;
    rdfs:comment "Identify friend/relative outside threatened area or shelter options." .

ffonto:ActionWearProtectiveClothing rdf:type ffonto:ImmediateEvacuationAction ;
    rdfs:label "Wear Protective Clothing" ;
    rdfs:comment "Sturdy shoes, cotton/wool long pants & sleeves, gloves, and eye protection." ;
    ffonto:hasClothing ffonto:SturdyBoots , ffonto:LongSleevesAndPants , ffonto:GlovesAndEyeProtection .

ffonto:ActionTellSomeone rdf:type ffonto:ImmediateEvacuationAction ;
    rdfs:label "Tell Someone When You Leave" ;
    rdfs:comment "Inform an out-of-area contact of destination and route." .

ffonto:ActionChooseRouteAwayFromFire rdf:type ffonto:ImmediateEvacuationAction ;
    rdfs:label "Choose Route Away From Fire" ;
    rdfs:comment "Select routes that move away from smoke and fire, watch for changes in fire behavior." .

ffonto:HomePrepInside rdf:type ffonto:HomeProtectionMeasure ;
    rdfs:label "Interior Home Prep" ;
    rdfs:comment "Close windows, vents, blinds; remove light curtains; shut off gas and pilot lights; move flammable furniture to center of rooms; turn on interior lights for visibility in smoke." ;
    ffonto:usesProtectionMethod ffonto:ShutOffGasAction .

ffonto:HomePrepOutside rdf:type ffonto:HomeProtectionMeasure ;
    rdfs:label "Exterior Home Prep" ;
    rdfs:comment "Seal vents, turn off propane tanks, remove combustibles within 10-30 feet, connect hoses, wet roof if possible, place lawn sprinklers on roof if safe, gather fire tools." ;
    ffonto:usesProtectionMethod ffonto:SealVentsAction , ffonto:WetRoofAction , ffonto:TurnOffPropane .

ffonto:EvacuateBringDocs rdf:type ffonto:ImmediateEvacuationAction ;
    rdfs:label "Take Important Documents and Kit" ;
    rdfs:comment "Bring waterproof/fireproof documents, go-kit with 5-7 days supplies if advised, medications, and pet supplies." .

ffonto:DocumentSafeguardFireproof rdf:type ffonto:ImportantDocument ;
    rdfs:label "Fireproof and Cloud Backup for Documents" ;
    rdfs:comment "Keep originals in a fire-resistant safe, copies in waterproof pouches, and encrypted cloud backups for redundancy." ;
    ffonto:documentStorageMethod "fire-resistant safe; waterproof pouches; encrypted cloud backup" .

ffonto:VehiclePrepGuidance rdf:type ffonto:VehiclePreparation ;
    rdfs:label "Vehicle Evacuation Preparation Guidance" ;
    rdfs:comment "Maintain vehicles, keep fuel above half tank, store emergency kit, and plan routes." ;
    ffonto:vehicleFuelLevel ">=50%" .

ffonto:CampfireRisk rdf:type ffonto:EvacuationAction ;
    rdfs:label "Campfire Risk Action" ;
    rdfs:comment "Observe burn bans, keep water and a shovel nearby, and ensure campfires are cold before leaving." .

ffonto:TrafficAvoidance rdf:type ffonto:ImmediateEvacuationAction ;
    rdfs:label "Traffic Avoidance Actions" ;
    rdfs:comment "Leave early, follow official evacuation routes, obey traffic control and consider alternate routes." .

ffonto:DisabilityPrep rdf:type ffonto:SpecialNeedsPlan ;
    rdfs:label "Disability Evacuation Plan" ;
    rdfs:comment "Arrange accessible transport, backup power for medical devices, support network contacts, and accessible shelter options." .

ffonto:RoofWettingAdvisory rdf:type ffonto:HomeProtectionMeasure ;
    rdfs:label "Roof Wetting Advisory" ;
    rdfs:comment "Wetting the roof can reduce ember ignition briefly but is not a primary defense; prioritize removing combustibles and sealing vents." .

ffonto:GeneratorIndoorsProhibition rdf:type ffonto:GeneratorSafety ;
    rdfs:label "Generator Indoors Prohibition" ;
    rdfs:comment "Do not operate portable generators indoors, on balconies, or in enclosed areas due to carbon monoxide risk." ;
    ffonto:generatorUsage "Never operate indoors or on balconies; always use CO alarm" .

ffonto:WildfireVsPrescribed rdf:type owl:NamedIndividual ;
    rdfs:label "Wildfire vs Prescribed Burn - distinction" ;
    rdfs:comment "Wildfires are unplanned and uncontrolled; prescribed burns are planned and conducted under controlled conditions." .

ffonto:CarbonDioxide rdf:type ffonto:SmokeComponent ;
    rdfs:label "Carbon Dioxide" .

ffonto:CarbonMonoxide rdf:type ffonto:SmokeComponent ;
    rdfs:label "Carbon Monoxide" ;
    rdfs:comment "Colorless, odorless gas produced during incomplete combustion." .

ffonto:WaterVapor rdf:type ffonto:SmokeComponent ;
    rdfs:label "Water Vapor" .

ffonto:ParticulateMatter rdf:type ffonto:SmokeComponent ;
    rdfs:label "Particulate Matter" ;
    rdfs:comment "Fine particles less than 1 micron which scatter light and reduce visibility." .

ffonto:Hydrocarbons rdf:type ffonto:SmokeComponent ;
    rdfs:label "Hydrocarbons" .

ffonto:NitrogenOxides rdf:type ffonto:SmokeComponent ;
    rdfs:label "Nitrogen Oxides" .

ffonto:Acrolein rdf:type ffonto:AirToxic ;
    rdfs:label "Acrolein" ;
    rdfs:comment "A toxic aldehyde that causes irritation of eyes and respiratory system." .

ffonto:Formaldehyde rdf:type ffonto:AirToxic ;
    rdfs:label "Formaldehyde" ;
    rdfs:comment "Chemical irritant linked to respiratory damage and cancer risk." .

ffonto:Benzene rdf:type ffonto:AirToxic ;
    rdfs:label "Benzene" ;
    rdfs:comment "Carcinogenic chemical causing dizziness, anemia, and organ damage." .

ffonto:RespiratoryIrritation rdf:type ffonto:HealthEffect ;
    rdfs:label "Respiratory Irritation" .

ffonto:EyeIrritation rdf:type ffonto:HealthEffect ;
    rdfs:label "Eye Irritation" .

ffonto:CancerRisk rdf:type ffonto:HealthEffect ;
    rdfs:label "Cancer Risk" .

ffonto:Acrolein ffonto:causesHealthEffect ffonto:RespiratoryIrritation .
ffonto:Formaldehyde ffonto:causesHealthEffect ffonto:CancerRisk .
ffonto:Benzene ffonto:causesHealthEffect ffonto:CancerRisk .

ffonto:LightFuel rdf:type ffonto:FuelType ;
    rdfs:label "Light Fuel" ;
    rdfs:comment "Fast-burning fuels such as grass, leaves, and needles." .

ffonto:HeavyFuel rdf:type ffonto:FuelType ;
    rdfs:label "Heavy Fuel" ;
    rdfs:comment "Large materials like logs and branches that burn longer and produce more heat." .

ffonto:LadderFuel rdf:type ffonto:FuelType ;
    rdfs:label "Ladder Fuel" ;
    rdfs:comment "Vegetation that carries flames from the forest floor to tree crowns." .

ffonto:DownedLogs rdf:type ffonto:Fuel ;
    rdfs:label "Downed Logs" ;
    ffonto:hasFuelType ffonto:HeavyFuel .

ffonto:Grass rdf:type ffonto:Fuel ;
    rdfs:label "Grass" ;
    ffonto:hasFuelType ffonto:LightFuel .

ffonto:ElNino rdf:type ffonto:ClimateDriver ;
    rdfs:label "El Niño" ;
    rdfs:comment "Warm phase of ENSO affecting global precipitation patterns." .

ffonto:LaNina rdf:type ffonto:ClimateDriver ;
    rdfs:label "La Niña" ;
    rdfs:comment "Cool phase of ENSO often associated with drought conditions in some regions." .

ffonto:FWI rdf:type ffonto:FireWeatherIndex ;
    rdfs:label "Fire Weather Index (FWI)" ;
    rdfs:comment "Meteorological index estimating fire danger based on weather conditions." ;
    ffonto:resolution "0.1 degree global resolution" ;
    ffonto:dataSource "Temperature, humidity, wind speed, precipitation, snow depth" .

ffonto:SAR rdf:type ffonto:RemoteSensingMethod ;
    rdfs:label "Synthetic Aperture Radar (SAR)" ;
    rdfs:comment "Radar-based remote sensing used to estimate forest structure and stand height." .

ffonto:SatelliteImagery rdf:type ffonto:RemoteSensingMethod ;
    rdfs:label "Satellite Imagery" .

ffonto:NormalizedBurnRatio rdf:type ffonto:RemoteSensingIndex ;
    rdfs:label "Normalized Burn Ratio (NBR)" ;
    rdfs:comment "Remote sensing index used to measure burn severity using pre- and post-fire imagery." ;
    ffonto:derivedFrom ffonto:SatelliteImagery .

ffonto:FIRMS rdf:type ffonto:MonitoringSystem ;
    rdfs:label "NASA Fire Information for Resource Management System (FIRMS)" ;
    rdfs:comment "Satellite-based system providing active fire detection and alerts." ;
    ffonto:providedBy ffonto:NASA .

ffonto:ClimateEngine rdf:type ffonto:MonitoringSystem ;
    rdfs:label "Climate Engine" ;
    rdfs:comment "Web-based climate and remote sensing analysis platform using Google Earth Engine." ;
    ffonto:providedBy ffonto:NASA .

ffonto:NASA rdf:type ffonto:DataProvider ;
    rdfs:label "NASA" ;
    ffonto:website "https://www.nasa.gov" .

ffonto:USGS rdf:type ffonto:DataProvider ;
    rdfs:label "United States Geological Survey" ;
    ffonto:website "https://www.usgs.gov" .

ffonto:NOAA rdf:type ffonto:DataProvider ;
    rdfs:label "National Oceanic and Atmospheric Administration" ;
    ffonto:website "https://www.noaa.gov" .


ffonto:HEPAFilter rdf:type ffonto:IndoorAirQualityStrategy ;
    rdfs:label "HEPA Air Filter" ;
    rdfs:comment "High-efficiency air purifier used to remove smoke particles indoors." .

ffonto:MERV13Filter rdf:type ffonto:IndoorAirQualityStrategy ;
    rdfs:label "MERV-13 Filter" ;
    rdfs:comment "HVAC filter capable of capturing fine smoke particles." .

ffonto:CleanRoom rdf:type ffonto:IndoorAirQualityStrategy ;
    rdfs:label "Clean Air Room" ;
    rdfs:comment "Indoor room sealed to reduce smoke infiltration." .

ffonto:DataBackup rdf:type ffonto:ContinuityStrategy ;
    rdfs:label "Data Backup Strategy" .

ffonto:RemoteOperations rdf:type ffonto:ContinuityStrategy ;
    rdfs:label "Remote Operations Plan" .

ffonto:InsuranceReview rdf:type ffonto:ContinuityStrategy ;
    rdfs:label "Insurance Review" .

ffonto:EmergencyCommunicationPlan rdf:type ffonto:ContinuityStrategy ;
    rdfs:label "Emergency Communication Plan" .

ffonto:MeteorologicalObservation rdf:type owl:Class ;
    rdfs:label "Meteorological Variable" ;
    rdfs:comment "Weather variables used in fire danger and climate analysis." .

ffonto:Temperature rdf:type ffonto:MeteorologicalObservation ;
    rdfs:label "Air Temperature" .

ffonto:RelativeHumidity rdf:type ffonto:MeteorologicalObservation ;
    rdfs:label "Relative Humidity" .

ffonto:WindSpeed rdf:type ffonto:MeteorologicalObservation ;
    rdfs:label "Wind Speed" .

ffonto:Precipitation rdf:type ffonto:MeteorologicalObservation ;
    rdfs:label "Precipitation" .

ffonto:SnowDepth rdf:type ffonto:MeteorologicalObservation ;
    rdfs:label "Snow Depth" .

ffonto:DataRepository rdf:type owl:Class ;
    rdfs:label "Data Repository" ;
    rdfs:comment "Platform used to store and distribute Earth observation datasets." .

ffonto:DAAC rdf:type ffonto:DataRepository ;
    rdfs:label "Distributed Active Archive Center (DAAC)" ;
    rdfs:comment "NASA data centers responsible for archiving and distributing Earth science data." .

ffonto:EarthObservationPlatform rdf:type owl:Class ;
    rdfs:label "Earth Observation Platform" ;
    rdfs:comment "Computing platforms used to analyze satellite and climate datasets." .

ffonto:GoogleEarthEngine rdf:type ffonto:EarthObservationPlatform ;
    rdfs:label "Google Earth Engine" ;
    rdfs:comment "Cloud-based geospatial analysis platform used for environmental monitoring." .

ffonto:UAV rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EarthObservationPlatform ;
    rdfs:label "Unmanned Aerial Vehicle" .

ffonto:carriesSensor rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:UAV ;
    rdfs:range sosa:Sensor .

ffonto:carriesSensorOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:UAV ;
    rdfs:domain sosa:Sensor .

ffonto:carriesSensorOf owl:inverseOf ffonto:carriesSensor .

ffonto:QualityControlProcess rdf:type owl:Class ;
    rdfs:label "Data Quality Control Process" ;
    rdfs:comment "Procedures used to validate and verify scientific datasets before public release." .

ffonto:validatesData rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:QualityControlProcess ;
    rdfs:range ffonto:SatelliteData .

ffonto:validatesDataOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:QualityControlProcess ;
    rdfs:domain ffonto:SatelliteData .

ffonto:validatesDataOf owl:inverseOf ffonto:validatesData .

ffonto:VegetationIndex rdf:type owl:Class ;
    rdfs:label "Vegetation Index" ;
    rdfs:comment "Satellite-derived index used to monitor vegetation health and density." .

ffonto:NDVI rdf:type ffonto:VegetationIndex ;
    rdfs:label "Normalized Difference Vegetation Index (NDVI)" .

ffonto:SoilMoistureIndex rdf:type owl:Class ;
    rdfs:label "Soil Moisture Index" ;
    rdfs:comment "Indicator measuring soil water availability." .

ffonto:Evapotranspiration rdf:type owl:Class ;
    rdfs:label "Evapotranspiration" ;
    rdfs:comment "Combined evaporation and plant transpiration influencing drought conditions." .

ffonto:ClimateAnomaly rdf:type owl:Class ;
    rdfs:label "Climate Anomaly" ;
    rdfs:comment "Deviation of climate variables from long-term averages." .

ffonto:TimeSeriesAnalysis rdf:type owl:Class ;
    rdfs:label "Time Series Analysis" ;
    rdfs:comment "Analysis of environmental variables over time to detect trends or anomalies." .

ffonto:DataAssimilation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TimeSeriesAnalysis ;
    rdfs:label "Data Assimilation" .

ffonto:updatesModel rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:DataAssimilation ;
    rdfs:range ffonto:FireBehavior .

ffonto:updatesModelOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:DataAssimilation ;
    rdfs:domain ffonto:FireBehavior .

ffonto:updatesModelOf owl:inverseOf ffonto:updatesModel .

ffonto:ActiveFireDetection rdf:type owl:Class ;
    rdfs:label "Active Fire Detection" ;
    rdfs:comment "Satellite detection of actively burning fires using thermal sensors." .

ffonto:FireAlertSystem rdf:type owl:Class ;
    rdfs:label "Fire Alert System" ;
    rdfs:comment "Systems that notify users about active fires or fire danger conditions." .

ffonto:WorldviewPlatform rdf:type ffonto:FireAlertSystem ;
    rdfs:label "NASA Worldview Fire Monitoring Platform" ;
    rdfs:comment "NASA web application for visualizing near-real-time satellite imagery including wildfire detections." .

ffonto:DeciduousForest rdf:type ffonto:VegetationType ;
    rdfs:label "Deciduous Forest" ;
    rdfs:comment "Forest dominated by trees that shed leaves seasonally." .

ffonto:ConiferForest rdf:type ffonto:VegetationType ;
    rdfs:label "Conifer Forest" ;
    rdfs:comment "Forest dominated by cone-bearing trees such as pine or fir." .

ffonto:SeasonalFlammability rdf:type owl:Class ;
    rdfs:label "Seasonal Flammability" ;
    rdfs:comment "Variation in vegetation flammability depending on seasonal conditions." .

ffonto:influencedByWeather rdf:type owl:ObjectProperty ;
    rdfs:label "influenced by weather" ;
    rdfs:comment "Indicates wildfire risk influenced by weather variability." ;
    rdfs:domain ffonto:ForestFireRisk ;
    rdfs:range ffonto:WeatherCondition .

ffonto:influencedByWeatherOf rdf:type owl:ObjectProperty ;
    rdfs:label "influenced by weather" ;
    rdfs:comment "Indicates wildfire risk influenced by weather variability." ;
    rdfs:range ffonto:ForestFireRisk ;
    rdfs:domain ffonto:WeatherCondition ;
    owl:inverseOf ffonto:influencedByWeather .

ffonto:monitoredUsing rdf:type owl:ObjectProperty ;
    rdfs:label "monitored using" ;
    rdfs:comment "Links wildfire monitoring to remote sensing systems." ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:RemoteSensingSensor .

ffonto:monitoredUsingInverse a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:RemoteSensingSensor ;
    rdfs:label "inverse of monitored using"@en  .

ffonto:monitoredUsingInverse owl:inverseOf ffonto:monitoredUsing .

ffonto:estimatedBy
    rdf:type owl:ObjectProperty ;
    rdfs:label "estimated by" ;
    rdfs:comment "Relates a forest fire to the method used to estimate it." ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:EstimationMethod .

ffonto:estimatesFire
    rdf:type owl:ObjectProperty ;
    rdfs:label "estimates fire" ;
    rdfs:domain ffonto:EstimationMethod ;
    rdfs:range ffonto:ForestFire ;
    owl:inverseOf ffonto:estimatedBy .

ffonto:EstimationMethod
    rdf:type owl:Class ;
    rdfs:label "Estimation method" ;
    rdfs:comment "A method used to estimate wildfire characteristics such as spread, size, or risk." .

ffonto:HumanEstimation
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EstimationMethod ;
    rdfs:label "Human estimation" ;
    rdfs:comment "A wildfire estimation produced by human experts such as firefighters or analysts." .

ffonto:ModelEstimation
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EstimationMethod ;
    rdfs:label "Model estimation" ;
    rdfs:comment "A wildfire estimation generated using computational or predictive models." .

ffonto:HumanExpertAssessment
    rdf:type ffonto:HumanEstimation ;
    rdfs:label "Human expert wildfire assessment" .

ffonto:FireSpreadModel
    rdf:type ffonto:ModelEstimation ;
    rdfs:label "Fire spread prediction model" .

ffonto:SpatialEntity
    rdf:type owl:Class ;
    rdfs:label "Spatial entity"@en ;
    rdfs:comment "An entity that exists in physical or geographic space and can have a spatial location or geometry."@en ;
    rdfs:subClassOf geo:SpatialObject .

ffonto:Country
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SpatialEntity ;
    rdfs:label "Country" ;
    rdfs:comment "A sovereign nation or state." .

ffonto:Region
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SpatialEntity ;
    rdfs:label "Region" ;
    rdfs:comment "A large geographic or administrative area within a country." .

ffonto:Division
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Region ;
    rdfs:label "Division" ;
    rdfs:comment "A major administrative subdivision within a region." .

ffonto:City
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SpatialEntity ;
    rdfs:label "City" ;
    rdfs:comment "A large human settlement." .

ffonto:Town
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SpatialEntity ;
    rdfs:label "Town" ;
    rdfs:comment "A smaller urban settlement than a city." .

ffonto:Village
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SpatialEntity ;
    rdfs:label "Village" ;
    rdfs:comment "A small rural settlement." .

ffonto:Site
    rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SpatialEntity ;
    rdfs:label "Site" ;
    rdfs:comment "A specific geographic location such as a fire incident site." .

ffonto:hasLocation rdf:type owl:ObjectProperty ;
    rdfs:label "located at" ;
    rdfs:comment "Indicates the place where a spatial entity is located." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range ffonto:Observation .

ffonto:isLocationOf a owl:ObjectProperty ;
    rdfs:range ffonto:SpatialEntity ;
    rdfs:domain ffonto:Observation ;
    rdfs:label "inverse of located at"@en .

ffonto:isLocationOf owl:inverseOf ffonto:hasLocation .

ffonto:hasLatitude rdf:type owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    rdfs:comment "Latitude coordinate of a spatial entity." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range xsd:decimal .

ffonto:hasLongitude rdf:type owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    rdfs:comment "Longitude coordinate of a spatial entity." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range xsd:decimal .

ffonto:hasElevation rdf:type owl:DatatypeProperty ;
    rdfs:label "elevation" ;
    rdfs:comment "Elevation above sea level." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range xsd:decimal .

ffonto:hasArea rdf:type owl:DatatypeProperty ;
    rdfs:label "area" ;
    rdfs:comment "Area of the spatial entity in square kilometers." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range xsd:decimal .

ffonto:placeName rdf:type owl:DatatypeProperty ;
    rdfs:label "place name" ;
    rdfs:comment "Name of the place." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range xsd:string .

ffonto:postalCode rdf:type owl:DatatypeProperty ;
    rdfs:label "postal code" ;
    rdfs:comment "Postal code of a city or region." ;
    rdfs:domain ffonto:SpatialEntity ;
    rdfs:range xsd:string .

ffonto:FuelMoisture  rdfs:comment "The moisture content of combustible vegetation or fuels, usually expressed as a percentage."@en .
 ffonto:SmokeDispersionModel  rdfs:comment "A computational model that simulates the transport and spread of smoke in the atmosphere."@en .
 ffonto:PredictiveInterval  rdfs:comment "A statistical interval that quantifies the uncertainty range for future observations or forecasts."@en .
 ffonto:Encryption  rdfs:comment "The process of encoding information to prevent unauthorized access."@en .
 ffonto:CardiovascularEffect  rdfs:comment "Any physiological effect that impacts the cardiovascular system."@en .
 ffonto:SafetyOfficer  rdfs:comment "An individual responsible for overseeing health and safety practices during an incident."@en .
 ffonto:GeoTIFF  rdfs:comment "A georeferenced TIFF image format commonly used for storing raster geographic data."@en .
 ffonto:PoliceCar  rdfs:comment "A vehicle operated by police personnel for law enforcement and emergency response."@en .
 ffonto:BarkBeetleOutbreak  rdfs:comment "A widespread infestation event of bark beetles causing tree mortality."@en .
 ffonto:LeftFlank  rdfs:comment "The left lateral edge of a wildfire's active burning front."@en .
 ffonto:Aspect  rdfs:comment "The compass direction that a slope faces, affecting sun exposure and fire behavior."@en .
 ffonto:CampfireIgnition  rdfs:comment "The event or action that causes a campfire to be ignited."@en .
 ffonto:InsurancePolicy  rdfs:comment "A contract that provides financial protection against specified losses or damages."@en .
 ffonto:FirePerimeter  rdfs:comment "A boundary line delineating the outermost extent of active or recently active fire."@en .
 ffonto:SituationReport  rdfs:comment "A concise report summarizing current conditions, impacts, and response actions."@en .
 ffonto:RemoteSensor  rdfs:comment "A sensor that collects data from a distance, often without direct contact with the measurement target."@en .
 ffonto:RollbackStrategy  rdfs:comment "A plan to revert systems, deployments, or operations to a previous stable state."@en .
 ffonto:ConfidenceScore  rdfs:comment "A numeric value representing the estimated reliability of a prediction or measurement."@en .
 ffonto:DebrisBurning  rdfs:comment "The controlled or uncontrolled burning of vegetative or man-made debris."@en .
 ffonto:ClimateFeedbackLoop  rdfs:comment "A process where climate system responses amplify or dampen an initial forcing."@en .
 ffonto:ActiveFire  rdfs:comment "An area where combustion is currently occurring and producing flames, heat, or smoke."@en .
 ffonto:DownedPowerLineHazard  rdfs:comment "A danger posed by electrical conductors that have fallen and may be energized."@en .
 ffonto:FuelReduction  rdfs:comment "Actions taken to decrease available combustible material to lower fire risk."@en .
 ffonto:OperationsSection  rdfs:comment "The organizational unit responsible for tactical operations during an incident."@en .
 ffonto:VehicleAccess  rdfs:comment "The ability for vehicles to reach or traverse a location or route."@en .
 ffonto:DeployableShelter  rdfs:comment "A portable shelter intended for temporary housing during emergencies."@en .
 ffonto:PyrocumulusCloud  rdfs:comment "A convective cloud generated by intense fire heat and smoke, sometimes producing its own weather."@en .
 ffonto:MLOpsPipeline  rdfs:comment "A sequence of processes for developing, deploying, and maintaining machine learning models in production."@en .
 ffonto:HoseLine  rdfs:comment "A length of fire hose deployed to deliver water or foam to a fire."@en .
 ffonto:VolcanicActivity  rdfs:comment "Geologic processes and events associated with volcanic unrest or eruptions."@en .
 ffonto:CrowdsourcedReport  rdfs:comment "A report or observation submitted by members of the public or volunteers."@en .
 ffonto:AirSupport  rdfs:comment "Aerial resources assigned to assist ground operations, such as water drops or reconnaissance."@en .
 ffonto:EmergencyResponder  rdfs:comment "A trained person who responds to incidents to provide assistance or protection."@en .
 ffonto:NaturalCause  rdfs:comment "An event or condition originating from natural processes rather than human action."@en .
 ffonto:ForestManagement  rdfs:comment "Practices aimed at sustaining forest health, productivity, and ecological values."@en .
 ffonto:IncidentCommand  rdfs:comment "The authority and structure responsible for overall incident management and decision-making."@en .
 ffonto:WaterTender  rdfs:comment "A vehicle designed to transport and supply water for firefighting operations."@en .
 ffonto:IoU  rdfs:comment "Intersection over Union; a metric comparing area overlap between predicted and reference regions."@en .
 ffonto:AircraftTracking  rdfs:comment "Monitoring and recording the position and movement of aircraft."@en .
 ffonto:LogisticsSection  rdfs:comment "The organizational unit responsible for support services and resource provision during an incident."@en .
 ffonto:FirearmsExplosives  rdfs:comment "Items classified as firearms or explosives that may pose safety or legal concerns."@en .
 ffonto:VulnerabilityAssessment  rdfs:comment "An evaluation of susceptibilities to harm from hazards or threats."@en .
 ffonto:Barricade  rdfs:comment "A physical obstruction placed to block access or protect an area."@en .
 ffonto:Arson  rdfs:comment "The deliberate ignition of fires with malicious or unlawful intent."@en .
 ffonto:Precipitation  rdfs:comment "Any form of water, liquid or solid, that falls from the atmosphere to the ground."@en .
 ffonto:VulnerablePopulation  rdfs:comment "Groups of people who may require special assistance or are at increased risk during emergencies."@en .
 ffonto:Birds  rdfs:comment "Avian species present in an area; may be affected by environmental events."@en .
 ffonto:NDVI  rdfs:comment "Normalized Difference Vegetation Index; a satellite-derived index indicating vegetation greenness."@en .
 ffonto:OperationalPeriod  rdfs:comment "A defined time interval for which incident operations are planned or reported."@en .
 ffonto:HandTool  rdfs:comment "A manually operated tool used for tasks such as cutting, digging, or clearing."@en .
 ffonto:CigaretteButt  rdfs:comment "The remnant of a smoked cigarette, often a source of ignition if improperly discarded."@en .
 ffonto:Resident  rdfs:comment "A person who lives in a specified area or community."@en .
 ffonto:PredictionUncertainty  rdfs:comment "A quantitative or qualitative measure of how uncertain a prediction or forecast is."@en .
 ffonto:Slope  rdfs:comment "The steepness or incline of terrain, commonly expressed as a percentage or angle."@en .
 ffonto:ClimateMitigation  rdfs:comment "Actions taken to reduce greenhouse gas emissions or limit climate change impacts."@en .
 ffonto:RemoteSensing  rdfs:comment "The acquisition of information about objects or areas from a distance, typically via satellites or aircraft."@en .
 ffonto:RailOperations  rdfs:comment "Activities involved in the movement, control, and management of railway services."@en .
 ffonto:GeoJSON  rdfs:comment "A JSON-based format for encoding geographic data structures such as points and polygons."@en .
 ffonto:CommunityWorkshop  rdfs:comment "A public meeting or training session aimed at community engagement and education."@en .
 ffonto:DownedPowerLine  rdfs:comment "An electrical conductor that has fallen from its support and may present hazard."@en .
 ffonto:Person  rdfs:comment "A human individual; used to represent people in data and processes."@en .
 ffonto:RadioComms  rdfs:comment "Two-way communication using radio frequencies for coordination and information exchange."@en .
 ffonto:Segmentation  rdfs:comment "The process of partitioning data or images into meaningful regions or classes."@en .
 ffonto:ReportVerification  rdfs:comment "The process of confirming the accuracy, source, or validity of a report or observation."@en .
 ffonto:Temperature  rdfs:comment "A measure of heat expressed in degrees on a specified scale (e.g., Celsius)."@en .
 ffonto:ModelTrainingTechnique  rdfs:comment "A method or algorithm used to train a machine learning model."@en .
 ffonto:EvacuationOperation  rdfs:comment "An organized activity to move people from danger to safety."@en .
 ffonto:HotspotLocalization  rdfs:comment "Determining the geographic location of thermal anomalies indicating active fire or heat sources."@en .
 ffonto:PhysicsInformedModel  rdfs:comment "A model that incorporates known physical laws or constraints into its structure."@en .
 ffonto:ModelDrift  rdfs:comment "A change in model performance over time due to changes in data or environment."@en .
 ffonto:BurnSeverityMap  rdfs:comment "A spatial representation indicating the intensity or ecological severity of burned areas."@en .
 ffonto:MinorMisuse  rdfs:comment "Usage of a resource or tool outside intended procedures that causes little or no harm."@en .
 ffonto:VehicleSafety  rdfs:comment "Design features and practices that reduce risk to vehicle occupants and responders."@en .
 ffonto:RelativeHumidity  rdfs:comment "The amount of moisture in the air expressed as a percentage of the maximum possible at that temperature."@en .
 ffonto:IndirectAttack  rdfs:comment "A firefighting tactic where control lines are established at a distance and fires are allowed to burn to them."@en .
 ffonto:IncidentBriefing  rdfs:comment "A short, focused presentation of current situation, objectives, and safety information for personnel."@en .
 ffonto:GatedWye  rdfs:comment "A three-way valve fitting used in fire hydrant or water distribution systems to control flow."@en .
 ffonto:Recall  rdfs:comment "An action to withdraw or request the return of a product or service due to safety or quality issues."@en .
 ffonto:SmokeDetection  rdfs:comment "The process or technology used to identify the presence of smoke in an environment."@en .
 ffonto:CommandPost  rdfs:comment "A location from which incident command and coordination are conducted."@en .
 ffonto:TelemetryData  rdfs:comment "Remote measurements transmitted from sensors or systems for monitoring and analysis."@en .
 ffonto:AirQualityIndex  rdfs:comment "A numeric scale indicating the quality of air and potential health impacts."@en .
 ffonto:F1Score  rdfs:comment "The harmonic mean of precision and recall, used as a performance metric for classification."@en .
 ffonto:ForestRestoration  rdfs:comment "Actions intended to return forest ecosystems to a desired ecological state."@en .
 ffonto:AerialDropOperation  rdfs:comment "A mission to release water, retardant, or supplies from aircraft to a target area."@en .
 ffonto:CampfireSafety  rdfs:comment "Practices that reduce the risk of accidental fires when using campfires."@en .
 ffonto:DozerLine  rdfs:comment "A fire control line constructed by bulldozer to remove fuel and stop spread."@en .
 ffonto:CaliforniaForestFireStatistic  rdfs:comment "A statistical measure or dataset specific to forest fire activity in California."@en .
 ffonto:EthicalConsideration  rdfs:comment "A factor reflecting moral implications or responsibilities associated with an action or system."@en .
 ffonto:GOES  rdfs:comment "Geostationary Operational Environmental Satellite; a family of weather-monitoring satellites."@en .
 ffonto:DecisionSupportSystem  rdfs:comment "A tool or system providing information and analysis to aid decision-makers."@en .
 ffonto:FuelTreatment  rdfs:comment "Management actions (e.g., thinning, grazing, prescribed fire) to alter fuel characteristics."@en .
 ffonto:HeatStressHazard  rdfs:comment "Conditions that increase risk of heat-related illness or performance degradation."@en .
 ffonto:EvacuationRoutingAlgorithm  rdfs:comment "An algorithm that computes recommended evacuation paths given constraints and hazards."@en .
 ffonto:AirspaceManagement  rdfs:comment "Procedures and controls for safe and efficient use of airspace during operations."@en .
 ffonto:ForestFireTechnology  rdfs:comment "Technologies designed to detect, model, mitigate, or respond to forest fires."@en .
 ffonto:HazardMapping  rdfs:comment "The process of creating maps that identify and characterize hazards in an area."@en .
 ffonto:ModelVersion  rdfs:comment "A named or numbered release of a model representing a specific state of development."@en .
 ffonto:HeatWave  rdfs:comment "A prolonged period of excessively hot weather relative to the normal climate for the area."@en .
 ffonto:CAPAlert  rdfs:comment "Common Alerting Protocol message used to distribute emergency alerts and warnings."@en .
 ffonto:SHAP  rdfs:comment "SHapley Additive exPlanations; a method for interpreting contributions of features to model predictions."@en .
 ffonto:DiscardedCigarette  rdfs:comment "A cigarette that has been discarded; potential ignition source if still burning."@en .
 ffonto:DirectAttack  rdfs:comment "A firefighting tactic where suppression efforts are applied directly to the fire's edge."@en .
 ffonto:ActiveLearning  rdfs:comment "A machine learning approach where the algorithm selects data points to be labeled to improve learning efficiency."@en .
 ffonto:COG  rdfs:comment "Center of gravity (COG); a weighted center point used in analysis or modeling contexts."@en .
 ffonto:AshPitHazard  rdfs:comment "A danger from hot, smoldering ash pits that can cause burns or reignition."@en .
 ffonto:ProlongedFireSeason  rdfs:comment "An extended period of the year with elevated wildfire activity compared to historical norms."@en .
 ffonto:RespiratoryEffect  rdfs:comment "Any effect that impacts the respiratory system, including irritation or disease."@en .
 ffonto:HeatStressRisk  rdfs:comment "The likelihood that individuals will experience heat-related health effects under given conditions."@en .
 ffonto:FlameLength  rdfs:comment "The vertical distance from base to tip of visible flame, used as a fire behavior metric."@en .
 ffonto:PortableWaterTank  rdfs:comment "A movable container used to store water for firefighting or emergency supply."@en .
 ffonto:FireSimulationSoftware  rdfs:comment "Software used to simulate fire behavior, spread, and related environmental effects."@en .
 ffonto:AerialDropPlanning  rdfs:comment "The logistical planning process for aircraft drops including safety, target selection, and quantities."@en .
 ffonto:FireBehaviorModel  rdfs:comment "A model that simulates the spread, intensity, and effects of fire under various conditions."@en .
 ffonto:CyberSecurityPractice  rdfs:comment "A policy, control, or procedure intended to protect information systems from cyber threats."@en .
 ffonto:SchoolEducation  rdfs:comment "Educational programs targeting students and school communities on preparedness and safety topics."@en .
 ffonto:Asthma  rdfs:comment "A chronic respiratory condition characterized by airway inflammation and episodic breathing difficulties."@en .
 ffonto:Airspace  rdfs:comment "A defined volume of airspace where specific rules and procedures apply."@en .
 ffonto:FocalLoss  rdfs:comment "A loss function used to address class imbalance by down-weighting easy examples."@en .
 ffonto:RealTimeMonitoring  rdfs:comment "Continuous observation and reporting of data as events occur or data become available."@en .
 ffonto:ScrapeLine  rdfs:comment "A cleared or scraped area used as a control line to slow or stop fire spread."@en .
 ffonto:PublicWarningSystem  rdfs:comment "A system for issuing warnings and alerts to the public during emergencies."@en .
 ffonto:SwarmUAV  rdfs:comment "A coordinated group of unmanned aerial vehicles operating together to accomplish tasks."@en .
 ffonto:CanaryDeployment  rdfs:comment "A software deployment strategy that releases changes to a subset of users to reduce risk."@en .
 ffonto:PregnantPerson  rdfs:comment "A person who is currently pregnant; may have specific health and safety considerations."@en .
 ffonto:CarbonSequestration  rdfs:comment "The process of removing carbon dioxide from the atmosphere and storing it in biomass or soils."@en .
 ffonto:EmergencyAlert  rdfs:comment "A message intended to notify the public or specific groups about an immediate hazard."@en .
 ffonto:AircraftSensor  rdfs:comment "A sensor mounted on an aircraft used to collect airborne observations or imagery."@en .
 ffonto:FireRadiativePower  rdfs:comment "A measurement of fire energy release rate estimated from thermal remote sensing data."@en .
 ffonto:PowerLineFailure  rdfs:comment "A malfunction or breakage in electrical power lines that can result in outages or hazards."@en .
 ffonto:LookoutTower  rdfs:comment "A staffed elevated structure used for fire detection and observation."@en .
 ffonto:ImageContribution  rdfs:comment "An image or photograph provided by a person or organization for analysis or documentation."@en .
 ffonto:AirspaceConflictDetection  rdfs:comment "The process of identifying potential conflicts between aircraft or airspace users."@en .
 ffonto:Deer  rdfs:comment "A cervid species; wildlife potentially affected by habitat change or fire."@en .
 ffonto:ComputerVisionTask  rdfs:comment "A defined problem in computer vision such as detection, segmentation, or classification."@en .
 ffonto:HumanActivity  rdfs:comment "Actions or behaviors by people that may influence or indicate conditions in an area."@en .
 ffonto:SaliencyMap  rdfs:comment "A representation highlighting regions of an input that most influence model predictions."@en .
 ffonto:Ridge  rdfs:comment "A long, narrow elevation of land, often influencing fire spread and weather."@en .
 ffonto:StructureShelter  rdfs:comment "A building or structure designated to provide protection to people during emergencies."@en .
 ffonto:AirAttackSupervisor  rdfs:comment "An individual responsible for coordinating aerial firefighting resources and tactics."@en .
 ffonto:SuppressionMethod  rdfs:comment "A technique or tactic used to extinguish or control fire."@en .
 ffonto:DebrisFlowRisk  rdfs:comment "The potential for rapid mass-wasting events composed of water-saturated debris following storms or fires."@en .
 ffonto:AtmosphericTransportModel  rdfs:comment "A model that simulates the transport of pollutants or particles through the atmosphere."@en .
 ffonto:AudioAnalytics  rdfs:comment "Automated analysis of audio signals to detect events or extract features."@en .
 ffonto:WatershedManagement  rdfs:comment "Planning and practices to manage water resources and land use in a watershed."@en .
 ffonto:SocialEquity  rdfs:comment "The fair and just distribution of resources, opportunities, and burdens across populations."@en .
 ffonto:Sensor  rdfs:comment "A device that detects and measures physical or environmental properties and outputs data."@en .
 ffonto:EdgeDevice  rdfs:comment "A computing device located near data sources for local processing and low-latency responses."@en .
 ffonto:MountainSlope  rdfs:comment "The inclined surface of mountainous terrain, often affecting water flow and fire behavior."@en .
 ffonto:DebrisFlowHazard  rdfs:comment "The presence of conditions that increase the likelihood of debris flows."@en .
 ffonto:HumanCause  rdfs:comment "An event or condition initiated by human activity that may lead to incidents."@en .
 ffonto:SmokePlume  rdfs:comment "A concentrated column or mass of smoke rising from a fire source."@en .
 ffonto:Smoking  rdfs:comment "The act of inhaling and exhaling tobacco or other substances; a potential fire ignition source."@en .
 ffonto:EmissionEstimate  rdfs:comment "An estimate of pollutant or greenhouse gas emissions produced by a source or event."@en .
 ffonto:AirQualityRisk  rdfs:comment "The risk to health or environment due to degraded air quality conditions."@en .
 ffonto:BuildingCode  rdfs:comment "Regulations that set standards for construction to ensure safety and performance."@en .
 ffonto:PhysicalHazard  rdfs:comment "A tangible environmental or structural danger that can cause injury or damage."@en .
 ffonto:BVLOS  rdfs:comment "Beyond Visual Line Of Sight: UAV operations conducted without direct visual contact with the aircraft."@en .
 ffonto:WetLine  rdfs:comment "A line of water applied to vegetation or ground to act as a temporary firebreak."@en .
 ffonto:MODIS  rdfs:comment "Moderate Resolution Imaging Spectroradiometer; a satellite sensor providing Earth observation data."@en .
 ffonto:EDXLMessage  rdfs:comment "An Emergency Data Exchange Language message used for interoperable emergency communications."@en .
 ffonto:Precision  rdfs:comment "A measure of the proportion of true positive results among positive predictions."@en .
 ffonto:AwarenessCampaign  rdfs:comment "An organized effort to inform the public about risks and preparedness actions."@en .
 ffonto:FirefighterHealthSafety  rdfs:comment "Policies and practices aimed at protecting the health and wellbeing of firefighting personnel."@en .
 ffonto:BurnScarSegmentation  rdfs:comment "The classification of satellite or aerial imagery to delineate areas affected by burning."@en .
 ffonto:Fireworks  rdfs:comment "Pyrotechnic devices intended for celebration that may present fire hazards if misused."@en .
 ffonto:PublicAlert  rdfs:comment "A notification issued to inform the public about an emergency or required action."@en .
 ffonto:ShortestSafePath  rdfs:comment "A computed route that minimizes distance while satisfying safety constraints."@en .
 ffonto:Branch  rdfs:comment "A large organizational subdivision within an incident management structure."@en .
 ffonto:PreventionMeasure  rdfs:comment "An action designed to reduce the likelihood or impact of an adverse event."@en .
 ffonto:Chainsaw  rdfs:comment "A powered cutting tool used for felling and cutting wood; requires safety protocols."@en .
 ffonto:GeospatialDataFormat  rdfs:comment "A file format or specification for storing and exchanging geographic data."@en .
 ffonto:Hyperspectral  rdfs:comment "Imaging that captures data across many narrow spectral bands for detailed material analysis."@en .
 ffonto:Helispot  rdfs:comment "A prepared area where helicopters can land and take off safely during operations."@en .
 ffonto:ModelOutput  rdfs:comment "Results produced by a model, including predictions, maps, or summary statistics."@en .
 ffonto:RateOfSpread  rdfs:comment "The rate at which a fire front advances over the landscape, typically distance per time."@en .
 ffonto:ChangeDetection  rdfs:comment "Techniques to identify differences between datasets or images acquired at different times."@en .
 ffonto:PrescribedBurnPolicy  rdfs:comment "Regulatory or operational guidelines governing the planning and execution of prescribed fires."@en .
 ffonto:FirefighterSafety  rdfs:comment "Measures and practices to reduce risk and injury for firefighters."@en .
 ffonto:MeshNetwork  rdfs:comment "A network topology where nodes relay data for robust, decentralized communications."@en .
 ffonto:CommunicationNetwork  rdfs:comment "Systems and infrastructure enabling information exchange among stakeholders and responders."@en .
 ffonto:VegetationDryness  rdfs:comment "A measure of moisture deficiency in vegetation that influences flammability."@en .
 ffonto:ProvenanceRecord  rdfs:comment "Metadata that documents the origin, lineage, and processing history of data or artifacts."@en .
 ffonto:Smoker  rdfs:comment "A person who uses tobacco or other smoked substances; potential ignition source in certain contexts."@en .
 ffonto:STAC  rdfs:comment "SpatioTemporal Asset Catalog; a specification for describing geospatial data assets and metadata."@en .
 ffonto:AgriculturalBuilding  rdfs:comment "A structure used for farming activities, storage, or livestock housing."@en .
 ffonto:FiveGNetwork  rdfs:comment "A cellular network architecture that provides high bandwidth and low latency connectivity."@en .
 ffonto:FlameDetection  rdfs:comment "Technologies or methods used to detect the presence of flames in imagery or sensors."@en .
 ffonto:MentalHealthRisk  rdfs:comment "The potential for adverse psychological impacts resulting from exposure to stressors or trauma."@en .
 ffonto:NaturalFireline  rdfs:comment "A physical landscape feature that acts as a natural barrier to fire spread."@en .
 ffonto:Revegetation  rdfs:comment "The process of planting or encouraging vegetation regrowth after disturbance."@en .
 ffonto:EmergencyKit  rdfs:comment "A collection of essential supplies and tools prepared for use during emergencies."@en .
 ffonto:DiceCoefficient  rdfs:comment "A statistic for measuring similarity between two samples, commonly used in segmentation evaluation."@en .
 ffonto:LicensePlateBlurring  rdfs:comment "A privacy-preserving technique that obscures vehicle license plates in images or videos."@en .
 ffonto:SatelliteData  rdfs:comment "Observational data collected by Earth-orbiting satellites, including imagery and sensor measurements."@en .
 ffonto:FlightPath  rdfs:comment "A planned or recorded trajectory that an aircraft follows between waypoints."@en .
 ffonto:PlanningSection  rdfs:comment "The organizational unit responsible for incident planning, documentation, and future operations."@en .
 ffonto:FaceBlurring  rdfs:comment "A privacy technique that obscures facial features in imagery to protect individual identity."@en .
 ffonto:RightFlank  rdfs:comment "The right lateral edge of a wildfire's active burning front."@en .
 ffonto:RecreationCeremony  rdfs:comment "A recreational or ceremonial activity, potentially relevant for public safety considerations."@en .
 ffonto:FinanceAdministrationSection  rdfs:comment "The organizational unit handling fiscal, procurement, and administrative tasks during an incident."@en .
 ffonto:AirTankerDrop  rdfs:comment "An aerial operation where an aircraft releases fire retardant or water over a target area."@en .
 ffonto:COPD  rdfs:comment "Chronic Obstructive Pulmonary Disease; a respiratory condition that can be exacerbated by smoke exposure."@en .
 ffonto:IncidentCommander  rdfs:comment "The person with overall responsibility for managing an incident and its response."@en .
 ffonto:Handline  rdfs:comment "A control line built by hand crews using hand tools to stop or contain fire."@en .
 ffonto:RoadAccess  rdfs:comment "Availability and condition of roadways allowing passage for vehicles and responders."@en .
 ffonto:SpontaneousCombustion  rdfs:comment "A self-ignition event caused by internal heat generation without external ignition sources."@en .
 ffonto:SelfSupervisedLearning  rdfs:comment "A machine learning paradigm using automatically generated labels from input data structure."@en .
 ffonto:ContainedFire  rdfs:comment "A fire that has been confined within established control lines or barriers."@en .
 ffonto:Fireline  rdfs:comment "A cleared or treated strip of land intended to stop fire spread."@en .
 ffonto:SatelliteInternet  rdfs:comment "Internet connectivity provided via satellites rather than terrestrial infrastructure."@en .
 ffonto:DataStream  rdfs:comment "A continuous flow of data records generated over time from sensors or systems."@en .
 ffonto:DataAugmentation  rdfs:comment "Techniques to increase training data diversity by transforming existing examples."@en .
 ffonto:EnsembleForecast  rdfs:comment "A forecast produced by combining multiple model runs to represent uncertainty and improve robustness."@en .
 ffonto:CigaretteSafety  rdfs:comment "Practices or measures aimed at reducing ignition risk associated with smoking materials."@en .
 ffonto:PostFireFloodRisk  rdfs:comment "The increased risk of flooding or debris flow following vegetation loss from fire."@en .
 ffonto:Radio  rdfs:comment "A device or system for wireless audio communication used in operations."@en .
 ffonto:BrushEngine  rdfs:comment "A small firefighting vehicle designed for off-road access to brush and wildland fires."@en .
 ffonto:CommunityPlanning  rdfs:comment "Processes by which communities prepare policies and actions to reduce hazard impacts."@en .
 ffonto:CommunityProgram  rdfs:comment "An organized local initiative to support preparedness, mitigation, or response activities."@en .
 ffonto:Backburning  rdfs:comment "A controlled burning operation set inside control lines to consume fuel and reduce fire intensity."@en .
 ffonto:AccessControl  rdfs:comment "Mechanisms that restrict or permit entry to locations or data based on rules."@en .
 ffonto:EconomicImpact  rdfs:comment "The financial or economic consequences resulting from an event or action."@en .
 ffonto:SuppressionTactic  rdfs:comment "A specific technique applied to control or extinguish a fire."@en .
 ffonto:StructureProtection  rdfs:comment "Measures undertaken to defend buildings and infrastructure from fire damage."@en .
 ffonto:EmissionInventory  rdfs:comment "A compiled estimate of emissions by source, type, and timeframe."@en .
 ffonto:ParticulateMatterPM25  rdfs:comment "Fine particulate matter with diameter ≤2.5 micrometers, associated with health impacts."@en .
 ffonto:MultimodalDataFusion  rdfs:comment "Combining data from different modalities (e.g., imagery, audio, text) to improve analysis."@en .
 ffonto:ResourceAllocationOptimization  rdfs:comment "Methods to allocate limited resources efficiently to meet objectives under constraints."@en .
 ffonto:PublicEducationProgram  rdfs:comment "An organized effort to educate the public about risks, preparedness, and safe behaviors."@en .
 ffonto:ModelMonitoring  rdfs:comment "Ongoing assessment of a model's performance and behavior after deployment."@en .
 ffonto:LiabilityRule  rdfs:comment "A legal rule or policy that assigns responsibility for damages or harms."@en .
 ffonto:CarbonEmission  rdfs:comment "The release of carbon dioxide or equivalent greenhouse gases into the atmosphere."@en .
 ffonto:WeatherCondition  rdfs:comment "Current atmospheric state including variables such as temperature, wind, and precipitation."@en .
 ffonto:PublicReporting  rdfs:comment "Mechanisms by which the public submits observations or incident reports to authorities."@en .
 ffonto:CitizenObservation  rdfs:comment "An observation or report made by a member of the public, often for situational awareness."@en .
 ffonto:ControlledFire  rdfs:comment "A deliberately ignited fire conducted under controlled conditions for management objectives."@en .
 ffonto:EmergencyOperation  rdfs:comment "Planned actions and activities performed to respond to and manage an emergency."@en .
 ffonto:Damaged  rdfs:comment "An item or structure that has sustained physical harm or impairment."@en .
 ffonto:Intact  rdfs:comment "An item or structure that remains whole and unharmed."@en .
 ffonto:ZeroTrustArchitecture  rdfs:comment "A security model that assumes no implicit trust and enforces continuous verification."@en .
 ffonto:GrazingManagement  rdfs:comment "Practices that manage livestock grazing to influence fuel loads and ecosystem health."@en .
 ffonto:ADSB  rdfs:comment "Automatic Dependent Surveillance–Broadcast; an aircraft surveillance technology broadcasting position information."@en .
 ffonto:NeurologicalDevelopmentIssue  rdfs:comment "A developmental condition affecting the nervous system and cognitive or motor function."@en .
 ffonto:BAERAssessment  rdfs:comment "Burned Area Emergency Response assessment evaluating post-fire risks and recovery needs."@en .
 ffonto:DripTorch  rdfs:comment "A handheld device used for controlled ignition of prescribed burns or backburning."@en .
 ffonto:DetectionMethod  rdfs:comment "A technique or sensor approach used to detect events or features of interest."@en .
 ffonto:VIIRS  rdfs:comment "Visible Infrared Imaging Radiometer Suite; satellite instrument used for thermal anomaly detection."@en .
 ffonto:EvaluationMetric  rdfs:comment "A quantitative measure used to assess model or system performance."@en .
 ffonto:ProtectiveEquipment  rdfs:comment "Personal gear intended to protect individuals from hazards (e.g., helmets, masks)."@en .
 ffonto:LandManagementPractice  rdfs:comment "A method applied to land to achieve ecological, safety, or production goals."@en .
 ffonto:burningNearRiver  rdfs:comment "The act or risk of burning activities occurring adjacent to riverine environments."@en .
 ffonto:dependsOnWaterSource  rdfs:comment "Indicates that an entity or activity relies on availability of water from a specified source."@en .
 ffonto:hasICSFunction  rdfs:comment "Denotes assignment to an Incident Command System functional role (e.g., operations, planning)."@en .
 ffonto:hasShelterType  rdfs:comment "Specifies the category or type of shelter available for use (e.g., evacuation center, safe room)."@en .
 ffonto:usedFor  rdfs:comment "A general-purpose relation indicating the intended use or function of an entity."@en .
 ffonto:causesAnimalSmokeExposure  rdfs:comment "Indicates that an event or condition may expose animals to smoke and associated effects."@en .
 ffonto:hasProtectionMeasure  rdfs:comment "Associates an entity with a specific mitigation or protective action."@en .
 ffonto:usesModel  rdfs:comment "Indicates that an entity or process employs a specific model for analysis or prediction."@en .
 ffonto:hasResourcePlacement  rdfs:comment "Describes the assigned location or staging of resources for operational use."@en .
 ffonto:hasEvacuationPlan  rdfs:comment "Relates an entity (e.g., building or zone) to a defined evacuation plan."@en .
 ffonto:animalVisible  rdfs:comment "Indicates that one or more animals are visibly present in an observation or image."@en .
 ffonto:enables  rdfs:comment "A general relation indicating that one entity makes another action or capability possible."@en .
 ffonto:contributesTo  rdfs:comment "Indicates that an entity has a causal or supporting role in an outcome."@en .
 ffonto:hasEmergencyKit  rdfs:comment "Associates an entity with possession or availability of an emergency supply kit."@en .
 ffonto:affects  rdfs:comment "A general relation indicating influence or impact on another entity."@en .
 ffonto:hasFireSpread  rdfs:comment "Relates an entity to information describing the progression or pattern of fire spread."@en .
 ffonto:crosses  rdfs:comment "Indicates that one spatial feature intersects or passes through another."@en .
 ffonto:derivedFromData  rdfs:comment "Indicates that an artifact or value was generated from specific input data."@en .
 ffonto:generatedByModel  rdfs:comment "Denotes that an output or dataset was produced by a specific model."@en .
 ffonto:respondedBy  rdfs:comment "Associates an incident or request with the responding unit(s) or agency(ies)."@en .
 ffonto:hasHealthAffects  rdfs:comment "Relates an entity to health impacts or effects on people or animals."@en .
 ffonto:causesHabitatLoss  rdfs:comment "Indicates that an action or event results in loss or degradation of habitat."@en .
 ffonto:createsFuelLoad  rdfs:comment "Indicates activities or conditions that contribute to accumulation of combustible fuels."@en .
 ffonto:hasSuppressionOperation  rdfs:comment "Links an incident or area to an active suppression activity or campaign."@en .
 ffonto:usesEquipment  rdfs:comment "Indicates that an operation or task makes use of specific equipment."@en .
 ffonto:threatensInfrastructure  rdfs:comment "Indicates that a hazard or event poses risk to built infrastructure."@en .
 ffonto:hasObservation  rdfs:comment "Associates an entity with a recorded observation or measurement."@en .
 ffonto:hasCluster  rdfs:comment "Indicates membership in a spatial or data cluster representing grouped items."@en .
 ffonto:createsPyroWeather  rdfs:comment "Denotes conditions where fires alter local atmospheric behavior, producing fire-driven weather."@en .
 ffonto:hasCommunicationMethod  rdfs:comment "Specifies the mode used for communication (e.g., radio, cellular, satellite)."@en .
 ffonto:providesInformation  rdfs:comment "Indicates that an entity offers data, guidance, or descriptive content."@en .
 ffonto:trainedWith  rdfs:comment "Relates a machine learning model to the technique or data used for its training."@en .
 ffonto:affectsWildlife  rdfs:comment "Indicates an effect or impact on wildlife populations or habitats."@en .
 ffonto:fusesData  rdfs:comment "Combines multiple data sources into a unified representation for analysis."@en .
 ffonto:threatensCommunity  rdfs:comment "Indicates that a hazard or event poses risk to a specific community."@en .
 ffonto:mitigatedBy  rdfs:comment "Associates hazards or risks with measures that reduce their likelihood or impact."@en .
 ffonto:createsHazard  rdfs:comment "Indicates that an action or condition generates a potential danger."@en .
 ffonto:threatensFarmland  rdfs:comment "Indicates that a hazard or event poses risk to agricultural lands and production."@en .
 ffonto:toolInUse  rdfs:comment "Denotes that a specific tool is currently being employed in an operation."@en .
 ffonto:hasGridLocation  rdfs:comment "Provides a grid-based coordinate location for spatial referencing."@en .
 ffonto:hasAerialResource  rdfs:comment "Associates an incident or operation with assigned aerial assets."@en .
 ffonto:causesHealthRisk  rdfs:comment "Indicates that an event or condition may pose risks to human health."@en .
 ffonto:operatesEquipment  rdfs:comment "Denotes the action of controlling or using a piece of equipment."@en .
 ffonto:structureAffected  rdfs:comment "Identifies a building or structure that is impacted by an event."@en .
 ffonto:improvesSafety  rdfs:comment "Indicates that an action or measure enhances safety or reduces risk."@en .
 ffonto:hasSymptom  rdfs:comment "Associates an entity (person or animal) with an observed symptom or sign."@en .
 ffonto:reachedWUI  rdfs:comment "Indicates that wildfire activity has extended into the Wildland–Urban Interface."@en .
 ffonto:reachedWUIOf  rdfs:comment "Indicates that wildfire activity has extended into the Wildland–Urban Interface."@en .
 ffonto:hasGroundCrew  rdfs:comment "Associates an incident or operation with assigned ground-based personnel."@en .
 ffonto:hasAlertStatus  rdfs:comment "Specifies the current alert or warning level for an entity or area."@en .
 ffonto:hasSuppressionDifficulty  rdfs:comment "A descriptor indicating the relative difficulty of suppressing a fire or hazard."@en .
 ffonto:affectsAviationRoute  rdfs:comment "Indicates that conditions or events interfere with or endanger aviation routes."@en .
 ffonto:estimatesFire  rdfs:comment "Denotes an assessment or model output that quantifies fire extent or behavior."@en .
 ffonto:advancingToward  rdfs:comment "Indicates directionality of movement toward a specified target or area."@en .
 ffonto:monitorsInfrastructure  rdfs:comment "The activity of observing and assessing the condition of critical infrastructure."@en .
 ffonto:educatesPublic  rdfs:comment "Relates an entity or program to public education and outreach activities."@en .
 ffonto:hasRiskAssessment  rdfs:comment "Links an entity to an assessment that evaluates potential risks and vulnerabilities."@en .
 ffonto:appliesToWater  rdfs:comment "Indicates that a policy, action, or property is relevant to water resources."@en .
 ffonto:deploysAirTanker  rdfs:comment "Indicates the assignment of an air tanker for suppression or support operations."@en .
 ffonto:evaluatedBy  rdfs:comment "Associates an entity with the agent or method used to perform an evaluation."@en .
 ffonto:usesSuppressionMethod  rdfs:comment "Indicates reliance on a specific firefighting technique or tactic."@en .
 ffonto:usesGIS  rdfs:comment "Denotes that geographic information systems are used for mapping or analysis."@en .
 ffonto:createsFireline  rdfs:comment "Indicates the act of constructing or establishing a fire control line."@en .
 ffonto:hasEcologicalEffect  rdfs:comment "Links an action or event to its ecological consequences."@en .
 ffonto:deploysFireTruck  rdfs:comment "Indicates the assignment of a fire apparatus to an incident or location."@en .
 ffonto:hasStructureLossStatus  rdfs:comment "Describes whether a structure has been lost, damaged, or remains intact."@en .
 ffonto:heavyEquipmentInUse  rdfs:comment "Indicates that heavy machinery (e.g., dozers, graders) is being employed on-site."@en .
 ffonto:usesTechnology  rdfs:comment "Denotes that technology or technical systems are utilized within an activity."@en .
 ffonto:implementsPSPS  rdfs:comment "Indicates execution of Public Safety Power Shutoff procedures to reduce fire ignition risk."@en .
 ffonto:suppresses  rdfs:comment "A general relation indicating that an entity provides protection to another."@en .
 ffonto:hasEnvironmentalCondition  rdfs:comment "Associates an entity with prevailing environmental variables or states."@en .
 ffonto:reachedAgriculturalLand  rdfs:comment "Indicates that fire or hazard has spread into agricultural areas."@en .
 ffonto:managedBy  rdfs:comment "Associates an entity or operation with the responsible managing organization or agency."@en .
 ffonto:crossedWatershed  rdfs:comment "Indicates that a feature or event spans across watershed boundaries."@en .
 ffonto:performsTask  rdfs:comment "Denotes that an agent or resource is executing a specified task or duty."@en .
 ffonto:impactsTransportation  rdfs:comment "Indicates that an event or condition affects transport systems and mobility."@en .
 ffonto:locatedInWUI  rdfs:comment "Indicates that a location or asset is situated within the Wildland–Urban Interface."@en .
 ffonto:computesEvacuationRoute  rdfs:comment "Denotes computational generation of recommended evacuation routes based on constraints."@en .
 ffonto:burningVegetation  rdfs:comment "Vegetation currently undergoing combustion and contributing to fire activity."@en .
 ffonto:usesDetectionMethod  rdfs:comment "Indicates that a particular technique or sensor is used for detection tasks."@en .
 ffonto:hasSpottingEvent  rdfs:comment "Indicates occurrence of fire spotting (embers igniting new fires separate from main front)."@en .
 ffonto:hasImpactHazard  rdfs:comment "Relates an entity to hazards that have tangible impacts on people, property, or environment."@en .
 ffonto:aircraftAction  rdfs:comment "An action performed by an aircraft during operations (e.g., drop, reconnaissance)."@en .
 ffonto:usesDataFormat  rdfs:comment "Indicates the data format used to encode or exchange information."@en .
 ffonto:stagedNear  rdfs:comment "Indicates that resources or personnel are positioned in proximity to a location for rapid deployment."@en .
 ffonto:communicatesVia  rdfs:comment "Specifies the medium or channel through which communication occurs."@en .
 ffonto:windDirection  rdfs:comment "The compass direction from which wind is blowing at a location."@en .
 ffonto:hasCracklingSound  rdfs:comment "Indicates detection of crackling noises typically associated with burning materials."@en .
 ffonto:roadNarrowOrSteep  rdfs:comment "A descriptor indicating that a road is constrained by narrow width or steep grade."@en .
 ffonto:relativeHumidityPercent  rdfs:comment "Relative humidity expressed as a percentage value."@en .
 ffonto:livestockTrailerPresent  rdfs:comment "Indicates the presence of a trailer used for transporting livestock."@en .
 ffonto:foamVisibleAroundStructureFires  rdfs:comment "Indicates observation of firefighting foam applied near structure fires."@en .
 ffonto:powerShutoffPossibility  rdfs:comment "The potential for intentional power shutdowns to reduce ignition risk."@en .
 ffonto:sprinklersOperating  rdfs:comment "Indicates that sprinkler systems are actively discharging water for protection or suppression."@en .
 ffonto:fireHydrantVisible  rdfs:comment "Indicates that a fire hydrant is present and observable at a location."@en .
 ffonto:visibilityReducedBySmoke  rdfs:comment "An observation that atmospheric visibility is diminished due to smoke presence."@en .
 ffonto:explosionConfidence  rdfs:comment "A measure indicating confidence that an explosion event has occurred based on observations."@en .
 ffonto:dipSiteBeingUsed  rdfs:comment "Indicates active use of a water dip site for aircraft refilling or supply."@en .
 ffonto:gridY  rdfs:comment "The Y coordinate index in a grid-based spatial indexing system."@en .
 ffonto:statisticLabel  rdfs:comment "A human-readable label describing a statistical measure or field."@en .
 ffonto:vehicleCarryingPeopleOrPets  rdfs:comment "Indicates that a vehicle contains occupants such as people or pets."@en .
 ffonto:bridgeVisible  rdfs:comment "Indicates that a bridge structure is present and observable in imagery or reports."@en .
 ffonto:downedPowerLineAdvice  rdfs:comment "Guidance provided to the public regarding safety around downed power lines."@en .
 ffonto:shelterInPlaceGuidance  rdfs:comment "Instructions advising individuals to remain indoors and take protective actions during hazards."@en .
 ffonto:respondersUsingSceneLights  rdfs:comment "Indicates that emergency personnel are using lights to illuminate or signal at a scene."@en .
 ffonto:fuseesVisible  rdfs:comment "Indicates that fusees or pyrotechnic markers are observed at a location."@en .
 ffonto:roadVisible  rdfs:comment "Indicates that a roadway is observable in imagery or reports."@en .
 ffonto:roadWidth  rdfs:comment "The measured width of a road, used for access and safety planning."@en .
 ffonto:elevatedFireDanger  rdfs:comment "A condition indicating that fire danger indices are above normal levels."@en .
 ffonto:hasHeatStressRisk  rdfs:comment "Associates an entity or population with potential heat-related health risk."@en .
 ffonto:crewsOperatingInTeams  rdfs:comment "Indicates that responders are organized and working in defined teams."@en .
 ffonto:multipleFireClusters  rdfs:comment "The occurrence of more than one spatially separated area of active burning."@en .
 ffonto:shelteringInPlace  rdfs:comment "The act of remaining in a safe indoor location rather than evacuating."@en .
 ffonto:audioDuration  rdfs:comment "The duration of an audio clip or recording, typically measured in seconds."@en .
 ffonto:hoseLinesDeployedToProtectBuilding  rdfs:comment "Indicates deployment of hose lines specifically positioned to defend a structure."@en .
 ffonto:isActive  rdfs:comment "A general boolean descriptor indicating an entity is currently active or engaged."@en .
 ffonto:headlightsOnDueToSmoke  rdfs:comment "Indicates that vehicle headlights are observed as a response to reduced visibility from smoke."@en .
