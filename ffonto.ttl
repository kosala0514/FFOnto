ffonto:PublicSafetyGuidance rdf:type owl:Class ;
    rdfs:label "Public Safety Guidance" ;
    rdfs:comment "Advice for drivers/evacuees and general safety Q&A." .

ffonto:Ridge rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TerrainFeature ;
    rdfs:label "Ridge" .

ffonto:FireFlank rdf:type owl:Class ;
    rdfs:label "Fire Flank" ;
