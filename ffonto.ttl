#################################################################
# Individuals
#################################################################

ffonto:LightGray rdf:type owl:NamedIndividual, ffonto:SmokeColor ; rdfs:label "light-gray" .
ffonto:Gray rdf:type owl:NamedIndividual, ffonto:SmokeColor ; rdfs:label "gray" .
ffonto:DarkGray rdf:type owl:NamedIndividual, ffonto:SmokeColor ; rdfs:label "dark-gray" .
ffonto:Black rdf:type owl:NamedIndividual, ffonto:SmokeColor ; rdfs:label "black" .
ffonto:BrownTinge rdf:type owl:NamedIndividual, ffonto:SmokeColor ; rdfs:label "brown-tinge" .

ffonto:LowVisibility rdf:type owl:NamedIndividual, ffonto:VisibilityCategory ; rdfs:label "low" .
ffonto:MediumVisibility rdf:type owl:NamedIndividual, ffonto:VisibilityCategory ; rdfs:label "medium" .
ffonto:HighVisibility rdf:type owl:NamedIndividual, ffonto:VisibilityCategory ; rdfs:label "high" .

ffonto:Increasing rdf:type owl:NamedIndividual, ffonto:Trend ; rdfs:label "increasing" .
ffonto:Decreasing rdf:type owl:NamedIndividual, ffonto:Trend ; rdfs:label "decreasing" .
ffonto:Stable rdf:type owl:NamedIndividual, ffonto:Trend ; rdfs:label "stable" .

ffonto:NAspect rdf:type ffonto:AspectCategory ; rdfs:label "north" .
ffonto:EAspect rdf:type ffonto:AspectCategory ; rdfs:label "east" .
ffonto:SAspect rdf:type ffonto:AspectCategory ; rdfs:label "south" .
ffonto:WAspect rdf:type ffonto:AspectCategory ; rdfs:label "west" .
ffonto:NWAspect rdf:type ffonto:AspectCategory ; rdfs:label "northwest" .

ffonto:WaterDropOperation rdf:type ffonto:FirefightingOperation ;
    rdfs:label "Helicopter Water Drop Operation" .

ffonto:RetardantDropOperation rdf:type ffonto:FirefightingOperation ;
    rdfs:label "Airtanker Retardant Drop" .

ffonto:IncidentCommandContact rdf:type ffonto:Contact ;
    rdfs:label "Incident Command Contact" ;
    ffonto:description "Primary public contact for the incident" ;
    ffonto:phone "+1-555-0100" ;
    ffonto:website "http://incident.example.org" .

ffonto:IncidentCommandContactAlaska rdf:type ffonto:Contact ;
    rdfs:label "Alaska Interagency Fire Information Center (AICC) Contact" ;
    ffonto:description "Primary contact for Alaska wildfire information." ;
    ffonto:phone "+1-907-356-5511" ;
    ffonto:website "https://fire.ak.blm.gov/predsvcs/intel.php" ;
    rdfs:comment "Phone and website provided as a real contact example for Alaska (from user input)." .

ffonto:FairbanksWebcam rdf:type ffonto:Contact ;
    rdfs:label "Fairbanks Daily News-Miner Arctic Webcam" ;
    ffonto:website "https://www.newsminer.com/arctic_cam/" ;
    rdfs:comment "Webcam example to view smoke/fires in Fairbanks; included per user-supplied references." .

ffonto:GINAWebcam rdf:type ffonto:Contact ;
    rdfs:label "Geographic Information Network of Alaska (GINA)" ;
    ffonto:website "https://gina.alaska.edu" ;
    rdfs:comment "Webcam/satellite imagery resource example (user-supplied)." .

#################################################################
# Prevention CQ

#################################################################
# Classes
#################################################################

ffonto:FireTriangle rdf:type owl:Class ;
    rdfs:label "Fire Triangle" ;
    rdfs:comment "Concept describing the three elements required for combustion: heat, fuel, and oxygen." .

ffonto:FireElement rdf:type owl:Class ;
    rdfs:label "Fire Element" ;
    rdfs:comment "An essential component required for fire ignition and combustion." .

ffonto:Heat rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireElement ;
    rdfs:label "Heat" ;
    rdfs:comment "Ignition energy source that starts combustion." .

ffonto:Fuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireElement ;
    rdfs:label "Fuel" ;
    rdfs:comment "Combustible material consumed during a wildfire." .

ffonto:Oxygen rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireElement ;
    rdfs:label "Oxygen" ;
    rdfs:comment "Oxidizing agent enabling combustion." .

ffonto:GroundFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelType ;
    rdfs:label "Ground Fuel" ;
    rdfs:comment "Subsurface organic materials like roots and peat that can smolder." .

ffonto:LadderFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelType ;
    rdfs:label "Ladder Fuel" ;
    rdfs:comment "Vegetation enabling fire to climb from surface to canopy." .

ffonto:AerialFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelType ;
    rdfs:label "Aerial Fuel" ;
    rdfs:comment "Tree crowns forming canopy fuels." .

ffonto:FuelCharacteristic rdf:type owl:Class ;
    rdfs:label "Fuel Characteristic" ;
    rdfs:comment "Properties affecting how fuels burn." .

ffonto:influencesFireBehaviorByCharacteristic rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FuelCharacteristic ;
    rdfs:range ffonto:FireBehavior .

ffonto:influencesFireBehaviorByCharacteristicOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FuelCharacteristic ;
    rdfs:domain ffonto:FireBehavior .

ffonto:influencesFireBehaviorByCharacteristicOf owl:inverseOf ffonto:influencesFireBehaviorByCharacteristic .

ffonto:Topography rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:label "Topography" ;
    rdfs:comment "Physical features of terrain influencing wildfire behavior." .

ffonto:Slope rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Topography ;
    rdfs:label "Slope" .

ffonto:Aspect rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Topography ;
    rdfs:label "Aspect" .

ffonto:Canyon rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Topography ;
    rdfs:label "Canyon"@en ;
    rdfs:comment "A deep valley with steep sides that can influence wildfire behavior and wind patterns."@en .

ffonto:WeatherFactor rdf:type owl:Class ;
    rdfs:label "Weather Factor" ;
    rdfs:comment "Weather conditions affecting wildfire spread." .

ffonto:Temperature rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WeatherFactor ;
    rdfs:subClassOf ffonto:ForestFireRiskFactor ;
    rdfs:label "Temperature" .

ffonto:RelativeHumidity rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WeatherFactor ;
    rdfs:subClassOf ffonto:ForestFireRiskFactor ;
    rdfs:label "Relative Humidity" .

ffonto:Precipitation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WeatherFactor ;
    rdfs:label "Precipitation" .

ffonto:DetectionMethod rdf:type owl:Class ;
    rdfs:label "ForestFire Detection Method" .

ffonto:LookoutTower rdf:type owl:Class ;
    rdfs:subClassOf ffonto:DetectionMethod ;
    rdfs:label "Lookout Tower Detection" .

ffonto:AerialPatrol rdf:type owl:Class ;
    rdfs:subClassOf ffonto:DetectionMethod ;
    rdfs:label "Aerial Patrol Detection" ;
     rdfs:comment "Aerial surveillance flight conducted to detect hazards, fires, or other incidents."@en .


ffonto:PublicReporting rdf:type owl:Class ;
    rdfs:subClassOf ffonto:DetectionMethod ;
    rdfs:label "Public Fire Reporting" .

ffonto:SuppressionMethod rdf:type owl:Class ;
    rdfs:label "ForestFire Suppression Method" .

ffonto:DirectAttack rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionMethod ;
    rdfs:label "Direct Attack" .

ffonto:IndirectAttack rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionMethod ;
    rdfs:label "Indirect Attack" .

ffonto:Backburning rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionMethod ;
    rdfs:subClassOf ffonto:SuppressionTactic ;
    rdfs:label "Backburning" .

ffonto:AirTankerDrop rdf:type owl:Class ; rdfs:subClassOf ffonto:SuppressionTactic ; rdfs:label "Air Tanker Drop" .

ffonto:AirSupport rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionMethod ;
    rdfs:label "Air Support Suppression" .

ffonto:Fireline rdf:type owl:Class ;
    rdfs:label "Fireline" .

ffonto:Handline rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Fireline ;
    rdfs:subClassOf ffonto:SuppressionTactic ;
    rdfs:label "Handline" .

ffonto:DozerLine rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Fireline ;
    rdfs:subClassOf ffonto:SuppressionTactic ;
    rdfs:label "Dozer Line" .

ffonto:ScrapeLine rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Fireline ;
    rdfs:label "Scrape Line" .

ffonto:WetLine rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Fireline ;
    rdfs:label "Wet Line" .

ffonto:NaturalFireline rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Fireline ;
    rdfs:label "Natural Fireline" .

ffonto:PrescribedBurn rdf:type owl:Class ;
    rdfs:subClassOf ffonto:PreventionMeasure ;
    rdfs:label "Prescribed Burning" ;
     rdfs:comment "A planned, controlled fire intentionally ignited to manage fuel and ecosystem health."@en .


ffonto:DefensibleZone rdf:type owl:Class ;
    rdfs:label "Defensible Zone" ;
    rdfs:comment "A named sub-area within defensible space (e.g., Zone 1, Zone 2, Zone 3)." .

ffonto:Zone1 rdf:type owl:Class ;
    rdfs:subClassOf ffonto:DefensibleZone ;
    rdfs:label "Zone 1 (Home Zone)" ;
    rdfs:comment "Closest zone to the structure; typically 0-5 feet (or meters) - remove all flammable materials." .

ffonto:Zone2 rdf:type owl:Class ;
    rdfs:subClassOf ffonto:DefensibleZone ;
    rdfs:label "Zone 2 (Intermediate Zone)" ;
    rdfs:comment "Intermediate area for fuel reduction and spacing (e.g., 5-30 feet)." .

