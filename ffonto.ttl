    rdfs:comment "Relates an analytical process or system to the specific zero-shot learning AI model utilized for classification or prediction."@en .

ffonto:hasDayName a owl:DatatypeProperty ;
    rdfs:label "has day name"@en ;
    rdfs:comment "Connects a temporal record or scheduled event to the specific day of the week (e.g., Monday, Tuesday)."@en .

ffonto:hasDateTime a owl:DatatypeProperty ;
    rdfs:label "has date time"@en ;
    rdfs:comment "Links an event, observation, or log entry to an exact timestamp combining both date and time of day."@en .

ffonto:hasDay a owl:DatatypeProperty ;
    rdfs:label "has day"@en ;
    rdfs:comment "Connects a temporal entity or recorded event to the specific numerical day of the month."@en .

ffonto:ForestFireEffect a owl:Class ;
    rdfs:label "forest fire effect"@en ;
    rdfs:comment "Represents the ecological, environmental, or economic consequence resulting from a wildfire, such as soil erosion or habitat loss."@en .

ffonto:isModelOf a owl:ObjectProperty ;
    rdfs:label "is model of"@en ;
    rdfs:comment "Links a computational, mathematical, or physical model back to the real-world phenomenon or system it simulates."@en .

ffonto:deploysFireTruckOf a owl:ObjectProperty ;
    rdfs:label "deploys fire truck of"@en ;
    rdfs:comment "Connects a dispatch action or operational decision back to the specific fire engine resource mobilized."@en .

ffonto:usesTechnologyOf a owl:ObjectProperty ;
    rdfs:label "uses technology of"@en ;
    rdfs:comment "Relates a specific technological system or device back to the operational process or organization utilizing it."@en .

ffonto:isSpottingEventOf a owl:ObjectProperty ;
    rdfs:label "is spotting event of"@en ;
    rdfs:comment "Links a secondary ignition caused by flying embers back to the primary wildfire incident."@en .

ffonto:implementsPSPSOf a owl:ObjectProperty ;
    rdfs:label "implements PSPS of"@en ;
    rdfs:comment "Connects an executed Public Safety Power Shutoff (PSPS) event back to the utility policy or hazard mitigation plan that required it."@en .

ffonto:hasVisionModelScores a owl:ObjectProperty ;
    rdfs:label "has vision model scores"@en ;
    rdfs:comment "Links an image, video frame, or visual dataset to the quantitative confidence scores generated by a computer vision model."@en .

ffonto:burningVegetationOf a owl:ObjectProperty ;
    rdfs:label "burning vegetation of"@en ;
    rdfs:comment "Relates an area of actively combusting plant matter to the broader geographic region or wildfire incident."@en .

ffonto:hasModelProvenance a owl:ObjectProperty ;
    rdfs:label "has model provenance"@en ;
    rdfs:comment "Connects a predictive model or AI output to the documentation detailing its training data, versioning, and lineage."@en .

ffonto:isMediaAssetOf a owl:ObjectProperty ;
    rdfs:label "is media asset of"@en ;
    rdfs:comment "Links a photograph, video, or audio recording to the specific incident, database, or report it illustrates."@en .

ffonto:heavyEquipmentInUseOf a owl:ObjectProperty ;
    rdfs:label "heavy equipment in use of"@en ;
    rdfs:comment "Connects bulldozers, graders, or other large machinery back to the suppression operation or construction task utilizing them."@en .

ffonto:affectsAviationRouteOf a owl:ObjectProperty ;
    rdfs:label "affects aviation route of"@en ;
    rdfs:comment "Links a smoke plume, Temporary Flight Restriction (TFR), or hazard back to the specific flight corridor it disrupts."@en .

ffonto:isAlertStatusOf a owl:ObjectProperty ;
    rdfs:label "is alert status of"@en ;
    rdfs:comment "Connects a specific warning level or notification state to the hazard, operational system, or community it applies to."@en .

ffonto:crossedWatershedOf a owl:ObjectProperty ;
    rdfs:label "crossed watershed of"@en ;
    rdfs:comment "Relates a fire's progression or environmental impact back to the specific hydrological boundary it breached."@en .

ffonto:isGroundCrewOf a owl:ObjectProperty ;
    rdfs:label "is ground crew of"@en ;
    rdfs:comment "Links a handcrew, engine module, or suppression team to the incident, division, or agency they are assigned to."@en .

ffonto:isEcologicalEffectOf a owl:ObjectProperty ;
    rdfs:label "is ecological effect of"@en ;
    rdfs:comment "Connects a biological or environmental impact (like habitat loss) back to the specific natural disaster that caused it."@en .

ffonto:isICSFunctionOf a owl:ObjectProperty ;
    rdfs:label "is ICS function of"@en ;
    rdfs:comment "Relates a specific role, section, or operational task back to the Incident Command System structure governing it."@en .

ffonto:isModelProvenanceOf a owl:ObjectProperty ;
    rdfs:label "is model provenance of"@en ;
    rdfs:comment "Links a lineage record, training dataset log, or version history back to the specific computational model it documents."@en .

ffonto:locatedInWUIOf a owl:ObjectProperty ;
    rdfs:label "located in WUI of"@en ;
    rdfs:comment "Connects a structure, incident, or operation to the specific Wildland-Urban Interface zone where human development meets natural terrain."@en .

ffonto:aircraftActionOf a owl:ObjectProperty ;
    rdfs:label "aircraft action of"@en ;
    rdfs:comment "Links a specific aerial maneuver, drop, or reconnaissance flight back to the broader aviation operation or incident strategy."@en .

ffonto:stagedNearOf a owl:ObjectProperty ;
    rdfs:label "staged near of"@en ;
    rdfs:comment "Connects a deployed resource, equipment cache, or staging area back to the geographic feature or incident it is positioned for."@en .

ffonto:hasProvenanceRecord a owl:ObjectProperty ;
    rdfs:label "has provenance record"@en ;
    rdfs:comment "Links a dataset, physical sample, or analytical conclusion to the detailed historical log of its origin and chain of custody."@en .

ffonto:usedModel a owl:ObjectProperty ;
    rdfs:label "used model"@en ;
    rdfs:comment "Relates a forecast, analysis, or decision process to the specific simulation, mathematical framework, or AI deployed to generate it."@en .

ffonto:performsTaskOf a owl:ObjectProperty ;
    rdfs:label "performs task of"@en ;
    rdfs:comment "Connects a specific action, duty, or assignment back to the operational role, team, or agent executing it."@en .

ffonto:usesDetectionMethodOf a owl:ObjectProperty ;
    rdfs:label "uses detection method of"@en ;
    rdfs:comment "Links a specific sensor technology, analytical technique, or human observation protocol back to the early warning system relying on it."@en .

ffonto:computesEvacuationRouteOf a owl:ObjectProperty ;
    rdfs:label "computes evacuation route of"@en ;
    rdfs:comment "Connects a generated escape path or traffic model back to the spatial analysis software or incident action plan that created it."@en .

ffonto:isResultOf a owl:ObjectProperty ;
    rdfs:label "is result of"@en ;
    rdfs:comment "Links an outcome, physical effect, or analytical output back to the specific event, process, or calculation that produced it."@en .

ffonto:isImpactHazardOf a owl:ObjectProperty ;
    rdfs:label "is impact hazard of"@en ;
    rdfs:comment "Connects a specific danger, such as a falling tree or debris flow, back to the destabilizing event or environment that created the risk."@en .

ffonto:reachedAgriculturalLandOf a owl:ObjectProperty ;
    rdfs:label "reached agricultural land of"@en ;
    rdfs:comment "Relates the expanding perimeter of a fire or environmental hazard back to the specific farming or pastoral region it encroached upon."@en .

ffonto:impactsTransportationOf a owl:ObjectProperty ;
    rdfs:label "impacts transportation of"@en ;
    rdfs:comment "Links a hazard, visibility reduction, or physical barrier back to the specific road network, railway, or logistical route it impedes."@en .

ffonto:isSuppressionDifficultyOf a owl:ObjectProperty ;
    rdfs:label "is suppression difficulty of"@en ;
    rdfs:comment "Connects a metric or qualitative assessment of firefighting challenge back to the specific terrain, fuel type, or weather condition causing it."@en .

ffonto:isVisionModelScoresOf a owl:ObjectProperty ;
    rdfs:label "is vision model scores of"@en ;
    rdfs:comment "Links a set of confidence ratings or classification metrics back to the specific computer vision model that output them."@en .

ffonto:isStructureLossStatusOf a owl:ObjectProperty ;
    rdfs:label "is structure loss status of"@en ;
    rdfs:comment "Connects a damage assessment or destroyed building count back to the specific wildfire incident or geographic area evaluated."@en .

ffonto:hasResult a owl:ObjectProperty ;
    rdfs:label "has result"@en ;
    rdfs:comment "Links a process, computation, or physical event to its direct outcome, measurement, or consequential state."@en .

ffonto:managedOf a owl:ObjectProperty ;
    rdfs:label "managed of"@en ;
    rdfs:comment "Relates an overseen incident, resource, or operational phase back to the commanding entity or agency responsible for it."@en .

ffonto:producedBy a owl:ObjectProperty ;
    rdfs:label "produced by"@en ;
    rdfs:comment "Links an output, emission, physical artifact, or dataset back to the process, event, or entity that created it."@en .

ffonto:communicatesBy a owl:ObjectProperty ;
    rdfs:label "communicates by"@en ;
    rdfs:comment "Connects a responder, system, or organization to the specific protocol, device, or network used to transmit information."@en .

ffonto:hasModel a owl:ObjectProperty ;
    rdfs:label "has model"@en ;
    rdfs:comment "Relates a predictive system, research project, or hardware device to the specific computational framework or conceptual model it relies upon."@en .

ffonto:usesDataFormatOf a owl:ObjectProperty ;
    rdfs:label "uses data format of"@en ;
    rdfs:comment "Links a specific file type, schema, or encoding standard back to the database, software, or data exchange process requiring it."@en .

ffonto:isProvenanceRecordOf a owl:ObjectProperty ;
    rdfs:label "is provenance record of"@en ;
    rdfs:comment "Connects a specific historical log or metadata file back to the dataset, entity, or event it documents."@en .

ffonto:isEnvironmentalConditionOf a owl:ObjectProperty ;
    rdfs:label "is environmental condition of"@en ;
    rdfs:comment "Links a specific weather state, fuel moisture level, or atmospheric metric back to the geographic region or incident it describes."@en .

# =====================================================================
# Datatype Properties (Attributes / Literals)
# =====================================================================

ffonto:gridY a owl:DatatypeProperty ;
    rdfs:label "grid y"@en ;
    rdfs:comment "Specifies the Y-coordinate or vertical index within a spatial grid system."@en .

ffonto:gridX a owl:DatatypeProperty ;
    rdfs:label "grid x"@en ;
    rdfs:comment "Specifies the X-coordinate or horizontal index within a spatial grid system."@en .

ffonto:labelType a owl:DatatypeProperty ;
    rdfs:label "label type"@en ;
    rdfs:comment "Specifies the classification category or semantic nature of a given annotation or data tag."@en .

ffonto:audioDurationMs a owl:DatatypeProperty ;
    rdfs:label "audio duration ms"@en ;
    rdfs:comment "Records the total length of an acoustic sample or recording, measured in milliseconds."@en .

ffonto:fireScore a owl:DatatypeProperty ;
    rdfs:label "fire score"@en ;
    rdfs:comment "Indicates a numerical value or confidence metric representing the likelihood or intensity of a detected fire."@en .

ffonto:imageQualityCloudCover a owl:DatatypeProperty ;
    rdfs:label "image quality cloud cover"@en ;
    rdfs:comment "Quantifies the percentage or metric of an image obscured by atmospheric clouds, affecting visibility."@en .

ffonto:labelSeverity a owl:DatatypeProperty ;
    rdfs:label "label severity"@en ;
    rdfs:comment "Indicates the level of intensity, danger, or urgency associated with a specific classification or alert."@en .

ffonto:provenanceURI a owl:DatatypeProperty ;
    rdfs:label "provenance URI"@en ;
    rdfs:comment "Provides the standard Uniform Resource Identifier linking to the detailed origin and lineage metadata of a resource."@en .

ffonto:imageQualityBlur a owl:DatatypeProperty ;
    rdfs:label "image quality blur"@en ;
    rdfs:comment "Quantifies the level of distortion or lack of sharpness in a visual dataset or photograph."@en .

ffonto:crsLiteral a owl:DatatypeProperty ;
    rdfs:label "CRS literal"@en ;
    rdfs:comment "Specifies the Coordinate Reference System (e.g., EPSG code) used for spatial data as a literal string."@en .

ffonto:smokeThreshold a owl:DatatypeProperty ;
    rdfs:label "smoke threshold"@en ;
    rdfs:comment "Defines the specific numerical boundary or concentration level at which a smoke detection alert is triggered."@en .

ffonto:siteLiteral a owl:DatatypeProperty ;
    rdfs:label "site literal"@en ;
    rdfs:comment "Records the localized name, physical designation, or descriptive text of an observation station or facility."@en .

ffonto:licenseText a owl:DatatypeProperty ;
    rdfs:label "license text"@en ;
    rdfs:comment "Provides the legal terms, attribution requirements, or usage rights string associated with a dataset or media asset."@en .

ffonto:labelSourceLiteral a owl:DatatypeProperty ;
    rdfs:label "label source literal"@en ;
    rdfs:comment "Specifies the entity, system, or annotator responsible for generating a specific data tag, recorded as a text string."@en .

ffonto:rowIndex a owl:DatatypeProperty ;
    rdfs:label "row index"@en ;
    rdfs:comment "Indicates the specific sequential line number or tabular position of a record within a dataset."@en .

ffonto:rainMm a owl:DatatypeProperty ;
    rdfs:label "rain mm"@en ;
    rdfs:comment "Records the accumulated precipitation volume at a specific location, measured in millimeters."@en .

ffonto:hasObservationSource a owl:DatatypeProperty ;
    rdfs:label "has observation source"@en ;
    rdfs:comment "Links a recorded metric or detected event to the original sensor, system, or human observer that provided the data."@en .

ffonto:imageWidthPx a owl:DatatypeProperty ;
    rdfs:label "image width px"@en ;
    rdfs:comment "Specifies the horizontal dimension of a digital image or visual matrix, measured in pixels."@en .

ffonto:provenanceChecksumSHA256 a owl:DatatypeProperty ;
    rdfs:label "provenance checksum SHA256"@en ;
    rdfs:comment "Records the SHA-256 cryptographic hash value used to verify the integrity and unchanged state of a digital asset."@en .

ffonto:fireThreshold a owl:DatatypeProperty ;
    rdfs:label "fire threshold"@en ;
    rdfs:comment "Defines the specific thermal, visual, or algorithmic limit at which a system classifies an anomaly as a fire."@en .

ffonto:captureTimeUTC a owl:DatatypeProperty ;
    rdfs:label "capture time UTC"@en ;
    rdfs:comment "Records the exact temporal instant an image, audio clip, or observation was recorded, standardized to Coordinated Universal Time."@en .

ffonto:imageHeightPx a owl:DatatypeProperty ;
    rdfs:label "image height px"@en ;
    rdfs:comment "Specifies the vertical dimension of a digital image or visual matrix, measured in pixels."@en .

ffonto:hasRecordConfidence a owl:DatatypeProperty ;
    rdfs:label "has record confidence"@en ;
    rdfs:comment "Indicates the statistical certainty or reliability score associated with a specific database entry or log."@en .

ffonto:areaHa a owl:DatatypeProperty ;
    rdfs:label "area ha"@en ;
    rdfs:comment "Records the calculated spatial extent or geographic footprint of an entity or incident, measured in hectares."@en .

ffonto:sourceLiteral a owl:DatatypeProperty ;
    rdfs:label "source literal"@en ;
    rdfs:comment "Specifies the origin, creating agency, or foundational system of a dataset or observation as a text string."@en .

ffonto:classMapSHA1 a owl:DatatypeProperty ;
    rdfs:label "class map SHA1"@en ;
    rdfs:comment "Records the SHA-1 cryptographic hash value used to uniquely identify and verify a specific classification map or schema file."@en .

ffonto:frameThreshold a owl:DatatypeProperty ;
    rdfs:label "frame threshold"@en ;
    rdfs:comment "Defines the required number or interval of sequential video frames or images needed to trigger a confirmed detection."@en .

ffonto:fireOccurred a owl:DatatypeProperty ;
    rdfs:label "fire occurred"@en ;
    rdfs:comment "A boolean flag or categorical indicator recording whether a combustion event actually took place at a given location and time."@en .

ffonto:smokeScore a owl:DatatypeProperty ;
    rdfs:label "smoke score"@en ;
    rdfs:comment "Indicates a numerical value or algorithmic confidence metric representing the likelihood or density of detected smoke."@en .

ffonto:deviceID a owl:DatatypeProperty ;
    rdfs:label "device ID"@en ;
    rdfs:comment "Specifies the unique alphanumeric identifier or serial number assigned to a specific hardware sensor or tool."@en .

ffonto:rawLabel a owl:DatatypeProperty ;
    rdfs:label "raw label"@en ;
    rdfs:comment "Records the original, unprocessed annotation or category tag assigned to data before standardization or transformation."@en .

ffonto:globalDetectionThreshold a owl:DatatypeProperty ;
    rdfs:label "global detection threshold"@en ;
    rdfs:comment "Defines the overarching, system-wide baseline limit required to flag an anomaly or trigger an alert across all sensors."@en .

ffonto:countryLiteral a owl:DatatypeProperty ;
    rdfs:label "country literal"@en ;
    rdfs:comment "Specifies the sovereign nation encompassing a geographic coordinate or incident as a text string."@en .

ffonto:imageSourceLiteral a owl:DatatypeProperty ;
    rdfs:label "image source literal"@en ;
    rdfs:comment "Records the specific camera, satellite platform, or digital repository from which a visual asset was acquired."@en .

ffonto:smokeScoreAboveThreshold a owl:DatatypeProperty ;
    rdfs:label "smoke score above threshold"@en ;
    rdfs:comment "A boolean flag or indicator denoting whether the calculated smoke density metric exceeds the established warning limit."@en .

ffonto:resolutionM a owl:DatatypeProperty ;
    rdfs:label "resolution m"@en ;
    rdfs:comment "Specifies the spatial granularity or pixel size of a map, grid, or raster dataset, measured in meters."@en .

ffonto:regionLiteral a owl:DatatypeProperty ;
    rdfs:label "region literal"@en ;
    rdfs:comment "Records the administrative state, province, or localized geographic area of an incident or observation as a text string."@en .

ffonto:audioThreshold a owl:DatatypeProperty ;
    rdfs:label "audio threshold"@en ;
    rdfs:comment "Defines the acoustic decibel limit or anomaly score required for a sound-based sensor to trigger an alert."@en .

ffonto:schemaVersion a owl:DatatypeProperty ;
    rdfs:label "schema version"@en ;
    rdfs:comment "Specifies the numeric or alphanumeric release identifier of the ontological or structural framework governing the dataset."@en .

ffonto:labelConfidence a owl:DatatypeProperty ;
    rdfs:label "label confidence"@en ;
    rdfs:comment "Indicates the statistical probability or subjective certainty that a specific annotation or tag is correct."@en .

ffonto:audioModel a owl:DatatypeProperty ;
    rdfs:label "audio model"@en ;
    rdfs:comment "Identifies the specific machine learning framework or algorithmic system used to process and classify acoustic data."@en .

ffonto:opacity a owl:DatatypeProperty ;
    rdfs:label "opacity"@en ;
    rdfs:comment "Quantifies the degree to which an emission, such as a smoke plume, obscures visibility or blocks light transmission."@en .


ffonto:DataAnalysisProcess rdfs:subClassOf prov:Activity .
ffonto:UAVOperation rdfs:subClassOf prov:Activity .
ffonto:PostFireRehabilitation rdfs:subClassOf prov:Activity .
ffonto:LandManagementPractice rdfs:subClassOf prov:Activity .
ffonto:PhysicalProcess rdfs:subClassOf prov:Activity .
ffonto:EarthObservationData rdfs:subClassOf prov:Entity .
ffonto:IncidentReport rdfs:subClassOf prov:Entity .
ffonto:SimulationModel rdfs:subClassOf prov:Entity .
ffonto:WildfireStatistic rdfs:subClassOf prov:Entity .
ffonto:InformationSystem rdfs:subClassOf prov:Entity .
ffonto:CommunityPreparednessPlan rdfs:subClassOf prov:Entity .
ffonto:TemporalRecord rdfs:subClassOf ffonto:TemporalExtent .
ffonto:ClimateEvent rdfs:subClassOf ffonto:TemporalExtent .
ffonto:AirQualityMitigationDevice rdfs:subClassOf sosa:Platform .
ffonto:CommunicationDevice rdfs:subClassOf sosa:Platform .
ffonto:VegetationIndex rdfs:subClassOf ffonto:ObservableProperty .
ffonto:AirPollutionMetric rdfs:subClassOf ffonto:ObservableProperty .
ffonto:FireBehaviorMetric rdfs:subClassOf ffonto:ObservableProperty .
ffonto:PredictionMetric rdfs:subClassOf ffonto:ObservableProperty .
ffonto:OperationsSection rdfs:subClassOf ffonto:IncidentCommandSection .
ffonto:PlanningSection rdfs:subClassOf ffonto:IncidentCommandSection .
ffonto:SafetyOfficer rdfs:subClassOf ffonto:IncidentCommandRole .
ffonto:EnvironmentalImpact rdfs:subClassOf ffonto:ForestFireEffect .
ffonto:HealthImpact rdfs:subClassOf ffonto:ForestFireEffect .
ffonto:VehicleDamage rdfs:subClassOf ffonto:ForestFireEffect .
ffonto:ClimateFeedbackLoop rdfs:subClassOf ffonto:ClimatePattern .
ffonto:AnthropogenicFactor rdfs:subClassOf ffonto:ClimatePattern .
ffonto:mitigatesAirPollution a owl:ObjectProperty ;
    rdfs:label "mitigates air pollution"@en ;
    rdfs:comment "Relates an air quality mitigation strategy to the specific air pollution metric it addresses."@en ;
    owl:inverseOf ffonto:isMitigatedByStrategy ;
    rdfs:domain ffonto:AirQualityMitigationStrategy ;
    rdfs:range ffonto:AirPollutionMetric .

ffonto:isMitigatedByStrategy a owl:ObjectProperty ;
    rdfs:label "is mitigated by strategy"@en ;
    rdfs:comment "Inverse property indicating the mitigation strategy addressing an air pollution metric."@en ;
    rdfs:range ffonto:AirQualityMitigationStrategy ;
    rdfs:domain ffonto:AirPollutionMetric .

ffonto:utilizesDevice a owl:ObjectProperty ;
    rdfs:label "utilizes device"@en ;
    rdfs:comment "Indicates the hardware or equipment utilized by an air quality mitigation strategy."@en ;
    owl:inverseOf ffonto:isDeviceUtilizedBy ;
    rdfs:domain ffonto:AirQualityMitigationStrategy ;
    rdfs:range ffonto:AirQualityMitigationDevice .

ffonto:isDeviceUtilizedBy a owl:ObjectProperty ;
    rdfs:label "is device utilized by"@en ;
    rdfs:comment "Inverse property linking a device to the mitigation strategy utilizing it."@en ;
    rdfs:range ffonto:AirQualityMitigationStrategy ;
    rdfs:domain ffonto:AirQualityMitigationDevice .

ffonto:governsModel a owl:ObjectProperty ;
    rdfs:label "governs model"@en ;
    rdfs:comment "Connects an AI model governance framework to the MLOps pipeline it oversees."@en ;
    owl:inverseOf ffonto:isModelGovernedBy ;
    rdfs:domain ffonto:AIModelGovernance ;
    rdfs:range ffonto:MLOpsPipeline .

ffonto:isModelGovernedBy a owl:ObjectProperty ;
    rdfs:label "is model governed by"@en ;
    rdfs:comment "Inverse property linking an MLOps pipeline to its governing framework."@en ;
    rdfs:range ffonto:AIModelGovernance ;
    rdfs:domain ffonto:MLOpsPipeline .

ffonto:reliesOnData a owl:ObjectProperty ;
    rdfs:label "relies on data"@en ;
    rdfs:comment "Specifies the earth observation data that a sensor fusion process relies upon."@en ;
    owl:inverseOf ffonto:isDataReliedOnBy ;
    rdfs:domain ffonto:SensorFusion ;
    rdfs:range ffonto:EarthObservationData .

ffonto:isDataReliedOnBy a owl:ObjectProperty ;
    rdfs:label "is data relied on by"@en ;
    rdfs:comment "Inverse property indicating the sensor fusion process that depends on specific observation data."@en ;
    rdfs:range ffonto:SensorFusion ;
    rdfs:domain ffonto:EarthObservationData .

ffonto:guidesOperation a owl:ObjectProperty ;
    rdfs:label "guides operation"@en ;
    rdfs:comment "Relates an operational strategy to the specific operations section it guides."@en ;
    owl:inverseOf ffonto:isOperationGuidedBy ;
    rdfs:domain ffonto:OperationalStrategy ;
    rdfs:range ffonto:OperationsSection .

ffonto:isOperationGuidedBy a owl:ObjectProperty ;
    rdfs:label "is operation guided by"@en ;
    rdfs:comment "Inverse property linking an operations section to the strategy that guides it."@en ;
    rdfs:range ffonto:OperationalStrategy ;
    rdfs:domain ffonto:OperationsSection .

ffonto:evaluatesOpportunity a owl:ObjectProperty ;
    rdfs:label "evaluates opportunity"@en ;
    rdfs:comment "Connects an ethical consideration to the challenge or opportunity it evaluates."@en ;
    owl:inverseOf ffonto:isOpportunityEvaluatedBy ;
    rdfs:domain ffonto:EthicalConsideration ;
    rdfs:range ffonto:ChallengeOpportunity .

ffonto:isOpportunityEvaluatedBy a owl:ObjectProperty ;
    rdfs:label "is opportunity evaluated by"@en ;
    rdfs:comment "Inverse property linking a challenge or opportunity back to its ethical consideration."@en ;
    rdfs:range ffonto:EthicalConsideration ;
    rdfs:domain ffonto:ChallengeOpportunity .

ffonto:processesCloudCover a owl:ObjectProperty ;
    rdfs:label "processes cloud cover"@en ;
    rdfs:comment "Relates an atmospheric transport model to the cloud cover quality data it processes."@en ;
    owl:inverseOf ffonto:isCloudCoverProcessedBy ;
    rdfs:domain ffonto:AtmosphericTransportModel ;
    rdfs:range ffonto:CloudCoverQuality .

ffonto:isCloudCoverProcessedBy a owl:ObjectProperty ;
    rdfs:label "is cloud cover processed by"@en ;
    rdfs:comment "Inverse property indicating which atmospheric transport model processes the cloud cover quality."@en ;
    rdfs:range ffonto:AtmosphericTransportModel ;
    rdfs:domain ffonto:CloudCoverQuality .

ffonto:incorporatesSidingData a owl:ObjectProperty ;
    rdfs:label "incorporates siding data"@en ;
    rdfs:comment "Links a simulation model to the exterior siding data it incorporates."@en ;
    owl:inverseOf ffonto:isSidingDataIncorporatedIn ;
    rdfs:domain ffonto:SimulationModel ;
    rdfs:range ffonto:ExteriorSiding .

ffonto:isSidingDataIncorporatedIn a owl:ObjectProperty ;
    rdfs:label "is siding data incorporated in"@en ;
    rdfs:comment "Inverse property linking exterior siding data to the simulation model using it."@en ;
    rdfs:range ffonto:SimulationModel ;
    rdfs:domain ffonto:ExteriorSiding .

ffonto:causesEffect a owl:ObjectProperty ;
    rdfs:label "causes effect"@en ;
    rdfs:comment "Links a forest fire event to the specific environmental or socio-economic effects it causes."@en ;
    owl:inverseOf ffonto:isEffectCausedBy ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:ForestFireEffect .

ffonto:isEffectCausedBy a owl:ObjectProperty ;
    rdfs:label "is effect caused by"@en ;
    rdfs:comment "Inverse property linking a resulting effect back to the forest fire that caused it."@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:ForestFireEffect .

ffonto:influencesFireBehavior a owl:ObjectProperty ;
    rdfs:label "influences fire behavior"@en ;
    rdfs:comment "Relates a prevailing climate pattern to the forest fire behavior it influences."@en ;
    owl:inverseOf ffonto:isFireBehaviorInfluencedBy ;
    rdfs:domain ffonto:ClimatePattern ;
    rdfs:range ffonto:ForestFire .

ffonto:isFireBehaviorInfluencedBy a owl:ObjectProperty ;
    rdfs:label "is fire behavior influenced by"@en ;
    rdfs:comment "Inverse property indicating the climate pattern that influenced a specific forest fire."@en ;
    rdfs:range ffonto:ClimatePattern ;
    rdfs:domain ffonto:ForestFire .

ffonto:simulatedByActivity a owl:ObjectProperty ;
    rdfs:label "simulated by activity"@en ;
    rdfs:comment "Relates a forest fire to a provenance-tracked modeling or simulation activity."@en ;
    owl:inverseOf ffonto:simulatesFire ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range prov:Activity .

ffonto:simulatesFire a owl:ObjectProperty ;
    rdfs:label "simulates fire"@en ;
    rdfs:comment "Inverse property linking a computational or analytical activity to the fire it simulates."@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain prov:Activity .

ffonto:generatesDataEntity a owl:ObjectProperty ;
    rdfs:label "generates data entity"@en ;
    rdfs:comment "Links a processing activity to the provenance entity (e.g., report, dataset) it produces."@en ;
    owl:inverseOf ffonto:isDataEntityGeneratedBy ;
    rdfs:domain prov:Activity ;
    rdfs:range prov:Entity .

ffonto:isDataEntityGeneratedBy a owl:ObjectProperty ;
    rdfs:label "is data entity generated by"@en ;
    rdfs:comment "Inverse property linking a data entity back to the activity that generated it."@en ;
    rdfs:range prov:Activity ;
    rdfs:domain prov:Entity .

ffonto:managedBySection a owl:ObjectProperty ;
    rdfs:label "managed by section"@en ;
    rdfs:comment "Links a forest fire to the specific Incident Command Section managing its response."@en ;
    owl:inverseOf ffonto:managesFireEvent ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:IncidentCommandSection .

ffonto:managesFireEvent a owl:ObjectProperty ;
    rdfs:label "manages fire event"@en ;
    rdfs:comment "Inverse property linking an Incident Command Section to the forest fire it is actively managing."@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:IncidentCommandSection .

ffonto:includesCommandRole a owl:ObjectProperty ;
    rdfs:label "includes command role"@en ;
    rdfs:comment "Relates an Incident Command Section to the specific personnel roles assigned within it."@en ;
    owl:inverseOf ffonto:assignedToSection ;
    rdfs:domain ffonto:IncidentCommandSection ;
    rdfs:range ffonto:IncidentCommandRole .

ffonto:assignedToSection a owl:ObjectProperty ;
    rdfs:label "assigned to section"@en ;
    rdfs:comment "Inverse property mapping an Incident Command Role to its encompassing section."@en ;
    rdfs:range ffonto:IncidentCommandSection ;
    rdfs:domain ffonto:IncidentCommandRole .

ffonto:operatesFromFacility a owl:ObjectProperty ;
    rdfs:label "operates from facility"@en ;
    rdfs:comment "Links an Incident Command Section to the physical emergency facility (e.g., basecamp) it operates from."@en ;
    owl:inverseOf ffonto:isFacilityOperatedBy ;
    rdfs:domain ffonto:IncidentCommandSection ;
    rdfs:range ffonto:EmergencyFacility .

ffonto:isFacilityOperatedBy a owl:ObjectProperty ;
    rdfs:label "is facility operated by"@en ;
    rdfs:comment "Inverse property linking an emergency facility to the command section utilizing it."@en ;
    rdfs:range ffonto:IncidentCommandSection ;
    rdfs:domain ffonto:EmergencyFacility .

ffonto:deploysPlatform a owl:ObjectProperty ;
    rdfs:label "deploys platform"@en ;
    rdfs:comment "Indicates the observational platform (e.g., drone, tower) deployed by an incident command section."@en ;
    owl:inverseOf ffonto:isPlatformDeployedBy ;
    rdfs:domain ffonto:IncidentCommandSection ;
    rdfs:range sosa:Platform .

ffonto:isPlatformDeployedBy a owl:ObjectProperty ;
    rdfs:label "is platform deployed by"@en ;
    rdfs:comment "Inverse property linking a sensor platform back to the command section that deployed it."@en ;
    rdfs:range ffonto:IncidentCommandSection ;
    rdfs:domain sosa:Platform .

ffonto:implementsRollback a owl:ObjectProperty ;
    rdfs:label "implements rollback"@en ;
    rdfs:comment "Connects an MLOps Pipeline to its corresponding data or model rollback strategy."@en ;
    owl:inverseOf ffonto:isRollbackImplementedBy ;
    rdfs:domain ffonto:MLOpsPipeline ;
    rdfs:range ffonto:RollbackStrategy .

ffonto:isRollbackImplementedBy a owl:ObjectProperty ;
    rdfs:label "is rollback implemented by"@en ;
    rdfs:comment "Inverse property linking a rollback strategy to the MLOps pipeline executing it."@en ;
    rdfs:range ffonto:MLOpsPipeline ;
    rdfs:domain ffonto:RollbackStrategy .
