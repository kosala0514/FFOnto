    rdfs:range ffonto:AssemblyArea ;
    rdfs:comment "Civilians gathering at a safe area." .

ffonto:gatheringAtOf a owl:ObjectProperty ;
    rdfs:range ffonto:Civilian ;
    rdfs:domain ffonto:AssemblyArea ;
    rdfs:label "inverse of gathering at"@en .

ffonto:gatheringAtOf owl:inverseOf ffonto:gatheringAt .

ffonto:blockingRoad rdf:type owl:ObjectProperty ;
    rdfs:label "blocking road" ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:Road ;
    rdfs:comment "Responder or device blocking a road." .

ffonto:blockingRoadOf rdf:type owl:ObjectProperty ;
    rdfs:label "blocking road of" ;
    rdfs:range ffonto:Responder ;
    rdfs:domain ffonto:Road ;
    rdfs:comment "Inverse - Responder or device blocking a road." .

ffonto:blockingRoadOf owl:inverseOf ffonto:blockingRoad .

ffonto:guidingTraffic rdf:type owl:ObjectProperty ;
    rdfs:label "guiding traffic" ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:Road ;
    rdfs:comment "Responder actively guiding traffic on a road." .

ffonto:guidingTrafficOf a owl:ObjectProperty ;
    rdfs:range ffonto:Responder ;
    rdfs:domain ffonto:Road ;
    rdfs:label "inverse of guiding traffic"@en .

ffonto:guidingTrafficOf owl:inverseOf ffonto:guidingTraffic .

ffonto:mediaKeptAtDistance rdf:type owl:ObjectProperty ;
    rdfs:label "media kept at distance" ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:MediaGroup ;
    rdfs:comment "Indicates media/observers are held at a safe distance by responders." .

ffonto:mediaKeptAtDistanceOf rdf:type owl:ObjectProperty ;
    rdfs:label "media kept at distance of" ;
    rdfs:range ffonto:Responder ;
    rdfs:domain ffonto:MediaGroup ;
    rdfs:comment "Inverse - Indicates media/observers are held at a safe distance by responders." .

ffonto:mediaKeptAtDistance owl:inverseOf ffonto:mediaKeptAtDistanceOf .
