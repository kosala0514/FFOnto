@prefix ffonto: <http://purl.org/ffonto/ffonto-v2#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix ns2: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .

########################################################################
# Ontology metadata
########################################################################
ffonto: a owl:Ontology ;
    # --- Licensing ---
    cc:license "" ;
    dcterms:license "" ;

    # --- Description & Titles ---
    dc:title "Forest Fire Detection & Observation Ontology (FFONTO)"@en ;
    dc:description "This ontology describes forest fire detection observations including image, audio, and weather data."@en ;
    dc:abstract "The Forest Fire Detection & Observation Ontology (FFONTO) is designed to integrate multi-modal sensor data for early fire detection. It serves as an extensible framework with 'ForestFire' as the root class, incorporating concepts for visual detection, audio monitoring, and environmental conditions."@en ;
    rdfs:comment "Ontology for forest fire detection & observation (image, audio, weather). Root class: ForestFire. Designed for extensibility."@en ;

    # --- Contributors & Creators ---
    dc:creator [
        foaf:name "Ms. Charuni Kosala Jayaweera"@en ;
        # foaf:homepage <https://[your-website-or-profile]> ;
        schema:identifier <https://orcid.org/0009-0003-5790-62840> 
    ] ;
    dc:contributor [
        foaf:name "Prof. Dulani Meedeniya"@en ;
        # foaf:homepage <https://[contributor-profile-url]> ;
        schema:identifier <https://orcid.org/0000-0002-4520-3819> 
    ];

    # --- Publisher & Namespace Info ---
    #dcterms:publisher <https://[your-organization-or-lab-url]/> ;
    vann:preferredNamespacePrefix "ffonto"@en ;
    #vann:preferredNamespaceUri "https://w3id.org/def/ffonto#" ;
    
    # --- Versioning & Dates ---
    dcterms:issued "2026-01-27"^^xsd:date ;
    owl:versionIRI ffonto:V1.0 ;
    owl:versionInfo "Initial Release 1.0" ;
    ns2:status "Active" ;

    # --- Provenance ---
    prov:generatedAtTime "2026-01-27T00:00:00+00:00"^^xsd:dateTime ;
    prov:wasAttributedTo <https://github.com/kosala0514> ;
    # prov:wasDerivedFrom <https://link-to-previous-work-if-any> ;

    # --- Imports & External Links ---
    # owl:imports sosa: ;
    rdfs:seeAlso <https://github.com/kosala0514/FFOnto> ;
    # foaf:logo <https://link-to-your-logo-image.png> ;

    # --- Citations ---
    # schema:citation "Cite this ontology as: [Author Last Name], [First Initial]. (2024). FFONTO: An Ontology for Forest Fire Detection. [Conference/Journal Name]. https://doi.org/[your-doi-here]"@en ;
    # dcterms:doi <https://doi.org/0009-0003-5790-62840>
     .

########################################################################
# Core classes
########################################################################
ffonto:ForestFire a owl:Class ;
    rdfs:label "ForestFire" ;
    rdfs:comment "Root class representing an inferred or observed forest fire situation." .

ffonto:ActiveFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "ActiveFire" ;
    rdfs:comment "Active fire situation (smoke/flame detected; fire currently active)." .

ffonto:NonFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "NonFire" ;
    rdfs:comment "Situation determined to be not a fire (false alarm, controlled burn labeled separately if desired)." .

ffonto:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "Abstract observation. Observations are linked to ForestFire instances via ffonto:observedFor." .

ffonto:ImageObservation a owl:Class ;
    rdfs:subClassOf ffonto:Observation ;
    rdfs:label "ImageObservation" ;
    rdfs:comment "Observation derived from image-type sensors (camera, drone, satellite)." .

ffonto:AudioObservation a owl:Class ;
    rdfs:subClassOf ffonto:Observation ;
    rdfs:label "AudioObservation" ;
    rdfs:comment "Observation derived from audio sensors (field recorder, microphone)." .

ffonto:WeatherObservation a owl:Class ;
    rdfs:subClassOf ffonto:Observation ;
    rdfs:label "WeatherObservation" ;
    rdfs:comment "Observation containing fire weather indices and meteorological records." .

# ffonto:MeteorologicalRecord a owl:Class ;
#    rdfs:subClassOf ffonto:WeatherObservation .

# ffonto:FireWeatherRecord a owl:Class ;
#    rdfs:subClassOf ffonto:WeatherObservation .

########################################################################
# Reusable Measurement pattern
########################################################################
ffonto:Measurement a owl:Class ;
    rdfs:label "Measurement" ;
    rdfs:comment "Generic measurement wrapper. Use when attaching value+unit+time+confidence." .

ffonto:hasValue a owl:DatatypeProperty ;
    rdfs:domain ffonto:Measurement ;
    rdfs:range xsd:double ;
    rdfs:label "hasValue" ;
    rdfs:comment "Numeric measurement value (use units in ffonto:hasUnit)." .

ffonto:hasUnit a owl:DatatypeProperty ;
    rdfs:domain ffonto:Measurement ;
    rdfs:range xsd:string ;
    rdfs:label "hasUnit" ;
    rdfs:comment "Unit of measure (e.g., 'C', 'mm', 'm/s', 'index units')." .

ffonto:hasMeasurementTime a owl:DatatypeProperty ;
    rdfs:domain ffonto:Measurement ;
    rdfs:range xsd:dateTime ;
    rdfs:label "hasMeasurementTime" ;
    rdfs:comment "Timestamp of the measurement (recommended UTC / ISO-8601)." .

ffonto:hasMeasurementConfidence a owl:DatatypeProperty ;
    rdfs:domain ffonto:Measurement ;
    rdfs:range xsd:float ;
    rdfs:label "hasMeasurementConfidence" ;
    rdfs:comment "Confidence/quality of measurement (0.0-1.0)." .

########################################################################
# Weather records and fire-weather indices modeled via Measurement
########################################################################
ffonto:FireWeatherRecord a owl:Class ;
    rdfs:label "FireWeatherRecord" ;
    rdfs:comment "Container class holding index measurements relevant to fire danger." .

# Attachments (each is a Measurement)
ffonto:hasBUIMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to its Buildup Index (BUI) measurement."@en ;
    rdfs:label "hasBUIMeasurement" .

ffonto:hasDCMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to its Drought Code (DC) measurement."@en ;
    rdfs:label "hasDCMeasurement" .

ffonto:hasDMCMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to its Duff Moisture Code (DMC) measurement."@en ;
    rdfs:label "hasDMCMeasurement" .

ffonto:hasFFMCMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to its Fine Fuel Moisture Code (FFMC) measurement."@en ;
    rdfs:label "hasFFMCMeasurement" .

ffonto:hasFWIMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to its Fire Weather Index (FWI) measurement."@en ;
    rdfs:label "hasFWIMeasurement" .

ffonto:hasISIMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to its Initial Spread Index (ISI) measurement."@en ;
    rdfs:label "hasISIMeasurement" .

# Simple boolean indicating whether fire was present at this record
ffonto:recordedFireOccurred a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range xsd:boolean ;
    rdfs:label "recordedFireOccurred" ;
    rdfs:comment "Whether a fire was observed/recorded at the time of this record (boolean). May be inferred from sensors/field reports." .

########################################################################
# Meteorological records (temperature, rainfall, wind, RH...)
########################################################################
ffonto:MeteorologicalRecord a owl:Class ;
    rdfs:label "MeteorologicalRecord" ;
    rdfs:comment "Container class holding meteorological measurements." .

ffonto:hasTemperatureMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:MeteorologicalRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:label "hasTemperatureMeasurement" ;
    rdfs:comment "Air temperature measurement (Celsius recommended)." .

ffonto:hasRainfallMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:MeteorologicalRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:label "hasRainfallMeasurement" ;
    rdfs:comment "Precipitation accumulation or amount measurement (mm suggested)." .

ffonto:hasWindSpeedMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:MeteorologicalRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to a measurement of wind speed."@en ;
    rdfs:label "hasWindSpeedMeasurement" .

ffonto:hasRelativeHumidityMeasurement a owl:ObjectProperty ;
    rdfs:domain ffonto:MeteorologicalRecord ;
    rdfs:range ffonto:Measurement ;
    rdfs:comment "Relates an entity or event to a measurement of relative humidity."@en ;
    rdfs:label "hasRelativeHumidityMeasurement" .

########################################################################
# Temporal and spatial modeling
########################################################################
ffonto:TemporalExtent a owl:Class ;
    rdfs:label "TemporalExtent" ;
    rdfs:comment "Temporal wrapper to hold explicit date/year/month/day if needed." .

ffonto:hasDateTime a owl:DatatypeProperty ;
    rdfs:domain ffonto:TemporalExtent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "hasDateTime" ;
    rdfs:comment "ISO-8601 timestamp (date+time)." .

ffonto:hasYear a owl:DatatypeProperty ;
    rdfs:domain ffonto:TemporalExtent ;
    rdfs:range xsd:gYear ;
    rdfs:comment "Relates a temporal entity to the year in which it occurs."@en ;
    rdfs:label "hasYear" .

ffonto:hasMonth a owl:DatatypeProperty ;
    rdfs:domain ffonto:TemporalExtent ;
    rdfs:comment "Relates a temporal entity to the month in which it occurs."@en ;
    rdfs:range xsd:gMonth ;
    rdfs:label "hasMonth" .

ffonto:hasDay a owl:DatatypeProperty ;
    rdfs:domain ffonto:TemporalExtent ;
    rdfs:range xsd:gDay ;
    rdfs:comment "Relates a temporal entity to the day of the month on which it occurs."@en ;
    rdfs:label "hasDay" .

ffonto:SpatialExtent a owl:Class ;
    rdfs:label "SpatialExtent" ;
    rdfs:comment "Container for spatial references and grid coordinates." .

ffonto:country a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range xsd:string ;
    rdfs:comment "Represents the country associated with an address or location."@en ;
    rdfs:label "country" .

ffonto:region a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range xsd:string ;
    rdfs:comment "Represents an administrative or geographic region."@en ;
    rdfs:label "region" .

ffonto:site a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range xsd:string ;
    rdfs:label "site" ;
    rdfs:comment "Local site name or identifier." .

ffonto:grideX a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range xsd:double ;
    rdfs:label "gridX" ;
    rdfs:comment "Grid coordinate X (specify CRS in metadata)." .

ffonto:grideY a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range xsd:double ;
    rdfs:label "gridY" ;
    rdfs:comment "Grid coordinate Y (specify CRS in metadata)." .

ffonto:geoLatitude a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:comment "Represents the geographic latitude coordinate of a location."@en ;
    rdfs:range xsd:double ;
    rdfs:label "geoLatitude" .

ffonto:geoLongitude a owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range xsd:double ;
    rdfs:comment "Represents the geographic longitude coordinate of a location."@en ;
    rdfs:label "geoLongitude" .

########################################################################
# Link observations to forest fires and attach temporal/spatial info
########################################################################
ffonto:hasObservation a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Observation ;
    rdfs:label "hasObservation" ;
    rdfs:comment "From a ForestFire to its Observations (inverse of ffonto:observedFor)." .

ffonto:observedFor a owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "observedFor" ;
    rdfs:comment "Observation linked to a ForestFire instance." ;
    owl:inverseOf ffonto:hasObservation .

ffonto:ObservationTimestamp a owl:DatatypeProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range xsd:dateTime ;
    rdfs:label "observationTimestamp" ;
    rdfs:comment "Timestamp when observation was created/recorded (ISO-8601 UTC recommended)." .

ffonto:hasTemporalExtent a owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:TemporalExtent ;
    rdfs:comment "Relates an event or process to the time interval over which it occurs."@en ;
    rdfs:label "hasTemporalExtent" .

ffonto:hasSpatialExtent a owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:SpatialExtent ;
    rdfs:comment "Relates an event, process, or entity to the spatial area or region over which it extends."@en ;
    rdfs:label "hasSpatialExtent" .

########################################################################
# Image/Audio derivation metadata and ML outputs
########################################################################
ffonto:DerivationMetadata a owl:Class ;
    rdfs:label "DerivationMetadata" ;
    rdfs:comment "Metadata about algorithmic derivation from sensor data (ML outputs, provenance, thresholds...)." .

ffonto:predictedLabel a owl:DatatypeProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range xsd:string ;
    rdfs:label "predictedLabel" ;
    rdfs:comment "Model predicted label (string or controlled vocabulary)." .

ffonto:provenanceNote a owl:DatatypeProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range xsd:string ;
    rdfs:label "provenance" ;
    rdfs:comment "Human-readable provenance or link to provenance record (use PROV if available)." .

ffonto:scoringOutput a owl:DatatypeProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range xsd:string ;
    rdfs:label "scoringOutput" ;
    rdfs:comment "Serialized scoring output (e.g., JSON blob with per-class scores)." .

ffonto:sourceType a owl:ObjectProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range ffonto:SourceType ;
    rdfs:label "sourceType" ;
    rdfs:comment "Sensor source type (controlled vocabulary: fieldRecord, microphone, camera, drone, satellite)." .

ffonto:thresholdValue a owl:DatatypeProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range xsd:double ;
    rdfs:label "threshold" ;
    rdfs:comment "Threshold used to classify/pick label (if applicable)." .

ffonto:hasComputationalModel a owl:ObjectProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range ffonto:ComputationalModel ;
    rdfs:comment "Relates an entity or process to a computational model used to represent or simulate it."@en ;
    rdfs:label "hasComputationalModel" .

ffonto:modelConfidence a owl:DatatypeProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range xsd:float ;
    rdfs:label "modelConfidence" ;
    rdfs:comment "Confidence associated with the model's decision (0.0-1.0)." .

ffonto:checksumSHA256 a owl:DatatypeProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range xsd:string ;
    rdfs:label "checksumSHA256" ;
    rdfs:comment "SHA-256 checksum of media or artifact." .

ffonto:geoLocation a owl:ObjectProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range ffonto:SpatialExtent ;
    rdfs:label "geoLocation" ;
    rdfs:comment "Geolocation tied to the derivation (if different from observation-level)." .

ffonto:mediaAsset a owl:ObjectProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range ffonto:MediaAsset ;
    rdfs:label "mediaAsset" ;
    rdfs:comment "Link to the media asset (image file or audio clip)." .

ffonto:hasDerivationMetadata a owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:DerivationMetadata ;
    rdfs:label "hasDerivationMetadata" ;
    rdfs:comment "Attach derivation/ML metadata to image/audio observations." .

########################################################################
# Computational model & media asset classes
########################################################################
ffonto:ComputationalModel a owl:Class ;
    rdfs:label "ComputationalModel" ;
    rdfs:comment "Represents an ML/computational model used to derive results." .

ffonto:modelName a owl:DatatypeProperty ;
    rdfs:domain ffonto:ComputationalModel ;
    rdfs:comment "Represents the name of a computational or analytical model."@en ;
    rdfs:range xsd:string ;
    rdfs:label "modelName" .

ffonto:modelVersion a owl:DatatypeProperty ;
    rdfs:domain ffonto:ComputationalModel ;
    rdfs:comment "Represents the version identifier of a computational or analytical model."@en ;
    rdfs:range xsd:string ;
    rdfs:label "modelVersion" .

ffonto:modelParameters a owl:DatatypeProperty ;
    rdfs:domain ffonto:ComputationalModel ;
    rdfs:range xsd:string ;
    rdfs:label "modelParameters" ;
    rdfs:comment "Optional serialized model parameters (e.g., hyperparams, architecture) or a URI to model metadata." .

ffonto:MediaAsset a owl:Class ;
    rdfs:label "MediaAsset" ;
    rdfs:comment "Represents an image or audio file used as evidence." .

ffonto:assetFileName a owl:DatatypeProperty ;
    rdfs:domain ffonto:MediaAsset ;
    rdfs:label "assetFileName" ;
    rdfs:comment "Represents the file name of a digital asset."@en ;
    rdfs:range xsd:string .

ffonto:assetFormat a owl:DatatypeProperty ;
    rdfs:domain ffonto:MediaAsset ;
    rdfs:range xsd:string ;
    rdfs:label "assetFormat" ;
    rdfs:comment "File format/ MIME type e.g., image/tiff, audio/wav." .

ffonto:assetSizeBytes a owl:DatatypeProperty ;
    rdfs:label "assetSizeBytes" ;
    rdfs:comment "Represents the size of a digital asset in bytes."@en ;
    rdfs:domain ffonto:MediaAsset ;
    rdfs:range xsd:integer .

ffonto:assetURI a owl:DatatypeProperty ;
    rdfs:domain ffonto:MediaAsset ;
    rdfs:label "assetURI" ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "Pointer to storage system (careful re: privacy/security)." .

########################################################################
# SourceType vocabulary (controlled individuals)
########################################################################
ffonto:SourceType a owl:Class ;
    rdfs:label "SourceType" ;
    rdfs:comment "Controlled vocabulary for sensor source types." .

ffonto:fieldRecord a owl:NamedIndividual, ffonto:SourceType ; rdfs:label "fieldRecord" .
ffonto:microphone a owl:NamedIndividual, ffonto:SourceType ; rdfs:label "microphone" .
ffonto:camera a owl:NamedIndividual, ffonto:SourceType ; rdfs:label "camera" .
ffonto:drone a owl:NamedIndividual, ffonto:SourceType ; rdfs:label "drone" .
ffonto:satellite a owl:NamedIndividual, ffonto:SourceType ; rdfs:label "satellite" .

########################################################################
# Link WeatherObservation to Record containers
########################################################################
ffonto:hasFireWeatherRecord a owl:ObjectProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:range ffonto:FireWeatherRecord ;
    rdfs:comment "Relates a fire or event to its associated fire weather record."@en ;
    rdfs:label "hasFireWeatherRecord" .

ffonto:hasMeteorologicalRecord a owl:ObjectProperty ;
    rdfs:domain ffonto:WeatherObservation ;
    rdfs:comment "Relates an event or entity to an associated meteorological record."@en ;
    rdfs:range ffonto:MeteorologicalRecord ;
    rdfs:label "hasMeteorologicalRecord" .

########################################################################
# Cardinality / Consistency Constraints 
########################################################################
# Every Observation must be linked to at least one ForestFire (observedFor some ForestFire)
ffonto:Observation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:observedFor ;
    owl:someValuesFrom ffonto:ForestFire
] , [
    a owl:Restriction ;
    owl:onProperty ffonto:ObservationTimestamp ;
    owl:cardinality "1"^^xsd:nonNegativeInteger
] .

ffonto:FireWeatherRecord rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isRecordOf ;
    owl:someValuesFrom ffonto:WeatherObservation
] .

ffonto:isRecordOf a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:label "isRecordOf" ;
    rdfs:comment "Relates a record or observation to the entity, event, or phenomenon that it documents."@en ;
    rdfs:range ffonto:WeatherObservation .

ffonto:DerivationMetadata rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isMetadataOf ;
    owl:someValuesFrom ffonto:Observation
] .

ffonto:ComputationalModel rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isModelUsedIn ;
    owl:someValuesFrom ffonto:DerivationMetadata
] .

ffonto:isMetadataOf a owl:ObjectProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:label "isMetadataOf" ;
    rdfs:range ffonto:Observation .

# ImageObservation and AudioObservation should allow derivation metadata (optional but encouraged)
ffonto:ImageObservation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasDerivationMetadata ;
    owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
    owl:onClass ffonto:DerivationMetadata
] .

ffonto:AudioObservation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasDerivationMetadata ;
    owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
    owl:onClass ffonto:DerivationMetadata
] .

ffonto:isMetadataOf a owl:ObjectProperty ;
    rdfs:domain ffonto:DerivationMetadata ;
    rdfs:range ffonto:Observation ;
    rdfs:label "isMetadataOf" ;
    rdfs:comment "Links derivation metadata back to the observation it describes." ;
    owl:inverseOf ffonto:hasDerivationMetadata .

ffonto:isModelUsedIn a owl:ObjectProperty ;
    rdfs:domain ffonto:ComputationalModel ;
    rdfs:range ffonto:DerivationMetadata ;
    rdfs:label "isModelUsedIn" ;
    rdfs:comment "Links a computational model to the derivation metadata where it was used." ;
    owl:inverseOf ffonto:hasComputationalModel .

ffonto:isMeteorologicalRecordOf a owl:ObjectProperty ;
    rdfs:domain ffonto:MeteorologicalRecord ;
    rdfs:range ffonto:WeatherObservation ;
    rdfs:label "isMeteorologicalRecordOf" ;
    rdfs:comment "Relates a meteorological record to the fire or event that it describes."@en ;
    owl:inverseOf ffonto:hasMeteorologicalRecord .

ffonto:MeteorologicalRecord rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isMeteorologicalRecordOf ;
    owl:someValuesFrom ffonto:WeatherObservation
] .

ffonto:isFireWeatherRecordOf a owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherRecord ;
    rdfs:range ffonto:WeatherObservation ;
    rdfs:label "isFireWeatherRecordOf" ;
    rdfs:comment "Relates a fire weather record to the fire or event that it describes."@en ;
    owl:inverseOf ffonto:hasFireWeatherRecord .

ffonto:FireWeatherRecord rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isFireWeatherRecordOf ;
    owl:someValuesFrom ffonto:WeatherObservation
] .

ffonto:isMeasurementOf a owl:ObjectProperty ;
    rdfs:domain ffonto:Measurement ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf ( ffonto:MeteorologicalRecord ffonto:FireWeatherRecord )
    ] ;
    rdfs:label "isMeasurementOf" ;
    rdfs:comment "Links a measurement to the record it belongs to." .

ffonto:isMediaOf a owl:ObjectProperty ;
    rdfs:domain ffonto:MediaAsset ;
    rdfs:range ffonto:DerivationMetadata ;
    rdfs:label "isMediaOf" ;
    rdfs:comment "Relates a medium or carrier to the phenomenon or process that it conveys."@en ;
    owl:inverseOf ffonto:mediaAsset .

ffonto:isSourceTypeOf a owl:ObjectProperty ;
    rdfs:domain ffonto:SourceType ;
    rdfs:range ffonto:DerivationMetadata ;
    rdfs:label "isSourceTypeOf" ;
    rdfs:comment "Relates a source type to the phenomenon or event that originates from it."@en ;
    owl:inverseOf ffonto:sourceType .

ffonto:isSpatialExtentOf a owl:ObjectProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range ffonto:Observation ;
    rdfs:comment "Relates a spatial region to the event or entity that it describes."@en ;
    rdfs:label "isSpatialExtentOf" ;
    owl:inverseOf ffonto:hasSpatialExtent .

ffonto:isTemporalExtentOf a owl:ObjectProperty ;
    rdfs:domain ffonto:TemporalExtent ;
    rdfs:range ffonto:Observation ;
    rdfs:comment "Relates a temporal interval to the event or process that it describes."@en ;
    rdfs:label "isTemporalExtentOf" ;
    owl:inverseOf ffonto:hasTemporalExtent .

ffonto:measurementContributesToFire a owl:ObjectProperty ;
    rdfs:domain ffonto:Measurement ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates a measurement or index to the fire behavior or development that it influences."@en ;
    rdfs:label "measurementContributesToFire" .

# FireWeatherRecord should have at least one index measurement (min 1 measurement of the known set)
ffonto:FireWeatherRecord rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasFWIMeasurement ;
    owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
    owl:onClass ffonto:Measurement
] .

# MeteorologicalRecord recommended to include at least one of the usual meteorological measurements (flexible)
ffonto:MeteorologicalRecord rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasTemperatureMeasurement ;
    owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
    owl:onClass ffonto:Measurement
] .

ffonto:Measurement rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isMeasurementOf ;
    owl:someValuesFrom [
        a owl:Class ;
        owl:unionOf ( ffonto:MeteorologicalRecord ffonto:FireWeatherRecord )
    ]
] .

ffonto:MediaAsset rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isMediaOf ;
    owl:someValuesFrom ffonto:DerivationMetadata
] .

ffonto:SourceType rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isSourceTypeOf ;
    owl:someValuesFrom ffonto:DerivationMetadata
] .

ffonto:SpatialExtent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isSpatialExtentOf ;
    owl:someValuesFrom ffonto:Observation
] .

ffonto:TemporalExtent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isTemporalExtentOf ;
    owl:someValuesFrom ffonto:Observation
] .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:measurementContributesToFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:isMeasurementOf
      ffonto:isMeteorologicalRecordOf
      ffonto:observedFor
  )
] .

#################################################################
# Forest fire causes
#################################################################

ffonto:ForestFireCause a owl:Class ;
    rdfs:label "ForestFireCause" ;
    rdfs:comment "Abstract superclass for all causes leading to the ignition or spread of a forest fire." .

ffonto:hasCause a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:ForestFireCause ;
    rdfs:label "hasCause" ;
    rdfs:comment "Links a ForestFire event to one or more causal factors." .

#################################################################
# Top-level cause categories
#################################################################

ffonto:NaturalCause a owl:Class ;
    rdfs:subClassOf ffonto:ForestFireCause ;
    rdfs:label "NaturalCause" ;
    rdfs:comment "Causes originating from natural environmental or geophysical processes." .

ffonto:HumanCause a owl:Class ;
    rdfs:subClassOf ffonto:ForestFireCause ;
    rdfs:label "HumanCause" ;
    rdfs:comment "Causes originating from human activities, intentional or accidental." .

ffonto:AtmosphericCause a owl:Class ;
    rdfs:subClassOf ffonto:NaturalCause ;
    rdfs:label "AtmosphericCause" ;
    rdfs:comment "Causes related to atmospheric and weather phenomena." .

ffonto:ExtremeHeat a owl:Class ;
    rdfs:subClassOf ffonto:AtmosphericCause ;
    rdfs:label "ExtremeHeat" ;
    rdfs:comment "Atmospheric cause referring to unusually high temperatures that increase fire risk or intensify fire behavior." .

ffonto:Lightning a owl:Class ;
    rdfs:subClassOf ffonto:AtmosphericCause ;
    rdfs:label "Lightning" ;
    rdfs:comment "Atmospheric cause representing lightning strikes that can ignite fires naturally." .

ffonto:StrongWind a owl:Class ;
    rdfs:subClassOf ffonto:AtmosphericCause ;
    rdfs:label "StrongWind" ;
    rdfs:comment "Atmospheric cause referring to strong winds that accelerate fire spread and influence fire direction." .

ffonto:GeophysicalCause a owl:Class ;
    rdfs:subClassOf ffonto:NaturalCause ;
    rdfs:label "GeophysicalCause" ;
    rdfs:comment "Causes originating from geothermal or volcanic processes." .

ffonto:GeothermalActivity a owl:Class ;
    rdfs:subClassOf ffonto:GeophysicalCause ;
    rdfs:label "GeothermalActivity" ;
    rdfs:comment "Geophysical causes related to geothermal processes and heat released from the Earth's interior that can trigger or influence fires." .

ffonto:Fumarole a owl:Class ;
    rdfs:subClassOf ffonto:GeothermalActivity ;
    rdfs:label "Fumarole" ;
    rdfs:comment "Geothermal activity referring to openings in the Earth's surface that emit steam and volcanic gases, potentially igniting nearby materials." .

ffonto:GeothermalVent a owl:Class ;
    rdfs:subClassOf ffonto:GeothermalActivity ;
    rdfs:label "Geothermal vent" ;
    rdfs:comment "Geothermal activity representing vents that release hot fluids or gases from beneath the Earth's surface, creating ignition sources." .

ffonto:HotSpringOverflow a owl:Class ;
    rdfs:subClassOf ffonto:GeothermalActivity ;
    rdfs:label "HotSpringOverflow" ;
    rdfs:comment "Geothermal activity referring to overflow of hot spring water that can heat surrounding vegetation and increase fire risk." .

ffonto:SteamExplosion a owl:Class ;
    rdfs:subClassOf ffonto:GeothermalActivity ;
    rdfs:label "SteamExplosion" ;
    rdfs:comment "Geothermal activity representing sudden explosive releases of steam caused by rapid heating of groundwater, which may ignite fires or expose hot surfaces." .

ffonto:VolcanicActivity a owl:Class ;
    rdfs:subClassOf ffonto:GeophysicalCause ;
    rdfs:label "VolcanicActivity" ;
    rdfs:comment "Geophysical causes related to volcanic processes that produce heat, lava, ash, or gases capable of igniting or spreading fires." .

ffonto:LavaFlow a owl:Class ;
    rdfs:subClassOf ffonto:VolcanicActivity ;
    rdfs:label "LavaFlow" ;
    rdfs:comment "Volcanic activity referring to streams of molten lava that burn or ignite vegetation and infrastructure along their path." .

ffonto:LavaFountain a owl:Class ;
    rdfs:subClassOf ffonto:VolcanicActivity ;
    rdfs:label "LavaFountain" ;
    rdfs:comment "Volcanic activity representing jets or sprays of molten lava ejected from a volcanic vent, capable of igniting surrounding materials." .

ffonto:PyroclasticFlow a owl:Class ;
    rdfs:subClassOf ffonto:VolcanicActivity ;
    rdfs:label "PyroclasticFlow" ;
    rdfs:comment "Volcanic activity referring to fast-moving flows of hot gas, ash, and volcanic debris that can ignite vegetation and cause fires." .

ffonto:VolcanicBombInjection a owl:Class ;
    rdfs:subClassOf ffonto:VolcanicActivity ;
    rdfs:label "VolcanicBombInjection" ;
    rdfs:comment "Volcanic activity representing the ejection of incandescent volcanic fragments that can ignite vegetation or structures upon impact." .

ffonto:EquipmentFailure a owl:Class ;
    rdfs:subClassOf ffonto:HumanCause ;
    rdfs:label "EquipmentFailure" ;
    rdfs:comment "Ignitions caused by malfunctioning or overheated equipment." .

ffonto:AgriculturalMachineryFailure a owl:Class ;
    rdfs:subClassOf ffonto:EquipmentFailure ;
    rdfs:label "AgriculturalMachineryFailure" ;
    rdfs:comment "Equipment failure involving agricultural machinery that produces sparks, heat, or friction capable of igniting fires." .

ffonto:ForestryEquipmentFailure a owl:Class ;
    rdfs:subClassOf ffonto:EquipmentFailure ;
    rdfs:label "ForestryEquipmentFailure" ;
    rdfs:comment "Equipment failure involving forestry tools or machinery whose malfunction or overheating leads to fire ignition." .

ffonto:VehicleEquipmentFailure a owl:Class ;
    rdfs:subClassOf ffonto:EquipmentFailure ;
    rdfs:label "VehicleEquipmentFailure" ;
    rdfs:comment "Equipment failure involving vehicles whose mechanical or electrical faults generate sparks or heat that ignite surrounding materials." .

ffonto:InfrastructureFailure a owl:Class ;
    rdfs:subClassOf ffonto:HumanCause ;
    rdfs:label "InfrastructureFailure" ;
    rdfs:comment "Ignitions originating from damaged or faulty infrastructure systems." .

ffonto:PowerLineFailure a owl:Class ;
    rdfs:subClassOf ffonto:InfrastructureFailure ;
    rdfs:label "PowerLineFailure" ;
    rdfs:comment "Infrastructure failure involving power lines whose breakage, contact, or electrical discharge ignites surrounding vegetation or materials." .

ffonto:RailwaySpark a owl:Class ;
    rdfs:subClassOf ffonto:InfrastructureFailure ;
    rdfs:label "RailwaySpark" ;
    rdfs:comment "Infrastructure failure referring to sparks generated by railway operations or braking systems that ignite nearby combustible materials." .

ffonto:SubstationFault a owl:Class ;
    rdfs:subClassOf ffonto:InfrastructureFailure ;
    rdfs:label "SubstationFault" ;
    rdfs:comment "Infrastructure failure involving electrical substations whose faults, overheating, or short circuits cause fire ignition." .

ffonto:InfrastructureFailure a owl:Class ;
    rdfs:subClassOf ffonto:HumanCause ;
    rdfs:label "InfrastructureFailure" ;
    rdfs:comment "Ignitions originating from damaged or faulty infrastructure systems." .

ffonto:PowerLineFailure a owl:Class ;
    rdfs:subClassOf ffonto:InfrastructureFailure ;
    rdfs:label "PowerLineFailure" ;
    rdfs:comment "Infrastructure failure involving power transmission lines whose breakage, contact, or electrical discharge ignites surrounding vegetation or materials." .

ffonto:RailwaySpark a owl:Class ;
    rdfs:subClassOf ffonto:InfrastructureFailure ;
    rdfs:label "RailwaySpark" ;
    rdfs:comment "Infrastructure failure referring to sparks generated by railway operations, braking systems, or wheel–rail contact that ignite nearby combustible materials." .

ffonto:SubstationFault a owl:Class ;
    rdfs:subClassOf ffonto:InfrastructureFailure ;
    rdfs:label "SubstationFault" ;
    rdfs:comment "Infrastructure failure involving electrical substations whose faults, overheating, or short circuits result in fire ignition." .

ffonto:IntentionalCause a owl:Class ;
    rdfs:subClassOf ffonto:HumanCause ;
    rdfs:label "IntentionalCause" ;
    rdfs:comment "Deliberate ignitions with intent." .

ffonto:Arson a owl:Class ;
    rdfs:subClassOf ffonto:IntentionalCause ;
    rdfs:label "Arson" ;
    rdfs:comment "Intentional cause referring to the deliberate setting of fires with malicious or criminal intent." .

ffonto:InsuranceFraudFire a owl:Class ;
    rdfs:subClassOf ffonto:IntentionalCause ;
    rdfs:label "InsuranceFraudFire" ;
    rdfs:comment "Intentional cause involving the deliberate ignition of fires to obtain financial benefit through insurance claims." .

ffonto:LandClearingFire a owl:Class ;
    rdfs:subClassOf ffonto:IntentionalCause ;
    rdfs:label "LandClearingFire" ;
    rdfs:comment "Intentional cause referring to fires deliberately set to clear vegetation or prepare land for agriculture or development." .

ffonto:ProtestFire a owl:Class ;
    rdfs:subClassOf ffonto:IntentionalCause ;
    rdfs:label "ProtestFire" ;
    rdfs:comment "Intentional cause referring to fires deliberately set during protests, riots, or civil disturbances as a form of demonstration or unrest." .

ffonto:SabotageFire a owl:Class ;
    rdfs:subClassOf ffonto:IntentionalCause ;
    rdfs:label "SabotageFire" ;
    rdfs:comment "Intentional cause involving the deliberate ignition of fires to damage property, disrupt operations, or undermine organizations or infrastructure." .

ffonto:Negligence a owl:Class ;
    rdfs:subClassOf ffonto:HumanCause ;
    rdfs:label "Negligence" ;
    rdfs:comment "Accidental ignitions due to careless or improper human behavior." .

ffonto:Campfire a owl:Class ;
    rdfs:subClassOf ffonto:Negligence ;
    rdfs:label "Campfire" ;
    rdfs:comment "Negligent cause referring to improperly extinguished or unattended campfires that ignite surrounding vegetation or materials." .

ffonto:FireworkUse a owl:Class ;
    rdfs:subClassOf ffonto:Negligence ;
    rdfs:label "FireworkUse" ;
    rdfs:comment "Negligent cause involving the use of fireworks that produce sparks or embers capable of igniting fires in dry or combustible environments." .

ffonto:TrashBurning a owl:Class ;
    rdfs:subClassOf ffonto:Negligence ;
    rdfs:label "TrashBurning" ;
    rdfs:comment "Negligent cause referring to the burning of waste or debris that escapes control and ignites surrounding vegetation or structures." .

ffonto:NaturalCause owl:disjointWith ffonto:HumanCause .
ffonto:IntentionalCause owl:disjointWith ffonto:Negligence .
ffonto:EquipmentFailure owl:disjointWith ffonto:InfrastructureFailure .

#################################################################
# Inferred fire types by cause
#################################################################

ffonto:HumanCausedFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "HumanCausedFire" ;
    rdfs:comment "Forest fires that have at least one human-related cause." .

ffonto:NaturalCausedFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "NaturalCausedFire" ;
    rdfs:comment "Forest fires that have only natural causes." .

ffonto:HumanCausedFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCause ;
          owl:someValuesFrom ffonto:HumanCause
        ]
    )
] .

ffonto:NaturalCausedFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCause ;
          owl:someValuesFrom ffonto:NaturalCause
        ]
    )
] .

ffonto:IntentionallyCausedFire a owl:Class ;
    rdfs:subClassOf ffonto:HumanCausedFire ;
    rdfs:label "IntentionallyCausedFire" ;
    rdfs:comment "Human-caused fires that result from deliberate and purposeful ignition, regardless of motive or legality." .

ffonto:AccidentallyCausedFire a owl:Class ;
    rdfs:subClassOf ffonto:HumanCausedFire ;
    rdfs:label "AccidentallyCausedFire" ;
    rdfs:comment "Human-caused fires that result from unintentional actions, negligence, or equipment malfunction without deliberate intent to ignite." .

ffonto:IntentionallyCausedFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCause ;
          owl:someValuesFrom ffonto:IntentionalCause
        ]
    )
] .

ffonto:AccidentallyCausedFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCause ;
          owl:someValuesFrom ffonto:Negligence
        ]
    )
] .

ffonto:isCauseOf a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFireCause ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isCauseOf" ;
    rdfs:comment "Relates a cause to the effect or event that it produces."@en ;
    owl:inverseOf ffonto:hasCause .

ffonto:ForestFireCause rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isCauseOf ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:SmokingRelated a owl:Class ;
    rdfs:subClassOf ffonto:HumanCause ;
    rdfs:label "SmokingRelated" ;
    rdfs:comment "Human-related causes of fire ignition associated with smoking activities and discarded smoking materials." .

ffonto:CigaretteButt a owl:Class ;
    rdfs:subClassOf ffonto:SmokingRelated ;
    rdfs:label "CigaretteButt" ;
    rdfs:comment "Smoking-related cause referring to improperly discarded or smoldering cigarette butts that ignite dry vegetation or combustible materials." .

ffonto:PowerToolUse a owl:Class ;
    rdfs:subClassOf ffonto:EquipmentFailure ;
    rdfs:label "PowerToolUse" ;
    rdfs:comment "Equipment-related cause involving the use of power tools that generate sparks, heat, or friction capable of igniting fires." .

#################################################################
# Fire characteristics
#################################################################

ffonto:FireCharacteristic a owl:Class ;
    rdfs:label "FireCharacteristic" ;
    rdfs:comment "Abstract superclass for intrinsic measurable or observable properties of a forest fire event." .

ffonto:hasCharacteristic a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FireCharacteristic ;
    rdfs:label "hasCharacteristic" ;
    rdfs:comment "Links a ForestFire event to one or more intrinsic fire characteristics." .

ffonto:isCharacteristicOf a owl:ObjectProperty ;
    rdfs:domain ffonto:FireCharacteristic ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isCharacteristicOf" ;
    rdfs:comment "Relates a characteristic or property to the entity of which it is a characteristic."@en ;
    owl:inverseOf ffonto:hasCharacteristic .

ffonto:FireCharacteristic rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isCharacteristicOf ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:derivedFromObservation a owl:ObjectProperty ;
    rdfs:domain ffonto:FireCharacteristic ;
    rdfs:range ffonto:Observation ;
    rdfs:label "derivedFromObservation" ;
    rdfs:comment "Indicates that a fire characteristic was derived or estimated from an observation." .

ffonto:derivedFromModel a owl:ObjectProperty ;
    rdfs:domain ffonto:FireCharacteristic ;
    rdfs:range ffonto:ComputationalModel ;
    rdfs:label "derivedFromModel" ;
    rdfs:comment "Indicates that a fire characteristic was derived using a computational or simulation model." .

#################################################################
# Fire behaviour characteristics
#################################################################

ffonto:FireBehaviourCharacteristic a owl:Class ;
    rdfs:subClassOf ffonto:FireCharacteristic ;
    rdfs:label "FireBehaviourCharacteristic" ;
    rdfs:comment "Describes how the fire spreads and behaves dynamically." .

ffonto:spreadRate a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehaviourCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "spreadRate" ;
    rdfs:comment "Rate of fire spread (e.g., m/min). Unit ontology recommended." .

ffonto:directionOfSpread a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehaviourCharacteristic ;
    rdfs:range xsd:string ;
    rdfs:label "directionOfSpread" ;
    rdfs:comment "Dominant direction of fire spread (e.g., N, NE, azimuth degrees)." .

ffonto:flameLength a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehaviourCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "flameLength" ;
    rdfs:comment "Average or maximum flame length (m)." .

ffonto:rateOfGrowth a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehaviourCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "rateOfGrowth" ;
    rdfs:comment "Rate of increase in fire size or perimeter." .

ffonto:spottingDistance a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehaviourCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "spottingDistance" ;
    rdfs:comment "Maximum distance of firebrand spotting (m)." .

ffonto:fireFrontType a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireBehaviourCharacteristic ;
    rdfs:range xsd:string ;
    rdfs:label "fireFrontType" ;
    rdfs:comment "Type of fire front: surface, crown, or ground." .

#################################################################
# Fire emission characteristics
#################################################################

ffonto:FireEmissionCharacteristic a owl:Class ;
    rdfs:subClassOf ffonto:FireCharacteristic ;
    rdfs:label "FireEmissionCharacteristic" ;
    rdfs:comment "Describes gaseous and particulate emissions and their effects." .

ffonto:smokeDensity a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "smokeDensity" ;
    rdfs:comment "Optical or mass-based smoke density measure." .

ffonto:particulateMatterPM25 a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "particulateMatterPM25" ;
    rdfs:comment "Fine particulate matter concentration (µg/m3)." .

ffonto:particulateMatterPM10 a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "particulateMatterPM10" ;
    rdfs:comment "Coarse particulate matter concentration (µg/m3)." .

ffonto:COEmission a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "COEmission" ;
    rdfs:comment "Carbon monoxide emission rate or concentration." .

ffonto:CO2Emission a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "CO2Emission" ;
    rdfs:comment "Carbon dioxide emission rate or concentration." .

ffonto:NOxEmission a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "NOxEmission" ;
    rdfs:comment "Nitrogen oxides emission rate or concentration." .

ffonto:visibilityReduction a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEmissionCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "visibilityReduction" ;
    rdfs:comment "Reduction in visibility due to smoke (m or %)." .

#################################################################
# Fire extent characteristics
#################################################################

ffonto:FireExtentCharacteristic a owl:Class ;
    rdfs:subClassOf ffonto:FireCharacteristic ;
    rdfs:label "FireExtentECharacteristic" ;
    rdfs:comment "Describes spatial extent, geometry, and impacted area of the fire." .

ffonto:burnedArea a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireExtentCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "burnedArea" ;
    rdfs:comment "Total burned area (ha or m2)." .

ffonto:perimeterLength a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireExtentCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "perimeterLength" ;
    rdfs:comment "Length of fire perimeter (m or km)." .

ffonto:affectedVegetationType a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireExtentCharacteristic ;
    rdfs:range xsd:string ;
    rdfs:label "affectedVegetationType" ;
    rdfs:comment "Dominant vegetation type affected (forest, shrubland, grassland, peat, etc.)." .

ffonto:depthOfBurn a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireExtentCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "depthOfBurn" ;
    rdfs:comment "Depth of soil/organic layer consumed by fire (cm or m)." .

ffonto:verticalExtent a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireExtentCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "verticalExtent" ;
    rdfs:comment "Vertical extent of flames or plume height (m)." .

#################################################################
# Fire intensity characteristics
#################################################################

ffonto:FireIntensityCharacteristic a owl:Class ;
    rdfs:subClassOf ffonto:FireCharacteristic ;
    rdfs:label "FireIntensityCharacteristic" ;
    rdfs:comment "Describes energetic strength and thermal output of the fire." .

ffonto:firelineIntensity a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireIntensityCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "firelineIntensity" ;
    rdfs:comment "Fireline intensity (kW/m), standard wildfire metric." .

ffonto:heatReleaseRate a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireIntensityCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "heatReleaseRate" ;
    rdfs:comment "Rate of heat release (kW or MW)." .

ffonto:flameTemperature a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireIntensityCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "flameTemperature" ;
    rdfs:comment "Average or peak flame temperature (°C or K)." .

ffonto:radiantHeatFlux a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireIntensityCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "radiantHeatFlux" ;
    rdfs:comment "Radiant heat flux at a reference distance (kW/m2)." .

ffonto:energyOutput a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireIntensityCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "energyOutput" ;
    rdfs:comment "Total energy released over time (MJ, GJ)." .

ffonto:FireBehaviourCharacteristic owl:disjointWith ffonto:FireEmissionCharacteristic .
ffonto:FireBehaviourCharacteristic owl:disjointWith ffonto:FireExtentCharacteristic .
ffonto:FireBehaviourCharacteristic owl:disjointWith ffonto:FireIntensityCharacteristic .

ffonto:FireEmissionCharacteristic owl:disjointWith ffonto:FireExtentCharacteristic .
ffonto:FireEmissionCharacteristic owl:disjointWith ffonto:FireIntensityCharacteristic .

ffonto:FireExtentCharacteristic owl:disjointWith ffonto:FireIntensityCharacteristic .

ffonto:HighIntensityFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "HighIntensityFire" ;
    rdfs:comment "Forest fires exhibiting high energetic intensity." .

ffonto:HighIntensityFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCharacteristic ;
          owl:someValuesFrom ffonto:FireIntensityCharacteristic
        ]
    )
] .

ffonto:RapidlySpreadingFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "RapidlySpreadingFire" ;
    rdfs:comment "Forest fires with high spread rate or growth dynamics." .

ffonto:RapidlySpreadingFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCharacteristic ;
          owl:someValuesFrom ffonto:FireBehaviourCharacteristic
        ]
    )
] .

ffonto:LargeExtentFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "LargeExtentFire" ;
    rdfs:comment "Forest fires affecting a large spatial area or perimeter." .

ffonto:LargeExtentFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasCharacteristic ;
          owl:someValuesFrom ffonto:FireExtentCharacteristic
        ]
    )
] .

ffonto:FireFuelCharacteristic a owl:Class ;
    rdfs:subClassOf ffonto:FireCharacteristic ;
    rdfs:label "FireFuelCharacteristic" ;
    rdfs:comment "Describes fuel properties influencing fire behaviour and intensity." .

ffonto:fuelLoad a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireFuelCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "fuelLoad" ;
    rdfs:comment "Available fuel mass per unit area." .

ffonto:fuelMoistureContent a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireFuelCharacteristic ;
    rdfs:range xsd:double ;
    rdfs:label "fuelMoistureContent" ;
    rdfs:comment "Moisture content of fuels (%)." .

ffonto:FireSeverityCharacteristic a owl:Class ;
    rdfs:subClassOf ffonto:FireCharacteristic ;
    rdfs:label "FireSeverityCharacteristic" ;
    rdfs:comment "Describes ecological damage and post-fire impact severity." .

ffonto:severityIndex a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireSeverityCharacteristic ;
    rdfs:range xsd:string ;
    rdfs:label "severityIndex" ;
    rdfs:comment "Severity classification (low, moderate, high, extreme)." .

#################################################################
# Fire management
#################################################################

ffonto:FireManagement a owl:Class ;
    rdfs:label "FireManagement" ;
    rdfs:comment "Abstract container for fire management, response, and coordination processes." .

ffonto:isManagedBy a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FireManagement ;
    rdfs:label "isManagedBy" ;
    rdfs:comment "Links a forest fire to its management and response context." .

ffonto:ManagementAction a owl:Class ;
    rdfs:label "ManagementAction" ;
    rdfs:comment "Abstract superclass for actions taken to manage, suppress, contain, or monitor a forest fire." .

ffonto:ContainmentAction a owl:Class ;
    rdfs:subClassOf ffonto:ManagementAction ;
    rdfs:label "ContainmentAction" ;
    rdfs:comment "Management actions undertaken to control, slow, or stop the spread of an active fire." .

ffonto:ControlledBurn a owl:Class ;
    rdfs:subClassOf ffonto:ContainmentAction ;
    rdfs:label "ControlledBurn" ;
    rdfs:comment "Containment action involving the deliberate ignition of vegetation under controlled conditions to reduce fuel and limit fire spread." .

ffonto:FireLineCreation a owl:Class ;
    rdfs:subClassOf ffonto:ContainmentAction ;
    rdfs:label "FireLineCreation" ;
    rdfs:comment "Containment action involving the construction of fire lines or breaks to remove vegetation and create barriers to fire spread." .

ffonto:FireRetardantDrop a owl:Class ;
    rdfs:subClassOf ffonto:ContainmentAction ;
    rdfs:label "FireRetardantDrop" ;
    rdfs:comment "Containment action involving the aerial or ground-based application of fire retardant chemicals to slow or inhibit fire spread." .

ffonto:WaterDrop a owl:Class ;
    rdfs:subClassOf ffonto:ContainmentAction ;
    rdfs:label "WaterDrop" ;
    rdfs:comment "Containment action involving the aerial or ground-based dropping of water to cool burning areas and suppress flames." .

ffonto:EvacuationAction a owl:Class ;
    rdfs:subClassOf ffonto:ManagementAction ;
    rdfs:label "EvacuationAction" ;
    rdfs:comment "Management actions undertaken to protect people by relocating or warning populations threatened by fire." .

ffonto:EvacuationOrder a owl:Class ;
    rdfs:subClassOf ffonto:EvacuationAction ;
    rdfs:label "EvacuationOrder" ;
    rdfs:comment "Evacuation action representing a mandatory directive requiring people to leave an area due to imminent fire danger." .

ffonto:EvacuationWarning a owl:Class ;
    rdfs:subClassOf ffonto:EvacuationAction ;
    rdfs:label "EvacuationWarning" ;
    rdfs:comment "Evacuation action representing an advisory notice informing people of potential fire danger and the need to prepare for possible evacuation." .

ffonto:SuppressionAction a owl:Class ;
    rdfs:subClassOf ffonto:ManagementAction ;
    rdfs:label "SuppressionAction" ;
    rdfs:comment "Management actions undertaken to actively extinguish or reduce the intensity of an ongoing fire." .

ffonto:DirectAttack a owl:Class ;
    rdfs:subClassOf ffonto:SuppressionAction ;
    rdfs:label "DirectAttack" ;
    rdfs:comment "Suppression action involving direct engagement with the fire edge using water, tools, or retardant to extinguish flames." .

ffonto:IndirectAttack a owl:Class ;
    rdfs:subClassOf ffonto:SuppressionAction ;
    rdfs:label "IndirectAttack" ;
    rdfs:comment "Suppression action involving operations conducted at a distance from the fire front, such as constructing control lines or using backburns to contain the fire." .

ffonto:AerialSuppression a owl:Class ;
    rdfs:subClassOf ffonto:SuppressionAction ;
    rdfs:label "AerialSuppression" ;
    rdfs:comment "Suppression action involving the use of aircraft to apply water, foam, or retardant to active fire areas." .

ffonto:MaintainingAction a owl:Class ;
    rdfs:subClassOf ffonto:ManagementAction ;
    rdfs:label "MaintainingAction" ;
    rdfs:comment "Management actions undertaken after initial control to monitor fire behavior and prevent renewed spread." .

ffonto:Monitoring a owl:Class ;
    rdfs:subClassOf ffonto:MaintainingAction ;
    rdfs:label "Monitoring" ;
    rdfs:comment "Maintaining action involving continuous observation of fire conditions, weather, and containment lines to detect changes or flare-ups." .

ffonto:Patrolling a owl:Class ;
    rdfs:subClassOf ffonto:MaintainingAction ;
    rdfs:label "Patrolling" ;
    rdfs:comment "Maintaining action involving systematic inspection of fire perimeters and controlled areas to identify hotspots or breaches." .

ffonto:ReIgnitionPrevention a owl:Class ;
    rdfs:subClassOf ffonto:MaintainingAction ;
    rdfs:label "ReIgnitionPrevention" ;
    rdfs:comment "Maintaining action involving measures taken to eliminate residual heat, embers, or fuel sources to prevent fire re-ignition." .

ffonto:performedBy a owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:comment "Relates an action or process to the agent or organization that performs it."@en ;
    rdfs:label "performedBy" .

ffonto:usesResource a owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:range ffonto:ResponseResource ;
    rdfs:comment "Relates an activity or agent to the resource that it uses."@en ;
    rdfs:label "usesResource" .

ffonto:ForestFire rdfs:subClassOf
  [ a owl:Restriction ;
    owl:onProperty ffonto:usesResource ;
    owl:someValuesFrom ffonto:ResponseResource
  ] .

ffonto:ManagementAction rdfs:subClassOf
  [ a owl:Restriction ;
    owl:onProperty ffonto:usesResource ;
    owl:someValuesFrom ffonto:ResponseResource
  ] .


#################################################################
# Response organizations
#################################################################

ffonto:ResponseOrganization a owl:Class ;
    rdfs:label "ResponseOrganization" ;
    rdfs:comment "Abstract superclass for organizations involved in wildfire management and response." .

ffonto:EmergencyResponseOrganization a owl:Class ;
    rdfs:subClassOf ffonto:ResponseOrganization ;
    rdfs:label "EmergencyResponseOrganization" ;
    rdfs:comment "Response organizations responsible for providing immediate emergency services and coordinating actions during fire incidents and other emergencies." .

ffonto:CivilEnforcement a owl:Class ;
    rdfs:subClassOf ffonto:EmergencyResponseOrganization ;
    rdfs:label "CivilEnforcement" ;
    rdfs:comment "Emergency response organization responsible for law enforcement, public order, area control, and support of evacuation and safety operations during fire incidents." .

ffonto:EmergencyService a owl:Class ;
    rdfs:subClassOf ffonto:EmergencyResponseOrganization ;
    rdfs:label "EmergencyService" ;
    rdfs:comment "Emergency response organization providing general emergency services such as rescue, coordination, and immediate assistance during fire and disaster incidents." .

ffonto:FireDepartment a owl:Class ;
    rdfs:subClassOf ffonto:EmergencyResponseOrganization ;
    rdfs:label "FireDepartment" ;
    rdfs:comment "Emergency response organization responsible for firefighting operations, fire suppression, rescue, and fire prevention activities." .

ffonto:LawEnforcement a owl:Class ;
    rdfs:subClassOf ffonto:ResponseOrganization ;
    rdfs:label "LawEnforcement" ;
    rdfs:comment "Response organizations responsible for enforcing laws, maintaining public order, securing affected areas, and supporting emergency operations during fire incidents." .

ffonto:FireInvestigationUnit a owl:Class ;
    rdfs:subClassOf ffonto:LawEnforcement ;
    rdfs:label "FireInvestigationUnit" ;
    rdfs:comment "Law enforcement unit specialized in investigating the origin, cause, and circumstances of fires for legal and safety purposes." .

ffonto:PoliceDepartment a owl:Class ;
    rdfs:subClassOf ffonto:LawEnforcement ;
    rdfs:label "PoliceDepartment" ;
    rdfs:comment "Law enforcement organization responsible for public safety, traffic control, evacuation enforcement, and security during fire incidents." .

ffonto:MedicalResponse a owl:Class ;
    rdfs:subClassOf ffonto:ResponseOrganization ;
    rdfs:label "MedicalResponse" ;
    rdfs:comment "Response organizations responsible for providing medical care, emergency treatment, and health services during and after fire incidents." .

ffonto:Hospital a owl:Class ;
    rdfs:subClassOf ffonto:MedicalResponse ;
    rdfs:label "Hospital" ;
    rdfs:comment "Medical response organization providing inpatient and emergency medical treatment to individuals injured or affected by fire incidents." .

ffonto:MedicalService a owl:Class ;
    rdfs:subClassOf ffonto:MedicalResponse ;
    rdfs:label "MedicalService" ;
    rdfs:comment "Medical response organization providing emergency medical services, ambulance transport, and on-scene medical care during fire incidents." .

ffonto:FireAgency a owl:Class ;
    rdfs:subClassOf ffonto:ResponseOrganization ;
    rdfs:label "FireAgency" ;
    rdfs:comment "Response organizations specifically responsible for wildfire management, fire suppression, prevention, and coordination at various administrative levels." .

ffonto:FederalAgency a owl:Class ;
    rdfs:subClassOf ffonto:FireAgency ;
    rdfs:label "FederalAgency" ;
    rdfs:comment "Fire agency operating at the national or federal level, responsible for large-scale fire management, policy implementation, and inter-state coordination." .

ffonto:StateAgency a owl:Class ;
    rdfs:subClassOf ffonto:FireAgency ;
    rdfs:label "StateAgency" ;
    rdfs:comment "Fire agency operating at the state or regional level, responsible for wildfire suppression, prevention, and coordination within its jurisdiction." .

ffonto:LocalDepartment a owl:Class ;
    rdfs:subClassOf ffonto:FireAgency ;
    rdfs:label "LocalDepartment" ;
    rdfs:comment "Fire agency operating at the local or municipal level, responsible for frontline firefighting, emergency response, and community fire protection." .

ffonto:VolunteerDepartment a owl:Class ;
    rdfs:subClassOf ffonto:FireAgency ;
    rdfs:label "VolunteerDepartment" ;
    rdfs:comment "Fire agency composed primarily of volunteer personnel providing firefighting and emergency services, often in rural or underserved areas." .

ffonto:MediaOrganization a owl:Class ;
    rdfs:subClassOf ffonto:ResponseOrganization ;
    rdfs:label "MediaOrganization" ;
    rdfs:comment "Response organizations responsible for disseminating information, public warnings, news coverage, and situational updates during fire incidents." .

ffonto:NGO a owl:Class ;
    rdfs:subClassOf ffonto:ResponseOrganization ;
    rdfs:label "NGO" ;
    rdfs:comment "Non-governmental organizations providing humanitarian assistance, logistical support, community aid, or recovery services during and after fire incidents." .

ffonto:organizationName a owl:DatatypeProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:label "organizationName" ;
    rdfs:comment "Represents the name of an organization."@en ;
    rdfs:range xsd:string .

ffonto:address a owl:DatatypeProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:label "address" ;
    rdfs:comment "Represents a postal or physical address."@en ;
    rdfs:range xsd:string .

ffonto:postcode a owl:DatatypeProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:label "postcode" ;
    rdfs:comment "Represents a postal code associated with an address."@en ;
    rdfs:range xsd:string .

ffonto:email a owl:DatatypeProperty ;
    rdfs:label "email" ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:comment "Represents an electronic mail address used for contact."@en ;
    rdfs:range xsd:string .

ffonto:mobile a owl:DatatypeProperty ;
    rdfs:label "mobile" ;
    rdfs:comment "Represents a mobile telephone number used for contact."@en ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:range xsd:string .

ffonto:contactPerson a owl:DatatypeProperty ;
    rdfs:label "contactPerson" ;
    rdfs:comment "Relates an organization or entity to a designated contact person."@en ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:range xsd:string .

ffonto:deploys a owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:range ffonto:ResponseResource ;
    rdfs:comment "Relates an organization or agent to the resource, unit, or equipment that it deploys."@en ;
    rdfs:label "deploys" .

ffonto:hasResource a owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:range ffonto:ResponseResource ;
    rdfs:comment "Relates an activity, organization, or fire to a resource that it possesses or uses."@en ;
    rdfs:label "hasResource" .

#################################################################
# Response resources
#################################################################

ffonto:ResponseResource a owl:Class ;
    rdfs:label "ResponseResource" ;
    rdfs:comment "Abstract superclass for personnel, equipment, vehicles, and animals used in fire response." .

ffonto:Equipment a owl:Class ;
    rdfs:subClassOf ffonto:ResponseResource ;
    rdfs:label "Equipment" ;
    rdfs:comment "Response resources consisting of physical tools, devices, vehicles, or animals used to support firefighting, suppression, and emergency operations." .

ffonto:Horse a owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Horse" ;
    rdfs:comment "Equipment resource referring to horses used for transport, patrol, or supply delivery in terrain inaccessible to vehicles during fire operations." .

ffonto:Pump a owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Pump" ;
    rdfs:comment "Equipment resource representing portable or fixed pumps used to move water or fire suppressant to support firefighting and suppression activities." .

ffonto:ThermalCamera a owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "ThermalCamera" ;
    rdfs:comment "Equipment resource referring to thermal imaging devices used to detect hotspots, hidden fires, or residual heat during firefighting and monitoring operations." .

ffonto:AerialEquipment a owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "AerialEquipment" ;
    rdfs:comment "Equipment resources designed for use with aircraft to support aerial firefighting, suppression, or reconnaissance operations." .

ffonto:BambiBucket a owl:Class ;
    rdfs:subClassOf ffonto:AerialEquipment ;
    rdfs:label "BambiBucket" ;
    rdfs:comment "Aerial equipment consisting of an external bucket suspended beneath a helicopter for collecting and dropping water on active fires." .

ffonto:Snorkel a owl:Class ;
    rdfs:subClassOf ffonto:AerialEquipment ;
    rdfs:label "Snorkel" ;
    rdfs:comment "Aerial equipment referring to a retractable hose system used by helicopters to rapidly fill water tanks from lakes, rivers, or reservoirs during firefighting operations." .

ffonto:Personnel a owl:Class ;
    rdfs:label "Personnel" ;
    rdfs:comment "Human resources engaged in wildfire response." .

ffonto:Firefighter a owl:Class ;
    rdfs:subClassOf ffonto:Personnel ;
    rdfs:label "Firefighter" ;
    rdfs:comment "Personnel trained and assigned to suppress fires, perform rescue operations, and protect lives, property, and the environment during fire incidents." .

ffonto:Vehicle a owl:Class ;
    rdfs:subClassOf ffonto:ResponseResource ;
    rdfs:label "Vehicle" ;
    rdfs:comment "Response resources consisting of ground or aerial vehicles used to transport personnel, equipment, and suppressants during firefighting and emergency operations." .

ffonto:FireEngine a owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "FireEngine" ;
    rdfs:comment "Vehicle designed for firefighting operations, equipped with pumps, hoses, water tanks, and tools for fire suppression and rescue." .

ffonto:Helicopter a owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "Helicopter" ;
    rdfs:comment "Aerial vehicle used for firefighting, transport, reconnaissance, and delivery of water, retardant, or personnel to fire locations." .

ffonto:WaterTanker a owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "WaterTanker" ;
    rdfs:comment "Vehicle equipped with a large water tank used to transport and deliver water to support firefighting and suppression activities." .

#################################################################
# Operational units
#################################################################

ffonto:OperationalUnit a owl:Class ;
    rdfs:label "OperationalUnit" ;
    rdfs:comment "Team or unit operating under a response organization." .

ffonto:EngineCompany a owl:Class ;
    rdfs:subClassOf ffonto:OperationalUnit ;
    rdfs:label "EngineCompany" ;
    rdfs:comment "Operational unit consisting of a fire engine and its assigned crew, responsible for fire suppression, water delivery, and initial attack operations." .

ffonto:HandCrew a owl:Class ;
    rdfs:subClassOf ffonto:OperationalUnit ;
    rdfs:label "HandCrew" ;
    rdfs:comment "Operational unit composed of firefighters equipped with hand tools, responsible for constructing fire lines, clearing vegetation, and performing ground-based suppression tasks." .

ffonto:StrikeTeam a owl:Class ;
    rdfs:subClassOf ffonto:OperationalUnit ;
    rdfs:label "StrikeTeam" ;
    rdfs:comment "Operational unit consisting of multiple similar resources organized under a single leader to carry out coordinated firefighting or suppression operations." .

ffonto:memberOf a owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:OperationalUnit ;
    rdfs:comment "Relates a person or agent to the organization or group of which it is a member."@en ;
    rdfs:label "memberOf" .

ffonto:assignedTo a owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:OperationalUnit ;
    rdfs:comment "Relates a resource, person, or unit to the task, operation, or fire to which it is assigned."@en ;
    rdfs:label "assignedTo" .

#################################################################
# Personal Protective Equipment
#################################################################

ffonto:PersonalProtectiveEquipment a owl:Class ;
    rdfs:label "PersonalProtectiveEquipment" ;
    rdfs:comment "Protective clothing and equipment worn by personnel to reduce exposure to hazards and prevent injury during firefighting and emergency operations." .

ffonto:FireShelter a owl:Class ;
    rdfs:subClassOf ffonto:PersonalProtectiveEquipment ;
    rdfs:label "FireShelter" ;
    rdfs:comment "Personal protective equipment consisting of a heat-resistant emergency shelter used by firefighters as a last resort to protect against radiant heat and flames." .

ffonto:HeatLamp a owl:Class ;
    rdfs:subClassOf ffonto:PersonalProtectiveEquipment ;
    rdfs:label "HeatLamp" ;
    rdfs:comment "Personal protective equipment providing localized heat for warming personnel or preventing hypothermia during cold or wet firefighting conditions." .

ffonto:NomexSuit a owl:Class ;
    rdfs:subClassOf ffonto:PersonalProtectiveEquipment ;
    rdfs:label "NomexSuit" ;
    rdfs:comment "Personal protective equipment consisting of flame-resistant clothing made from Nomex fabric to protect firefighters from heat, sparks, and brief flame exposure." .

ffonto:RadioHarness a owl:Class ;
    rdfs:subClassOf ffonto:PersonalProtectiveEquipment ;
    rdfs:label "RadioHarness" ;
    rdfs:comment "Personal protective equipment used to securely carry and protect portable radios, ensuring reliable communication during firefighting operations." .

ffonto:MaskN95 a owl:Class ;
    rdfs:subClassOf ffonto:PersonalProtectiveEquipment ;
    rdfs:label "MaskN95" ;
    rdfs:comment "Personal protective equipment consisting of a particulate-filtering mask designed to reduce inhalation of smoke, ash, and fine airborne particles." .

ffonto:Respirator a owl:Class ;
    rdfs:subClassOf ffonto:PersonalProtectiveEquipment ;
    rdfs:label "Respirator" ;
    rdfs:comment "Personal protective equipment providing respiratory protection by filtering or supplying clean air to reduce exposure to smoke, toxic gases, and hazardous particles." .

ffonto:wears a owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:PersonalProtectiveEquipment ;
    rdfs:comment "Relates a person or agent to an item of equipment or clothing that they wear."@en ;
    rdfs:label "wears" .

#################################################################
# Command structure and roles
#################################################################

ffonto:CommandRole a owl:Class ;
    rdfs:label "CommandRole" ;
    rdfs:comment "Abstract superclass for Incident Command System roles." .

ffonto:CommandStaff a owl:Class ;
    rdfs:subClassOf ffonto:Personnel ;
    rdfs:label "CommandStaff" ;
    rdfs:comment "Personnel assigned to leadership and advisory roles responsible for directing, coordinating, and overseeing fire incident operations under the incident command system." .

ffonto:IncidentCommander a owl:Class ;
    rdfs:subClassOf ffonto:CommandStaff ;
    rdfs:label "IncidentCommander" ;
    rdfs:comment "Command staff role responsible for overall management, strategic decision-making, and coordination of all activities during a fire incident." .

ffonto:PublicInformationOfficer a owl:Class ;
    rdfs:subClassOf ffonto:CommandStaff ;
    rdfs:label "PublicInformationOfficer" ;
    rdfs:comment "Command staff role responsible for disseminating accurate information to the public, media, and stakeholders regarding fire incidents and response activities." .

ffonto:SafetyOfficer a owl:Class ;
    rdfs:subClassOf ffonto:CommandStaff ;
    rdfs:label "SafetyOfficer" ;
    rdfs:comment "Command staff role responsible for monitoring operational safety conditions and developing measures to ensure the health and safety of personnel during fire operations." .

ffonto:FinanceSection a owl:Class ;
    rdfs:subClassOf ffonto:CommandRole ;
    rdfs:label "FinanceSection" ;
    rdfs:comment "Command role responsible for tracking costs, managing contracts, handling compensation, and overseeing financial aspects of fire incident operations." .

ffonto:LogisticsSection a owl:Class ;
    rdfs:subClassOf ffonto:CommandRole ;
    rdfs:label "LogisticsSection" ;
    rdfs:comment "Command role responsible for providing facilities, services, personnel support, equipment, and supplies necessary to sustain fire incident operations." .

ffonto:PlanningSection a owl:Class ;
    rdfs:subClassOf ffonto:CommandRole ;
    rdfs:label "PlanningSection" ;
    rdfs:comment "Command role responsible for collecting and analyzing incident information, developing action plans, and maintaining situational awareness during fire incidents." .

ffonto:OperationsSection a owl:Class ;
    rdfs:subClassOf ffonto:CommandRole ;
    rdfs:label "OperationsSection" ;
    rdfs:comment "Command role responsible for directing and executing all tactical operations to achieve incident objectives, including fire suppression, containment, and field coordination." .

ffonto:divisionSupervisor a owl:Class ;
    rdfs:subClassOf ffonto:CommandRole ;
    rdfs:label "divisionSupervisor" ;
    rdfs:comment "Command role responsible for supervising firefighting operations within a defined geographic division or functional area and coordinating assigned operational units." .

ffonto:hasRole a owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:CommandRole ;
    rdfs:comment "Relates an agent or entity to the role that it plays."@en ;
    rdfs:label "hasRole" .

ffonto:responsibleFor a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:comment "Relates an agent or organization to the activity, resource, or outcome for which it is responsible."@en ;
    rdfs:range ffonto:ManagementAction ;
    rdfs:label "responsibleFor" .

#################################################################
# Firefighting tactics and tools
#################################################################

ffonto:FireFightingTactic a owl:Class ;
    rdfs:label "FireFightingTactic" ;
    rdfs:comment "Strategic or tactical methods applied by firefighting personnel to control, suppress, or mitigate the effects of fires." .

ffonto:Backburn a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTactic ;
    rdfs:label "Backburn" ;
    rdfs:comment "Firefighting tactic involving the intentional ignition of vegetation ahead of an advancing fire to remove fuel and halt or slow fire spread." .

ffonto:DefensibleSpaceManagement a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTactic ;
    rdfs:label "DefensibleSpaceManagement" ;
    rdfs:comment "Firefighting tactic involving the modification or removal of vegetation and combustible materials around structures to reduce fire intensity and improve protection." .

ffonto:MopUp a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTactic ;
    rdfs:label "MopUp" ;
    rdfs:comment "Firefighting tactic involving the extinguishment of remaining embers, hotspots, and smoldering materials after active fire suppression to prevent re-ignition." .

ffonto:FireFightingTool a owl:Class ;
    rdfs:label "FireFightingTool" ;
    rdfs:comment "Hand tools and devices used by firefighting personnel to construct fire lines, remove fuel, ignite control burns, and suppress fires." .

ffonto:Chainsaw a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTool ;
    rdfs:label "Chainsaw" ;
    rdfs:comment "Firefighting tool consisting of a motorized cutting device used to fell trees, cut brush, and remove fuel during fire line construction and suppression." .

ffonto:DripTorch a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTool ;
    rdfs:label "DripTorch" ;
    rdfs:comment "Firefighting tool used to ignite controlled burns or backburns by dripping a flammable fuel mixture to create ignition lines." .

ffonto:Mcleod a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTool ;
    rdfs:label "Mcleod" ;
    rdfs:comment "Firefighting tool combining a rake and hoe used to scrape vegetation, clear fire lines, and remove combustible material from the ground." .

ffonto:Pulaski a owl:Class ;
    rdfs:subClassOf ffonto:FireFightingTool ;
    rdfs:label "Pulaski" ;
    rdfs:comment "Firefighting tool combining an axe and adze used to chop roots, dig trenches, and construct fire lines in wildland firefighting." .

ffonto:usesTactic a owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:comment "Relates an activity, agent, or operation to the tactic that it uses."@en ;
    rdfs:range ffonto:FireFightingTactic ;
    rdfs:label "usesTactic" .

#################################################################
# Fuel and fire triangle
#################################################################

ffonto:FireTriangleComponent a owl:Class ;
    rdfs:label "FireTriangleComponent" ;
    rdfs:comment "Fundamental component of the fire triangle representing one of the essential elements required for combustion: fuel, heat, or oxygen." .

ffonto:Fuel a owl:Class ;
    rdfs:subClassOf ffonto:FireTriangleComponent ;
    rdfs:label "Fuel" ;
    rdfs:comment "Fire triangle component representing combustible material that provides energy to sustain a fire." .

ffonto:FineFuel a owl:Class ;
    rdfs:subClassOf ffonto:Fuel ;
    rdfs:label "FineFuel" ;
    rdfs:comment "Fuel category consisting of small, lightweight, and quickly ignitable materials such as grass, leaves, needles, and small twigs that promote rapid fire spread." .

ffonto:HeavyFuel a owl:Class ;
    rdfs:subClassOf ffonto:Fuel ;
    rdfs:label "HeavyFuel" ;
    rdfs:comment "Fuel category consisting of large, dense, or woody materials such as logs, branches, and thick vegetation that burn more slowly but produce high heat and long-duration fires." .

ffonto:consumesFuel a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:comment "Relates a fire or process to the fuel that it consumes."@en ;
    rdfs:range ffonto:Fuel ;
    rdfs:label "consumesFuel" .

#################################################################
# Hose and equipment components
#################################################################

ffonto:HoseComponent a owl:Class ;
    rdfs:label "HoseComponent" ;
    rdfs:comment "Components of a firefighting hose system used to transport, control, and distribute water or fire suppressants during suppression operations." .

ffonto:FireHose a owl:Class ;
    rdfs:subClassOf ffonto:HoseComponent ;
    rdfs:label "FireHose" ;
    rdfs:comment "Hose component consisting of a flexible tube used to convey water or fire suppressant from a pump or hydrant to the fire scene." .

ffonto:Nozzle a owl:Class ;
    rdfs:subClassOf ffonto:HoseComponent ;
    rdfs:label "Nozzle" ;
    rdfs:comment "Hose component attached to the end of a fire hose used to control the flow rate, pressure, and spray pattern of water or suppressant." .

ffonto:PortableTank a owl:Class ;
    rdfs:subClassOf ffonto:HoseComponent ;
    rdfs:label "PortableTank" ;
    rdfs:comment "Hose component consisting of a collapsible or portable reservoir used to temporarily store water for firefighting operations in areas without fixed water supply." .

ffonto:WyeValve a owl:Class ;
    rdfs:subClassOf ffonto:HoseComponent ;
    rdfs:label "WyeValve" ;
    rdfs:comment "Hose component used to split a single hose line into two or more lines, allowing multiple streams to be supplied from one water source." .

#################################################################
# Firefighter posture
#################################################################

ffonto:FirefighterPosture a owl:Class ;
    rdfs:label "FirefighterPosture" ;
    rdfs:comment "Physical body positions adopted by firefighters during operations that influence mobility, visibility, stability, and exposure to heat and smoke." .

ffonto:Kneeling a owl:Class ;
    rdfs:subClassOf ffonto:FirefighterPosture ;
    rdfs:label "Kneeling" ;
    rdfs:comment "Firefighter posture in which the firefighter is positioned on one or both knees to improve stability, lower profile, or control hose and tools during operations." .

ffonto:Standing a owl:Class ;
    rdfs:subClassOf ffonto:FirefighterPosture ;
    rdfs:label "Standing" ;
    rdfs:comment "Firefighter posture in which the firefighter is upright to maximize mobility, visibility, and reach during firefighting and rescue activities." .

ffonto:Crawling a owl:Class ;
    rdfs:subClassOf ffonto:FirefighterPosture ;
    rdfs:label "Crawling" ;
    rdfs:comment "Firefighter posture involving movement close to the ground to reduce exposure to heat and smoke, improve visibility, and navigate confined or hazardous environments." .

#################################################################
# Weather interaction with operations
#################################################################

ffonto:WeatherInteraction a owl:Class ;
    rdfs:label "WeatherInteraction" ;
    rdfs:comment "Weather phenomena influencing fire behaviour and firefighting operations." .

ffonto:DownslopeWind a owl:Class ;
    rdfs:subClassOf ffonto:WeatherInteraction ;
    rdfs:label "DownslopeWind" ;
    rdfs:comment "Weather interaction referring to wind flowing downhill along terrain slopes, often warming and drying air and accelerating fire spread downslope or into valleys." .

ffonto:Updraft a owl:Class ;
    rdfs:subClassOf ffonto:WeatherInteraction ;
    rdfs:label "Updraft" ;
    rdfs:comment "Weather interaction representing rising columns of hot air generated by a fire that influence flame height, ember transport, plume development, and fire intensity." .

ffonto:affectedBy a owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:range ffonto:WeatherInteraction ;
    rdfs:comment "Relates an entity or process to the factor or event that affects it."@en ;
    rdfs:label "affectedBy" .

ffonto:ResponseOrganization owl:disjointWith ffonto:ResponseResource .
ffonto:Equipment owl:disjointWith ffonto:Personnel .
ffonto:Equipment owl:disjointWith ffonto:Vehicle .
ffonto:Vehicle owl:disjointWith ffonto:Personnel .

ffonto:FireFightingTool owl:disjointWith ffonto:Equipment .
ffonto:FireFightingTactic owl:disjointWith ffonto:ManagementAction .

ffonto:CommandRole owl:disjointWith ffonto:OperationalUnit .
ffonto:CommandRole owl:disjointWith ffonto:Personnel .

ffonto:isActionOfFire a owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates an action or process to the fire of which it is a part."@en ;
    rdfs:label "isActionOfFire" .

ffonto:ManagementAction rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isActionOfFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:ResponseOrganization rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isCoordinatorOf ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:resourceUsedInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseResource ;
    rdfs:comment "Relates a resource to the fire in which it is used."@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "resourceUsedInFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:resourceUsedInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:usesResource
      ffonto:isActionOfFire
  )
] .

ffonto:MultiAgencyFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "MultiAgencyFire" ;
    rdfs:comment "Forest fires coordinated by multiple response organizations." .

ffonto:MultiAgencyFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:coordinatedBy ;
          owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
          owl:onClass ffonto:ResponseOrganization
        ]
    )
] .

ffonto:HighRiskOperationFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "HighRiskOperationFire" ;
    rdfs:comment "Fires involving risky tactics under adverse weather conditions." .

ffonto:HighRiskOperationFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasManagementAction ;
          owl:someValuesFrom ffonto:SuppressionAction
        ]
    )
] .

#################################################################
# FireManagement chaining
#################################################################

ffonto:hasFireManagement a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FireManagement ;
    rdfs:comment "Relates a fire or event to its associated fire management activity or strategy."@en ;
    rdfs:label "hasFireManagement" .

ffonto:hasManagementAction a owl:ObjectProperty ;
    rdfs:domain ffonto:FireManagement ;
    rdfs:range ffonto:ManagementAction ;
    rdfs:label "hasManagementAction" ;
    rdfs:comment "Associates fire management with its management actions." .

ffonto:isManagementOf a owl:ObjectProperty ;
    rdfs:domain ffonto:FireManagement ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isManagementOf" ;
    rdfs:comment "Relates a management activity or strategy to the fire, asset, or process that it manages."@en ;
    owl:inverseOf ffonto:hasFireManagement .

ffonto:isActionOfManagement a owl:ObjectProperty ;
    rdfs:label "isActionOfManagement" ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:range ffonto:FireManagement ;
    rdfs:comment "Associates a management action with the management process it belongs to." .

ffonto:FireManagement rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isManagementOf ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:ManagementAction rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isActionOfManagement ;
    owl:someValuesFrom ffonto:FireManagement
] .

ffonto:actionOfFire a owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates an action or process to the fire of which it is part."@en ;
    rdfs:label "actionOfFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:actionOfFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:isActionOfManagement
      ffonto:isManagementOf
  )
] .

ffonto:hasPosture a owl:ObjectProperty ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:comment "Relates an agent, organization, or operation to its operational or strategic posture."@en ;
    rdfs:range ffonto:FirefighterPosture ;
    rdfs:label "hasPosture" .

ffonto:FirefighterPosture rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:hasPosture ] ;
    owl:someValuesFrom ffonto:Firefighter
] .

ffonto:appliesTactic a owl:ObjectProperty ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:comment "Relates an agent or operation to the tactic that it applies."@en ;
    rdfs:range ffonto:FireFightingTactic ;
    rdfs:label "appliesTactic" .

ffonto:FireFightingTactic rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:appliesTactic ] ;
    owl:someValuesFrom ffonto:Firefighter
] .

ffonto:FireFightingTool rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:usesTool ] ;
    owl:someValuesFrom ffonto:Firefighter
] .

ffonto:firefighterOfFire a owl:ObjectProperty ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates a firefighter to the fire in which they are involved."@en ;
    rdfs:label "firefighterOfFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:firefighterOfFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:memberOf
      ffonto:partOf
      ffonto:isCoordinatorOf
  )
] .

ffonto:FireHose a owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "FireHose" ;
    rdfs:comment "Flexible hose used to convey water or retardant during firefighting." .

ffonto:hasComponent a owl:ObjectProperty ;
    rdfs:domain ffonto:FireHose ;
    rdfs:range ffonto:HoseComponent ;
    rdfs:comment "Relates an entity to one of its constituent components."@en ;
    rdfs:label "hasComponent" .

ffonto:HoseComponent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:hasComponent ] ;
    owl:someValuesFrom ffonto:FireHose
] .

ffonto:PersonalProtectiveEquipment rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:wears ] ;
    owl:someValuesFrom ffonto:Personnel
] .

ffonto:ppeUsedInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:PersonalProtectiveEquipment ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates personal protective equipment to the fire in which it is used."@en ;
    rdfs:label "ppeUsedInFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:ppeUsedInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:wears ]
      ffonto:firefighterOfFire
  )
] .

ffonto:ResponseResource rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:hasResource ] ;
    owl:someValuesFrom ffonto:ResponseOrganization
] .

ffonto:resourceUsedInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseResource ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "resourceUsedInFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:resourceUsedInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:usesResource ]
      ffonto:actionOfFire
  )
] .

ffonto:observedWeatherInteraction a owl:ObjectProperty ;
    rdfs:domain ffonto:FireManagement ;
    rdfs:range ffonto:WeatherInteraction ;
    rdfs:label "observedWeatherInteraction" ;
    rdfs:comment "Weather interactions observed or considered during fire management." .

ffonto:WeatherInteraction rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:observedWeatherInteraction ] ;
    owl:someValuesFrom ffonto:FireManagement
] .

ffonto:weatherAffectingFire a owl:ObjectProperty ;
    rdfs:domain ffonto:WeatherInteraction ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates a weather condition or phenomenon to the fire that it influences."@en ;
    rdfs:label "weatherAffectingFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:weatherAffectingFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:observedWeatherInteraction ]
      ffonto:isManagementOf
  )
] .

ffonto:toolUsedInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:FireFightingTool ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates a tool or equipment item to the fire in which it is used."@en ;
    rdfs:label "toolUsedInFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:toolUsedInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:usesTool ]
      ffonto:firefighterOfFire
  )
] .

ffonto:tacticAppliedInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:FireFightingTactic ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Relates a tactical action or strategy to the fire in which it is applied."@en ;
    rdfs:label "tacticAppliedInFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:tacticAppliedInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:appliesTactic ]
      ffonto:firefighterOfFire
  )
] .

ffonto:FirefighterPosture owl:disjointWith ffonto:FireFightingTactic .
ffonto:FirefighterPosture owl:disjointWith ffonto:FireFightingTool .
ffonto:FireFightingTool owl:disjointWith ffonto:FireFightingTactic .

ffonto:PersonalProtectiveEquipment owl:disjointWith ffonto:FireFightingTool .
ffonto:PersonalProtectiveEquipment owl:disjointWith ffonto:Equipment .

#################################################################
# Human resources 
#################################################################

ffonto:HumanResource a owl:Class ;
    rdfs:subClassOf ffonto:ResponseResource ;
    rdfs:label "HumanResource" ;
    rdfs:comment "Abstract superclass for human-based response resources, including individuals and operational units." .

ffonto:Personnel rdfs:subClassOf ffonto:HumanResource .

ffonto:OperationalUnit rdfs:subClassOf ffonto:HumanResource .

#################################################################
# Personnel – OperationalUnit composition
#################################################################

ffonto:memberOf a owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:OperationalUnit ;
    rdfs:label "memberOf" .

ffonto:hasMember a owl:ObjectProperty ;
    rdfs:domain ffonto:OperationalUnit ;
    rdfs:range ffonto:Personnel ;
    rdfs:comment "Relates an organization or group to one of its members."@en ;
    rdfs:label "hasMember" ;
    owl:inverseOf ffonto:memberOf .

ffonto:Personnel rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:memberOf ;
    owl:someValuesFrom ffonto:OperationalUnit
] .

ffonto:OperationalUnit rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasMember ;
    owl:someValuesFrom ffonto:Personnel
] .

ffonto:partOf a owl:ObjectProperty ;
    rdfs:domain ffonto:OperationalUnit ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:comment "Relates an entity to a larger entity of which it is a component or part."@en ;
    rdfs:label "partOf" .

ffonto:OperationalUnit rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:partOf ;
    owl:someValuesFrom ffonto:ResponseOrganization
] .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:firefighterOfFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:memberOf
      ffonto:partOf
      ffonto:isCoordinatorOf
  )
] .

ffonto:unitDeployedInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:OperationalUnit ;
    rdfs:comment "Relates an operational unit to the fire in which it is deployed."@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "unitDeployedInFire" .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:unitDeployedInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:partOf
      ffonto:isCoordinatorOf
  )
] .

ffonto:roleInFire a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "roleInFire" ;
    rdfs:comment "Inferred link: this command role is involved in managing a specific forest fire." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:roleInFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:responsibleFor
      ffonto:isActionOfManagement
      ffonto:isManagementOf
  )
] .

ffonto:personInCommandOfFire a owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "personInCommandOfFire" ;
    rdfs:comment "Inferred link: this person held a command role in a forest fire." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:personInCommandOfFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:hasRole
      ffonto:roleInFire
  )
] .

ffonto:CommandRole rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:responsibleFor ;
    owl:someValuesFrom ffonto:ManagementAction
] .

ffonto:roleInManagement a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:range ffonto:FireManagement ;
    rdfs:label "roleInManagement" ;
    rdfs:comment "Inferred link: this command role participates in a fire management context." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:roleInManagement ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:responsibleFor
      ffonto:isActionOfManagement
  )
] .

ffonto:roleOfOrganization a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:label "roleOfOrganization" ;
    rdfs:comment "Inferred link: this command role operates under a specific response organization." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:roleOfOrganization ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:hasRole ]
      ffonto:memberOf
      ffonto:partOf
  )
] .

ffonto:roleCommandsUnit a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:range ffonto:OperationalUnit ;
    rdfs:label "roleCommandsUnit" ;
    rdfs:comment "Inferred link: this command role commands or supervises an operational unit." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:roleCommandsUnit ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:hasRole ]
      ffonto:memberOf
  )
] .

ffonto:roleControlsResource a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:range ffonto:ResponseResource ;
    rdfs:label "roleControlsResource" ;
    rdfs:comment "Inferred link: this command role exercised authority over deployed resources." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:roleControlsResource ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:responsibleFor
      ffonto:usesResource
  )
] .

ffonto:roleExposedToWeatherRisk a owl:ObjectProperty ;
    rdfs:domain ffonto:CommandRole ;
    rdfs:range ffonto:WeatherInteraction ;
    rdfs:label "roleExposedToWeatherRisk" ;
    rdfs:comment "Inferred link: this command role operated under specific hazardous weather interactions." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:roleExposedToWeatherRisk ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      ffonto:responsibleFor
      ffonto:affectedBy
  )
] .

ffonto:HighRiskCommandRole a owl:Class ;
    rdfs:subClassOf ffonto:CommandRole ;
    rdfs:label "HighRiskCommandRole" ;
    rdfs:comment "Command roles operating under hazardous weather or high-risk suppression conditions." .

ffonto:HighRiskCommandRole owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:CommandRole
        [ a owl:Restriction ;
          owl:onProperty ffonto:responsibleFor ;
          owl:someValuesFrom ffonto:SuppressionAction
        ]
    )
] .

#################################################################
# Fire environmental and physical driving factors
#################################################################

ffonto:FireEnvironmentalFactor a owl:Class ;
    rdfs:label "FireEnvironmentalFactor" ;
    rdfs:comment "Abstract superclass for physical and environmental factors influencing fire ignition, behaviour, intensity, and suppression." .

ffonto:FireTriangleComponent rdfs:subClassOf ffonto:FireEnvironmentalFactor .
ffonto:WeatherInteraction rdfs:subClassOf ffonto:FireEnvironmentalFactor .

ffonto:hasEnvironmentalFactor a owl:ObjectProperty ;
    rdfs:domain ffonto:FireManagement ;
    rdfs:range ffonto:FireEnvironmentalFactor ;
    rdfs:label "hasEnvironmentalFactor" ;
    rdfs:comment "Environmental and physical factors considered during fire management and operations." .

ffonto:FireEnvironmentalFactor rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf ffonto:hasEnvironmentalFactor ] ;
    owl:someValuesFrom ffonto:FireManagement
] .

ffonto:environmentAffectingFire a owl:ObjectProperty ;
    rdfs:domain ffonto:FireEnvironmentalFactor ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "environmentAffectingFire" ;
    rdfs:comment "Inferred link: this environmental or physical factor influenced a forest fire." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:environmentAffectingFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget (
      [ owl:inverseOf ffonto:hasEnvironmentalFactor ]
      ffonto:isManagementOf
  )
] .

ffonto:influencesFireProcess a owl:ObjectProperty ;
    rdfs:domain ffonto:FireEnvironmentalFactor ;
    rdfs:range ffonto:FireCharacteristic ;
    rdfs:label "influencesFireProcess" ;
    rdfs:comment "Environmental or physical factor influencing fire behaviour, intensity, extent, or emissions." .

ffonto:affectsManagement a owl:ObjectProperty ;
    rdfs:domain ffonto:FireEnvironmentalFactor ;
    rdfs:range ffonto:FireManagement ;
    rdfs:label "affectsManagement" ;
    rdfs:comment "Environmental or physical factor affecting fire management and suppression operations." .

#################################################################
# Topographic interaction 
#################################################################

ffonto:TopographicInteraction a owl:Class ;
    rdfs:subClassOf ffonto:FireEnvironmentalFactor ;
    rdfs:label "TopographicInteraction" ;
    rdfs:comment "Terrain and landform features influencing fire spread, intensity, and suppression." .

ffonto:Slope a owl:Class ;
    rdfs:subClassOf ffonto:TopographicInteraction ;
    rdfs:label "Slope" ;
    rdfs:comment "Topographic interaction representing the steepness of terrain, which strongly influences fire spread rate, flame angle, and preheating of uphill fuels." .

ffonto:Aspect a owl:Class ;
    rdfs:subClassOf ffonto:TopographicInteraction ;
    rdfs:label "Aspect" ;
    rdfs:comment "Topographic interaction representing the compass orientation of a slope, affecting solar exposure, fuel moisture, and fire behavior patterns." .

ffonto:CanyonEffect a owl:Class ;
    rdfs:subClassOf ffonto:TopographicInteraction ;
    rdfs:label "CanyonEffect" ;
    rdfs:comment "Topographic interaction referring to wind channeling and acceleration within canyons or narrow valleys that intensify fire spread and create unpredictable fire behavior." .

ffonto:RidgeTop a owl:Class ;
    rdfs:subClassOf ffonto:TopographicInteraction ;
    rdfs:label "RidgeTop" ;
    rdfs:comment "Topographic interaction representing ridge or crest locations where winds often increase, fire behavior intensifies, and fires may change direction or spread rapidly." .

ffonto:FireTriangleComponent owl:disjointWith ffonto:WeatherInteraction .
ffonto:FireTriangleComponent owl:disjointWith ffonto:TopographicInteraction .
ffonto:WeatherInteraction owl:disjointWith ffonto:TopographicInteraction .

ffonto:ExtremeEnvironmentFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFire ;
    rdfs:label "ExtremeEnvironmentFire" ;
    rdfs:comment "Fires influenced by multiple severe environmental factors." .

ffonto:ExtremeEnvironmentFire owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        ffonto:ForestFire
        [ a owl:Restriction ;
          owl:onProperty ffonto:hasFireManagement ;
          owl:someValuesFrom [
              a owl:Restriction ;
              owl:onProperty ffonto:hasEnvironmentalFactor ;
              owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
              owl:onClass ffonto:FireEnvironmentalFactor
          ]
        ]
    )
] .



#################################################################
# Core Effect Structure
#################################################################

ffonto:ForestFireEffect a owl:Class ;
    rdfs:label "ForestFireEffect" ;
    rdfs:comment "Abstract superclass for all effects and impacts caused by a forest fire." .

ffonto:EnvironmentalEffect a owl:Class ;
    rdfs:label "EnvironmentalEffect" ;
    rdfs:subClassOf ffonto:ForestFireEffect ;
    rdfs:comment "Abstract class for environmental impacts caused by forest fires." .

ffonto:HumanEffect a owl:Class ;
    rdfs:label "HumanEffect" ;
    rdfs:subClassOf ffonto:ForestFireEffect ;
    rdfs:comment "Impacts of forest fires on humans, health, and livelihoods." .

ffonto:InfrastructureEffect a owl:Class ;
    rdfs:label "InfrastructureEffect" ;
    rdfs:subClassOf ffonto:ForestFireEffect ;
    rdfs:comment "Impacts of forest fires on built infrastructure and physical assets." .

# Pairwise disjointness
ffonto:EnvironmentalEffect owl:disjointWith ffonto:HumanEffect , ffonto:InfrastructureEffect .
ffonto:HumanEffect owl:disjointWith ffonto:InfrastructureEffect .

#################################################################
# Human Effects
#################################################################

ffonto:InjuryImpact a owl:Class ;
    rdfs:label "InjuryImpact" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Non-fatal injuries caused by fire exposure." .

ffonto:FatalityImpact a owl:Class ;
    rdfs:label "FatalityImpact" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Human deaths caused directly or indirectly by forest fires." .

ffonto:DisplacementImpact a owl:Class ;
    rdfs:label "DisplacementImpact" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Population displacement and loss of housing or shelter." .

ffonto:HealthImpact a owl:Class ;
    rdfs:label "aHealthImpactspect" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Health degradation such as respiratory illness, trauma, or long-term conditions." .

ffonto:PopulationGroup a owl:Class ;
    rdfs:label "Population group"@en ;
    rdfs:comment "A demographically or geographically defined group of people (e.g., communities, vulnerable cohorts) potentially affected by fire or smoke."@en .

# Human effect property
ffonto:affectsPopulation a owl:ObjectProperty ;
    rdfs:domain ffonto:HumanEffect ;
    rdfs:label "affectsPopulation" ;
    rdfs:range ffonto:PopulationGroup ;
    rdfs:comment "Links a human effect to the affected population group." .

#################################################################
# Fire → Human Effects → Population
#################################################################

ffonto:hasEffect rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "hasEffect" ;
    rdfs:range ffonto:EnvironmentalEffect ;
    rdfs:comment "Associates a forest fire with environmental effects it produces." .

ffonto:affectsPopulation a owl:ObjectProperty ;
    owl:propertyChainAxiom ( ffonto:hasEffect ffonto:affectsPopulation ) ;
    rdfs:comment "Infers populations affected by a fire via human impacts (injury, displacement, livelihood, health, psychological)." .

#################################################################
# Environmental Effects Hierarchy
#################################################################

ffonto:VegetationImpact a owl:Class ;
    rdfs:label "VegetationImpact" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Damage or loss of vegetation due to fire." .

ffonto:ForestLoss a owl:Class ;
    rdfs:label "ForestLoss" ;
    rdfs:subClassOf ffonto:VegetationImpact ;
    rdfs:comment "Loss of forested areas due to burning." .

ffonto:GrasslandLoss a owl:Class ;
    rdfs:label "GrasslandLoss" ;
    rdfs:subClassOf ffonto:VegetationImpact ;
    rdfs:comment "Loss of grassland ecosystems due to burning." .

ffonto:WaterQualityImpact a owl:Class ;
    rdfs:label "WaterQualityImpact" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Impacts of fire on surface and groundwater quality." .

ffonto:Contamination a owl:Class ;
    rdfs:label "Contamination" ;
    rdfs:subClassOf ffonto:WaterQualityImpact ;
    rdfs:comment "Chemical or ash contamination of water bodies." .

ffonto:SedimentIncrease a owl:Class ;
    rdfs:label "SedimentIncrease" ;
    rdfs:subClassOf ffonto:WaterQualityImpact ;
    rdfs:comment "Increase of sediments in water due to erosion after fire." .

#################################################################
# Ecological Consequences
#################################################################

ffonto:EcologicalConsequences a owl:Class ;
    rdfs:label "EcologicalConsequences" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Higher-level ecological consequences of fire." .

ffonto:EcologicalImpact a owl:Class ;
    rdfs:label "EcologicalImpact" ;
    rdfs:subClassOf ffonto:EcologicalConsequences ;
    rdfs:comment "General ecological disturbances caused by fire." .

ffonto:ImmediateImpact a owl:Class ;
    rdfs:label "ImmediateImpact" ;
    rdfs:subClassOf ffonto:EcologicalConsequences ;
    rdfs:comment "Short-term ecological impacts immediately after fire." .

ffonto:LongTermImpact a owl:Class ;
    rdfs:label "LongTermImpact" ;
    rdfs:subClassOf ffonto:EcologicalConsequences ;
    rdfs:comment "Long-term ecological transformations following fire." .

ffonto:Regeneration a owl:Class ;
    rdfs:label "Regeneration" ;
    rdfs:subClassOf ffonto:EcologicalConsequences ;
    rdfs:comment "Natural or assisted ecosystem recovery after fire." .

ffonto:BiodiversityLoss a owl:Class ;
    rdfs:label "BiodiversityLoss" ;
    rdfs:subClassOf ffonto:EcologicalConsequences ;
    rdfs:comment "Reduction in species diversity caused by fire." .

# Disjoint ecological time impacts
ffonto:ImmediateImpact owl:disjointWith ffonto:LongTermImpact .

#################################################################
# Ecosystem Impacts
#################################################################

ffonto:ForestEcosystemImpact a owl:Class ;
    rdfs:label "ForestEcosystemImpact" ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:comment "Impacts affecting forest ecosystems." .

ffonto:GrasslandEcosystemImpact a owl:Class ;
    rdfs:label "GrasslandEcosystemImpact" ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:comment "Impacts affecting grassland ecosystems." .

ffonto:ForestEcosystemImpact owl:disjointWith ffonto:GrasslandEcosystemImpact .

#################################################################
# Environmental State & Conditions
#################################################################

ffonto:EnvironmentalState a owl:Class ;
   rdfs:label "EnvironmentalState" ;
    rdfs:comment "Represents the state of the environment before or after a fire." .

ffonto:PreFireState a owl:Class ;
   rdfs:label "PreFireState" ;
    rdfs:subClassOf ffonto:EnvironmentalState ;
    rdfs:comment "Environmental condition before fire occurrence." .

ffonto:PostFireState a owl:Class ;
   rdfs:label "PostFireState" ;
    rdfs:subClassOf ffonto:EnvironmentalState ;
    rdfs:comment "Environmental condition after fire occurrence." .

ffonto:FuelState a owl:Class ;
   rdfs:label "FuelState" ;
    rdfs:comment "State of combustible material before, during, or after fire." .

ffonto:DryFuelState a owl:Class ;
    rdfs:label "DryFuelState" ;
    rdfs:subClassOf ffonto:FuelState ;
    rdfs:comment "Dry combustible fuel condition." .

ffonto:MoistFuelState a owl:Class ;
    rdfs:label "MoistFuelState" ;
    rdfs:subClassOf ffonto:FuelState ;
    rdfs:comment "Moist combustible fuel condition." .

ffonto:ConsumedFuelState a owl:Class ;
    rdfs:label "ConsumedFuelState" ;
    rdfs:subClassOf ffonto:FuelState ;
    rdfs:comment "Fuel that has been partially or fully consumed by fire." .

ffonto:SoilCondition a owl:Class ;
    rdfs:label "SoilCondition" ;
    rdfs:comment "Post-fire soil condition." .

ffonto:HydrophobicSoil a owl:Class ;
    rdfs:label "HydrophobicSoil" ;
    rdfs:subClassOf ffonto:SoilCondition ;
    rdfs:comment "Water-repellent soil condition caused by intense heating." .

#################################################################
# Environmental Effect Properties
#################################################################

ffonto:affectsEcosystem a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "affectsEcosystem" ;
    rdfs:range ffonto:EcosystemEffect ;
    rdfs:comment "Links an environmental effect to an affected ecosystem." .

ffonto:altersEnvironmentalState a owl:ObjectProperty ;
    rdfs:domain ffonto:EnvironmentalEffect ;
    rdfs:range ffonto:EnvironmentalState ;
    rdfs:label "EnvironmentalState" ;
    rdfs:comment "Indicates a change in environmental state caused by fire." .

ffonto:changesFuelState a owl:ObjectProperty ;
    rdfs:domain ffonto:EnvironmentalEffect ;
    rdfs:range ffonto:FuelState ;
    rdfs:label "changesFuelState" ;
    rdfs:comment "Indicates fuel state transformation due to fire." .

ffonto:degradesSoil a owl:ObjectProperty ;
    rdfs:label "degradesSoil" ;
    rdfs:domain ffonto:EnvironmentalEffect ;
    rdfs:range ffonto:SoilCondition ;
    rdfs:comment "Represents soil degradation caused by fire." .

#################################################################
# Infrastructure Effects
#################################################################

ffonto:Structure a owl:Class ;
    rdfs:label "Structure" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Damage to buildings and constructed structures." .

ffonto:ResidentialBuilding a owl:Class ;
    rdfs:label "ResidentialBuilding" ;
    rdfs:subClassOf ffonto:Structure ;
    rdfs:comment "Damage to residential buildings." .

ffonto:CommercialBuilding a owl:Class ;
    rdfs:label "CommercialBuilding" ;
    rdfs:subClassOf ffonto:Structure ;
    rdfs:comment "Damage to commercial buildings." .

ffonto:Road a owl:Class ;
    rdfs:label "Road" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Damage to transportation roads and highways." .

ffonto:Utility a owl:Class ;
    rdfs:label "Utility" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Damage to utility systems." .

ffonto:PowerLine a owl:Class ;
    rdfs:label "PowerLine" ;
    rdfs:subClassOf ffonto:Utility ;
    rdfs:comment "Damage to electrical transmission lines." .

ffonto:CommunicationTower a owl:Class ;
    rdfs:label "CommunicationTower" ;
    rdfs:subClassOf ffonto:Utility ;
    rdfs:comment "Damage to communication towers and networks." .

ffonto:Vehicle a owl:Class ;
    rdfs:label "Vehicle" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Damage to vehicles caused by fire." .

ffonto:FireVehicleDamage a owl:Class ;
    rdfs:label "FireVehicleDamage" ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:comment "Damage to firefighting vehicles." .

ffonto:CivilianVehicleDamage a owl:Class ;
    rdfs:label "CivilianVehicleDamage" ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:comment "Damage to civilian vehicles." .

# Disjoint infrastructure classes
ffonto:Structure owl:disjointWith ffonto:Utility , ffonto:Vehicle .
ffonto:Utility owl:disjointWith ffonto:Vehicle .

ffonto:InfrastructureAsset a owl:Class ;
    rdfs:label "InfrastructureAsset" ;
    rdfs:comment "Built assets (roads, power lines, buildings) potentially affected by wildfire."@en .

# Infrastructure property
ffonto:damagesAsset a owl:ObjectProperty ;
    rdfs:domain ffonto:InfrastructureEffect ;
    rdfs:range ffonto:InfrastructureAsset ;
    rdfs:label "damagesAsset"@en ;
    rdfs:comment "Links an infrastructure effect to the damaged asset." .

#################################################################
# Environmental Factors & Conditions
#################################################################

ffonto:EnvironmentalFactor a owl:Class ;
    rdfs:label "EnvironmentalFactor" ;
    rdfs:comment "External environmental factor influencing fire behavior and impacts." .

ffonto:EnvironmentalCondition a owl:Class ;
    rdfs:label "EnvironmentalCondition" ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:comment "Local environmental conditions influencing fires." .

ffonto:SoilQuality a owl:Class ;
    rdfs:label "SoilQuality" ;
    rdfs:subClassOf ffonto:EnvironmentalCondition ;
    rdfs:comment "Soil properties influencing fire spread and recovery." .

ffonto:SnowCover a owl:Class ;
    rdfs:label "SnowCover" ;
    rdfs:subClassOf ffonto:EnvironmentalCondition ;
    rdfs:comment "Snow presence affecting ignition and suppression." .

ffonto:DroughtCondition a owl:Class ;
    rdfs:label "DroughtCondition" ;
    rdfs:subClassOf ffonto:EnvironmentalCondition ;
    rdfs:comment "Drought conditions increasing fire susceptibility." .

ffonto:VegetationMoisture a owl:Class ;
    rdfs:label "VegetationMoisture" ;
    rdfs:subClassOf ffonto:EnvironmentalCondition ;
    rdfs:comment "Moisture level in vegetation affecting ignition probability." .

ffonto:ClimateChangeImpact a owl:Class ;
    rdfs:label "ClimateChangeImpact" ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:comment "Long-term climate-driven influences on fire regimes." .

ffonto:ProlongedDrought a owl:Class ;
    rdfs:label "ProlongedDrought" ;
    rdfs:subClassOf ffonto:ClimateChangeImpact ;
    rdfs:comment "Extended drought linked to climate change." .

ffonto:HeatWaveTrend a owl:Class ;
    rdfs:label "HeatWaveTrend" ;
    rdfs:subClassOf ffonto:ClimateChangeImpact ;
    rdfs:comment "Increasing frequency and intensity of heat waves." .

ffonto:AlteredRainfallPattern a owl:Class ;
    rdfs:label "AlteredRainfallPattern" ;
    rdfs:subClassOf ffonto:ClimateChangeImpact ;
    rdfs:comment "Changes in precipitation distribution affecting fire risk." .

ffonto:InfluencedEntity a owl:Class ;
    rdfs:label "InfluencedEntity" ;
    rdfs:comment "Abstract entity that can be influenced by environmental or operational factors." .

ffonto:influencedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:InfluencedEntity ;
    rdfs:label "influencedBy" ;
    rdfs:range ffonto:EnvironmentalFactor ;
    rdfs:comment "Associates an influenced entity with an environmental or climatic influencing factor." .

ffonto:affectsFireCharacteristic a owl:ObjectProperty ;
    rdfs:domain ffonto:EnvironmentalFactor ;
    rdfs:label "affectsFireCharacteristic" ;
    rdfs:range ffonto:FireCharacteristic ;
    rdfs:comment "Links environmental factors to fire characteristics." .

ffonto:contributesTo a owl:ObjectProperty ;
    rdfs:label "contributesTo" ;
    rdfs:domain ffonto:EnvironmentalFactor ;
    rdfs:range ffonto:ForestFireCause ;
    rdfs:comment "Indicates environmental contribution to fire causation." .

#################################################################
# Damage & Severity Properties
#################################################################

ffonto:damageLevel a owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range xsd:string ;
    rdfs:label "damageLevel" ;
    rdfs:comment "Categorical severity level: low, moderate, high, extreme." .

ffonto:economicLoss a owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range xsd:double ;
    rdfs:label "economicLoss" ;
    rdfs:comment "Estimated economic loss caused by this effect." .

ffonto:affectedArea a owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range xsd:double ;
    rdfs:label "affectedArea" ;
    rdfs:comment "Affected area in hectares." .

ffonto:recoveryTimeEstimate a owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range xsd:duration ;
    rdfs:label "recoveryTimeEstimate" ;
    rdfs:comment "Estimated time required for recovery." .

#################################################################
#  Human & Socio-Economic Impacts
#################################################################

ffonto:LivelihoodLoss a owl:Class ;
    rdfs:label "LivelihoodLoss" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Loss of income or employment due to damage to agriculture, forestry, or tourism." .

ffonto:PsychologicalImpact a owl:Class ;
    rdfs:label "PsychologicalImpact" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Mental health effects such as trauma, anxiety, or PTSD following fire events." .

ffonto:AirQualityHealthImpact a owl:Class ;
    rdfs:label "AirQualityHealthImpact" ;
    rdfs:subClassOf ffonto:HumanEffect ;
    rdfs:comment "Health impacts caused by smoke exposure and degraded air quality." .

#################################################################
#  Environmental Impacts
#################################################################

ffonto:CarbonEmissionImpact a owl:Class ;
    rdfs:label "CarbonEmissionImpact" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Greenhouse gas emissions released by forest fires contributing to climate feedback loops." .

ffonto:HabitatFragmentation a owl:Class ;
    rdfs:label "HabitatFragmentation" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Breaking of continuous habitats into isolated patches due to fire." .

ffonto:InvasiveSpeciesSpread a owl:Class ;
    rdfs:label "InvasiveSpeciesSpread" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Colonization of burned areas by invasive or opportunistic species." .

ffonto:WatershedImpact a owl:Class ;
    rdfs:label "WatershedImpact" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Impacts on watershed stability, runoff patterns, and downstream flooding risk after fire." .

#################################################################
# Additional Infrastructure & Economic Impacts
#################################################################

ffonto:CriticalInfrastructureImpact a owl:Class ;
    rdfs:label "CriticalInfrastructureImpact" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Damage to essential infrastructure such as hospitals, emergency facilities, and water treatment plants." .

ffonto:SupplyChainDisruption a owl:Class ;
    rdfs:label "SupplyChainDisruption" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Interruption of logistics, transport, or essential goods delivery caused by fire damage." .

ffonto:InsuranceClaimImpact a owl:Class ;
    rdfs:label "InsuranceClaimImpact" ;
    rdfs:subClassOf ffonto:InfrastructureEffect ;
    rdfs:comment "Financial and administrative impacts associated with insurance claims after fire damage." .

#################################################################
# Recovery, Restoration & Monitoring Concepts
#################################################################

ffonto:RestorationAction a owl:Class ;
    rdfs:label "RestorationAction" ;
    rdfs:comment "Post-fire actions aimed at restoring ecosystems, infrastructure, or communities." .

ffonto:MonitoringIndicator a owl:Class ;
    rdfs:label "MonitoringIndicator" ;
    rdfs:comment "Measured indicator used to track post-fire recovery and environmental health." .

#################################################################
# Recovery & Monitoring Properties
#################################################################

ffonto:hasRestorationAction a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:RestorationAction ;
    rdfs:label "hasRestorationAction" ;
    rdfs:comment "Links a fire event to restoration or rehabilitation actions." .

ffonto:trackedByIndicator a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range ffonto:MonitoringIndicator ;
    rdfs:label "trackedByIndicator" ;
    rdfs:comment "Associates an effect with monitoring indicators for recovery assessment." .

#################################################################
# Ecosystem Class Hierarchy
#################################################################

ffonto:EcosystemEffect a owl:Class ;
    rdfs:label "EcosystemEffect" ;
    rdfs:subClassOf ffonto:ForestFireEffect ;
    rdfs:comment "Abstract superclass representing natural ecosystems affected by forest fires." .

ffonto:ForestEcosystem a owl:Class ;
    rdfs:label "ForestEcosystem" ;
    rdfs:subClassOf ffonto:EcosystemEffect ;
    rdfs:comment "Forest-type ecosystems affected by fire." .

ffonto:ConiferousForestEcosystem a owl:Class ;
    rdfs:label "ConiferousForestEcosystem" ;
    rdfs:subClassOf ffonto:ForestEcosystem ;
    rdfs:comment "Forest ecosystem dominated by coniferous tree species." .

ffonto:DeciduousForestEcosystem a owl:Class ;
    rdfs:label "DeciduousForestEcosystem" ;
    rdfs:subClassOf ffonto:ForestEcosystem ;
    rdfs:comment "Forest ecosystem dominated by deciduous tree species." .

ffonto:MixedForestEcosystem a owl:Class ;
    rdfs:label "MixedForestEcosystem" ;
    rdfs:subClassOf ffonto:ForestEcosystem ;
    rdfs:comment "Forest ecosystem containing both coniferous and deciduous species." .

ffonto:GrasslandEcosystem a owl:Class ;
    rdfs:label "GrasslandEcosystem" ;
    rdfs:subClassOf ffonto:EcosystemEffect ;
    rdfs:comment "Grass-dominated ecosystems such as plains and steppes." .

ffonto:SavannaEcosystem a owl:Class ;
    rdfs:label "SavannaEcosystem" ;
    rdfs:subClassOf ffonto:GrasslandEcosystem ;
    rdfs:comment "Tropical or subtropical grassland with scattered trees." .

ffonto:PrairieEcosystem a owl:Class ;
    rdfs:label "PrairieEcosystem" ;
    rdfs:subClassOf ffonto:GrasslandEcosystem ;
    rdfs:comment "Temperate grassland ecosystem with herbaceous vegetation." .

ffonto:ShrublandEcosystem a owl:Class ;
    rdfs:label "ShrublandEcosystem" ;
    rdfs:subClassOf ffonto:EcosystemEffect ;
    rdfs:comment "Ecosystem dominated by shrubs and woody vegetation." .

ffonto:WetlandEcosystem a owl:Class ;
    rdfs:label "WetlandEcosystem" ;
    rdfs:subClassOf ffonto:EcosystemEffect ;
    rdfs:comment "Ecosystems characterized by saturated soils and aquatic vegetation." .

# Disjoint core ecosystem types
ffonto:ForestEcosystem owl:disjointWith ffonto:GrasslandEcosystem , ffonto:ShrublandEcosystem , ffonto:WetlandEcosystem .
ffonto:GrasslandEcosystem owl:disjointWith ffonto:ShrublandEcosystem , ffonto:WetlandEcosystem .
ffonto:ShrublandEcosystem owl:disjointWith ffonto:WetlandEcosystem .

#################################################################
# Ecosystem Impact Specialization
#################################################################

ffonto:EcosystemImpact a owl:Class ;
    rdfs:label "EcosystemImpact" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Environmental effects specifically targeting ecosystems." .

ffonto:ForestEcosystemImpact a owl:Class ;
    rdfs:label "ForestEcosystemImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Impacts affecting forest ecosystems." .

ffonto:GrasslandEcosystemImpact a owl:Class ;
    rdfs:label "GrasslandEcosystemImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Impacts affecting grassland ecosystems." .

ffonto:ShrublandEcosystemImpact a owl:Class ;
    rdfs:label "ShrublandEcosystemImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Impacts affecting shrubland ecosystems." .

ffonto:WetlandEcosystemImpact a owl:Class ;
    rdfs:label "WetlandEcosystemImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Impacts affecting wetland ecosystems." .

#################################################################
# Ecosystem Impact Targeting Properties
#################################################################

ffonto:targetsEcosystem a owl:ObjectProperty ;
    rdfs:domain ffonto:EcosystemImpact ;
    rdfs:range ffonto:EcosystemEffect ;
    rdfs:label "targetsEcosystem" ;
    rdfs:comment "Specifies which ecosystem is targeted by an ecosystem impact." .

# Semantic alignment restrictions
ffonto:ForestEcosystemImpact rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:affectsEcosystem ;
    owl:allValuesFrom ffonto:ForestEcosystem
] .

ffonto:GrasslandEcosystemImpact rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:affectsEcosystem ;
    owl:allValuesFrom ffonto:GrasslandEcosystem
] .

ffonto:ShrublandEcosystemImpact rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:affectsEcosystem ;
    owl:allValuesFrom ffonto:ShrublandEcosystem
] .

ffonto:WetlandEcosystemImpact rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:affectsEcosystem ;
    owl:allValuesFrom ffonto:WetlandEcosystem
] .

#################################################################
# Additional Ecological Impact Dimensions
#################################################################

ffonto:HabitatLossImpact a owl:Class ;
    rdfs:label "HabitatLossImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Loss or fragmentation of natural habitats caused by fire." .

ffonto:SpeciesMortalityImpact a owl:Class ;
    rdfs:label "SpeciesMortalityImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Mortality of fauna and flora due to fire exposure." .

ffonto:SoilDegradationImpact a owl:Class ;
    rdfs:label "SoilDegradationImpact" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Soil fertility and structure degradation following fire." .

ffonto:InvasiveSpeciesRisk a owl:Class ;
    rdfs:label "InvasiveSpeciesRisk" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Increased risk of invasive species establishment after fire." .

ffonto:CarbonStockLoss a owl:Class ;
    rdfs:label "CarbonStockLoss" ;
    rdfs:subClassOf ffonto:EcosystemImpact ;
    rdfs:comment "Loss of stored carbon in biomass and soil due to burning." .

#################################################################
# Inverse & Helper Properties
#################################################################

ffonto:isAffectedByFire a owl:ObjectProperty ;
    rdfs:domain ffonto:EcosystemEffect ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isAffectedByFire" ;
    rdfs:comment "Inverse relation indicating a fire that affected an ecosystem." .

ffonto:hasEcosystemImpact a owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:hasEffect ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:EcosystemImpact ;
    rdfs:label "hasEcosystemImpact" ;
    rdfs:comment "Specialized link from fire to ecosystem-related impacts." .

#################################################################
# Reasoning Property Chains (Annotated Pattern)
#################################################################

# Fire → Ecosystem inference
[ a owl:Axiom ;
  owl:annotatedSource ffonto:affectsEcosystem ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasEffect ffonto:affectsEcosystem ) ;
  rdfs:comment "Infers ecosystems affected by a forest fire through its environmental effects."
] .

#################################################################

# Helper sub-property for forest ecosystem classification
ffonto:affectsForestEcosystem a owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:affectsEcosystem ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:ForestEcosystem ;
    rdfs:label "affectsForestEcosystem" ;
    rdfs:comment "Indicates that a forest fire affected a forest ecosystem." .

# Fire → Ecosystem type inference
[ a owl:Axiom ;
  owl:annotatedSource ffonto:affectsForestEcosystem ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:affectsEcosystem rdf:type ) ;
  rdfs:comment "Infers that a forest fire affected a forest ecosystem when the ecosystem is typed as ForestEcosystem."
] .

#################################################################

# Fire → Impact type inference
ffonto:hasEnvironmentalImpact a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:EnvironmentalEffect ;
    rdfs:label "hasEnvironmentalImpact" ;
    rdfs:comment "Marks fires that have environmental impacts." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:hasEnvironmentalImpact ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasEffect rdf:type ) ;
  rdfs:comment "Infers that a forest fire has environmental impact when it has an environmental effect."
] .

#################################################################

# Management influence chain
ffonto:mitigatedEnvironmentalEffect a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:EnvironmentalEffect ;
    rdfs:label "mitigatedEnvironmentalEffect" ;
    rdfs:comment "Environmental effects mitigated by management actions." .

ffonto:mitigatesEffect rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:label "mitigatesEffect" ;
    rdfs:range ffonto:EnvironmentalEffect ;
    rdfs:comment "Associates a management action with environmental effects it mitigates." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:mitigatedEnvironmentalEffect ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasManagementAction ffonto:mitigatesEffect ) ;
  rdfs:comment "Infers environmental effects mitigated by management actions taken during the fire."
] .

#################################################################
# Effect ↔ Fire Direct Connection (Missing Core Link)
#################################################################

ffonto:EnvironmentalEffect owl:disjointWith ffonto:HumanEffect , ffonto:InfrastructureEffect .
ffonto:HumanEffect owl:disjointWith ffonto:InfrastructureEffect .

ffonto:EcosystemImpact owl:disjointWith 
    ffonto:VegetationImpact ,
    ffonto:WaterQualityImpact ,
    ffonto:EcologicalConsequences ,
    ffonto:CarbonEmissionImpact ,
    ffonto:HabitatFragmentation ,
    ffonto:WatershedImpact ,
    ffonto:InvasiveSpeciesSpread .

ffonto:ForestEcosystemImpact owl:disjointWith 
    ffonto:GrasslandEcosystemImpact ,
    ffonto:ShrublandEcosystemImpact ,
    ffonto:WetlandEcosystemImpact .

ffonto:GrasslandEcosystemImpact owl:disjointWith 
    ffonto:ShrublandEcosystemImpact ,
    ffonto:WetlandEcosystemImpact .

ffonto:ShrublandEcosystemImpact owl:disjointWith 
    ffonto:WetlandEcosystemImpact .

ffonto:HabitatLossImpact owl:disjointWith 
    ffonto:SpeciesMortalityImpact ,
    ffonto:SoilDegradationImpact ,
    ffonto:InvasiveSpeciesRisk ,
    ffonto:CarbonStockLoss .

ffonto:SpeciesMortalityImpact owl:disjointWith 
    ffonto:SoilDegradationImpact ,
    ffonto:InvasiveSpeciesRisk ,
    ffonto:CarbonStockLoss .

ffonto:SoilDegradationImpact owl:disjointWith 
    ffonto:InvasiveSpeciesRisk ,
    ffonto:CarbonStockLoss .

ffonto:InvasiveSpeciesRisk owl:disjointWith 
    ffonto:CarbonStockLoss .

ffonto:ImmediateImpact owl:disjointWith ffonto:LongTermImpact .

#################################################################
# HumanEffect Subclass Disjointness
#################################################################

ffonto:InjuryImpact owl:disjointWith 
    ffonto:FatalityImpact ,
    ffonto:DisplacementImpact ,
    ffonto:HealthImpact ,
    ffonto:LivelihoodLoss ,
    ffonto:PsychologicalImpact ,
    ffonto:AirQualityHealthImpact .

ffonto:FatalityImpact owl:disjointWith 
    ffonto:DisplacementImpact ,
    ffonto:HealthImpact ,
    ffonto:LivelihoodLoss ,
    ffonto:PsychologicalImpact ,
    ffonto:AirQualityHealthImpact .

ffonto:DisplacementImpact owl:disjointWith 
    ffonto:HealthImpact ,
    ffonto:LivelihoodLoss ,
    ffonto:PsychologicalImpact ,
    ffonto:AirQualityHealthImpact .

ffonto:HealthImpact owl:disjointWith 
    ffonto:LivelihoodLoss ,
    ffonto:PsychologicalImpact ,
    ffonto:AirQualityHealthImpact .

ffonto:Structure owl:disjointWith ffonto:Utility , ffonto:Vehicle .
ffonto:Utility owl:disjointWith ffonto:Vehicle .

ffonto:ResidentialBuilding owl:disjointWith ffonto:CommercialBuilding .
ffonto:FireVehicleDamage owl:disjointWith ffonto:CivilianVehicleDamage .

ffonto:isEffectOf a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isEffectOf" ;
    rdfs:comment "Links an effect back to the forest fire that produced it." .

ffonto:causedByFire a owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:isEffectOf ;
    rdfs:label "causedByFire" ;
    rdfs:domain ffonto:ForestFireEffect ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Indicates the forest fire that causally produced this effect." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:causedByFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:isEffectOf ) ;
  rdfs:comment "Infers the causal fire for each forest fire effect from inverse hasEffect relation."
] .

ffonto:ForestFireEffect rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:causedByFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

#################################################################
# EnvironmentalFactor must influence some ForestFire
#################################################################

ffonto:leadsToFire rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFireCause ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "leadsToFire" ;
    rdfs:comment "Associates a fire cause with the forest fire it leads to." .

ffonto:EnvironmentalFactor rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:leadsToFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

#################################################################
# EnvironmentalState must be altered by some EnvironmentalEffect
#################################################################

ffonto:EnvironmentalState rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:altersEnvironmentalState ;
    owl:someValuesFrom ffonto:EnvironmentalEffect
] .

#################################################################
# FuelState must influence some ForestFire
#################################################################

ffonto:FuelStatus a owl:Class ;
    rdfs:label "FuelStatus"@en ;
    rdfs:comment "Characterization of available combustible material (moisture, load, continuity) that influences fire behavior."@en .

ffonto:influencedByFuelStatus rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "influencedByFuelStatus"@en ;
    rdfs:range ffonto:FuelStatus ;
    rdfs:comment "Associates a forest fire with the fuel status influencing its behavior." .

ffonto:FuelState rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:influencedByFuelStatus ;
    owl:someValuesFrom ffonto:ForestFire
] .

#################################################################
# MonitoringIndicator must monitor some ForestFire or SoilCondition
#################################################################

ffonto:monitorsSoilCondition rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:range ffonto:SoilCondition ;
    rdfs:label "monitorsSoilCondition" ;
    rdfs:comment "Associates a sensor with the soil condition it monitors." .

ffonto:MonitoringIndicator rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:monitorsSoilCondition ;
    owl:someValuesFrom ffonto:SoilCondition
] .

#################################################################
# PopulationGroup must be affected by some ForestFire
#################################################################

ffonto:PopulationGroup rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isAffectedByFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

#################################################################
# ResilienceMetrics must evaluate some ForestFireEffect
#################################################################

ffonto:evaluatesEffect a owl:ObjectProperty ;
    rdfs:domain ffonto:ResilienceMetrics ;
    rdfs:range ffonto:ForestFireEffect ;
    rdfs:label "evaluatesEffect" ;
    rdfs:comment "Evaluates recovery capacity or resilience for a given fire effect." .


ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:evaluatesEffect ;
    owl:someValuesFrom ffonto:ForestFireEffect
] .

#################################################################
# RestorationAction must be applied after some ForestFire
#################################################################

ffonto:RestorationAction rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasRestorationAction ;
    owl:someValuesFrom ffonto:ForestFire
] .


ffonto:RestorationAction rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:targetsEcosystem ;
    owl:someValuesFrom ffonto:EcosystemEffect
] .

#################################################################
# SoilCondition must be degraded by some EnvironmentalEffect
#################################################################

ffonto:SoilCondition rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:degradesSoil ;
    owl:someValuesFrom ffonto:EnvironmentalEffect
] .

#################################################################
# SoilCondition → SoilQuality Relationship
#################################################################

ffonto:influencesSoilQuality a owl:ObjectProperty ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:label "influencesSoilQuality" ;
    rdfs:range ffonto:SoilQuality ;
    rdfs:comment "Indicates how post-fire soil condition influences long-term soil quality." .

ffonto:SoilQuality rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:influencesSoilQuality ;
    owl:someValuesFrom ffonto:SoilCondition
] .

#################################################################
# Infrastructure and Human Domains Must Be Disjoint
#################################################################

ffonto:InfrastructureAsset owl:disjointWith ffonto:HumanEffect .

#################################################################
# Inverse property: asset is damaged by effect
#################################################################

ffonto:isDamagedBy a owl:ObjectProperty ;
    owl:inverseOf ffonto:damagesAsset ;
    rdfs:domain ffonto:InfrastructureAsset ;
    rdfs:range ffonto:InfrastructureEffect ;
    rdfs:label "isDamagedBy" ;
    rdfs:comment "Indicates the infrastructure effect that damaged this asset." .

#################################################################
# Every InfrastructureAsset must be damaged by some InfrastructureEffect
#################################################################

ffonto:InfrastructureAsset rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isDamagedBy ;
    owl:someValuesFrom ffonto:InfrastructureEffect
] .

#################################################################
# Every InfrastructureAsset is ultimately damaged because of a ForestFire
#################################################################

ffonto:InfrastructureAsset rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isDamagedBy ;
    owl:someValuesFrom [
        a owl:Restriction ;
        owl:onProperty ffonto:causedByFire ;
        owl:someValuesFrom ffonto:ForestFire
    ]
] .

#################################################################
# Every ResilienceMetric must evaluate some ForestFireEffect
#################################################################

ffonto:ResilienceMetrics
  rdfs:label "resilience metrics"@en ;
  rdfs:comment "A set of quantitative or qualitative indicators used to measure the resilience of a system, asset, or ecosystem before, during, or after a fire event."@en .

ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:evaluatesEffect ;
    owl:someValuesFrom ffonto:ForestFireEffect
] .

ffonto:appliesToEcosystem a owl:ObjectProperty ;
    rdfs:domain ffonto:ResilienceMetrics ;
    rdfs:label "appliesToEcosystem" ;
    rdfs:range ffonto:EcosystemEffect ;
    rdfs:comment "Indicates the ecosystem for which resilience is being measured." .

#################################################################
# Every ResilienceMetric applies to some Ecosystem
#################################################################

ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:appliesToEcosystem ;
    owl:someValuesFrom ffonto:EcosystemEffect
] .

ffonto:appliesToAsset a owl:ObjectProperty ;
    rdfs:label "appliesToAsset" ;
    rdfs:domain ffonto:ResilienceMetrics ;
    rdfs:range ffonto:InfrastructureAsset ;
    rdfs:comment "Indicates the infrastructure or economic system for which resilience is measured." .

#################################################################
# Every ResilienceMetric applies to some InfrastructureAsset or Ecosystem
#################################################################

ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:appliesToAsset ;
    owl:someValuesFrom ffonto:InfrastructureAsset
] .

#################################################################
# Every ResilienceMetric evaluates an effect caused by a ForestFire
#################################################################

ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:evaluatesEffect ;
    owl:someValuesFrom [
        a owl:Restriction ;
        owl:onProperty ffonto:causedByFire ;
        owl:someValuesFrom ffonto:ForestFire
    ]
] .

ffonto:PostFireResilienceMetric a owl:Class ;
    rdfs:label "PostFireResilienceMetric" ;
    rdfs:subClassOf ffonto:ResilienceMetrics ;
    rdfs:comment "Resilience metrics computed specifically after a forest fire." .


#################################################################
# Recovery Stages
#################################################################

ffonto:RecoveryStage a owl:Class ;
    rdfs:label "RecoveryStage" ;
    rdfs:comment "Abstract superclass representing stages of post-fire ecosystem recovery." .

ffonto:EarlyRecoveryStage a owl:Class ;
    rdfs:label "EarlyRecoveryStage" ;
    rdfs:subClassOf ffonto:RecoveryStage ;
    rdfs:comment "Initial post-fire recovery phase with pioneer species and soil stabilization." .

ffonto:MidRecoveryStage a owl:Class ;
    rdfs:label "MidRecoveryStage" ;
    rdfs:subClassOf ffonto:RecoveryStage ;
    rdfs:comment "Intermediate recovery phase with vegetation regrowth and habitat reformation." .

ffonto:LateRecoveryStage a owl:Class ;
    rdfs:label "LateRecoveryStage" ;
    rdfs:subClassOf ffonto:RecoveryStage ;
    rdfs:comment "Advanced recovery phase approaching pre-fire ecosystem structure and function." .

# Disjointness
ffonto:EarlyRecoveryStage owl:disjointWith 
    ffonto:MidRecoveryStage , 
    ffonto:LateRecoveryStage .

ffonto:MidRecoveryStage owl:disjointWith 
    ffonto:LateRecoveryStage .

ffonto:hasRecoveryStage a owl:ObjectProperty ;
    rdfs:domain ffonto:EcosystemImpact ;
    rdfs:range ffonto:RecoveryStage ;
    rdfs:label "hasRecoveryStage" ;
    rdfs:comment "Indicates the current recovery stage of an impacted ecosystem." .

ffonto:EcosystemImpact rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasRecoveryStage ;
    owl:someValuesFrom ffonto:RecoveryStage
] .

#################################################################
# Resilience Thresholds
#################################################################

ffonto:ResilienceThreshold a owl:Class ;
    rdfs:label "ResilienceThreshold" ;
    rdfs:comment "Abstract classification of resilience capacity levels." .

ffonto:LowResilience a owl:Class ;
    rdfs:label "LowResilience" ;
    rdfs:subClassOf ffonto:ResilienceThreshold ;
    rdfs:comment "Low recovery capacity and slow ecosystem or system regeneration." .

ffonto:MediumResilience a owl:Class ;
    rdfs:label "MediumResilience" ;
    rdfs:subClassOf ffonto:ResilienceThreshold ;
    rdfs:comment "Moderate recovery capacity with partial regeneration potential." .

ffonto:HighResilience a owl:Class ;
    rdfs:label "HighResilience" ;
    rdfs:subClassOf ffonto:ResilienceThreshold ;
    rdfs:comment "High recovery capacity and rapid regeneration potential." .

# Disjointness
ffonto:LowResilience owl:disjointWith 
    ffonto:MediumResilience , 
    ffonto:HighResilience .

ffonto:MediumResilience owl:disjointWith 
    ffonto:HighResilience .

ffonto:hasResilienceThreshold a owl:ObjectProperty ;
    rdfs:domain ffonto:ResilienceMetrics ;
    rdfs:range ffonto:ResilienceThreshold ;
    rdfs:label "hasResilienceThreshold" ;
    rdfs:comment "Assigns a categorical resilience level to a resilience metric." .

ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasResilienceThreshold ;
    owl:someValuesFrom ffonto:ResilienceThreshold
] .

#################################################################
# Resilience Change Over Time
#################################################################

ffonto:ResilienceChange a owl:Class ;
    rdfs:label "ResilienceChange" ;
    rdfs:comment "Represents temporal change in resilience following a forest fire." .

ffonto:ResilienceIncrease a owl:Class ;
    rdfs:label "ResilienceIncrease" ;
    rdfs:subClassOf ffonto:ResilienceChange ;
    rdfs:comment "Increase in recovery capacity over time." .

ffonto:ResilienceDecrease a owl:Class ;
    rdfs:label "ResilienceDecrease" ;
    rdfs:subClassOf ffonto:ResilienceChange ;
    rdfs:comment "Decrease in recovery capacity due to degradation or repeated disturbance." .

ffonto:ResilienceStable a owl:Class ;
    rdfs:label "ResilienceStable" ;
    rdfs:subClassOf ffonto:ResilienceChange ;
    rdfs:comment "No significant change in resilience capacity over time." .

# Disjointness
ffonto:ResilienceIncrease owl:disjointWith 
    ffonto:ResilienceDecrease , 
    ffonto:ResilienceStable .

ffonto:ResilienceDecrease owl:disjointWith 
    ffonto:ResilienceStable .

ffonto:hasResilienceChange a owl:ObjectProperty ;
    rdfs:domain ffonto:ResilienceMetrics ;
    rdfs:label "hasResilienceChange" ;
    rdfs:range ffonto:ResilienceChange ;
    rdfs:comment "Indicates how resilience changes over time after fire." .

ffonto:measuredAtStage a owl:ObjectProperty ;
    rdfs:domain ffonto:ResilienceMetrics ;
    rdfs:range ffonto:RecoveryStage ;
    rdfs:label "measuredAtStage" ;
    rdfs:comment "Specifies the recovery stage at which resilience was measured." .

ffonto:ResilienceMetrics rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasResilienceChange ;
    owl:someValuesFrom ffonto:ResilienceChange
] .

#################################################################
# Fire Severity Levels
#################################################################

ffonto:FireSeverity a owl:Class ;
    rdfs:label "FireSeverity" ;
    rdfs:comment "Classification of forest fire severity levels." .

ffonto:LowSeverityFire a owl:Class ;
    rdfs:label "LowSeverityFire" ;
    rdfs:subClassOf ffonto:FireSeverity ;
    rdfs:comment "Low-intensity fire with limited ecological damage." .

ffonto:ModerateSeverityFire a owl:Class ;
    rdfs:label "ModerateSeverityFire" ;
    rdfs:subClassOf ffonto:FireSeverity ;
    rdfs:comment "Moderate-intensity fire with partial ecosystem damage." .

ffonto:HighSeverityFire a owl:Class ;
    rdfs:label "HighSeverityFire" ;
    rdfs:subClassOf ffonto:FireSeverity ;
    rdfs:comment "High-intensity fire causing extensive ecosystem damage." .

ffonto:ExtremeSeverityFire a owl:Class ;
    rdfs:label "ExtremeSeverityFire" ;
    rdfs:subClassOf ffonto:FireSeverity ;
    rdfs:comment "Extreme-intensity fire causing ecosystem collapse and long recovery." .

# Disjointness
ffonto:LowSeverityFire owl:disjointWith 
    ffonto:ModerateSeverityFire , 
    ffonto:HighSeverityFire , 
    ffonto:ExtremeSeverityFire .

ffonto:ModerateSeverityFire owl:disjointWith 
    ffonto:HighSeverityFire , 
    ffonto:ExtremeSeverityFire .

ffonto:HighSeverityFire owl:disjointWith 
    ffonto:ExtremeSeverityFire .

ffonto:hasFireSeverity a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FireSeverity ;
    rdfs:label "hasFireSeverity" ;
    rdfs:comment "Assigns a severity classification to a forest fire." .

ffonto:ForestFire rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasFireSeverity ;
    owl:someValuesFrom ffonto:FireSeverity
] .

ffonto:causesResilienceDrop a owl:ObjectProperty ;
    rdfs:domain ffonto:FireSeverity ;
    rdfs:label "causesResilienceDrop" ;
    rdfs:range ffonto:ResilienceDecrease ;
    rdfs:comment "Indicates that a fire severity level causes a decrease in resilience." .

#################################################################
# High and Extreme Severity must cause Resilience Decrease
#################################################################

ffonto:HighSeverityFire rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:causesResilienceDrop ;
    owl:someValuesFrom ffonto:ResilienceDecrease
] .

ffonto:ExtremeSeverityFire rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:causesResilienceDrop ;
    owl:someValuesFrom ffonto:ResilienceDecrease
] .

#################################################################
# Inverse helper for ResilienceThreshold <-> ResilienceMetrics
#################################################################
ffonto:isThresholdFor a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasResilienceThreshold ;
    rdfs:domain ffonto:ResilienceThreshold ;
    rdfs:range ffonto:ResilienceMetrics ;
    rdfs:label "isThresholdFor" ;
    rdfs:comment "Inverse of ffonto:hasResilienceThreshold. Links a threshold instance to the resilience metric(s) it classifies." .

# Existential: every ResilienceThreshold is assigned to at least one ResilienceMetrics
ffonto:ResilienceThreshold rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isThresholdFor ;
    owl:someValuesFrom ffonto:ResilienceMetrics
] ;
rdfs:comment "Each ResilienceThreshold must be associated with one or more ResilienceMetrics (prevents orphan threshold instances)." .

#################################################################
# Inverse helper for ResilienceChange <-> ResilienceMetrics
#################################################################
ffonto:isChangeOf a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasResilienceChange ;
    rdfs:domain ffonto:ResilienceChange ;
    rdfs:range ffonto:ResilienceMetrics ;
    rdfs:label "isChangeOf" ;
    rdfs:comment "Inverse of ffonto:hasResilienceChange. Links a resilience-change record to the metric(s) that record it." .

# Existential: every ResilienceChange instance relates to at least one ResilienceMetrics
ffonto:ResilienceChange rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isChangeOf ;
    owl:someValuesFrom ffonto:ResilienceMetrics
] ;
rdfs:comment "Each ResilienceChange must be linked to one or more ResilienceMetrics (ensures resilience-change observations are grounded)." .

#################################################################
# Inverse helper for RecoveryStage <-> EcosystemImpact (EcosystemImpact domain)
#################################################################
ffonto:isStageOfImpact a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasRecoveryStage ;
    rdfs:label "isStageOfImpact" ;
    rdfs:domain ffonto:RecoveryStage ;
    rdfs:range ffonto:EcosystemImpact ;
    rdfs:comment "Inverse of ffonto:hasRecoveryStage. Links a recovery stage instance to the ecosystem impact(s) it describes." .

# Existential: every RecoveryStage is tied to at least one EcosystemImpact
ffonto:RecoveryStage rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isStageOfImpact ;
    owl:someValuesFrom ffonto:EcosystemImpact
] ;
rdfs:comment "Each RecoveryStage instance must be associated with at least one EcosystemImpact (binds stage instances to real impacts)." .

#################################################################
# Inverse helper for FireSeverity <-> ForestFire
#################################################################
ffonto:isSeverityOf a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasFireSeverity ;
    rdfs:domain ffonto:FireSeverity ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isSeverityOf" ;
    rdfs:comment "Inverse of ffonto:hasFireSeverity. Links a severity class/instance to forest fires assigned that severity." .

# Existential: every FireSeverity instance must classify at least one ForestFire
ffonto:FireSeverity rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isSeverityOf ;
    owl:someValuesFrom ffonto:ForestFire
] ;
rdfs:comment "Each FireSeverity instance must be applied to one or more ForestFire instances (prevents standalone severity instances)." .

#################################################################
# Fire Phases (Lifecycle Modeling)
#################################################################

ffonto:FirePhase a owl:Class ;
    rdfs:label "FirePhase" ;
    rdfs:comment "Abstract superclass representing temporal phases in the lifecycle of a forest fire." .

ffonto:ActiveFirePhase a owl:Class ;
    rdfs:label "ActiveFirePhase" ;
    rdfs:subClassOf ffonto:FirePhase ;
    rdfs:comment "Phase during which the fire is actively burning and spreading." .

ffonto:ControlledFirePhase a owl:Class ;
    rdfs:label "ControlledFirePhase" ;
    rdfs:subClassOf ffonto:FirePhase ;
    rdfs:comment "Phase in which the fire is under control but not yet fully extinguished." .

ffonto:PostFirePhase a owl:Class ;
    rdfs:label "PostFirePhase" ;
    rdfs:subClassOf ffonto:FirePhase ;
    rdfs:comment "Phase following fire extinction, focused on assessment and recovery." .

# Disjointness
ffonto:ActiveFirePhase owl:disjointWith ffonto:ControlledFirePhase , ffonto:PostFirePhase .
ffonto:ControlledFirePhase owl:disjointWith ffonto:PostFirePhase .

# Phase properties
ffonto:hasPhase a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FirePhase ;
    rdfs:label "hasPhase" ;
    rdfs:comment "Associates a forest fire with one of its lifecycle phases." .

ffonto:phaseOf a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasPhase ;
    rdfs:domain ffonto:FirePhase ;
    rdfs:label "phaseOf" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Inverse relation linking a phase back to the fire it belongs to." .

# Existential grounding
ffonto:FirePhase rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:phaseOf ;
    owl:someValuesFrom ffonto:ForestFire
] .

#################################################################
# Post-Fire Evidence
#################################################################

ffonto:PostFireEvidence a owl:Class ;
    rdfs:label "PostFireEvidence" ;
    rdfs:subClassOf ffonto:EnvironmentalEffect ;
    rdfs:comment "Observable physical evidence remaining after a forest fire." .

ffonto:AshDeposit a owl:Class ;
    rdfs:label "AshDeposit" ;
    rdfs:subClassOf ffonto:PostFireEvidence ;
    rdfs:comment "Accumulated ash deposits after burning." .

ffonto:CharMark a owl:Class ;
    rdfs:label "CharMark" ;
    rdfs:subClassOf ffonto:PostFireEvidence ;
    rdfs:comment "Charred markings on vegetation or structures." .

ffonto:BurnSeverity a owl:Class ;
    rdfs:label "BurnSeverity" ;
    rdfs:subClassOf ffonto:PostFireEvidence ;
    rdfs:comment "Evidence indicating intensity and severity of burning." .

ffonto:SoilConditionEvidence a owl:Class ;
    rdfs:label "SoilConditionEvidence" ;
    rdfs:subClassOf ffonto:PostFireEvidence ;
    rdfs:comment "Observed post-fire soil condition indicators." .

ffonto:HydrophobicSoilEvidence a owl:Class ;
    rdfs:label "HydrophobicSoilEvidence" ;
    rdfs:subClassOf ffonto:PostFireEvidence ;
    rdfs:comment "Evidence of hydrophobic soil formation after fire." .

ffonto:revealsEvidence a owl:ObjectProperty ;
    rdfs:domain ffonto:PostFirePhase ;
    rdfs:label "revealsEvidence" ;
    rdfs:range ffonto:PostFireEvidence ;
    rdfs:comment "Indicates evidence revealed during post-fire assessment." .

ffonto:observedBy a owl:ObjectProperty ;
    rdfs:label "observedBy" ;
    rdfs:domain ffonto:PostFireEvidence ;
    rdfs:range ffonto:Observation ;
    rdfs:comment "Links post-fire evidence to an observation activity." .

#################################################################
# Fire Activity Level
#################################################################

ffonto:FireActivityLevel a owl:Class ;
    rdfs:label "FireActivityLevel" ;
    rdfs:comment "Classification of fire activity intensity level." .

ffonto:LowActivity a owl:Class ;
    rdfs:label "LowActivity" ;
    rdfs:subClassOf ffonto:FireActivityLevel ;
    rdfs:comment "Fire activity level characterized by low flame intensity, slow spread rate, and limited fire behavior, typically manageable with minimal suppression effort." .

ffonto:ModerateActivity a owl:Class ;
    rdfs:label "ModerateActivity" ;
    rdfs:subClassOf ffonto:FireActivityLevel ;
    rdfs:comment "Fire activity level characterized by moderate flame intensity and spread, requiring organized suppression tactics and continuous monitoring." .

ffonto:StrenuousActivity a owl:Class ;
    rdfs:label "StrenuousActivity" ;
    rdfs:subClassOf ffonto:FireActivityLevel ;
    rdfs:comment "Fire activity level characterized by high flame intensity, rapid spread, and increased resistance to control, demanding sustained and aggressive suppression efforts." .

ffonto:ExtremeActivity a owl:Class ;
    rdfs:label "ExtremeActivity" ;
    rdfs:subClassOf ffonto:FireActivityLevel ;
    rdfs:comment "Fire activity level characterized by very high intensity, extreme spread rates, and erratic behavior, often overwhelming suppression capabilities and posing severe safety risks." .

ffonto:hasActivityLevel a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "hasActivityLevel" ;
    rdfs:range ffonto:FireActivityLevel ;
    rdfs:comment "Indicates current fire activity intensity." .

#################################################################
# Fire Events
#################################################################

ffonto:FireEvent a owl:Class ;
    rdfs:label "FireEvent" ;
    rdfs:comment "Abstract superclass for situational fire event types." .

ffonto:PrescribedFireEvent a owl:Class ;
    rdfs:label "PrescribedFireEvent" ;
    rdfs:subClassOf ffonto:FireEvent ;
    rdfs:comment "Fire event representing a planned and deliberately ignited fire conducted under controlled conditions to achieve management objectives such as fuel reduction, ecosystem restoration, or hazard mitigation." .

ffonto:StructuralFireEvent a owl:Class ;
    rdfs:label "StructuralFireEvent" ;
    rdfs:subClassOf ffonto:FireEvent ;
    rdfs:comment "Fire event involving the ignition and burning of buildings or built structures, including residential, commercial, industrial, or public facilities." .

ffonto:WildfireEvent a owl:Class ;
    rdfs:subClassOf ffonto:FireEvent ;
    rdfs:label "WildfireEvent"@en ;
    rdfs:comment "A specific occurrence of uncontrolled fire in wildland vegetation, defined by location, time, and fire behavior."@en .

# Disjoint
ffonto:PrescribedFireEvent owl:disjointWith ffonto:StructuralFireEvent , ffonto:WildfireEvent .
ffonto:StructuralFireEvent owl:disjointWith ffonto:WildfireEvent .

ffonto:hasEvent a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "hasEvent" ;
    rdfs:range ffonto:FireEvent ;
    rdfs:comment "Associates a forest fire with an event classification." .

ffonto:occursAt a owl:ObjectProperty ;
    rdfs:label "occursAt" ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:comment "Relates an event or process to the location at which it occurs."@en ;
    rdfs:range ffonto:Location .

ffonto:occursOn a owl:DatatypeProperty ;
    rdfs:label "occursOn" ;
    rdfs:comment "Relates an event to the calendar date on which it occurs."@en ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range xsd:dateTime .

#################################################################
# Fire Hazards
#################################################################

ffonto:FireHazard a owl:Class ;
    rdfs:label "FireHazard"@en ;
    rdfs:comment "Abstract superclass for dangerous fire mechanisms." .

ffonto:CrownFire a owl:Class ;
    rdfs:subClassOf ffonto:ForestFireType ,
                    ffonto:FireHazard ;
    rdfs:label "CrownFire"@en ;
    rdfs:comment "Fire spreading through the forest canopy and crowns of trees." .

ffonto:RadiantHeatIgnition a owl:Class ;
    rdfs:label "RadiantHeatIgnition"@en ;
    rdfs:comment "Ignition of combustible material caused by exposure to radiant heat emitted by a fire."@en ;
    rdfs:subClassOf ffonto:FireHazard .

ffonto:RootFire a owl:Class ;
    rdfs:subClassOf ffonto:FireHazard ;
    rdfs:label "RootFire"@en ;
    rdfs:comment "A subsurface fire burning through root systems and buried organic matter."@en .

ffonto:Spotting a owl:Class ;
    rdfs:label "Spotting"@en ;
    rdfs:comment "Fire behavior phenomenon in which embers are carried by wind and ignite new fires ahead of the main fire front."@en ;
    rdfs:subClassOf ffonto:FireHazard .

ffonto:FireWhirl a owl:Class ;
    rdfs:subClassOf ffonto:FireHazard ;
    rdfs:label "FireWhirl"@en ;
    rdfs:comment "A vortex of flame formed by intense convective rotation, capable of throwing embers and causing spot fires."@en .

ffonto:EmberStorm a owl:Class ;
    rdfs:subClassOf ffonto:FireHazard ;
    rdfs:label "EmberStorm"@en ;
    rdfs:comment "A high-density fall of burning embers lofted by fire convection and transported by wind, capable of igniting spot fires downwind."@en .

ffonto:generatesHazard a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FireHazard ;
    rdfs:label "generatesHazard" ;
    rdfs:comment "Indicates hazards generated by a forest fire." .

#################################################################
# Human Health Symptoms
#################################################################

ffonto:HealthSymptom a owl:Class ;
    rdfs:label "HealthSymptom"@en ;
    rdfs:comment "Abstract superclass for fire-related health symptoms." .

ffonto:NeurologicalSymptom a owl:Class ;
    rdfs:label "NeurologicalSymptom"@en ;
    rdfs:subClassOf ffonto:HealthSymptom ;
    rdfs:comment "Health symptoms affecting the nervous system, potentially resulting from smoke inhalation, heat exposure, hypoxia, or toxic gases during fire incidents."@en .

ffonto:Dizziness a owl:Class ;
    rdfs:subClassOf ffonto:NeurologicalSymptom ;
    rdfs:label "Dizziness"@en ;
    rdfs:comment "A neurological symptom possibly associated with smoke inhalation, heat stress, or other exposures."@en .

ffonto:Headache a owl:Class ;
    rdfs:label "Headache"@en ;
    rdfs:subClassOf ffonto:NeurologicalSymptom ;
    rdfs:comment "A neurological symptom characterized by head pain or pressure, often associated with smoke exposure, dehydration, heat stress, or carbon monoxide inhalation."@en .

ffonto:Confusion a owl:Class ;
    rdfs:label "Confusion"@en ;
    rdfs:subClassOf ffonto:NeurologicalSymptom ;
    rdfs:comment "A neurological symptom involving impaired awareness, disorientation, or difficulty thinking clearly, potentially indicating hypoxia, toxic exposure, or severe heat stress."@en .

ffonto:RespiratorySymptom a owl:Class ;
    rdfs:subClassOf ffonto:HealthSymptom ;
    rdfs:label "RespiratorySymptom"@en ;
    rdfs:comment "Any clinical symptom affecting the respiratory system (e.g., coughing, shortness of breath) associated with smoke or pollutant exposure."@en .

ffonto:Coughing a owl:Class ;
    rdfs:label "Coughing"@en ;
    rdfs:subClassOf ffonto:RespiratorySymptom ;
    rdfs:comment "A respiratory symptom characterized by reflexive expulsion of air from the lungs, commonly caused by irritation of the airways due to smoke or particulate inhalation."@en .

ffonto:ShortnessOfBreath a owl:Class ;
    rdfs:subClassOf ffonto:RespiratorySymptom ;
    rdfs:label "ShortnessOfBreath"@en ;
    rdfs:comment "A respiratory symptom that can indicate smoke exposure; may require medical attention."@en .

ffonto:AsthmaExacerbation a owl:Class ;
    rdfs:label "AsthmaExacerbation"@en ;
    rdfs:subClassOf ffonto:RespiratorySymptom ;
    rdfs:comment "A respiratory symptom representing the worsening of asthma symptoms triggered by smoke, particulate matter, or chemical irritants during fire events."@en .

ffonto:causesSymptom a owl:ObjectProperty ;
    rdfs:domain ffonto:HumanEffect ;
    rdfs:label "causesSymptom" ;
    rdfs:range ffonto:HealthSymptom ;
    rdfs:comment "Links a human effect to resulting health symptoms." .

#################################################################
# Human Safety & Health Domains
#################################################################

ffonto:HumanSafetyHealth a owl:Class ;
    rdfs:label "HumanSafetyHealth"@en ;
    rdfs:comment "Abstract superclass for human safety and health protection domains." .

ffonto:FoodSafety a owl:Class ;
    rdfs:subClassOf ffonto:HumanSafetyHealth ;
    rdfs:label "FoodSafety"@en ;
    rdfs:comment "Practices and conditions to prevent foodborne illness in emergency shelters or operational camps."@en .

ffonto:WaterSafety a owl:Class ;
    rdfs:label "WaterSafety"@en ;
    rdfs:subClassOf ffonto:HumanSafetyHealth ;
    rdfs:comment "Conditions and practices ensuring that drinking and service water is safe, uncontaminated, and suitable for human use during fire incidents and emergency response operations."@en .

ffonto:AirQualitySafety a owl:Class ;
    rdfs:label "AirQualitySafety"@en ;
    rdfs:subClassOf ffonto:HumanSafetyHealth ;
    rdfs:comment "Assessment and management of air conditions to reduce health risks from smoke, particulate matter, and toxic gases during fire incidents."@en .

ffonto:ShelterSafety a owl:Class ;
    rdfs:subClassOf ffonto:HumanSafetyHealth ;
    rdfs:label "ShelterSafety"@en ;
    rdfs:comment "A set of conditions or assessments indicating whether a shelter location is safe for occupants during a wildfire event."@en .

ffonto:impactsSafety a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:HumanSafetyHealth ;
    rdfs:label "impactsSafety" ;
    rdfs:comment "Indicates safety and health domains impacted by a fire." .

#################################################################
# Health Precautions
#################################################################

ffonto:HealthPrecaution a owl:Class ;
    rdfs:label "HealthPrecaution"@en ;
    rdfs:subClassOf ffonto:ManagementAction ;
    rdfs:comment "Preventive or protective health action during fire events." .

ffonto:Hydration a owl:Class ;
    rdfs:subClassOf ffonto:HealthPrecaution ;
    rdfs:label "Hydration"@en ;
    rdfs:comment "Health precaution involving adequate fluid intake to prevent dehydration, heat stress, and fatigue during fire incidents and smoke exposure conditions."@en .

ffonto:SealHome a owl:Class ;
    rdfs:subClassOf ffonto:HealthPrecaution ;
    rdfs:label "SealHome"@en ;
    rdfs:comment "Health precaution involving sealing doors, windows, and ventilation openings to reduce indoor smoke infiltration and improve indoor air quality during fire events."@en .

ffonto:WearMask a owl:Class ;
    rdfs:subClassOf ffonto:HealthPrecaution ;
    rdfs:label "WearMask"@en ;
    rdfs:comment "Health precaution involving the use of protective masks or respirators to reduce inhalation of smoke, particulate matter, and airborne pollutants during fire incidents."@en .

ffonto:AvoidOutdoorActivity a owl:Class ;
    rdfs:subClassOf ffonto:HealthPrecaution ;
    rdfs:label "AvoidOutdoorActivity"@en ;
    rdfs:comment "Health precaution involving limiting or avoiding outdoor physical activity to reduce exposure to smoke, heat, and poor air quality during fire events."@en .

ffonto:EvacuateVulnerableGroups a owl:Class ; 
    rdfs:subClassOf ffonto:HealthPrecaution ;
    rdfs:label "EvacuateVulnerableGroups"@en ;
    rdfs:comment "A management action directing the evacuation of populations with reduced mobility or increased health risk."@en .

ffonto:ProtectsAgainst a owl:ObjectProperty ;
    rdfs:label "ProtectsAgainst"@en ;
    rdfs:domain ffonto:HealthPrecaution ;
    rdfs:comment "Relates a protective measure or resource to the hazard or impact that it protects against."@en ;
    rdfs:range ffonto:HealthSymptom .

ffonto:MitigatesHazard a owl:ObjectProperty ;
    rdfs:label "MitigatesHazard"@en ;
    rdfs:domain ffonto:HealthPrecaution ;
    rdfs:comment "Relates an action, strategy, or resource to the hazard that it mitigates."@en ;
    rdfs:range ffonto:FireHazard .

#################################################################
# Fire Risk Modeling
#################################################################

ffonto:FireRisk a owl:Class ;
    rdfs:label "FireRisk"@en ;
    rdfs:comment "Abstract superclass representing probabilistic fire-related risks." .

ffonto:IgnitionRisk a owl:Class ;
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "IgnitionRisk"@en ;
    rdfs:comment "Fire risk representing the likelihood that a fire will start due to natural conditions, human activity, or equipment failure."@en .

ffonto:SpreadRisk a owl:Class ;
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "SpreadRisk"@en ;
    rdfs:comment "Fire risk representing the probability and potential rate at which an existing fire may spread based on fuel, weather, and topographic conditions."@en .

ffonto:HealthRisk a owl:Class ;
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "HealthRisk"@en ;
    rdfs:comment "Fire risk representing the potential for adverse health effects on populations or responders due to smoke exposure, heat, toxic gases, or physical injury."@en .

ffonto:InfrastructureRisk a owl:Class ;
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "InfrastructureRisk"@en ;
    rdfs:comment "Fire risk representing the potential for damage or disruption to buildings, utilities, transportation systems, and critical infrastructure caused by fire."@en .

ffonto:EcologicalRisk a owl:Class ;
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "EcologicalRisk"@en ;
    rdfs:comment "Fire risk representing the potential for negative impacts on ecosystems, wildlife, vegetation, soil stability, and long-term environmental health."@en .

ffonto:EvacuationRisk a owl:Class ;
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "EvacuationRisk"@en ;
    rdfs:comment "Fire risk representing the potential danger, difficulty, or failure associated with evacuating populations threatened by fire, including congestion, access limitations, and timing constraints."@en .

ffonto:ReIgnitionRisk a owl:Class ; 
    rdfs:subClassOf ffonto:FireRisk ;
    rdfs:label "ReIgnitionRisk"@en ;
    rdfs:comment "The likelihood that smoldering fuels or hotspots will re-ignite active flaming after initial control or suppression efforts."@en .

ffonto:hasRisk a owl:ObjectProperty ;    
    rdfs:label "hasRisk" ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:comment "Relates an entity, asset, or event to a risk that affects it."@en ;
    rdfs:range ffonto:FireRisk .

ffonto:causedBy a owl:ObjectProperty ;
    rdfs:label "causedBy" ;
    rdfs:domain ffonto:FireRisk ;
    rdfs:comment "Relates an effect, event, or state to the entity or process that caused it."@en ;
    rdfs:range ffonto:EnvironmentalFactor .

ffonto:increasedBy a owl:ObjectProperty ;
    rdfs:label "increasedBy" ;
    rdfs:comment "Relates a quantity, risk, or state to the factor that increases it."@en ;
    rdfs:domain ffonto:FireRisk ;
    rdfs:range ffonto:FireHazard .

#################################################################
# Reasoning Chains (Annotated Pattern)
#################################################################

ffonto:hasPostFireEvidence rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:PostFirePhase ;
    rdfs:range ffonto:PostFireEvidence ;
    rdfs:label "hasPostFireEvidence" ;
    rdfs:comment "Associates a post-fire phase with evidence collected after fire activity." .

# Fire → Phase → Evidence
[ a owl:Axiom ;
  owl:annotatedSource ffonto:hasPostFireEvidence ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasPhase ffonto:revealsEvidence ) ;
  rdfs:comment "Infers post-fire evidence revealed through post-fire phase assessment."
] .

# Fire → Hazard → Risk
[ a owl:Axiom ;
  owl:annotatedSource ffonto:hasRisk ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:generatesHazard ffonto:increasedBy ) ;
  rdfs:comment "Infers risks generated by hazards produced by a forest fire."
] .

# Fire → Effect → Symptom
[ a owl:Axiom ;
  owl:annotatedSource ffonto:causesSymptom ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasEffect ffonto:causesSymptom ) ;
  rdfs:comment "Infers health symptoms caused by forest fire through human effects."
] .

# Fire → Event → Phase alignment
[ a owl:Axiom ;
  owl:annotatedSource ffonto:hasPhase ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasEvent rdf:type ) ;
  rdfs:comment "Aligns prescribed fire events with controlled fire phase."
] .

#################################################################
# Core Disjointness
#################################################################

ffonto:FireHazard owl:disjointWith ffonto:FireRisk .
ffonto:HealthSymptom owl:disjointWith ffonto:HumanSafetyHealth .


#################################################################
# FireActivityLevel grounding
#################################################################

ffonto:isActivityLevelOf a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasActivityLevel ;
    rdfs:domain ffonto:FireActivityLevel ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isActivityLevelOf" ;
    rdfs:comment "Inverse relation linking a fire activity level to the fire it characterizes." .

ffonto:FireActivityLevel rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isActivityLevelOf ;
    owl:someValuesFrom ffonto:ForestFire
] ;
rdfs:comment "Every FireActivityLevel must characterize at least one ForestFire." .

#################################################################
# FireEvent grounding
#################################################################

ffonto:isEventOf a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasEvent ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:label "isEventOf" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Inverse relation linking a fire event to the forest fire it classifies." .

# Every FireEvent must belong to a ForestFire
ffonto:FireEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isEventOf ;
    owl:someValuesFrom ffonto:ForestFire
] .

# Every FireEvent must occur at some Location
ffonto:FireEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:occursAt ;
    owl:someValuesFrom ffonto:Location
] .

# Every FireEvent must occur at some time
ffonto:FireEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:occursOn ;
    owl:someValuesFrom xsd:dateTime
] .

#################################################################
# FireHazard grounding
#################################################################

ffonto:isGeneratedByFire a owl:ObjectProperty ;
    owl:inverseOf ffonto:generatesHazard ;
    rdfs:domain ffonto:FireHazard ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isGeneratedByFire" ;
    rdfs:comment "Inverse relation linking a hazard to the fire that generated it." .

# Every FireHazard must be generated by some ForestFire
ffonto:FireHazard rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isGeneratedByFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

# Every FireHazard must increase at least one FireRisk
ffonto:FireHazard rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:increasedBy ;
    owl:someValuesFrom ffonto:FireRisk
] .

#################################################################
# FireRisk grounding
#################################################################

ffonto:isRiskOfFire a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasRisk ;
    rdfs:domain ffonto:FireRisk ;
    rdfs:label "isRiskOfFire" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Inverse relation linking a risk to the fire it belongs to." .

# Every FireRisk must belong to some ForestFire
ffonto:FireRisk rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isRiskOfFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

# Every FireRisk must be caused by some EnvironmentalFactor
ffonto:FireRisk rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:causedBy ;
    owl:someValuesFrom ffonto:EnvironmentalFactor
] .

# Every FireRisk must be increased by at least one FireHazard
ffonto:FireRisk rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:increasedBy ;
    owl:someValuesFrom ffonto:FireHazard
] .

#################################################################
# HealthSymptom grounding
#################################################################

ffonto:isSymptomOf a owl:ObjectProperty ;
    owl:inverseOf ffonto:causesSymptom ;
    rdfs:domain ffonto:HealthSymptom ;
    rdfs:label "isSymptomOf" ;
    rdfs:range ffonto:HumanEffect ;
    rdfs:comment "Inverse relation linking a health symptom to the human effect that caused it." .

# Every HealthSymptom must be caused by some HumanEffect
ffonto:HealthSymptom rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isSymptomOf ;
    owl:someValuesFrom ffonto:HumanEffect
] .

ffonto:triggeredByHazard a owl:ObjectProperty ;
    rdfs:domain ffonto:HealthSymptom ;
    rdfs:range ffonto:FireHazard ;
    rdfs:label "triggeredByHazard" ;
    rdfs:comment "Indicates fire hazard that triggered this symptom." .

ffonto:HealthSymptom rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:triggeredByHazard ;
    owl:someValuesFrom ffonto:FireHazard
] .

#################################################################
# HumanSafetyHealth grounding
#################################################################

ffonto:isSafetyImpactedByFire a owl:ObjectProperty ;
    owl:inverseOf ffonto:impactsSafety ;
    rdfs:domain ffonto:HumanSafetyHealth ;
    rdfs:label "isSafetyImpactedByFire" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Inverse relation linking a safety domain to the fire impacting it." .

# Every HumanSafetyHealth must be impacted by some ForestFire
ffonto:HumanSafetyHealth rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:isSafetyImpactedByFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

#################################################################
# Spatial Layer
#################################################################

ffonto:Location a owl:Class ;
    rdfs:label "Location"@en ;
    rdfs:subClassOf ffonto:SpatialExtent ;
    rdfs:comment "Geographic location where fire events occur." .

# Every Location must be location of some FireEvent (in this ontology scope)
ffonto:Location rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:occursAt ;
    owl:someValuesFrom ffonto:FireEvent
] .

#################################################################
# Fire Suppression & Containment Status
#################################################################

ffonto:SuppressionStatus a owl:Class ;
    rdfs:label "SuppressionStatus"@en ;
    rdfs:comment "Abstract superclass representing suppression and containment status of a forest fire." .

ffonto:UncontainedFire a owl:Class ;
    rdfs:label "UncontainedFire"@en ;
    rdfs:subClassOf ffonto:SuppressionStatus ;
    rdfs:comment "Fire with no effective containment." .

ffonto:PartiallyContainedFire a owl:Class ;
    rdfs:label "PartiallyContainedFire"@en ;
    rdfs:subClassOf ffonto:SuppressionStatus ;
    rdfs:comment "Fire partially contained by suppression actions." .

ffonto:FullyContainedFire a owl:Class ;
    rdfs:label "FullyContainedFire"@en ;
    rdfs:subClassOf ffonto:SuppressionStatus ;
    rdfs:comment "Fire fully contained but not necessarily extinguished." .

ffonto:ExtinguishedFire a owl:Class ;
    rdfs:label "ExtinguishedFire"@en ;
    rdfs:subClassOf ffonto:SuppressionStatus ;
    rdfs:comment "Fire fully extinguished with no active burning." .

# Disjointness
ffonto:UncontainedFire owl:disjointWith 
    ffonto:PartiallyContainedFire ,
    ffonto:FullyContainedFire ,
    ffonto:ExtinguishedFire .

ffonto:PartiallyContainedFire owl:disjointWith 
    ffonto:FullyContainedFire ,
    ffonto:ExtinguishedFire .

ffonto:FullyContainedFire owl:disjointWith 
    ffonto:ExtinguishedFire .

ffonto:hasSuppressionStatus a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "hasSuppressionStatus" ;
    rdfs:range ffonto:SuppressionStatus ;
    rdfs:comment "Indicates the current suppression or containment status of a fire." .

ffonto:isStatusOfFire a owl:ObjectProperty ;
    owl:inverseOf ffonto:hasSuppressionStatus ;
    rdfs:label "isStatusOfFire" ;
    rdfs:domain ffonto:SuppressionStatus ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Inverse relation linking suppression status to a fire." .

ffonto:ForestFire rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasSuppressionStatus ;
    owl:someValuesFrom ffonto:SuppressionStatus
] .

#################################################################
# Risk Probability & Severity Scores
#################################################################

ffonto:riskProbability a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireRisk ;
    rdfs:range xsd:double ;
    rdfs:label "riskProbability" ;
    rdfs:comment "Probability of occurrence of this fire risk (0.0–1.0)." .

ffonto:riskSeverityScore a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireRisk ;
    rdfs:range xsd:double ;
    rdfs:label "riskSeverityScore" ;
    rdfs:comment "Numeric severity score representing expected impact magnitude." .

ffonto:riskLevel a owl:DatatypeProperty ;
    rdfs:domain ffonto:FireRisk ;
    rdfs:range xsd:string ;
    rdfs:label "riskLevel" ;
    rdfs:comment "Categorical risk level: low, medium, high, extreme." .

ffonto:FireRisk rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:riskProbability ;
    owl:someValuesFrom xsd:double
] .

ffonto:FireRisk rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:riskSeverityScore ;
    owl:someValuesFrom xsd:double
] .

#################################################################
# Fire Phase Transitions
#################################################################

ffonto:PhaseTransition a owl:Class ;
    rdfs:label "PhaseTransition"@en ;
    rdfs:comment "Represents a temporal transition between two fire lifecycle phases." .

ffonto:hasPreviousPhase a owl:ObjectProperty ;
    rdfs:domain ffonto:PhaseTransition ;
    rdfs:range ffonto:FirePhase ;
    rdfs:label "hasPreviousPhase" ;
    rdfs:comment "Previous phase in a phase transition." .

ffonto:hasNextPhase a owl:ObjectProperty ;
    rdfs:domain ffonto:PhaseTransition ;
    rdfs:label "hasNextPhase" ;
    rdfs:range ffonto:FirePhase ;
    rdfs:comment "Next phase in a phase transition." .

ffonto:transitionOfFire a owl:ObjectProperty ;
    rdfs:domain ffonto:PhaseTransition ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "transitionOfFire" ;
    rdfs:comment "Indicates the fire whose lifecycle phase is transitioning." .

ffonto:PhaseTransition rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:transitionOfFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:PhaseTransition rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasPreviousPhase ;
    owl:someValuesFrom ffonto:FirePhase
] .

ffonto:PhaseTransition rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:hasNextPhase ;
    owl:someValuesFrom ffonto:FirePhase
] .

ffonto:hasCurrentPhase a owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FirePhase ;
    rdfs:label "hasCurrentPhase" ;
    rdfs:comment "Indicates the current lifecycle phase of the fire." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:hasCurrentPhase ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasPhase rdf:type ) ;
  rdfs:comment "Infers current phase of a fire from its phase classification."
] .

#################################################################
# Alert & Advisory System
#################################################################

ffonto:FireAlert a owl:Class ;
    rdfs:label "FireAlert"@en ;
    rdfs:comment "Abstract superclass representing alerts issued for fire-related hazards and risks." .

ffonto:EvacuationAlert a owl:Class ;
    rdfs:label "EvacuationAlert"@en ;
    rdfs:subClassOf ffonto:FireAlert ;
    rdfs:comment "Alert instructing evacuation of affected populations." .

ffonto:HealthAdvisory a owl:Class ;
    rdfs:label "HealthAdvisory"@en ;
    rdfs:subClassOf ffonto:FireAlert ;
    rdfs:comment "Public health advisory related to fire conditions." .

ffonto:AirQualityAlert a owl:Class ;
    rdfs:label "AirQualityAlert"@en ;
    rdfs:subClassOf ffonto:FireAlert ;
    rdfs:comment "Alert related to degraded air quality from smoke." .

ffonto:InfrastructureWarning a owl:Class ;
    rdfs:label "InfrastructureWarning"@en ;
    rdfs:subClassOf ffonto:FireAlert ;
    rdfs:comment "Warning about threats to critical infrastructure." .

ffonto:issuedForFire a owl:ObjectProperty ;
    rdfs:domain ffonto:FireAlert ;
    rdfs:label "issuedForFire" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Indicates the fire event for which the alert is issued." .

ffonto:triggeredByRisk a owl:ObjectProperty ;
    rdfs:label "triggeredByRisk" ;
    rdfs:domain ffonto:FireAlert ;
    rdfs:range ffonto:FireRisk ;
    rdfs:comment "Indicates the risk that triggered this alert." .

ffonto:advisesPrecaution a owl:ObjectProperty ;
    rdfs:domain ffonto:FireAlert ;
    rdfs:label "advisesPrecaution" ;
    rdfs:range ffonto:HealthPrecaution ;
    rdfs:comment "Precautions recommended by this alert." .

ffonto:targetsPopulation a owl:ObjectProperty ;
    rdfs:domain ffonto:FireAlert ;
    rdfs:label "targetsPopulation" ;
    rdfs:range ffonto:PopulationGroup ;
    rdfs:comment "Population group targeted by this alert." .

ffonto:FireAlert rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:issuedForFire ;
    owl:someValuesFrom ffonto:ForestFire
] .

ffonto:FireAlert rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ffonto:triggeredByRisk ;
    owl:someValuesFrom ffonto:FireRisk
] .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:issuedForFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasRisk ffonto:triggeredByRisk ) ;
  rdfs:comment "Infers alerts issued for a fire based on its associated risks."
] .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:issuedForFire ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:generatesHazard ffonto:increasedBy ffonto:triggeredByRisk ) ;
  rdfs:comment "Infers alerts from hazard-generated risks associated with a forest fire."
] .

#################################################################
# Firefighter Actions & Posture Integration
#################################################################

ffonto:FirefighterAction a owl:Class ;
    rdfs:label "FirefighterAction"@en ;
    rdfs:subClassOf ffonto:ManagementAction ;
    rdfs:comment "Operational action performed by firefighting personnel during wildfire management, used to assess exposure and operational risk." .

ffonto:Advancing a owl:Class ; 
    rdfs:subClassOf ffonto:FirefighterAction ;
    rdfs:label "Advancing"@en ;
    rdfs:comment "A firefighter action where crews move forward to engage a fire front."@en .

ffonto:Sheltering a owl:Class ; 
    rdfs:subClassOf ffonto:FirefighterAction ;
    rdfs:label "Sheltering"@en ;
    rdfs:comment "A firefighting posture or protective action where personnel seek cover to reduce exposure to radiant heat or flame (e.g., inside a defensible structure or temporary shelter)."@en .

ffonto:ConstructingLine a owl:Class ; 
    rdfs:subClassOf ffonto:FirefighterAction ;
    rdfs:label "ConstructingLine"@en ;
    rdfs:comment "A firefighting action involving creating fuel-free control lines to limit spread."@en .

ffonto:Communicating a owl:Class ;
    rdfs:subClassOf ffonto:FirefighterAction ;
    rdfs:label "Communicating"@en ;
    rdfs:comment "Firefighter action involving the exchange of information, warnings, status updates, or commands with team members or command staff during fire operations."@en .

ffonto:Retreating a owl:Class ;
    rdfs:subClassOf ffonto:FirefighterAction ;
    rdfs:label "Retreating"@en ;
    rdfs:comment "Firefighter action involving controlled withdrawal from a hazardous area to a safer position due to changing fire behavior, increased risk, or tactical repositioning."@en .

ffonto:MonitoringFireFront a owl:Class ;
    rdfs:subClassOf ffonto:FirefighterAction ;
    rdfs:label "MonitoringFireFront"@en ;
    rdfs:comment "Firefighter action involving observing and assessing the active edge of a fire to track spread direction, intensity changes, spotting, and potential threats."@en .

ffonto:performsAction rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:range ffonto:FirefighterAction ;
    rdfs:label "performsAction" ;
    rdfs:comment "Links personnel to the operational action they are performing." .

ffonto:involvesPosture rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FirefighterAction ;
    rdfs:label "involvesPosture" ;
    rdfs:range ffonto:FirefighterPosture ;
    rdfs:comment "Associates a firefighter action with a physical posture relevant for exposure and injury risk." .

ffonto:usesTool rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FirefighterAction ;
    rdfs:label "usesTool" ;
    rdfs:range ffonto:FireFightingTool ;
    rdfs:comment "Specifies the tool or equipment used in a firefighting action." .

#################################################################
# Fire Identification Sources
#################################################################

ffonto:FireIdentificationMethod a owl:Class ;
    rdfs:label "FireIdentificationMethod"@en ;
    rdfs:comment "Abstract mechanism through which a forest fire is initially identified or confirmed." .

ffonto:HumanDetection a owl:Class ;
    rdfs:label "HumanDetection"@en ;
    rdfs:subClassOf ffonto:FireIdentificationMethod ;
    rdfs:comment "Fire identified through direct human observation or reporting." .

ffonto:ModelInference a owl:Class ;
    rdfs:label "ModelInference"@en ;
    rdfs:subClassOf ffonto:FireIdentificationMethod ;
    rdfs:comment "Fire identified through computational or predictive model inference." .

ffonto:SensorObservation a owl:Class ;
    rdfs:label "SensorObservation"@en ;
    rdfs:subClassOf ffonto:FireIdentificationMethod ;
    rdfs:comment "Fire identified through sensor-based observation data." .

ffonto:identifiedBy rdf:type owl:ObjectProperty ;
    rdfs:label "identifiedBy"@en ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:FireIdentificationMethod ;
    rdfs:comment "Links a fire event to the method by which it was identified." .

ffonto:producedBy rdf:type owl:ObjectProperty ;
    rdfs:label "producedBy"@en ;
    rdfs:domain ffonto:FireIdentificationMethod ;
    rdfs:range owl:Thing ;
    rdfs:comment "Associates identification with the organization, model, or sensor that produced it." .

ffonto:identifiesFire rdf:type owl:ObjectProperty ;
    rdfs:label "identifiesFire"@en ;
    rdfs:domain ffonto:FireIdentificationMethod ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Associates an identification method with the forest fire it identifies." .

ffonto:FireIdentificationMethod rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:identifiesFire ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Every fire identification method must identify at least one forest fire."
    ] .

#################################################################
# Platforms for Fire Detection & Monitoring
#################################################################

ffonto:Platform a owl:Class ;
    rdfs:label "Platform"@en ;
    rdfs:comment "Abstract operational or sensing platform used to deploy sensors and perform wildfire observations."@en .

ffonto:GroundStation a owl:Class ;
    rdfs:subClassOf ffonto:Platform ;
    rdfs:label "GroundStation"@en ;
    rdfs:comment "Platform consisting of fixed ground-based stations used to host sensors and instruments for continuous wildfire monitoring, weather measurement, or air quality observation."@en .

ffonto:MobileUnit a owl:Class ;
    rdfs:subClassOf ffonto:Platform ;
    rdfs:label "MobileUnit"@en ;
    rdfs:comment "Platform consisting of movable ground-based units such as vehicles, trailers, or portable stations used to deploy sensors and collect wildfire observations in the field."@en .

ffonto:RemoteSensingPlatform a owl:Class ;
    rdfs:subClassOf ffonto:Platform ;
    rdfs:label "RemoteSensingPlatform"@en ;
    rdfs:comment "Platform used to collect wildfire observations from a distance using airborne or spaceborne sensors, enabling large-scale detection and monitoring."@en .

ffonto:Satellite a owl:Class ;
    rdfs:subClassOf ffonto:RemoteSensingPlatform ;
    rdfs:label "Satellite"@en ;
    rdfs:comment "Remote sensing platform consisting of orbiting satellites equipped with optical, thermal, or multispectral sensors used for wildfire detection, hotspot identification, smoke tracking, and fire progression monitoring."@en .

ffonto:UAV a owl:Class ; 
    rdfs:subClassOf ffonto:RemoteSensingPlatform ;
    rdfs:label "UAV"@en ;
    rdfs:comment "A small aerial platform often used for rapid fire detection, mapping, and plume observations."@en .

ffonto:MannedAircraft a owl:Class ;
    rdfs:subClassOf ffonto:RemoteSensingPlatform ;
    rdfs:label "MannedAircraft"@en ;
    rdfs:comment "Remote sensing platform consisting of crewed aircraft equipped with optical, infrared, or mapping sensors used for wildfire detection, perimeter mapping, intelligence gathering, and tactical aerial observation."@en .

ffonto:carriesSensor rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Platform ;
    rdfs:range ffonto:Sensor ;
    rdfs:label "carriesSensor" ;
    rdfs:comment "Specifies which sensors are deployed on a given platform." .

ffonto:performedFrom rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:Platform ;
    rdfs:label "performedFrom" ;
    rdfs:comment "Indicates the platform from which an observation was performed." .

ffonto:operatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Platform ;
    rdfs:label "operatedBy" ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:comment "Links a platform to the organization operating it." .

#################################################################
# Sensor Modeling & Types
#################################################################

ffonto:Sensor a owl:Class ;
    rdfs:label "Sensor"@en ;
    rdfs:comment "Abstract sensing device used to generate wildfire-related observations." .

ffonto:Anemometer a owl:Class ; 
    rdfs:subClassOf ffonto:Sensor ;
    rdfs:label "Anemometer"@en ;
    rdfs:comment "A meteorological instrument that measures wind speed (and sometimes direction), used to characterize fire weather and plume transport."@en .

ffonto:GasSensor a owl:Class ;
    rdfs:subClassOf ffonto:Sensor ;
    rdfs:label "GasSensor"@en ;
    rdfs:comment "Sensor designed to detect and measure concentrations of gaseous compounds such as carbon monoxide, carbon dioxide, ozone, or toxic gases associated with fire emissions and smoke."@en .

ffonto:LiDAR a owl:Class ; 
    rdfs:subClassOf ffonto:Sensor ;
    rdfs:label "LiDAR"@en ;
    rdfs:comment "Light Detection And Ranging sensor that measures surface structure and elevation, useful for fuel mapping and post-fire assessment."@en .

ffonto:OpticalCamera a owl:Class ; 
    rdfs:subClassOf ffonto:Sensor ;
    rdfs:label "OpticalCamera"@en ;
    rdfs:comment "A visible-spectrum imaging sensor used for mapping flames, smoke, and situational awareness."@en .

ffonto:ThermalSensor a owl:Class ; 
    rdfs:subClassOf ffonto:Sensor ;
    rdfs:label "ThermalSensor"@en ;
    rdfs:comment "A sensor detecting infrared radiation used to identify heat sources and active fire fronts."@en .

ffonto:SensorType a owl:Class ;
    rdfs:label "SensorType"@en ;
    rdfs:comment "Abstract class representing categories of sensors distinguished by the physical phenomenon or substance they measure, such as temperature, gas concentration, radiation, or particulate matter, in wildfire monitoring and emergency response contexts."@en .

ffonto:MeteorologicalSensor a owl:Class ;
    rdfs:subClassOf ffonto:SensorType ;
    rdfs:label "MeteorologicalSensor"@en ;
    rdfs:comment "Sensor type designed to measure atmospheric and weather variables such as temperature, humidity, wind speed, wind direction, pressure, and precipitation that influence fire behavior and firefighting operations."@en .

ffonto:ChemicalSensor a owl:Class ; 
    rdfs:subClassOf ffonto:SensorType ;
    rdfs:label "ChemicalSensor"@en ;
    rdfs:comment "A sensor that measures airborne chemical species such as CO, NOx, or volatile organics relevant to smoke composition."@en .

ffonto:ImagingSensor a owl:Class ;
    rdfs:subClassOf ffonto:SensorType ;
    rdfs:label "ImagingSensor"@en ;
    rdfs:comment "Sensor type designed to capture two-dimensional or three-dimensional images of fire, terrain, smoke, or infrastructure using optical, infrared, thermal, or multispectral imaging technologies."@en .

ffonto:RemoteSensingSensor a owl:Class ;
    rdfs:subClassOf ffonto:SensorType ;
    rdfs:label "RemoteSensingSensor"@en ;
    rdfs:comment "Sensor type designed to collect observations from a distance without direct contact, typically mounted on airborne or spaceborne platforms for large-scale wildfire detection, mapping, and monitoring."@en .

ffonto:hasSensorType rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:range ffonto:SensorType ;
    rdfs:label "hasSensorType" ;
    rdfs:comment "Classifies a sensor by its sensing modality or functional type." .

ffonto:mountedOn rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:range ffonto:Platform ;
    rdfs:label "mountedOn" ;
    owl:inverseOf ffonto:carriesSensor ;
    rdfs:comment "Specifies the platform hosting a given sensor." .

ffonto:generatesObservation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:label "generatesObservation" ;
    rdfs:range ffonto:Observation ;
    rdfs:comment "Links a sensor to the observations it produces." .

ffonto:sensorAccuracy rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:label "sensorAccuracy" ;
    rdfs:comment "Represents the accuracy of a sensor measurement."@en ;
    rdfs:range xsd:decimal .

ffonto:samplingRate rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:label "samplingRate" ;
    rdfs:comment "Represents the frequency at which a sensor or system collects measurements."@en ;
    rdfs:range xsd:decimal .

ffonto:detectionRange rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Sensor ;
    rdfs:comment "Represents the maximum distance or area within which a sensor can detect a phenomenon."@en ;
    rdfs:label "detectionRange" ;
    rdfs:range xsd:decimal .

#################################################################
# Policy Frameworks & Governance
#################################################################

ffonto:PolicyFramework a owl:Class ;
    rdfs:label "PolicyFramework"@en ;
    rdfs:comment "Abstract governance or regulatory framework constraining wildfire management and response actions." .

ffonto:WildfirePolicy a owl:Class ; 
    rdfs:subClassOf ffonto:PolicyFramework ;
    rdfs:label "WildfirePolicy"@en ;
    rdfs:comment "Policy instruments addressing prevention, preparedness, response, and recovery for wildfires."@en .

ffonto:EvacuationPolicy a owl:Class ; 
    rdfs:subClassOf ffonto:PolicyFramework ;
    rdfs:label "EvacuationPolicy"@en ;
    rdfs:comment "Policy that defines triggers, procedures, and authority for moving people away from hazard zones."@en .

ffonto:AirQualityPolicy a owl:Class ;
    rdfs:subClassOf ffonto:PolicyFramework ;
    rdfs:label "AirQualityPolicy"@en ;
    rdfs:comment "Policy framework defining rules, thresholds, standards, and response measures for managing air quality and protecting public health during wildfire smoke events and related atmospheric pollution."@en .

ffonto:LandManagementPolicy a owl:Class ; 
    rdfs:subClassOf ffonto:PolicyFramework ;
    rdfs:label "LandManagementPolicy"@en ;
    rdfs:comment "Policy governing use, treatment, and management of land to reduce wildfire risk and support ecosystem resilience."@en .

ffonto:governedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:PolicyFramework ;
    rdfs:label "governedBy" ;
    rdfs:comment "Associates a fire event with the applicable policy framework." .

ffonto:constrainedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:label "constrainedBy" ;
    rdfs:range ffonto:PolicyFramework ;
    rdfs:comment "Specifies policy constraints applied to management actions." .

ffonto:followsPolicy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:label "followsPolicy" ;
    rdfs:range ffonto:PolicyFramework ;
    rdfs:comment "Indicates organizational adherence to policy frameworks." .

ffonto:prohibits rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:PolicyFramework ;
    rdfs:label "prohibits" ;
    rdfs:range ffonto:ManagementAction ;
    rdfs:comment "Specifies management actions prohibited under a policy." .

ffonto:invalidAction rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ManagementAction ;
    rdfs:label "invalidAction" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Flags actions that violate policy constraints." .

#################################################################
# Insurance & Legal Processes
#################################################################

ffonto:InsuranceProcess a owl:Class ;
    rdfs:label "InsuranceProcess"@en ;
    rdfs:comment "Abstract insurance or compensation process triggered by wildfire impacts." .

ffonto:ClaimAssessment a owl:Class ; 
    rdfs:subClassOf ffonto:InsuranceProcess ;
    rdfs:label "ClaimAssessment"@en ;
    rdfs:comment "An insurance process evaluating the validity and value of submitted claims after a disaster."@en .

ffonto:DamageCompensation a owl:Class ; 
    rdfs:subClassOf ffonto:InsuranceProcess ;
    rdfs:label "DamageCompensation"@en ;
    rdfs:comment "An insurance or restitution process for compensating losses caused by wildfire impacts."@en .

ffonto:RiskPremiumCalculation a owl:Class ;
    rdfs:subClassOf ffonto:InsuranceProcess ;
    rdfs:label "RiskPremiumCalculation"@en ;
    rdfs:comment "Insurance process involving the estimation and computation of insurance premiums based on assessed wildfire risks, exposure levels, historical loss data, and projected fire impacts."@en .

ffonto:LiabilityConsideration a owl:Class ;
    rdfs:label "LiabilityConsideration"@en ;
    rdfs:comment "Abstract legal liability classification applied to wildfire-related responsibility." .

ffonto:NegligenceLiability a owl:Class ; 
    rdfs:subClassOf ffonto:LiabilityConsideration ;
    rdfs:label "NegligenceLiability"@en ;
    rdfs:comment "Legal consideration assigning responsibility due to negligent acts or omissions leading to damage."@en .

ffonto:InfrastructureLiability a owl:Class ;
    rdfs:subClassOf ffonto:LiabilityConsideration ;
    rdfs:label "InfrastructureLiability"@en ;
    rdfs:comment "Liability consideration relating to the legal responsibility of infrastructure owners or operators for fire ignition or damage resulting from faulty, poorly maintained, or improperly operated infrastructure such as power lines, railways, or substations."@en .

ffonto:NaturalCauseExemption a owl:Class ;
    rdfs:subClassOf ffonto:LiabilityConsideration ;
    rdfs:label "NaturalCauseExemption"@en ;
    rdfs:comment "Liability consideration indicating exemption from legal responsibility when a fire is determined to have been caused solely by natural phenomena such as lightning, volcanic activity, or extreme weather, without human negligence or fault."@en .

ffonto:triggersInsuranceProcess rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:InsuranceProcess ;
    rdfs:label "triggersInsuranceProcess" ;
    rdfs:comment "Links fire events to triggered insurance processes." .

ffonto:evaluatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:InfrastructureEffect ;
    rdfs:label "evaluatedBy" ;
    rdfs:range ffonto:InsuranceProcess ;
    rdfs:comment "Specifies which insurance process evaluates infrastructure damage." .

ffonto:involvesLiability rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "involvesLiability" ;
    rdfs:range ffonto:LiabilityConsideration ;
    rdfs:comment "Associates a fire event with applicable liability considerations." .

#################################################################
# Climate & Weather Anomalies
#################################################################

ffonto:ClimateAnomaly a owl:Class ;
    rdfs:label "ClimateAnomaly"@en ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:comment "Large-scale climate or weather anomaly influencing wildfire risk and behavior." .

ffonto:ElNino a owl:Class ; 
    rdfs:subClassOf ffonto:ClimateAnomaly ;
    rdfs:label "ElNiño"@en ;
    rdfs:comment "A large-scale ocean–atmosphere climate anomaly associated with shifts in precipitation and temperature patterns."@en .

ffonto:MarineHeatWave a owl:Class ; 
    rdfs:subClassOf ffonto:ClimateAnomaly ;
    rdfs:label "MarineHeatWave"@en ;
    rdfs:comment "A prolonged anomalous warming of ocean surface waters that can influence regional climate and drought patterns."@en .

ffonto:ProlongedDroughtAnomaly a owl:Class ;
    rdfs:subClassOf ffonto:ClimateAnomaly ;
    rdfs:label "ProlongedDroughtAnomaly"@en ;
    rdfs:comment "Climate anomaly representing an extended period of abnormally low precipitation and soil moisture that leads to persistent dry conditions, increased fuel desiccation, and elevated wildfire risk."@en .

ffonto:LaNina a owl:Class ;
    rdfs:subClassOf ffonto:ClimateAnomaly ;
    rdfs:label "LaNina"@en ;
    rdfs:comment "Climate anomaly representing the La Niña phase of the El Niño–Southern Oscillation, characterized by cooler-than-average sea surface temperatures in the equatorial Pacific and associated regional climate patterns that can influence drought, wind regimes, and wildfire risk."@en .

ffonto:influences rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ClimateAnomaly ;
    rdfs:label "influences" ;
    rdfs:range ffonto:EnvironmentalCondition ;
    rdfs:comment "Specifies environmental conditions influenced by a climate anomaly." .

ffonto:increasesRisk rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ClimateAnomaly ;
    rdfs:label "increasesRisk" ;
    rdfs:range ffonto:FireRisk ;
    rdfs:comment "Links anomalies to elevated wildfire risk levels." .

#################################################################
# Property Chains for Reasoning
#################################################################

# Fire → detectedBy Sensor
ffonto:detectedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Sensor ;
    rdfs:label "detectedBy" ;
    rdfs:comment "Associates a forest fire with the sensor that detected it." .

#################################################################
# Fire → Identification → Sensor detection inference
#################################################################

ffonto:generatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireIdentificationMethod ;
    rdfs:range owl:Thing ;
    rdfs:label "domain" ;
    rdfs:comment "Associates an identification method with the agent, model, or sensor that generated it." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:detectedBy ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:identifiedBy ffonto:generatedBy ) ;
  rdfs:comment "Infers which sensor detected a fire based on the identification method used and the sensor that generated the observation."
] .


# Platform monitors Fire
ffonto:monitors rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Platform ;
    rdfs:label "monitors" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Associates a monitoring platform with the forest fire it monitors." .

# Action → Exposure inference
ffonto:ExposureTarget a owl:Class ;
    rdfs:label "ExposureTarget" ;
    rdfs:comment "Abstract hazard or risk entity to which personnel may be exposed." .

ffonto:FireHazard rdfs:subClassOf ffonto:ExposureTarget .
ffonto:FireRisk rdfs:subClassOf ffonto:ExposureTarget .

ffonto:exposedTo rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Personnel ;
    rdfs:label "exposedTo" ;
    rdfs:range ffonto:ExposureTarget ;
    rdfs:comment "Associates personnel with hazards or risks to which they are exposed." .

#################################################################
# Platform → Fire monitoring inference
#################################################################

ffonto:ObservedEntity a owl:Class ;
    rdfs:label "ObservedEntity"@en ;
    rdfs:comment "Abstract entity that can be observed by sensors or observers." .

# ffonto:ForestFire rdfs:subClassOf ffonto:ObservedEntity .
ffonto:EnvironmentalCondition rdfs:subClassOf ffonto:ObservedEntity .
ffonto:SmokePlume rdfs:subClassOf ffonto:ObservedEntity .

ffonto:observes rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:label "observes" ;
    rdfs:range ffonto:ObservedEntity ;
    rdfs:comment "Associates an observation with the entity it observes." .

[ a owl:Axiom ;
  owl:annotatedSource ffonto:monitors ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:performedFrom ffonto:observes ) ;
  rdfs:comment "Infers which platform is monitoring a forest fire based on the platform from which an observation observing that fire was performed."
] .


#################################################################
# Action → Exposure inference
#################################################################

[ a owl:Axiom ;
  owl:annotatedSource ffonto:exposedTo ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:performsAction ffonto:involvesPosture ) ;
  rdfs:comment "Infers personnel exposure from the action they perform and the posture involved in that action."
] .


#################################################################
# Climate anomaly → Fire influence inference
#################################################################

[ a owl:Axiom ;
  owl:annotatedSource ffonto:influencedBy ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:increasesRisk ffonto:hasRisk ) ;
  rdfs:comment "Infers that a forest fire is influenced by a climate anomaly when the anomaly increases a fire risk that the fire has."
] .


#################################################################
# Disjointness & Constraints
#################################################################

#################################################################
# Disjoint Fire Identification Methods
#################################################################

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:HumanDetection
                ffonto:ModelInference
                ffonto:SensorObservation ) ;
  rdfs:comment "Fire identification methods are mutually exclusive: human, model-based, or sensor-based."
] .

#################################################################
# Platform and Sensor are disjoint
#################################################################

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:Platform
                ffonto:Sensor ) ;
  rdfs:comment "Platforms and sensors are disjoint: a platform hosts sensors but is not itself a sensor."
] .


#################################################################
# Policy, Insurance, and Liability domains are disjoint
#################################################################

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:PolicyFramework
                ffonto:InsuranceProcess
                ffonto:LiabilityConsideration ) ;
  rdfs:comment "Governance policies, insurance processes, and liability considerations are mutually disjoint legal and regulatory domains."
] .


#################################################################
# Climate anomalies and environmental conditions are disjoint
#################################################################

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:ClimateAnomaly
                ffonto:EnvironmentalCondition ) ;
  rdfs:comment "Climate anomalies are distinct from environmental conditions; anomalies influence conditions but are not conditions themselves."
] .

#################################################################
# Every Sensor must have at least one SensorType
#################################################################

ffonto:Sensor rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:hasSensorType ;
      owl:someValuesFrom ffonto:SensorType ;
      rdfs:comment "Every sensor must be classified by at least one sensor type."
    ] .

#################################################################
# FireTimeline & Temporal Modeling
#################################################################

ffonto:FireTimeline a owl:Class ;
    rdfs:label "FireTimeline"@en ;
    rdfs:comment "Temporal history of a forest fire capturing ignition, detection, response, containment, and extinguishment events."@en .

ffonto:TemporalInterval a owl:Class ;
    rdfs:label "TemporalInterval"@en ;
    rdfs:comment "Abstract time interval used to represent durations of fire phases and operational periods." .

ffonto:IgnitionTime a owl:Class ; 
    rdfs:label "IgnitionTime"@en ;
    rdfs:comment "Date and time when combustion first started."@en ;
    rdfs:subClassOf ffonto:FireTimeline .

ffonto:DetectionTime a owl:Class ; 
    rdfs:subClassOf ffonto:FireTimeline ;
    rdfs:label "DetectionTime"@en ;
    rdfs:comment "The date/time at which a fire was first detected or reported."@en .

ffonto:FirstResponseTime a owl:Class ; 
    rdfs:subClassOf ffonto:FireTimeline ;
    rdfs:label "FirstResponse time"@en ;
    rdfs:comment "Timestamp when the first responding unit or personnel arrived at the incident."@en .

ffonto:ContainmentTime a owl:Class ; 
    rdfs:label "ContainmentTime"@en ;
    rdfs:comment "Time at which the fire perimeter was fully surrounded by control lines."@en ;
    rdfs:subClassOf ffonto:FireTimeline .

ffonto:ControlTime a owl:Class ; 
    rdfs:subClassOf ffonto:FireTimeline ;
    rdfs:label "ControlTime"@en ;
    rdfs:comment "Time at which the fire was brought under control and spread was halted."@en .

ffonto:ExtinguishedTime a owl:Class ; 
    rdfs:subClassOf ffonto:FireTimeline ;
    rdfs:label "ExtinguishedTime"@en ;
    rdfs:comment "Time at which all flaming and smoldering combustion was eliminated."@en .

ffonto:ActiveDuration a owl:Class ; 
    rdfs:subClassOf ffonto:TemporalInterval ;
    rdfs:label "ActiveDuration"@en ;
    rdfs:comment "Time interval during which a fire displays active flaming and spread."@en .

ffonto:SuppressionDuration a owl:Class ; 
    rdfs:subClassOf ffonto:TemporalInterval ;
    rdfs:label "SuppressionDuration"@en ;
    rdfs:comment "Time interval during which active suppression operations are conducted on a fire."@en .

ffonto:RecoveryDuration a owl:Class ;
    rdfs:subClassOf ffonto:TemporalInterval ;
    rdfs:label "RecoveryDuration"@en ;
    rdfs:comment "Temporal interval representing the length of time required for ecological systems, infrastructure, communities, or services to recover to functional or pre-fire conditions following a fire event."@en .

ffonto:TemporalInterval rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:intervalOf ;
      owl:someValuesFrom ffonto:FireTimeline ;
      rdfs:comment "Every temporal interval must be part of at least one fire timeline."
    ] .

ffonto:intervalOf rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:TemporalInterval ;
    rdfs:label "intervalOf" ;
    rdfs:range ffonto:FireTimeline ;
    rdfs:comment "Associates a temporal interval with the fire timeline it belongs to." .

ffonto:hasTimeline rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "hasTimeline" ;
    rdfs:range ffonto:FireTimeline ;
    rdfs:comment "Associates a forest fire with one or more temporal timelines." .

ffonto:occursAtTime rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:label "occursAtTime" ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Specifies the exact time at which a fire-related event occurred." .

ffonto:occursDuring rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FirePhase ;
    rdfs:label "occursDuring" ;
    rdfs:range ffonto:TemporalInterval ;
    rdfs:comment "Associates a fire phase with its temporal duration interval." .

ffonto:hasTemporalInterval rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireTimeline ;
    rdfs:range ffonto:TemporalInterval ;
    rdfs:label "hasTemporalInterval" ;
    rdfs:comment "Links a fire timeline to its associated temporal intervals." .

ffonto:hasDuration rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "hasDuration" ;
    rdfs:range ffonto:TemporalInterval ;
    rdfs:comment "Represents the inferred duration of a forest fire." .

#################################################################
# Resource Deployment & Logistics
#################################################################

ffonto:ResourceDeployment a owl:Class ;
    rdfs:label "ResourceDeployment"@en ;
    rdfs:comment "Operational deployment record describing how resources are assigned, timed, and located during wildfire response." .

ffonto:ResourceStatus a owl:Class ;
    rdfs:label "ResourceStatus"@en ;
    rdfs:comment "Operational status of a response resource." .

ffonto:Available a owl:Class ; 
    rdfs:subClassOf ffonto:ResourceStatus ;
    rdfs:label "Available"@en ;
    rdfs:comment "Resource status indicating the asset is ready for deployment and not currently assigned."@en .

ffonto:Deployed a owl:Class ; 
    rdfs:subClassOf ffonto:ResourceStatus ;
    rdfs:label "Deployed"@en ;
    rdfs:comment "Resource status indicating the asset is currently assigned and active in the field."@en .

ffonto:Damaged a owl:Class ;
    rdfs:subClassOf ffonto:ResourceStatus ;
    rdfs:label "Damaged"@en ;
    rdfs:comment "Resource status indicating that a resource, asset, or infrastructure element has suffered physical harm or functional degradation due to fire, heat, smoke, or related hazards, potentially limiting its usability or requiring repair or replacement."@en .

ffonto:UnderMaintenance a owl:Class ; 
    rdfs:subClassOf ffonto:ResourceStatus ;
    rdfs:label "UnderMaintenance"@en ;
    rdfs:comment "Resource status indicating an asset is currently unavailable due to maintenance activities."@en .

ffonto:LogisticsSupport a owl:Class ;
    rdfs:label "LogisticsSupport"@en ;
    rdfs:comment "Logistical support entity providing supplies and services to operational units." .

ffonto:FuelSupply a owl:Class ;
    rdfs:subClassOf ffonto:LogisticsSupport ;
    rdfs:label "FuelSupply"@en ;
    rdfs:comment "Logistics support function responsible for providing, transporting, storing, and managing fuel required for vehicles, aircraft, generators, pumps, and other firefighting equipment during fire operations."@en .

ffonto:FoodSupply a owl:Class ;
    rdfs:subClassOf ffonto:LogisticsSupport ;
    rdfs:label "FoodSupply"@en ;
    rdfs:comment "Logistics support function responsible for providing meals, rations, and potable provisions to firefighters, responders, evacuees, and support personnel during fire incidents and emergency operations."@en .

ffonto:WaterSupply a owl:Class ; 
    rdfs:subClassOf ffonto:LogisticsSupport ;
    rdfs:label "WaterSupply"@en ;
    rdfs:comment "Logistical resource representing water available for suppression, camp use, or community needs."@en .

ffonto:ShelterCamp a owl:Class ;
    rdfs:subClassOf ffonto:LogisticsSupport ;
    rdfs:label "ShelterCamp"@en ;
    rdfs:comment "Logistics support function responsible for establishing and managing temporary shelters or camps to house evacuees, displaced populations, or firefighting personnel during fire incidents and emergency operations."@en .

ffonto:MedicalSupply a owl:Class ;
    rdfs:subClassOf ffonto:LogisticsSupport ;
    rdfs:label "MedicalSupply"@en ;
    rdfs:comment "Logistics support function responsible for providing medical equipment, medications, first aid materials, and healthcare consumables required for treating injuries, illnesses, and smoke-related conditions during fire incidents."@en .

ffonto:deployedIn rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResourceDeployment ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "deployedIn" ;
    rdfs:comment "Associates a deployment record with the fire in which it occurs." .

ffonto:assignsResource rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResourceDeployment ;
    rdfs:label "assignsResource" ;
    rdfs:range ffonto:ResponseResource ;
    rdfs:comment "Specifies which resource is assigned in a deployment." .

ffonto:coordinatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResourceDeployment ;
    rdfs:label "coordinatedBy" ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:comment "Links a deployment to the organization coordinating it." .

ffonto:isCoordinatorOf rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:range ffonto:OperationalUnit ;
    rdfs:label "isCoordinatorOf" ;
    rdfs:comment "Links an organization to entities it coordinates." .

ffonto:hasStatus rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResponseResource ;
    rdfs:range ffonto:ResourceStatus ;
    rdfs:label "hasStatus" ;
    rdfs:comment "Specifies the current operational status of a response resource." .

ffonto:supports rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:LogisticsSupport ;
    rdfs:label "supports" ;
    rdfs:range ffonto:OperationalUnit ;
    rdfs:comment "Associates logistics support entities with operational units they sustain." .

#################################################################
# Decision & Strategy Modeling
#################################################################

ffonto:Decision a owl:Class ;
    rdfs:label "Decision"@en ;
    rdfs:comment "Abstract command-level decision taken by firefighting leadership." .

ffonto:EvacuationDecision a owl:Class ;
    rdfs:subClassOf ffonto:Decision ;
    rdfs:label "EvacuationDecision"@en ;
    rdfs:comment "Decision concerning whether, when, and how to evacuate populations from threatened areas based on fire behavior, risk assessments, weather conditions, infrastructure status, and public safety considerations."@en .

ffonto:SuppressionDecision a owl:Class ;
    rdfs:subClassOf ffonto:Decision ;
    rdfs:label "SuppressionDecision"@en ;
    rdfs:comment "Decision concerning the selection, timing, and allocation of firefighting strategies, tactics, and resources to control, contain, or suppress a fire based on fire behavior, risk levels, operational capacity, and safety constraints."@en .

ffonto:BackburnAuthorization a owl:Class ; 
    rdfs:subClassOf ffonto:Decision ;
    rdfs:label "BackburnAuthorization"@en ;
    rdfs:comment "A decision or permit authorizing the use of backburns (controlled burns) to remove fuel ahead of an advancing wildfire."@en .

ffonto:ResourceReallocationDecision a owl:Class ;
    rdfs:subClassOf ffonto:Decision ;
    rdfs:label "ResourceReallocationDecision"@en ;
    rdfs:comment "Decision concerning the redistribution, redeployment, or reassignment of firefighting resources, personnel, equipment, or logistics assets between locations or tasks in response to changing fire behavior, risk levels, or operational priorities."@en .

ffonto:madeBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Decision ;
    rdfs:range ffonto:CommandStaff ;
    rdfs:label "madeBy" ;
    rdfs:comment "Associates a decision with the command staff member or unit that made it." .

ffonto:Decision rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:madeBy ;
      owl:someValuesFrom ffonto:CommandStaff ;
      rdfs:comment "Every decision must be made by at least one command staff member."
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:affects ;
      owl:someValuesFrom ffonto:ManagementAction ;
      rdfs:comment "Every decision must affect at least one management action."
    ] .

ffonto:OperationalStrategy a owl:Class ;
    rdfs:label "OperationalStrategy"@en ;
    rdfs:comment "Strategic operational approach selected to guide wildfire response actions." .

ffonto:DirectSuppressionStrategy a owl:Class ; 
    rdfs:subClassOf ffonto:OperationalStrategy ;
    rdfs:label "DirectSuppressionStrategy"@en ;
    rdfs:comment "A strategy using direct application of resources to the fire edge (e.g., wetting, line construction) to extinguish fire."@en .

ffonto:IndirectSuppressionStrategy a owl:Class ; 
    rdfs:subClassOf ffonto:OperationalStrategy ;
    rdfs:label "IndirectSuppressionStrategy"@en ;
    rdfs:comment "Strategy constructing control lines away from the fire edge and using burnout or backburn operations."@en .

ffonto:ContainmentStrategy a owl:Class ; 
    rdfs:subClassOf ffonto:OperationalStrategy ;
    rdfs:label "ContainmentStrategy"@en ;
    rdfs:comment "A strategy aimed at establishing control lines around a fire to prevent spread beyond the perimeter."@en .

ffonto:EvacuationStrategy a owl:Class ; 
    rdfs:subClassOf ffonto:OperationalStrategy ;
    rdfs:label "EvacuationStrategy"@en ;
    rdfs:comment "Strategy guiding the movement of populations away from threatened areas."@en .

ffonto:MonitoringStrategy a owl:Class ; 
    rdfs:subClassOf ffonto:OperationalStrategy ;
    rdfs:label "MonitoringStrategy"@en ;
    rdfs:comment "An operational strategy focused on observation, surveillance, and assessment rather than active suppression."@en .

ffonto:DecisionRationale a owl:Class ;
    rdfs:label "DecisionRationale"@en ;
    rdfs:comment "Justification basis used to explain and audit command decisions." .

ffonto:WeatherJustification a owl:Class ; 
    rdfs:subClassOf ffonto:DecisionRationale ;
    rdfs:label "WeatherJustification"@en ;
    rdfs:comment "A decision rationale that cites current or forecast meteorological conditions as the reason for a strategy choice."@en .

ffonto:RiskJustification a owl:Class ;
    rdfs:subClassOf ffonto:DecisionRationale ;
    rdfs:label "RiskJustification"@en ;
    rdfs:comment "Decision rationale based on the assessment of fire-related risks, including life safety, spread potential, infrastructure threat, or health impacts, used to justify the selection of actions or strategies."@en .

ffonto:PolicyJustification a owl:Class ;
    rdfs:subClassOf ffonto:DecisionRationale ;
    rdfs:label "PolicyJustification"@en ;
    rdfs:comment "Decision rationale based on compliance with laws, regulations, emergency policies, or institutional guidelines that govern wildfire response, evacuation, air quality management, or resource deployment."@en .

ffonto:ResourceJustification a owl:Class ;
    rdfs:subClassOf ffonto:DecisionRationale ;
    rdfs:label "ResourceJustification"@en ;
    rdfs:comment "Decision rationale based on the availability, scarcity, capability, or condition of resources, used to justify prioritization, reallocation, limitation, or selection of response actions."@en .

ffonto:justifies rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:DecisionRationale ;
    rdfs:label "justifies" ;
    rdfs:range ffonto:Decision ;
    rdfs:comment "Associates a rationale with the decision it justifies." .

ffonto:DecisionRationale rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:justifies ;
      owl:someValuesFrom ffonto:Decision ;
      rdfs:comment "Every decision rationale must justify at least one decision."
    ] .

ffonto:makesDecision rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:CommandStaff ;
    rdfs:label "makesDecision" ;
    rdfs:range ffonto:Decision ;
    rdfs:comment "Associates command staff with the decisions they issue." .

ffonto:selectsStrategy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Decision ;
    rdfs:label "selectsStrategy" ;
    rdfs:range ffonto:OperationalStrategy ;
    rdfs:comment "Specifies the operational strategy selected by a decision." .

ffonto:justifiedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Decision ;
    rdfs:label "justifiedBy" ;
    rdfs:range ffonto:DecisionRationale ;
    rdfs:comment "Links decisions to their explanatory rationale." .

ffonto:affects rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Decision ;
    rdfs:label "affects" ;
    rdfs:range ffonto:ManagementAction ;
    rdfs:comment "Associates decisions with the management actions they influence." .

ffonto:appliedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:OperationalStrategy ;
    rdfs:range ffonto:ManagementAction ;
    rdfs:label "appliedBy" ;
    rdfs:comment "Specifies which management actions implement a given strategy." .

ffonto:controls rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Decision ;
    rdfs:range ffonto:ManagementAction ;
    rdfs:label "controls" ;
    rdfs:comment "Represents management actions controlled by a decision." .

#################################################################
# Smoke Plume & Atmospheric Transport
#################################################################

ffonto:SmokePlume a owl:Class ;
    rdfs:label "SmokePlume"@en ;
    rdfs:comment "Atmospheric smoke plume generated by a forest fire and transported by meteorological processes." .

ffonto:Pollutant a owl:Class ;
    rdfs:label "Pollutant"@en ;
    rdfs:comment "Air pollutant emitted by wildfire combustion." .

ffonto:PM2_5 a owl:Class ; 
    rdfs:subClassOf ffonto:Pollutant ;
    rdfs:label "PM2_5"@en ;
    rdfs:comment "Fine particulate matter with diameter less than 2.5 micrometers, strongly associated with wildfire smoke health impacts."@en .

ffonto:PM10 a owl:Class ; 
    rdfs:subClassOf ffonto:Pollutant ;
    rdfs:label "PM10"@en ;
    rdfs:comment "Particulate matter with diameter less than 10 micrometers present in smoke and ash."@en .

ffonto:BlackCarbon a owl:Class ; 
    rdfs:subClassOf ffonto:Pollutant ;
    rdfs:label "BlackCarbon"@en ;
    rdfs:comment "A carbonaceous particulate produced by incomplete combustion; an important climate forcer and air quality pollutant."@en .

ffonto:CarbonMonoxide a owl:Class ; 
    rdfs:subClassOf ffonto:Pollutant ;
    rdfs:label "CarbonMonoxide (CO)"@en ;
    rdfs:comment "A colorless, odorless gas produced by incomplete combustion; important health hazard in smoke."@en .

ffonto:Ozone a owl:Class ; 
    rdfs:subClassOf ffonto:Pollutant ;
    rdfs:label "Ozone"@en ;
    rdfs:comment "Secondary air pollutant formed photochemically from wildfire emissions, harmful to respiratory health."@en .

ffonto:AtmosphericTransport a owl:Class ;
    rdfs:label "AtmosphericTransport"@en ;
    rdfs:comment "Atmospheric process transporting smoke and pollutants over distance." .

ffonto:LongRangeTransport a owl:Class ; 
    rdfs:subClassOf ffonto:AtmosphericTransport ;
    rdfs:label "LongRangeTransport"@en ;
    rdfs:comment "Atmospheric transport carrying smoke and pollutants across national or continental scales."@en .

ffonto:RegionalTransport a owl:Class ; 
    rdfs:subClassOf ffonto:AtmosphericTransport ;
    rdfs:label "RegionalTransport"@en ;
    rdfs:comment "Atmospheric transport operating on a regional scale, moving pollutants and smoke across hundreds of kilometers."@en .

ffonto:DepositionZone a owl:Class ; 
    rdfs:subClassOf ffonto:AtmosphericTransport ;
    rdfs:label "DepositionZone"@en ;
    rdfs:comment "Area where airborne particles and pollutants settle out of the atmosphere onto land or water."@en .

ffonto:partOfPlume rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:AtmosphericTransport ;
    rdfs:range ffonto:SmokePlume ;
    rdfs:label "partOfPlume" ;
    rdfs:comment "Associates an atmospheric transport process with the smoke plume in which it operates." .


ffonto:AtmosphericTransport rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:transports ;
      owl:someValuesFrom ffonto:Pollutant ;
      rdfs:comment "Every atmospheric transport process must carry at least one pollutant."
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:partOfPlume ;
      owl:someValuesFrom ffonto:SmokePlume ;
      rdfs:comment "Every atmospheric transport process must be part of at least one smoke plume."
    ] .

ffonto:generatesSmokePlume rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:SmokePlume ;
    rdfs:label "generatesSmokePlume" ;
    rdfs:comment "Associates a forest fire with generated smoke plumes." .

ffonto:transports rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SmokePlume ;
    rdfs:label "transports" ;
    rdfs:range ffonto:Pollutant ;
    rdfs:comment "Specifies which pollutants are transported within a smoke plume." .

ffonto:carries rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:AtmosphericTransport ;
    rdfs:label "carries" ;
    rdfs:range ffonto:Pollutant ;
    rdfs:comment "Specifies pollutants carried by atmospheric transport mechanisms." .

ffonto:threatensPopulation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "threatensPopulation" ;
    rdfs:range ffonto:PopulationGroup ;
    rdfs:comment "Represents populations threatened by fire-generated smoke exposure." .

#################################################################
# Secondary Disasters & Re-Ignition
#################################################################

ffonto:SecondaryDisaster a owl:Class ;
    rdfs:label "SecondaryDisaster"@en ;
    rdfs:comment "Cascading disaster triggered by wildfire impacts." .

ffonto:Landslide a owl:Class ; 
    rdfs:subClassOf ffonto:SecondaryDisaster ;
    rdfs:label "Landslide"@en ;
    rdfs:comment "Downslope movement of soil and rock often triggered by post-fire rainfall on destabilized slopes."@en .

ffonto:DebrisFlow a owl:Class ; 
    rdfs:subClassOf ffonto:SecondaryDisaster ;
    rdfs:label "DebrisFlow"@en ;
    rdfs:comment "A fast-moving mixture of water, soil, rock, and organic debris often triggered by post-fire rainfall over burn scars."@en .

ffonto:FlashFlood a owl:Class ; 
    rdfs:subClassOf ffonto:SecondaryDisaster ;
    rdfs:label "FlashFlood"@en ;
    rdfs:comment "Sudden flooding event occurring after intense rainfall over burn scars."@en .

ffonto:SoilErosion a owl:Class ; 
    rdfs:subClassOf ffonto:SecondaryDisaster ;
    rdfs:label "SoilErosion"@en ;
    rdfs:comment "Removal of topsoil following vegetation loss; commonly accelerated after wildfire and heavy rainfall."@en .

ffonto:InfrastructureCollapse a owl:Class ; 
    rdfs:subClassOf ffonto:SecondaryDisaster ;
    rdfs:label "InfrastructureCollapse"@en ;
    rdfs:comment "Failure of built structures due to fire damage or post-fire geomorphic hazards."@en .

ffonto:ReIgnitionEvent a owl:Class ;
    rdfs:label "ReIgnitionEvent"@en ;
    rdfs:comment "Post-fire ignition event restarting or expanding wildfire activity." .

ffonto:HotspotReIgnition a owl:Class ; 
    rdfs:subClassOf ffonto:ReIgnitionEvent ;
    rdfs:label "HotspotReIgnition"@en ;
    rdfs:comment "A re-ignition event initiated by an unextinguished hotspot or smoldering fuel."@en .

ffonto:SmolderingReIgnition a owl:Class ; 
    rdfs:subClassOf ffonto:ReIgnitionEvent ;
    rdfs:label "SmolderingReIgnition"@en ;
    rdfs:comment "Re-ignition caused by prolonged smoldering combustion reigniting surface fuels."@en .

ffonto:LightningReIgnition a owl:Class ; 
    rdfs:subClassOf ffonto:ReIgnitionEvent ;
    rdfs:label "LightningReIgnition"@en ;
    rdfs:comment "Re-ignition triggered by lightning strikes in recently burned areas."@en .

ffonto:triggersSecondaryDisaster rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:SecondaryDisaster ;
    rdfs:label "triggersSecondaryDisaster" ;
    rdfs:comment "Associates forest fires with triggered cascading disasters." .

ffonto:produces rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:PostFirePhase ;
    rdfs:label "produces" ;
    rdfs:range ffonto:ReIgnitionEvent ;
    rdfs:comment "Specifies re-ignition events produced during post-fire phases." .

ffonto:restarts rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ReIgnitionEvent ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "restarts" ;
    rdfs:comment "Associates re-ignition events with restarted fires." .

#################################################################
# Property Chains for Advanced Reasoning (RDF4J-safe)
#################################################################

# Fire → Timeline → Duration
[ a owl:Axiom ;
  owl:annotatedSource ffonto:hasDuration ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasTimeline ffonto:hasTemporalInterval ) ;
  rdfs:comment "Infers fire duration from its timeline and associated temporal intervals."
] .

# Fire → Deployment → Resource
[ a owl:Axiom ;
  owl:annotatedSource ffonto:usesResource ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:assignsResource ffonto:deployedIn ) ;
  rdfs:comment "Infers which resources are used by a fire based on deployment assignments."
] .

# Decision → Strategy → Action
[ a owl:Axiom ;
  owl:annotatedSource ffonto:controls ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:selectsStrategy ffonto:appliedBy ) ;
  rdfs:comment "Infers which management actions are controlled by a decision via selected strategies."
] .

# Fire → Smoke → Population
[ a owl:Axiom ;
  owl:annotatedSource ffonto:threatensPopulation ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:generatesSmokePlume ffonto:affectsPopulation ) ;
  rdfs:comment "Infers populations threatened by a fire based on its smoke plume impacts."
] .

ffonto:causes rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:EnvironmentalEffect ;    
    rdfs:label "causes" ;
    rdfs:range ffonto:SecondaryDisaster ;
    rdfs:comment "Associates an environmental effect with a secondary disaster it causes." .

# Fire → Effect → Secondary Disaster
[ a owl:Axiom ;
  owl:annotatedSource ffonto:triggersSecondaryDisaster ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedTarget ( ffonto:hasEffect ffonto:causes ) ;
  rdfs:comment "Infers secondary disasters triggered by a fire through environmental effects."
] .

#################################################################
# Disjointness & Constraints
#################################################################

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:Decision ffonto:OperationalStrategy ) ;
  rdfs:comment "Decisions and operational strategies are distinct cognitive and planning constructs."
] .

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:ResourceDeployment ffonto:LogisticsSupport ) ;
  rdfs:comment "Deployment records and logistics support entities are operationally disjoint."
] .

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:SmokePlume ffonto:Pollutant ) ;
  rdfs:comment "Smoke plumes are transport structures and are disjoint from the pollutants they carry."
] .

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:SecondaryDisaster ffonto:FireHazard ) ;
  rdfs:comment "Secondary disasters are not fire hazards but cascading consequences."
] .

[ a owl:AllDisjointClasses ;
  owl:members ( ffonto:ReIgnitionEvent ffonto:FireEvent ) ;
  rdfs:comment "Re-ignition events are distinct from primary fire events."
] .

#################################################################
# Every ForestFire must be identified by some identification method
#################################################################

ffonto:ForestFire rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:identifiedBy ;
      owl:someValuesFrom ffonto:FireIdentificationMethod ;
      rdfs:comment "Every forest fire must be identified by at least one fire identification method."
    ] .

#################################################################
# Every ForestFire must have a timeline
#################################################################

ffonto:ForestFire rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:hasTimeline ;
      owl:someValuesFrom ffonto:FireTimeline ;
      rdfs:comment "Every forest fire must be associated with at least one temporal timeline describing its evolution."
    ] .

#################################################################
# Every FireTimeline must include at least one temporal interval
#################################################################

ffonto:FireTimeline rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:hasTemporalInterval ;
      owl:someValuesFrom ffonto:TemporalInterval ;
      rdfs:comment "Every fire timeline must include at least one temporal interval representing fire activity or response phases."
    ] .

ffonto:FireTimeline rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:hasEvent ;
      owl:someValuesFrom ffonto:DetectionTime ;
      rdfs:comment "Every fire timeline must include a detection time event."
    ] .

ffonto:FireTimeline rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:hasEvent ;
      owl:someValuesFrom ffonto:IgnitionTime ;
      rdfs:comment "Every fire timeline must include an ignition time event."
    ] .

#################################################################
# Every InsuranceProcess must be triggered by some ForestFire
#################################################################

ffonto:InsuranceProcess rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:triggeredBy ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Every insurance process must be triggered by at least one forest fire event."
    ] .

#################################################################
# Every LiabilityConsideration must be assigned to some responsible entity
#################################################################

ffonto:LiabilityConsideration rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:assignedTo ;
      owl:someValuesFrom owl:Thing ;
      rdfs:comment "Every liability consideration must be assigned to some responsible person or organization."
    ] .

#################################################################
# Every LogisticsSupport must support at least one OperationalUnit
#################################################################

ffonto:LogisticsSupport rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:supports ;
      owl:someValuesFrom ffonto:OperationalUnit ;
      rdfs:comment "Every logistics support entity must support at least one operational unit."
    ] .

ffonto:evaluates rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:InsuranceProcess ;
    rdfs:label "evaluates"@en ;
    rdfs:range ffonto:InfrastructureEffect ;
    rdfs:comment "Associates an insurance process with infrastructure or asset effects it evaluates." .

ffonto:InsuranceProcess rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:evaluates ;
      owl:someValuesFrom ffonto:InfrastructureEffect ;
      rdfs:comment "Every insurance process must evaluate at least one infrastructure or asset effect."
    ] .

ffonto:FireRelatedEntity a owl:Class ;
    rdfs:label "FireRelatedEntity"@en ;
    rdfs:comment "Abstract entity that is related to or involves a forest fire." .

ffonto:LiabilityConsideration rdfs:subClassOf ffonto:FireRelatedEntity ;
    rdfs:label "LiabilityConsideration"@en ;
    rdfs:comment "Fire-related entity representing legal, regulatory, or responsibility factors used to determine fault, accountability, exemptions, or compensation obligations arising from fire ignition, spread, or damage."@en .

ffonto:InsuranceProcess rdfs:subClassOf ffonto:FireRelatedEntity ;
    rdfs:label "InsuranceProcess"@en ;
    rdfs:comment "Fire-related entity representing financial and administrative processes used to assess, price, insure, compensate, or recover losses associated with wildfire risk, damage, and recovery."@en .

ffonto:Decision rdfs:subClassOf ffonto:FireRelatedEntity ;
    rdfs:label "Decision"@en ;
    rdfs:comment "Fire-related entity representing a formal choice or determination made by authorities or command personnel that directs actions, resource use, or policies during fire incidents and emergency management."@en .

ffonto:involvesFire rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireRelatedEntity ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "involvesFire" ;
    rdfs:comment "Associates any fire-related entity with the forest fire it involves." .

ffonto:LiabilityConsideration rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:involvesFire ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Every liability consideration must relate to at least one forest fire event."
    ] .

ffonto:SupplyResource
  rdfs:label "supply resource"@en ;
  rdfs:comment "A resource or supply item used to support fire management, response, suppression, or recovery activities."@en .


ffonto:provides rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:LogisticsSupport ;
    rdfs:range ffonto:SupplyResource ;
    rdfs:label "provides" ;
    rdfs:comment "Associates a logistics support entity with the supply resources it provides." .

ffonto:LogisticsSupport rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:provides ;
      owl:someValuesFrom ffonto:SupplyResource ;
      rdfs:comment "Every logistics support entity must provide at least one type of supply resource."
    ] .

#################################################################
# Inverses needed for existential constraints
#################################################################

# inverse of Decision -> OperationalStrategy (selectsStrategy)
ffonto:selectedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:OperationalStrategy ;
    rdfs:label "selectedBy" ;
    rdfs:range ffonto:Decision ;
    rdfs:comment "Associates an operational strategy with the decision that selected it." .

# inverse of SmokePlume -> Pollutant (transports)
ffonto:transportedIn rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Pollutant ;
    rdfs:label "transportedIn" ;
    rdfs:range ffonto:SmokePlume ;
    rdfs:comment "Associates a pollutant with the smoke plume transporting it." .

# inverse of PostFirePhase -> ReIgnitionEvent (produces)
ffonto:producedDuring rdf:type owl:ObjectProperty ;
    rdfs:label "producedDuring" ;
    rdfs:domain ffonto:ReIgnitionEvent ;
    rdfs:range ffonto:PostFirePhase ;
    rdfs:comment "Associates a re-ignition event with the post-fire phase during which it occurred." .

# inverse of ForestFire -> SecondaryDisaster (triggersSecondaryDisaster)
ffonto:triggeredBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SecondaryDisaster ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "triggeredBy" ;
    rdfs:comment "Associates a secondary disaster with the forest fire that triggered it." .

# inverse of ResponseResource -> ResourceStatus (hasStatus)
ffonto:statusOf rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ResourceStatus ;
    rdfs:range ffonto:ResponseResource ;
    rdfs:label "statusOf" ;
    rdfs:comment "Associates a resource status with the response resource it describes." .

# inverse of PolicyFramework follows relation (followsPolicy exists from org -> policy)
ffonto:followedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:PolicyFramework ;
    rdfs:label "followedBy" ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:comment "Associates a policy framework with response organizations that follow it." .

# inverse of SmokePlume affectsPopulation (for clarity; not strictly required)
ffonto:affectedInPlume rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:PopulationGroup ;
    rdfs:label "affectedInPlume" ;
    rdfs:range ffonto:SmokePlume ;
    rdfs:comment "Associates a population group with the smoke plume affecting it." .

# Fire suppression status property (define if not present)
ffonto:hasSuppressionStatus rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:SuppressionStatus ;
    rdfs:label "hasSuppressionStatus" ;
    rdfs:comment "Associates a forest fire with a suppression status." .

ffonto:isStatusFor rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SuppressionStatus ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "isStatusFor" ;
    rdfs:comment "Associates a suppression status with the forest fire it refers to." .

# Timeline membership inverse (if not already present)
ffonto:partOfTimeline rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:TemporalEvent ;
    rdfs:label "partOfTimeline" ;
    rdfs:range ffonto:FireTimeline ;
    rdfs:comment "Associates a temporal event with the fire timeline it is part of." .

#################################################################
# Existential (some) restrictions — RDF4J-safe patterns
#################################################################

# OperationalStrategy: must be selected by at least one Decision OR applied by at least one ManagementAction
ffonto:OperationalStrategy rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:selectedBy ;
      owl:someValuesFrom ffonto:Decision ;
      rdfs:comment "Every operational strategy should be selected by at least one decision (existential)." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:appliedBy ;
      owl:someValuesFrom ffonto:ManagementAction ;
      rdfs:comment "Every operational strategy should be applied by at least one management action (existential)." 
    ] .

# Platform: must be operated by an organization OR carry at least one Sensor
ffonto:Platform rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:operatedBy ;
      owl:someValuesFrom ffonto:ResponseOrganization ;
      rdfs:comment "Each platform must be associated with an operating organization." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:carriesSensor ;
      owl:someValuesFrom ffonto:Sensor ;
      rdfs:comment "Each platform must carry at least one sensor." 
    ] .

# PolicyFramework: must be followed by at least one ResponseOrganization (existential)
ffonto:PolicyFramework rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:followedBy ;
      owl:someValuesFrom ffonto:ResponseOrganization ;
      rdfs:comment "Every policy framework must be followed by at least one response organization." 
    ] .

# Pollutant: must be transported in at least one SmokePlume (existential)
ffonto:Pollutant rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:transportedIn ;
      owl:someValuesFrom ffonto:SmokePlume ;
      rdfs:comment "Every pollutant instance should be transported (observed) in at least one smoke plume." 
    ] .

# ReIgnitionEvent: must be producedDuring a PostFirePhase AND must restart at least one ForestFire
ffonto:ReIgnitionEvent rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:producedDuring ;
      owl:someValuesFrom ffonto:PostFirePhase ;
      rdfs:comment "Every re-ignition event must be produced during a post-fire phase." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:restarts ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Every re-ignition event must restart or be linked to at least one forest fire." 
    ] .

# ResourceDeployment: must assign at least one resource and be deployed in at least one ForestFire
ffonto:ResourceDeployment rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:assignsResource ;
      owl:someValuesFrom ffonto:ResponseResource ;
      rdfs:comment "Each deployment must assign at least one response resource." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:deployedIn ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Each deployment must be associated with at least one forest fire." 
    ] .

# ResourceStatus: must be statusOf at least one ResponseResource (ensures statuses are grounded)
ffonto:ResourceStatus rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:statusOf ;
      owl:someValuesFrom ffonto:ResponseResource ;
      rdfs:comment "Each resource status instance must describe at least one response resource." 
    ] .

# SecondaryDisaster: must be triggeredBy at least one ForestFire OR causedBy at least one EnvironmentalEffect
# Note: SecondaryDisaster is NOT the same as ReIgnitionEvent. Secondary disasters are cascading non-fire phenomena
# (landslide, flash flood, erosion, collapse) while ReIgnitionEvent is a fire event that restarts burning.
ffonto:SecondaryDisaster rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:triggeredBy ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Secondary disasters should be traceable to at least one triggering forest fire." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:causedBy ;
      owl:someValuesFrom ffonto:EnvironmentalEffect ;
      rdfs:comment "Secondary disasters should be caused by at least one environmental effect linked to the fire." 
    ] .

# SmokePlume: must transport at least one Pollutant, be influenced by meteorology, and affect at least one population group
ffonto:SmokePlume rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:transports ;
      owl:someValuesFrom ffonto:Pollutant ;
      rdfs:comment "Each smoke plume must transport at least one pollutant." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:influencedBy ;
      owl:someValuesFrom ffonto:WeatherInteraction ;
      rdfs:comment "Each smoke plume must be influenced by at least one weather interaction." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:affectsPopulation ;
      owl:someValuesFrom ffonto:PopulationGroup ;
      rdfs:comment "Each smoke plume must affect at least one population group (for impact inference)." 
    ] .

# SuppressionStatus: require it to be isStatusFor some ForestFire (ensures statuses refer to a fire)
ffonto:SuppressionStatus rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:isStatusFor ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Each suppression status instance must be about at least one forest fire." 
    ] .

ffonto:TemporalEvent a owl:Class ;
    rdfs:label "TemporalEvent"@en ;
    rdfs:comment "Timestamped occurrence relevant to a fire timeline, such as ignition, detection, first response, containment, or extinguishment."@en .

# TemporalEvent: must have an occurrence time and be part of a FireTimeline
ffonto:TemporalEvent rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:occursAtTime ;
      owl:someValuesFrom xsd:dateTime ;
      rdfs:comment "Every temporal event must have at least one timestamp." 
    ] ,
    [ a owl:Restriction ;
      owl:onProperty ffonto:partOfTimeline ;
      owl:someValuesFrom ffonto:FireTimeline ;
      rdfs:comment "Every temporal event must belong to at least one fire timeline." 
    ] .

#################################################################
# Inverses for grounding SupplyResource and SensorType
#################################################################

ffonto:providedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SupplyResource ;
    rdfs:range ffonto:LogisticsSupport ;
    rdfs:label "providedBy" ;
    rdfs:comment "Associates a supply resource with the logistics support entity that provides it." .

ffonto:classifiesSensor rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SensorType ;
    rdfs:range ffonto:Sensor ;
    rdfs:label "classifiesSensor" ;
    rdfs:comment "Associates a sensor type with the sensors it classifies." .

#################################################################
# Every SupplyResource must be provided by some LogisticsSupport
#################################################################

ffonto:SupplyResource rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:providedBy ;
      owl:someValuesFrom ffonto:LogisticsSupport ;
      rdfs:comment "Every supply resource must be provided by at least one logistics support entity."
    ] .

#################################################################
# Every SensorType must classify at least one Sensor
#################################################################

ffonto:SensorType rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:classifiesSensor ;
      owl:someValuesFrom ffonto:Sensor ;
      rdfs:comment "Every sensor type must classify at least one sensor instance."
    ] .

ffonto:SupplyResource rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:supports ;
      owl:someValuesFrom ffonto:OperationalUnit ;
      rdfs:comment "Every supply resource should support at least one operational unit."
    ] .

#################################################################
# Forest Fire Type hierarchy
#################################################################

ffonto:ForestFireType a owl:Class ;
    rdfs:label "ForestFireType"@en ;
    rdfs:comment "Abstract classification of forest fire behavior and vertical burning structure." .

ffonto:SurfaceFire a owl:Class ;
    rdfs:label "SurfaceFire"@en ;
    rdfs:subClassOf ffonto:ForestFireType ;
    rdfs:comment "Fire burning through surface fuels such as grass, shrubs, and litter." .

ffonto:GroundFire a owl:Class ;
    rdfs:label "GroundFire"@en ;
    rdfs:subClassOf ffonto:ForestFireType ;
    rdfs:comment "Fire burning in subsurface organic material such as peat and roots." .

ffonto:PassiveCrownFire a owl:Class ;
    rdfs:label "PassiveCrownFire"@en ;
    rdfs:subClassOf ffonto:CrownFire ;
    rdfs:comment "Intermittent crown fire dependent on surface fire intensity." .

ffonto:ActiveCrownFire a owl:Class ;
    rdfs:label "ActiveCrownFire"@en ;
    rdfs:subClassOf ffonto:CrownFire ;
    rdfs:comment "Continuous crown fire independent of surface fire behavior." .

#################################################################
# Fire ↔ FireType linkage
#################################################################

ffonto:hasFireType rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:ForestFireType ;
    rdfs:label "hasFireType" ;
    rdfs:comment "Associates a forest fire with its behavioral fire type." .

ffonto:isTypeOf rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFireType ;
    rdfs:label "isSourceTypeOf" ;
    rdfs:range ffonto:ForestFire ;
    rdfs:comment "Associates a forest fire type with the forest fire instances exhibiting that type." .

#################################################################
# Every ForestFire must have at least one fire type
#################################################################

ffonto:ForestFire rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:hasFireType ;
      owl:someValuesFrom ffonto:ForestFireType ;
      rdfs:comment "Every forest fire must be classified by at least one forest fire type (surface, crown, ground, etc.)."
    ] .

#################################################################
# Every ForestFireType must classify at least one forest fire
#################################################################

ffonto:ForestFireType rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ffonto:isTypeOf ;
      owl:someValuesFrom ffonto:ForestFire ;
      rdfs:comment "Every forest fire type must classify at least one forest fire instance."
    ] .
