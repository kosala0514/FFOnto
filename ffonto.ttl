ffonto:workingNear rdf:type owl:ObjectProperty ;
    rdfs:label "working near" ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:StructureFire ;
    rdfs:comment "Indicates a responder group is operating near (or adjacent to) a structure." .

ffonto:workingNearOf a owl:ObjectProperty ;
    rdfs:range ffonto:Responder ;
    rdfs:domain ffonto:StructureFire ;
    rdfs:label "inverse of working near"@en .

ffonto:workingNearOf owl:inverseOf ffonto:workingNear .

