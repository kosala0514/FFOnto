    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indicates visible water sources such as streams or ponds." .

ffonto:portableTankSetup rdf:type owl:DatatypeProperty ;
    rdfs:label "portable tank setup" ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean ;
