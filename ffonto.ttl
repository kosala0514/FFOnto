    rdfs:range xsd:string .

# Traffic signs or posts charred
ffonto:trafficSignsCharred
    a owl:DatatypeProperty ;
    rdfs:label "traffic signs charred" ;
    rdfs:comment "Indicates whether traffic signs or posts are charred." ;
    rdfs:domain ffonto:Signpost ;
    rdfs:range xsd:boolean .

# Snags (standing dead trees) presence and count
ffonto:snagsPresent
    a owl:DatatypeProperty ;
    rdfs:label "snags present" ;
    rdfs:comment "Indicates whether dead standing trees (snags) are common in the frame." ;
    rdfs:domain ffonto:Snag ;
    rdfs:range xsd:boolean .

ffonto:snagsCount
    a owl:DatatypeProperty ;
    rdfs:label "snags count" ;
    rdfs:comment "Approximate number of snags visible (integer)." ;
    rdfs:domain ffonto:Snag ;
    rdfs:range xsd:integer .

# Bridge presence and heat damage
ffonto:bridgePresent
    a owl:DatatypeProperty ;
    rdfs:label "bridge present" ;
    rdfs:comment "Indicates whether a bridge is visible in the scene." ;
    rdfs:domain ffonto:Bridge ;
    rdfs:range xsd:boolean .

ffonto:bridgeHeatDamage
    a owl:DatatypeProperty ;
    rdfs:label "bridge heat damage" ;
    rdfs:comment "Indicates whether a visible bridge shows heat-related damage." ;
    rdfs:domain ffonto:Bridge ;
    rdfs:range xsd:boolean .

# Shrubs burned to stems
ffonto:shrubsBurnedToStems
    a owl:DatatypeProperty ;
    rdfs:label "shrubs burned to stems" ;
    rdfs:comment "Indicates whether shrubs or chaparral are burned down to stems." ;
    rdfs:domain ffonto:Shrub ;
    rdfs:range xsd:boolean .

# Ground vegetation burn pattern
ffonto:groundVegetationPattern
    a owl:DatatypeProperty ;
    rdfs:label "ground vegetation burn pattern" ;
    rdfs:comment "Describes whether ground vegetation is 'entirely black', 'patchy', or 'mostly unburned'." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:string .

# Ash piled on road reducing traction
ffonto:ashOnRoadReducingTraction
    a owl:DatatypeProperty ;
    rdfs:label "ash piled on road reducing traction" ;
    rdfs:comment "Indicates whether ash accumulation on the road could reduce vehicle traction." ;
    rdfs:domain ffonto:Roadway ;
    rdfs:range xsd:boolean .

ffonto:unburnedGreenPatches
    a owl:DatatypeProperty ;
    rdfs:label "unburned green patches visible" ;
    rdfs:comment "Indicates whether unburned green vegetation patches are visible within the burned area." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

# Culvert inlet clogged with ash/debris
ffonto:culvertInletsClogged
    a owl:DatatypeProperty ;
    rdfs:label "culvert inlets clogged with ash or debris" ;
    rdfs:comment "Indicates whether culvert inlets are clogged with ash/debris." ;
    rdfs:domain ffonto:Culvert ;
    rdfs:range xsd:boolean .

# Needles/leaves browned but still attached
ffonto:needlesBrownedAttached
    a owl:DatatypeProperty ;
    rdfs:label "needles/leaves browned but still attached" ;
    rdfs:comment "Indicates whether foliage is browned but still attached to branches." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

# Parking lot surface blackened or cracked
ffonto:parkingLotSurfaceDamaged
    a owl:DatatypeProperty ;
    rdfs:label "parking lot surface damaged" ;
    rdfs:comment "Indicates whether parking lot surfaces are blackened or cracked." ;
    rdfs:domain ffonto:Roadway ;
    rdfs:range xsd:boolean .

# Downed logs smoldering or cold
ffonto:downedLogsSmoldering
    a owl:DatatypeProperty ;
    rdfs:label "downed logs smoldering" ;
    rdfs:comment "Indicates whether downed logs are smoldering (true) or cold (false)." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

# Trail signs or markers burned
ffonto:trailSignsBurned
    a owl:DatatypeProperty ;
    rdfs:label "trail signs burned" ;
    rdfs:comment "Indicates whether trail signs or markers are burned." ;
    rdfs:domain ffonto:Signpost ;
    rdfs:range xsd:boolean .

# Evidence of torching (single trees fully burned)
ffonto:torchingEvidence
    a owl:DatatypeProperty ;
    rdfs:label "evidence of torching" ;
    rdfs:comment "Indicates whether torching (single trees fully burned) is evident." ;
    rdfs:domain ffonto:Tree ;
    rdfs:range xsd:boolean .

# Fine fuels completely consumed
ffonto:fineFuelsConsumed
    a owl:DatatypeProperty ;
    rdfs:label "fine fuels completely consumed" ;
    rdfs:comment "Indicates whether fine fuels (grasses) are completely consumed." ;
    rdfs:domain ffonto:Grass ;
    rdfs:range xsd:boolean .

# Ladder fuels mostly gone
ffonto:ladderFuelsMostlyGone
    a owl:DatatypeProperty ;
    rdfs:label "ladder fuels mostly gone" ;
    rdfs:comment "Indicates whether low branches and ladder fuels are mostly gone." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

# Canopy openness due to crown loss
ffonto:canopyOpen
    a owl:DatatypeProperty ;
    rdfs:label "canopy open due to crown loss" ;
    rdfs:comment "Indicates whether the canopy looks open because of crown loss." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

# Stumps smoking
ffonto:stumpsSmoking
    a owl:DatatypeProperty ;
    rdfs:label "stumps smoking" ;
    rdfs:comment "Indicates whether stumps are still smoking." ;
    rdfs:domain ffonto:Stump ;
    rdfs:range xsd:boolean .

# Invasive grasses visible in black (reburn risk)
ffonto:invasiveGrassesVisible
    a owl:DatatypeProperty ;
    rdfs:label "invasive grasses visible" ;
    rdfs:comment "Indicates whether invasive grasses are visible in the blackened area." ;
    rdfs:domain ffonto:Grass ;
    rdfs:range xsd:boolean .

# Ash color dominance
ffonto:ashColorDominance
    a owl:DatatypeProperty ;
    rdfs:label "ash color dominance" ;
    rdfs:comment "Dominant ash color observed: 'white', 'gray', or 'black'." ;
    rdfs:domain ffonto:BurnEvidence ;
    rdfs:range xsd:string .

ffonto:fireReachedWaterEdge
    a owl:DatatypeProperty ;
    rdfs:label "fire reached water edge" ;
    rdfs:comment "Indicates whether the fire reached the visible edge of a stream or pond." ;
    rdfs:domain ffonto:WaterBody ;
    rdfs:range xsd:boolean .

ffonto:groundSurfaceCharred
    a owl:DatatypeProperty ;
    rdfs:label "ground surface uniformly charred" ;
    rdfs:comment "Indicates whether the ground surface appears uniformly charred." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:vegetationAlongCreekBlackened
    a owl:DatatypeProperty ;
    rdfs:label "vegetation along creek blackened" ;
    rdfs:comment "Indicates whether vegetation along a creek appears blackened from wildfire." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:ashDepositsVisible
    a owl:DatatypeProperty ;
    rdfs:label "ash deposits visible" ;
    rdfs:comment "Indicates whether ash drifts or deep ash deposits are visible." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:waterDiscolored
    a owl:DatatypeProperty ;
    rdfs:label "water discolored" ;
    rdfs:comment "Indicates whether water appears discolored due to soot, ash, or sediment." ;
    rdfs:domain ffonto:WaterBody ;
    rdfs:range xsd:boolean .

ffonto:hydrophobicSoilSigns
    a owl:DatatypeProperty ;
    rdfs:label "hydrophobic soil signs visible" ;
    rdfs:comment "Indicates whether hydrophobic soil signs such as water beading are visible." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:culvertsFilledWithAsh
    a owl:DatatypeProperty ;
    rdfs:label "culverts filled with ash or debris" ;
    rdfs:comment "Indicates whether culverts or roadside ditches are filled with ash or debris." ;
    rdfs:domain ffonto:ErosionFeature ;
    rdfs:range xsd:boolean .

ffonto:mineralSoilExposed
    a owl:DatatypeProperty ;
    rdfs:label "mineral soil exposed" ;
    rdfs:comment "Indicates whether mineral soil is exposed due to duff consumption." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:steamVisible
    a owl:DatatypeProperty ;
    rdfs:label "steam visible where hot ground meets water" ;
    rdfs:comment "Indicates whether steam is visible where hot ground meets water." ;
    rdfs:domain ffonto:WaterBody ;
    rdfs:range xsd:boolean .

ffonto:rootsExposed
    a owl:DatatypeProperty ;
    rdfs:label "roots exposed by combustion or erosion" ;
    rdfs:comment "Indicates whether roots are exposed due to combustion or erosion." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:riparianTreesScorched
    a owl:DatatypeProperty ;
    rdfs:label "riparian trees scorched but standing" ;
    rdfs:comment "Indicates whether riparian trees appear scorched but remain standing." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:rocksHeatSpalled
    a owl:DatatypeProperty ;
    rdfs:label "rocks heat-spalled or cracked" ;
    rdfs:comment "Indicates whether rocks show heat cracking or spalling." ;
    rdfs:domain ffonto:RockSurface ;
    rdfs:range xsd:boolean .

ffonto:erosionRillsForming
    a owl:DatatypeProperty ;
    rdfs:label "erosion rills forming on slopes" ;
    rdfs:comment "Indicates whether erosion rills or channels are forming on slopes." ;
    rdfs:domain ffonto:ErosionFeature ;
    rdfs:range xsd:boolean .

ffonto:residualSmokeVisible
    a owl:DatatypeProperty ;
    rdfs:label "residual smoke visible" ;
    rdfs:comment "Indicates whether smoldering smoke remains visible." ;
    rdfs:domain ffonto:SmokeCondition ;
    rdfs:range xsd:boolean .

ffonto:activeFlamesPresent
    a owl:DatatypeProperty ;
    rdfs:label "active flames present" ;
    rdfs:comment "Indicates whether active flames are still present after the fire front." ;
    rdfs:domain ffonto:SmokeCondition ;
    rdfs:range xsd:boolean .

ffonto:vegetationMostAffected
    a owl:DatatypeProperty ;
    rdfs:label "vegetation most affected" ;
    rdfs:comment "Indicates which vegetation type appears most affected (grass, shrubs, trees)." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:string .

ffonto:treeCrownCondition
    a owl:DatatypeProperty ;
    rdfs:label "tree crown condition" ;
    rdfs:comment "Describes whether tree crowns appear scorched, intact, or mixed." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:string .

ffonto:groundcoverConsumed
    a owl:DatatypeProperty ;
    rdfs:label "groundcover consumed exposing mineral soil" ;
    rdfs:comment "Indicates whether groundcover has been consumed exposing mineral soil." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:snagsVisible
    a owl:DatatypeProperty ;
    rdfs:label "snags visible" ;
    rdfs:comment "Indicates whether many dead standing trees (snags) are visible." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:leafLitterConsumed
    a owl:DatatypeProperty ;
    rdfs:label "leaf litter or duff consumed" ;
    rdfs:comment "Indicates whether leaf litter and duff were consumed by fire." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:earlyRegrowthVisible
    a owl:DatatypeProperty ;
    rdfs:label "early regrowth visible" ;
    rdfs:comment "Indicates whether early vegetation regrowth is visible." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:riparianPlantsScorched
    a owl:DatatypeProperty ;
    rdfs:label "riparian plants scorched" ;
    rdfs:comment "Indicates whether riparian vegetation appears scorched." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:cropsOrOrchardsDamaged
    a owl:DatatypeProperty ;
    rdfs:label "crops or orchards damaged" ;
    rdfs:comment "Indicates whether nearby crops or orchards show wildfire damage." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:boolean .

ffonto:ashDepositsWidespread
    a owl:DatatypeProperty ;
    rdfs:label "ash deposits widespread" ;
    rdfs:comment "Indicates whether ash deposits are widespread on the forest floor." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:whiteGrayAshVisible
    a owl:DatatypeProperty ;
    rdfs:label "white or gray ash visible" ;
    rdfs:comment "Indicates presence of white or gray ash suggesting complete combustion." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:boolean .

ffonto:smokeDensity
    a owl:DatatypeProperty ;
    rdfs:label "smoke density level" ;
    rdfs:comment "Describes smoke density level (low, medium, high)." ;
    rdfs:domain ffonto:SmokeCondition ;
    rdfs:range xsd:string .

ffonto:smokeColor
    a owl:DatatypeProperty ;
    rdfs:label "smoke color" ;
    rdfs:comment "Indicates smoke color such as white, gray, brown, or black." ;
    rdfs:domain ffonto:SmokeCondition ;
    rdfs:range xsd:string .

ffonto:restorationMeasuresSuggested
    a owl:DatatypeProperty ;
    rdfs:label "restoration measures suggested" ;
    rdfs:comment "Describes restoration actions recommended for the landscape." ;
    rdfs:domain ffonto:RestorationStrategy ;
    rdfs:range xsd:string .

ffonto:biodiversityImpactDescription
    a owl:DatatypeProperty ;
    rdfs:label "biodiversity impact description" ;
    rdfs:comment "Describes how biodiversity may be impacted by wildfire disturbance." ;
    rdfs:domain ffonto:EcosystemImpact ;
    rdfs:range xsd:string .

ffonto:erosionRisk
    a owl:DatatypeProperty ;
    rdfs:label "erosion risk increased" ;
    rdfs:comment "Indicates whether wildfire disturbance increases soil erosion risk." ;
    rdfs:domain ffonto:ErosionFeature ;
    rdfs:range xsd:boolean .

ffonto:waterContaminationRisk
    a owl:DatatypeProperty ;
    rdfs:label "water contamination risk" ;
    rdfs:comment "Indicates whether runoff from burned areas may contaminate nearby water bodies." ;
    rdfs:domain ffonto:WaterBody ;
    rdfs:range xsd:boolean .

ffonto:value a owl:DatatypeProperty ;
    rdfs:domain ffonto:Result ;
    rdfs:range xsd:float ;
    rdfs:label "value" ;
    rdfs:comment "The numeric or literal value of the observed property." .

ffonto:unit a owl:DatatypeProperty ;
    rdfs:domain ffonto:Result ;
    rdfs:range xsd:string ;
    rdfs:label "unit" ;
    rdfs:comment "Specifies the scale or unit used to quantify the value of a ffonto:Result instance." .

ffonto:confidence a owl:DatatypeProperty ;
    rdfs:domain ffonto:Result ;
    rdfs:range xsd:float ;
    rdfs:label "confidence" ;
    rdfs:comment "Confidence score associated with the result." .

#################################################################
# Safety and Risk Assessment CQ

#################################################################
# Class
#################################################################

ffonto:Responder
    a owl:Class ;
    rdfs:label "Responder" ;
    rdfs:comment "Emergency personnel responding to wildfire incidents." .

ffonto:Civilian
    a owl:Class ;
    rdfs:label "Civilian" ;
    rdfs:comment "Non-responder individuals present in the wildfire area." .

ffonto:EmergencyVehicle
    a owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "Emergency Vehicle" ;
    rdfs:comment "Fire trucks, ambulances, and responder vehicles." .

ffonto:AerialVehicle
    a owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "Aerial Firefighting Vehicle" ;
    rdfs:comment "Aircraft used for aerial firefighting such as helicopters." .

ffonto:PPE
    a owl:Class ;
    rdfs:label "Personal Protective Equipment" ;
    rdfs:comment "Protective equipment worn by firefighters during operations." .

ffonto:FireSuppressionAction
    a owl:Class ;
    rdfs:label "Fire Suppression Action" ;
    rdfs:comment "Operational activity such as hose suppression, line cutting, or aerial water drops." .

ffonto:EvacuationStatus
    a owl:Class ;
    rdfs:label "Evacuation Status" ;
    rdfs:comment "Status of evacuation routes or decisions during wildfire emergencies." .

ffonto:Communication
    a owl:Class ;
    rdfs:label "Communication Activity" ;
    rdfs:comment "Communication among firefighters such as radio coordination." .

ffonto:AudioObservation
    a owl:Class ;
    rdfs:subClassOf ffonto:Observation ;
    rdfs:label "Audio Observation" ;
    rdfs:comment "Observation derived from audio captured at the wildfire scene." .

ffonto:PowerInfrastructure
    a owl:Class ;
    rdfs:label "Power Infrastructure" ;
    rdfs:comment "Powerlines and electrical infrastructure." .
    
ffonto:HealthRisk
    a owl:Class ;
    rdfs:label "Health Risk" ;
    rdfs:comment "Health risk caused by wildfire smoke exposure." .

ffonto:PopulationGroup
    a owl:Class ;
    rdfs:label "Population Group" ;
    rdfs:comment "Group of people potentially affected by wildfire smoke." .

ffonto:ProtectionMethod
    a owl:Class ;
    rdfs:label "Protection Method" ;
    rdfs:comment "Method used to reduce smoke exposure or health risk." .

ffonto:HealthSymptom
    a owl:Class ;
    rdfs:label "Health Symptom" ;
    rdfs:comment "Physical symptom caused by wildfire smoke exposure." .

ffonto:HealthAdvice
    a owl:Class ;
    rdfs:label "Health Advice" ;
    rdfs:comment "Guidance provided to the public for wildfire smoke protection." .

ffonto:ResponseOrganization
    a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "Organization providing health or wildfire safety information." .

ffonto:RespiratoryDisease
    a owl:Class ;
    rdfs:label "Respiratory Disease" ;
    rdfs:comment "Medical conditions affecting lungs such as asthma or COPD." .

ffonto:Asthma
    a owl:Class ;
    rdfs:subClassOf ffonto:RespiratoryDisease ;
    rdfs:label "Asthma" .

ffonto:COPD
    a owl:Class ;
    rdfs:subClassOf ffonto:RespiratoryDisease ;
    rdfs:label "Chronic Obstructive Pulmonary Disease" .

ffonto:PregnantPerson
    a owl:Class ;
    rdfs:subClassOf ffonto:PopulationGroup ;
    rdfs:label "Pregnant Person" .

ffonto:Smoker
    a owl:Class ;
    rdfs:subClassOf ffonto:PopulationGroup ;
    rdfs:label "Smoker" .

ffonto:CleanAirShelter
    a owl:Class ;
    rdfs:label "Clean Air Shelter" ;
    rdfs:comment "Building providing filtered indoor air during smoke events." .

ffonto:AirCleaner
    a owl:Class ;
    rdfs:label "Air Cleaner" ;
    rdfs:comment "Device used to filter indoor air." .

ffonto:AirConditioner
    a owl:Class ;
    rdfs:label "Air Conditioner" ;
    rdfs:comment "Cooling system used indoors that may filter air." .

ffonto:VisibilityRange
    a owl:Class ;
    rdfs:label "Visibility Range" ;
    rdfs:comment "Distance-based visibility indicator used to estimate air quality." .

ffonto:HeatStressRisk
    a owl:Class ;
    rdfs:subClassOf ffonto:HealthRisk ;
    rdfs:label "Heat Stress Risk" .

ffonto:AirQualityRisk
    a owl:Class ;
    rdfs:subClassOf ffonto:HealthRisk ;
    rdfs:label "Air Quality Risk" .

ffonto:ExplosionEvent rdf:type owl:Class ;
    rdfs:label "Explosion Event" ;
    rdfs:comment "An explosion detected within the wildfire response environment." .

ffonto:ProtectiveEquipment rdf:type owl:Class ;
    rdfs:label "Protective Equipment" .

ffonto:EmergencyResponder rdf:type owl:Class ;
    rdfs:label "Emergency Responder" .

ffonto:EmergencyOperation rdf:type owl:Class ;
    rdfs:label "Emergency Operation Activity" .

ffonto:EvacuationRoute rdf:type owl:Class ;
    rdfs:label "Evacuation Route" .

ffonto:InformationResource rdf:type owl:Class ;
    rdfs:label "Information Resource" ;
    rdfs:comment "Online resources providing wildfire safety and health information." .

ffonto:BuildingComponent rdf:type owl:Class ;
    rdfs:label "Building Component" ;
    rdfs:comment "Structural parts of a building that may influence wildfire vulnerability." .

ffonto:Gutter rdf:type owl:Class ;
    rdfs:subClassOf ffonto:BuildingComponent ;
    rdfs:label "Gutter" ;
    rdfs:comment "A drainage component attached to the roof edge that can collect leaves and debris, increasing fire risk." .

ffonto:Eaves rdf:type owl:Class ;
    rdfs:subClassOf ffonto:BuildingComponent ;
    rdfs:label "Eaves" ;
    rdfs:comment "The edges of a roof that overhang a building wall and may be exposed to embers or smoke." .

ffonto:Siding rdf:type owl:Class ;
    rdfs:subClassOf ffonto:BuildingComponent ;
    rdfs:label "Siding Material" ;
    rdfs:comment "Exterior wall covering material that may be combustible or fire resistant." .

ffonto:SafetyZone rdf:type owl:Class ;
    rdfs:label "Safety Zone" ;
    rdfs:comment "A cleared area used as refuge during wildfire operations where responders or civilians can remain safe." .

ffonto:WaterHose rdf:type owl:Class ;
    rdfs:label "Water Hose" ;
    rdfs:comment "Equipment used to deliver water to wet down structures or suppress wildfire flames." .

ffonto:FallingTreeHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Falling Tree Hazard" ;
    rdfs:comment "Risk of trees or branches falling due to wildfire damage or strong winds." .

ffonto:LandslideRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Landslide Risk" ;
    rdfs:comment "Potential ground instability or rockfall that may affect roads or evacuation routes." .

ffonto:EmergencyContact rdf:type owl:Class ;
    rdfs:label "Emergency Contact" ;
    rdfs:comment "A contact point such as a hotline or emergency number for wildfire-related assistance." .

ffonto:HealthGuideline rdf:type owl:Class ;
    rdfs:label "Health Guideline" ;
    rdfs:comment "Public health recommendations designed to reduce health impacts from wildfire smoke exposure." .

ffonto:ProtectiveAction rdf:type owl:Class ;
    rdfs:label "Protective Action" ;
    rdfs:comment "An action recommended to protect people from wildfire smoke or fire-related hazards." .

ffonto:PPE rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ProtectiveAction ;
    rdfs:label "Personal Protective Equipment" ;
    rdfs:comment "Respirators, fire-resistant clothing, eye protection, etc." .

ffonto:EvacuationOrder rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ProtectiveAction ;
    rdfs:label "Evacuation Order" ;
    rdfs:comment "Formal direction to evacuate from authorities." .

ffonto:Fuel rdf:type owl:Class ;
    rdfs:label "Fuel" ;
    rdfs:comment "Combustible materials such as dry grass, leaf litter, and logs that contribute to fire spread." .

ffonto:InfrastructureRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Infrastructure Risk" ;
    rdfs:comment "Risks posed to roads, settlements, water supply systems, or utilities." .

ffonto:SuppressionResource rdf:type owl:Class ;
    rdfs:label "Suppression Resource" ;
    rdfs:comment "Equipment or personnel used to control or extinguish wildfires." .

ffonto:SafetyMeasure rdf:type owl:Class ;
    rdfs:label "Safety Measure" ;
    rdfs:comment "Protective action or precaution used to reduce wildfire risks." .

ffonto:Person rdf:type owl:Class ;
    rdfs:label "Person" .

ffonto:Resident rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Person ;
    rdfs:label "Resident" .

ffonto:Animal rdf:type owl:Class ;
    rdfs:label "Animal" ;
    rdfs:comment "Domestic animals or pets potentially affected by wildfire smoke." .

ffonto:AerialResource rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionResource ;
    rdfs:label "Aerial Firefighting Resource" ;
    rdfs:comment "Aircraft used for water or retardant drops." .

ffonto:GroundResource rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionResource ;
    rdfs:label "Ground Firefighting Resource" ;
    rdfs:comment "Ground-based suppression equipment such as fire engines." .

ffonto:WaterSupply rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Water Supply System" ;
    rdfs:comment "Local water infrastructure used for community and firefighting needs." .

ffonto:ForestTerrain rdf:type owl:Class ;
    rdfs:label "Forest Terrain" ;
    rdfs:comment "Physical terrain conditions such as slopes and hills influencing fire behavior." .

ffonto:StructureFire rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireEvent ;
    rdfs:label "Structure Fire" ;
    rdfs:comment "Fire involving buildings / infrastructure (houses, outbuildings)." .

ffonto:AccessConstraint rdf:type owl:Class ;
    rdfs:label "Access Constraint" ;
    rdfs:comment "Limited roads, steep slopes, blocked evacuation routes, equipment access issues." .

ffonto:NaturalFirebreak rdf:type owl:Class ;
    rdfs:label "Natural Firebreak" ;
    rdfs:comment "Landscape features (rivers, wetlands, snowfields) that reduce fire spread risk." .

ffonto:TerrainFeature rdf:type owl:Class ;
    rdfs:label "Terrain Feature" ;
    rdfs:comment "Topographic elements that influence fire behavior (hills, slopes, valleys, rivers)." .

ffonto:Hillside rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TerrainFeature ;
    rdfs:label "Hillside"@en ;
    rdfs:comment "A sloping terrain area that can affect wildfire spread direction and intensity."@en .

ffonto:MountainSlope rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TerrainFeature ;
    rdfs:label "Mountain Slope" .

ffonto:Valley rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TerrainFeature ;
    rdfs:label "Valley"@en ;
    rdfs:comment "A low area between hills or mountains that may influence wildfire spread and smoke movement."@en .

ffonto:Grassland rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TerrainFeature ;
    rdfs:label "Grassland" .

ffonto:VisibilityCondition rdf:type owl:Class ;
    rdfs:label "Visibility Condition" ;
    rdfs:comment "Visibility measures for aerial and ground ops." .

ffonto:AerialVisibility rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VisibilityCondition ;
    rdfs:label "Aerial Visibility" ;
    rdfs:comment "Visibility condition relevant to aerial resources." .

ffonto:GroundVisibility rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VisibilityCondition ;
    rdfs:label "Ground Visibility" ;
    rdfs:comment "Visibility condition relevant to ground crews and roads." .

ffonto:AccessConstraintDetail rdf:type owl:Class ;
    rdfs:label "Access Constraint Detail" ;
    rdfs:comment "Specific access limitations (road blockage, steep grade, narrow road)." .

ffonto:RoadAccess rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AccessConstraintDetail ;
    rdfs:label "Road Access" .

ffonto:VehicleAccess rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AccessConstraintDetail ;
    rdfs:label "Vehicle Access" .

ffonto:FirelineAccess rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AccessConstraintDetail ;
    rdfs:label "Fireline Access" ;
    rdfs:comment "Ability to establish and access a fireline for suppression crews." .

ffonto:Wildlife rdf:type owl:Class ;
    rdfs:label "Wildlife" ;
    rdfs:comment "Wild animals affected by fire and smoke." .

ffonto:Deer rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Wildlife ;
    rdfs:label "Deer" .

ffonto:Birds rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Wildlife ;
    rdfs:label "Birds" .
    
ffonto:AnimalSmokeExposure rdf:type owl:Class ;
    rdfs:label "Animal Smoke Exposure" ;
    rdfs:comment "Risk of smoke inhalation or displacement for animals." .

ffonto:Community rdf:type owl:Class ;
    rdfs:label "Community" ;
    rdfs:comment "Population centers, towns, or settlements near a fire." .

ffonto:Farmland rdf:type owl:Class ;
    rdfs:label "Farmland" ;
    rdfs:comment "Agricultural land at risk from fire and embers." .

ffonto:FireGeneratedWeather rdf:type owl:Class ;
    rdfs:label "Fire Generated Weather" ;
    rdfs:comment "Pyro-weather phenomena created by intense fires." .

ffonto:PyrocumulusCloud rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireGeneratedWeather ;
    rdfs:label "Pyrocumulus Cloud" .

ffonto:FireInducedWind rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireGeneratedWeather ;
    rdfs:label "Fire Induced Wind" ;
    rdfs:comment "Locally generated winds from convection columns." .

ffonto:StructureDefense rdf:type owl:Class ;
    rdfs:label "Structure Defense" ;
    rdfs:comment "Measures to protect buildings (defensible space, sprinklers, roof coverings)." .

ffonto:DefensibleSpace rdf:type owl:Class ;
    rdfs:comment "Zone distances are guidance and may be adapted to local regulation; use local building codes and WUI guidance." ;
    rdfs:subClassOf ffonto:StructureDefense ;
    rdfs:subClassOf ffonto:PreventionMeasure ;
    rdfs:label "Defensible Space" .

ffonto:StructureLossStatus rdf:type owl:Class ;
    rdfs:label "Structure Loss Status" ;
    rdfs:comment "Classification for damage: intact, damaged, total loss." .

ffonto:Intact rdf:type owl:Class ;
    rdfs:subClassOf ffonto:StructureLossStatus ;
    rdfs:label "Intact" .

ffonto:Damaged rdf:type owl:Class ;
    rdfs:subClassOf ffonto:StructureLossStatus ;
    rdfs:label "Damaged" .

ffonto:TotalLoss rdf:type owl:Class ;
    rdfs:subClassOf ffonto:StructureLossStatus ;
    rdfs:label "Total Loss" ;
    rdfs:comment "Structure deemed unsalvageable; resource priorities change." .

ffonto:DropZone rdf:type owl:Class ;
    rdfs:label "Aerial Drop Zone" ;
    rdfs:comment "Designated area for aerial retardant/water drops; clearance & safety required." .

ffonto:ImpactHazard rdf:type owl:Class ;
    rdfs:label "Impact Hazard" ;
    rdfs:comment "Hazard from direct impact of drops (force, debris) or contamination." .

ffonto:ContainmentState rdf:type owl:Class ;
    rdfs:label "Containment State" ;
    rdfs:comment "Discrete incident status values." .

ffonto:ActiveFire rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ContainmentState ;
    rdfs:label "Active Fire" .

ffonto:ContainedFire rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ContainmentState ;
    rdfs:label "Contained Fire" .

ffonto:ControlledFire rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ContainmentState ;
    rdfs:label "Controlled Fire" .

ffonto:SuppressionOperation rdf:type owl:Class ;
    rdfs:label "Suppression Operation" ;
    rdfs:comment "An organized operation (ground, aerial, mop-up) to control a fire." .

ffonto:AerialDropOperation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionOperation ;
    rdfs:label "Aerial Drop Operation" .

ffonto:EvacuationOperation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SuppressionOperation ;
    rdfs:label "Evacuation Operation" .

#################################################################
# OBJECT PROPERTIES
#################################################################

ffonto:operatesAtScene
    a owl:ObjectProperty ;
    rdfs:label "operates at scene" ;
    rdfs:comment "Links responders or vehicles to the wildfire scene where they operate." ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:WildfireScene .

ffonto:operatesAtSceneOf
    a owl:ObjectProperty ;
    rdfs:label "operates at scene of" ;
    rdfs:comment "Inverse - Links responders or vehicles to the wildfire scene where they operate." ;
    rdfs:range ffonto:Responder ;
    rdfs:domain ffonto:WildfireScene .

ffonto:operatesAtSceneOf owl:inverseOf ffonto:operatesAtScene .

ffonto:performsSuppression
    a owl:ObjectProperty ;
    rdfs:label "performs suppression action" ;
    rdfs:comment "Indicates that responders perform a suppression activity." ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range ffonto:FireSuppressionAction .

ffonto:performsSuppressionOf
    a owl:ObjectProperty ;
    rdfs:label "performs suppression action of" ;
    rdfs:comment "Inverse - Indicates that responders perform a suppression activity." ;
    rdfs:range ffonto:Firefighter ;
    rdfs:domain ffonto:FireSuppressionAction .

ffonto:performsSuppressionOf owl:inverseOf ffonto:performsSuppression .

ffonto:wearsPPE
    a owl:ObjectProperty ;
    rdfs:label "wears protective equipment" ;
    rdfs:comment "Links firefighters to protective equipment they wear." ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range ffonto:PPE .

ffonto:wearsPPEOf a owl:ObjectProperty ;
    rdfs:label "inverse of wears ppe"@en  ;
    rdfs:range ffonto:Firefighter ;
    rdfs:domain ffonto:PPE .

ffonto:wearsPPEOf owl:inverseOf ffonto:wearsPPE .

ffonto:threatenedByHazard
    a owl:ObjectProperty ;
    rdfs:label "threatened by hazard" ;
    rdfs:comment "Indicates responders or civilians are threatened by operational hazards." ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:Hazard .

ffonto:threatenedByHazardOf a owl:ObjectProperty ;
    rdfs:range ffonto:Responder ;
    rdfs:domain ffonto:Hazard ;
    rdfs:label "inverse of threatened by hazard"@en  .

ffonto:threatenedByHazardOf owl:inverseOf ffonto:threatenedByHazard .

ffonto:affectsPopulation
    a owl:ObjectProperty ;
    rdfs:label "affects population group" ;
    rdfs:comment "Indicates that a health risk affects a specific population group." ;
    rdfs:domain ffonto:HealthRisk ;
    rdfs:range ffonto:PopulationGroup .

ffonto:causesSymptom
    a owl:ObjectProperty ;
    rdfs:label "causes symptom" ;
    rdfs:comment "Links smoke exposure to resulting symptoms." ;
    rdfs:domain ffonto:HealthRisk ;
    rdfs:range ffonto:HealthSymptom .

ffonto:causesSymptomOf
    a owl:ObjectProperty ;
    rdfs:label "causes symptom of" ;
    rdfs:comment "Inverse - Links smoke exposure to resulting symptoms." ;
    rdfs:range ffonto:HealthRisk ;
    rdfs:domain ffonto:HealthSymptom .

ffonto:causesSymptomOf owl:inverseOf ffonto:causesSymptom .

ffonto:recommendedProtection
    a owl:ObjectProperty ;
    rdfs:label "recommended protection method" ;
    rdfs:comment "Links health advice to recommended protection methods." ;
    rdfs:domain ffonto:HealthAdvice ;
    rdfs:range ffonto:ProtectionMethod .

ffonto:recommendedProtectionOf a owl:ObjectProperty ;
    rdfs:range ffonto:HealthAdvice ;
    rdfs:domain ffonto:ProtectionMethod ;
    rdfs:label "inverse of recommended protection"@en .

ffonto:recommendedProtectionOf owl:inverseOf ffonto:recommendedProtection .

ffonto:providedBy
    a owl:ObjectProperty ;
    rdfs:label "provided by organization" ;
    rdfs:comment "Indicates the organization providing health information." ;
    rdfs:domain ffonto:HealthAdvice ;
    rdfs:range ffonto:ResponseOrganization .

ffonto:providedOf a owl:ObjectProperty ;
    rdfs:range ffonto:HealthAdvice ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:label "inverse of provided by"@en  .

ffonto:providedOf owl:inverseOf ffonto:providedBy .

ffonto:exposedToSmoke
    a owl:ObjectProperty ;
    rdfs:label "exposed to smoke" ;
    rdfs:comment "Indicates a person or population group is exposed to wildfire smoke." ;
    rdfs:domain ffonto:PopulationGroup ;
    rdfs:range ffonto:HealthRisk .

ffonto:affectsPopulation a owl:ObjectProperty ;
    rdfs:label "affects population"@en ;
    rdfs:comment "Original property (exists in your ontology). Declared inverseOf :exposedToSmoke."@en .

ffonto:affectsPopulation owl:inverseOf ffonto:exposedToSmoke .

ffonto:protectedBy
    a owl:ObjectProperty ;
    rdfs:label "protected by" ;
    rdfs:comment "Indicates a protection method reduces smoke exposure." ;
    rdfs:domain ffonto:PopulationGroup ;
    rdfs:range ffonto:ProtectionMethod .

ffonto:protectedOf a owl:ObjectProperty ;
    rdfs:label "inverse of protected by"@en ;
    rdfs:range ffonto:PopulationGroup ;
    rdfs:domain ffonto:ProtectionMethod .

ffonto:protectedOf owl:inverseOf ffonto:protectedBy .

ffonto:recommendedFor
    a owl:ObjectProperty ;
    rdfs:label "recommended for population group" ;
    rdfs:comment "Links protection advice to vulnerable populations." ;
    rdfs:domain ffonto:HealthAdvice ;
    rdfs:range ffonto:PopulationGroup .

ffonto:recommendedOf a owl:ObjectProperty ;
    rdfs:range ffonto:HealthAdvice ;
    rdfs:domain ffonto:PopulationGroup ;
    rdfs:label "inverse of recommended for"@en .

ffonto:recommendedOf owl:inverseOf ffonto:recommendedFor .

ffonto:hasObservation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:Observation ;
    rdfs:label "has observation" .

ffonto:isObservationOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:Observation ;
    rdfs:label "inverse of is observation"@en .

ffonto:isObservationOf owl:inverseOf ffonto:hasObservation .

ffonto:hasResult rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:Result ;
    rdfs:label "has result" .

ffonto:isResultOf a owl:ObjectProperty ;
    rdfs:range ffonto:Observation ;
    rdfs:domain ffonto:Result ;
    rdfs:label "inverse of has result"@en .

ffonto:isResultOf owl:inverseOf ffonto:hasResult .

ffonto:hasAnnotation a owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:Annotation ;
    rdfs:label "has annotation" ;
    rdfs:comment "Links an observation to an annotation derived from it." .

ffonto:isAnnotationOf a owl:ObjectProperty ;
    rdfs:range ffonto:Observation ;
    rdfs:domain ffonto:Annotation ;
    rdfs:label "is annotation of" ;
    rdfs:comment "inverse of has annotation" .

ffonto:hasAnnotation owl:inverseOf ffonto:isAnnotationOf .

ffonto:observedProperty a owl:ObjectProperty ;
    rdfs:domain ffonto:Result ;
    rdfs:range ffonto:ObservableProperty ;
    rdfs:label "observed property" ;
    rdfs:comment "The property that was observed or estimated." .

ffonto:observedPropertyOf a owl:ObjectProperty ;
    rdfs:range ffonto:Result ;
    rdfs:domain ffonto:ObservableProperty ;
    rdfs:label "observed property of" ;
    rdfs:comment "Inverse of observed property." ;
    owl:inverseOf ffonto:observedProperty .

ffonto:isEvidenceFor a owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:FireEvent .

ffonto:hasEvidence a owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:Observation .

ffonto:isEvidenceFor owl:inverseOf ffonto:hasEvidence .

ffonto:hasEnvironmentalCondition rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:EnvironmentalCondition ;
    rdfs:label "has environmental condition" .

ffonto:isEnvironmentalConditionOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:EnvironmentalCondition ;
    rdfs:label "is environmental condition of" .

ffonto:isEnvironmentalConditionOf owl:inverseOf ffonto:hasEnvironmentalCondition .

ffonto:causesHealthRisk rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:HealthRisk ;
    rdfs:label "causes health risk" .

ffonto:causesHealthRiskOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:HealthRisk ;
    rdfs:label "inverse of causes health risk"@en .

ffonto:causesHealthRiskOf owl:inverseOf ffonto:causesHealthRisk .

ffonto:monitorsInfrastructure rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:Infrastructure ;
    rdfs:label "monitors infrastructure" .

ffonto:monitorsInfrastructureOf a owl:ObjectProperty ;
    rdfs:range ffonto:Observation ;
    rdfs:domain ffonto:Infrastructure ;
    rdfs:label "inverse of monitors infrastructure"@en  .

ffonto:monitorsInfrastructureOf owl:inverseOf ffonto:monitorsInfrastructure .

ffonto:providesInformation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:InformationResource ;
    rdfs:range ffonto:HealthRisk ;
    rdfs:label "provides information about health risk" .

ffonto:providesInformationOf a owl:ObjectProperty ;
    rdfs:range ffonto:InformationResource ;
    rdfs:domain ffonto:HealthRisk ;
    rdfs:label "inverse of provides information"@en .

ffonto:providesInformationOf owl:inverseOf ffonto:providesInformation .

ffonto:hasComponent rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Building ;
    rdfs:range ffonto:BuildingComponent ;
    rdfs:label "has building component" ;
    rdfs:comment "Relates a building to its structural components such as roof, gutter, or siding." .

ffonto:isComponentOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Building ;
    rdfs:domain ffonto:BuildingComponent ;
    rdfs:label "is building component of" ;
    rdfs:comment "Inverse - Relates a building to its structural components such as roof, gutter, or siding." .

ffonto:isComponentOf owl:inverseOf ffonto:hasComponent .

ffonto:usedAsSafetyZone rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Road ;
    rdfs:range ffonto:SafetyZone ;
    rdfs:label "used as safety zone" ;
    rdfs:comment "Indicates that a road or area is being used as a safety zone or refuge location." .

ffonto:usedAsSafetyZoneOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Road ;
    rdfs:domain ffonto:SafetyZone ;
    rdfs:label "used as safety zone of" ;
    rdfs:comment "Inverse - Indicates that a road or area is being used as a safety zone or refuge location." .

ffonto:usedAsSafetyZoneOf owl:inverseOf ffonto:usedAsSafetyZone .

ffonto:hasEmergencyContact rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:InformationResource ;
    rdfs:range ffonto:EmergencyContact ;
    rdfs:label "has emergency contact" ;
    rdfs:comment "Associates an information resource with emergency contact numbers." .

ffonto:isEmergencyContactOf a owl:ObjectProperty ;
    rdfs:label "inverse of is emergency contact"@en ;
    rdfs:range ffonto:InformationResource ;
    rdfs:domain ffonto:EmergencyContact .

ffonto:isEmergencyContactOf owl:inverseOf ffonto:hasEmergencyContact .

ffonto:recommendsAction rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:HealthGuideline ;
    rdfs:range ffonto:ProtectiveAction ;
    rdfs:label "recommends protective action" ;
    rdfs:comment "Links health guidelines to recommended protective actions." .

ffonto:recommendsActionOf a owl:ObjectProperty ;
    rdfs:range ffonto:HealthGuideline ;
    rdfs:domain ffonto:ProtectiveAction ;
    rdfs:label "inverse of recommends action"@en .

ffonto:recommendsActionOf owl:inverseOf ffonto:recommendsAction .

ffonto:createsHazard rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Hazard ;
    rdfs:label "creates hazard" .

ffonto:createsHazardOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:Hazard ;
    rdfs:label "inverse of creates hazard"@en  .

ffonto:createsHazardOf owl:inverseOf ffonto:createsHazard .

ffonto:mitigatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range ffonto:ProtectiveAction ;
    rdfs:label "mitigated by" .

ffonto:mitigatedOf a owl:ObjectProperty ;
    rdfs:range ffonto:Hazard ;
    rdfs:domain ffonto:ProtectiveAction ;
    rdfs:label "inverse of mitigated by"@en  .

ffonto:mitigatedOf owl:inverseOf ffonto:mitigatedBy .

ffonto:respondedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:SuppressionResource ;
    rdfs:label "responded by" .

ffonto:respondedOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:SuppressionResource ;
    rdfs:label "inverse of responded by"@en  .

ffonto:respondedOf owl:inverseOf ffonto:respondedBy .

ffonto:managedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:ResponseOrganization ;
    rdfs:label "managed by" .

ffonto:managedOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:ResponseOrganization ;
    rdfs:label "managed of" .

ffonto:managedOf owl:inverseOf ffonto:managedBy .

ffonto:affects rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range ffonto:Person ;
    rdfs:label "affects" .

ffonto:affectsOf a owl:ObjectProperty ;
    rdfs:range ffonto:Hazard ;
    rdfs:domain ffonto:Person ;
    rdfs:label "inverse of affects"@en  .

ffonto:affectsOf owl:inverseOf ffonto:affects .

ffonto:affectsAnimal rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Animal ;
    rdfs:label "affects animals or pets" ;
    rdfs:comment "Indicates animals impacted by wildfire smoke." .

ffonto:affectsAnimalOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:Animal ;
    rdfs:label "affects animals or pets of" ;
    rdfs:comment "Inverse - Indicates animals impacted by wildfire smoke." .

ffonto:affectsAnimal owl:inverseOf ffonto:affectsAnimalOf .

ffonto:affectedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Infrastructure ;
    rdfs:range ffonto:ForestFire ;
    rdfs:label "affected by wildfire" ;
    rdfs:comment "Indicates infrastructure threatened by wildfire." .

ffonto:affectedOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Infrastructure ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:label "affected by wildfire of" ;
