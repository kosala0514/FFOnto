ffonto:mayRequireRestorationInverse owl:inverseOf ffonto:mayRequireRestoration .

ffonto:controlsAccess rdf:type owl:ObjectProperty ;
    rdfs:label "controls access" ;
    rdfs:domain ffonto:TrafficControlDevice ;
    rdfs:range ffonto:Road ;
