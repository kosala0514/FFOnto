# ffonto:ResilienceMetrics, and ffonto:RestorationAction, ffonto:Measurement

ffonto:TemporalExtent a owl:Class ;
    rdfs:label "temporal extent"@en ;
    rdfs:comment "The specific timeframe, duration, or time interval during which an event or phenomenon occurs."@en .

ffonto:SpatialExtent a owl:Class ;
    rdfs:label "spatial extent"@en ;
    rdfs:comment "The physical area, geographic boundary, or geospatial footprint covered by an event or entity."@en .

ffonto:IncidentReport a owl:Class ;
    rdfs:label "incident report"@en ;
    rdfs:comment "A formal document or record detailing the occurrence, response, and conditions of a specific emergency event."@en .

ffonto:SimulationModel a owl:Class ;
    rdfs:label "simulation model"@en ;
    rdfs:comment "A computational model used to simulate physical processes, such as fire spread or smoke dispersion."@en .

ffonto:WildfireIncident a owl:Class ;
    rdfs:label "wildfire incident"@en ;
    rdfs:comment "An uncontrolled fire occurring in nature that requires an emergency response."@en .

ffonto:HealthImpact a owl:Class ;
    rdfs:label "health impact"@en ;
    rdfs:comment "The effect of an event or environmental condition (e.g., smoke inhalation) on human or animal health."@en .

ffonto:AirQualityMitigationDevice a owl:Class ;
    rdfs:label "air quality mitigation device"@en ;
    rdfs:comment "A physical apparatus designed to monitor, filter, or improve air quality conditions during or after a fire."@en .

ffonto:AirQualityMitigationStrategy a owl:Class ;
    rdfs:label "air quality mitigation strategy"@en ;
    rdfs:comment "A procedural or policy-based approach to reducing the harmful effects of air pollution on a population."@en .

ffonto:AirPollutionMetric a owl:Class ;
    rdfs:label "air pollution metric"@en ;
    rdfs:comment "A quantifiable measure used to assess the concentration of pollutants in the air."@en .

ffonto:PredictionMetric a owl:Class ;
    rdfs:label "prediction metric"@en ;
    rdfs:comment "A forecasted value or indicator generated by a model, such as the predicted speed of fire spread."@en .

ffonto:UAVOperation a owl:Class ;
    rdfs:label "UAV operation"@en ;
    rdfs:comment "A planned flight or deployment of an Unmanned Aerial Vehicle (UAV) for observation, communication, or mitigation."@en .

ffonto:WildfireStatistic a owl:Class ;
    rdfs:label "wildfire statistic"@en ;
    rdfs:comment "A quantitative data point or aggregated metric regarding a wildfire, such as acres burned or containment percentage."@en .

ffonto:EarthObservationData a owl:Class ;
    rdfs:label "earth observation data"@en ;
    rdfs:comment "Data collected from remote sensing platforms, such as satellites or UAVs, to monitor environmental conditions."@en .

ffonto:AIModelGovernance a owl:Class ;
    rdfs:label "AI model governance"@en ;
    rdfs:comment "The policies, procedures, and ethical guidelines governing the deployment and use of artificial intelligence models within the system."@en .

ffonto:IncidentCommandRole a owl:Class ;
    rdfs:label "incident command role"@en ;
    rdfs:comment "A designated function or position within the Incident Command System (ICS) managing the emergency response."@en .

ffonto:IncidentCommandSection a owl:Class ;
    rdfs:label "incident command section"@en ;
    rdfs:comment "A primary organizational division within the Incident Command System, such as Operations, Planning, or Logistics."@en .

ffonto:CommunityPreparednessPlan a owl:Class ;
    rdfs:label "community preparedness plan"@en ;
    rdfs:comment "A documented strategy outlining procedures and resources for a community to prepare for and respond to emergencies."@en .

ffonto:OperationalStrategy a owl:Class ;
    rdfs:label "operational strategy"@en ;
    rdfs:comment "A high-level plan of action designed to achieve specific goals during an incident response."@en .

ffonto:DataAnalysisProcess a owl:Class ;
    rdfs:label "data analysis process"@en ;
    rdfs:comment "The systematic computational or manual review of data to extract insights and inform decision-making."@en .

ffonto:PhysicalProcess a owl:Class ;
    rdfs:label "physical process"@en ;
    rdfs:comment "A natural or environmental mechanism, such as combustion or wind dynamics, affecting the incident."@en .

ffonto:EmergencyFacility a owl:Class ;
    rdfs:label "emergency facility"@en ;
    rdfs:comment "A physical building or location, such as a shelter or fire station, utilized during an incident response."@en .

ffonto:CommunicationDevice a owl:Class ;
    rdfs:label "communication device"@en ;
    rdfs:comment "Hardware used to transmit or receive information between responders, UAVs, or command centers."@en .

prov:Entity a owl:Class ;
    rdfs:label "entity"@en ;
    rdfs:comment "A physical, digital, conceptual, or other kind of thing with some fixed aspects; entities may be real or imagined."@en .

prov:Activity a owl:Class ;
    rdfs:label "activity"@en ;
    rdfs:comment "Something that occurs over a period of time and acts upon or with entities; it may include consuming, processing, transforming, modifying, relocating, using, or generating entities."@en .

sosa:Platform a owl:Class ;
    rdfs:label "platform"@en ;
    rdfs:comment "An entity that hosts other entities, particularly Sensors, Actuators, Samplers, and other Platforms."@en .

ffonto:EnvironmentalImpact a owl:Class ;
    rdfs:label "environmental impact"@en ;
    rdfs:comment "The observable or measurable effect of an event or action on the natural environment, such as vegetation loss or soil degradation."@en .

ffonto:InformationSystem a owl:Class ;
    rdfs:label "information system"@en ;
    rdfs:comment "A structured set of software, hardware, and networks used to collect, process, manage, and distribute data."@en .

ffonto:ClimatePattern a owl:Class ;
    rdfs:label "climate pattern"@en ;
    rdfs:comment "A recurring or sustained meteorological trend within a specific region or on a global scale (e.g., El Niño)."@en .

ffonto:FireBehaviorMetric a owl:Class ;
    rdfs:label "fire behavior metric"@en ;
    rdfs:comment "A quantitative measure used to describe how a fire burns, such as rate of spread, flame length, or intensity."@en .

ffonto:ClimateEvent a owl:Class ;
    rdfs:label "climate event"@en ;
    rdfs:comment "A specific, significant occurrence of weather or atmospheric conditions, such as a drought, heatwave, or storm."@en .

ffonto:collectsEnvironmentalData a owl:ObjectProperty ;
    rdfs:label "collects environmental data"@en ;
    rdfs:comment "Indicates that an entity, such as a sensor platform or UAV, gathers data regarding environmental conditions."@en .

ffonto:appliesToUAV a owl:ObjectProperty ;
