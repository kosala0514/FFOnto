ffonto:producesPollutionOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire;
    rdfs:domain ffonto:WildfireSmoke ;
    rdfs:label "inverse of produces pollution"@en  .

ffonto:producesPollutionOf owl:inverseOf ffonto:producesPollution .

ffonto:containsParticulate
    a owl:ObjectProperty ;
    rdfs:label "contains particulate matter" ;
    rdfs:comment "Indicates that air pollution contains particulate matter particles." ;
    rdfs:domain ffonto:AirPollution ;
    rdfs:range ffonto:ParticulateMatter .

ffonto:containsParticulateOf a owl:ObjectProperty ;
    rdfs:range ffonto:AirPollution ;
    rdfs:domain ffonto:ParticulateMatter ;
    rdfs:label "inverse of contains particulate"@en .

ffonto:containsParticulateOf owl:inverseOf ffonto:containsParticulate .

ffonto:affectsRespiratoryHealth
    a owl:ObjectProperty ;
    rdfs:label "affects respiratory health" ;
    rdfs:comment "Represents the impact of air pollution on human respiratory health." ;
    rdfs:domain ffonto:AirPollution ;
    rdfs:range ffonto:HumanHealth .

ffonto:affectsRespiratoryHealthOf
    a owl:ObjectProperty ;
    rdfs:label "affects respiratory health of" ;
    rdfs:comment "Inverse - Represents the impact of air pollution on human respiratory health." ;
    rdfs:range ffonto:AirPollution ;
    rdfs:domain ffonto:HumanHealth .

ffonto:affectsRespiratoryHealthOf owl:inverseOf ffonto:affectsRespiratoryHealth .

ffonto:burnsVegetation
    a owl:ObjectProperty ;
    rdfs:label "burns vegetation" ;
    rdfs:comment "Indicates that a wildfire burns vegetation within an ecosystem." ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Vegetation .

ffonto:burnsVegetationOf
    a owl:ObjectProperty ;
    rdfs:label "burns vegetation of" ;
    rdfs:comment "Inverse - Indicates that a wildfire burns vegetation within an ecosystem." ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:Vegetation .

ffonto:burnsVegetationOf owl:inverseOf ffonto:burnsVegetation .

ffonto:causesRegrowth
    a owl:ObjectProperty ;
    rdfs:label "causes regrowth" ;
    rdfs:comment "Indicates that a wildfire can trigger vegetation regrowth after the fire event." ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:VegetationRegrowth .

ffonto:causesRegrowthInverse a owl:ObjectProperty ;
    rdfs:label "inverse of causes regrowth"@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:VegetationRegrowth .

ffonto:causesRegrowthInverse owl:inverseOf ffonto:causesRegrowth .

ffonto:regrowthOfSpecies
    a owl:ObjectProperty ;
    rdfs:label "regrowth of species" ;
    rdfs:comment "Indicates the plant species that are involved in vegetation regrowth after a wildfire." ;
    rdfs:domain ffonto:VegetationRegrowth ;
    rdfs:range ffonto:PlantSpecies .

ffonto:regrowthOfSpeciesOf a owl:ObjectProperty ;
    rdfs:label "inverse of regrowth of species"@en ;
    rdfs:range ffonto:VegetationRegrowth ;
    rdfs:domain ffonto:PlantSpecies .

ffonto:regrowthOfSpeciesOf owl:inverseOf ffonto:regrowthOfSpecies .

ffonto:occursInEcosystem
    a owl:ObjectProperty ;
    rdfs:label "occurs in ecosystem" ;
