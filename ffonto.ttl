@prefix ffonto: <http://example.org/ffonto#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foo: <https://w3id.org/def/foo#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns2: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix wo:  <http://purl.org/ontology/wo/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix time: <http://www.w3.org/2006/time#> .

#################################################################
# Ontology
#################################################################

<http://example.org/ffonto#> rdf:type owl:Ontology ;
                              owl:versionIRI ffonto:V1.2 ;
                              cc:license "" ;
                              dc:abstract "The Forest Fire Ontology (FFONTO) is designed to integrate multi-modal sensor data for early fire detection. It serves as an extensible framework with 'ForestFire' as the root class, incorporating concepts for visual detection, audio monitoring, and environmental conditions."@en ;
                              dc:contributor [ foaf:name "Prof. Dulani Meedeniya"@en ;
                                               schema:identifier <https://orcid.org/0000-0002-4520-3819>
                                             ] ;
                              dc:creator [ foaf:name "Ms. Charuni Kosala Jayaweera"@en ;
                                           schema:identifier <https://orcid.org/0009-0003-5790-62840>
                                         ] ;
                              dc:description "This ontology describes forest fire detection observations including image, audio, and weather data."@en ;
                              dc:title "Forest Fire Ontology (FFONTO)"@en ;
                              dcterms:issued "2026-01-27"^^xsd:date ;
                              dcterms:license "" ;
                              vann:preferredNamespacePrefix "ffonto"@en ;
                              rdfs:comment "Ontology for forest fire detection & observation (image, audio, weather). Root class: ForestFire. Designed for extensibility."@en ;
                              rdfs:seeAlso <https://github.com/kosala0514/FFOnto> ;
                              owl:versionInfo "Initial Release 1.0" ;
                              ns2:status "Active" ;
                              prov:generatedAtTime "2026-01-27T00:00:00+00:00"^^xsd:dateTime ;
                              prov:wasAttributedTo <https://github.com/kosala0514> .

#################################################################
# Environmental Assessment CQ

#################################################################
# Classes
#################################################################

ffonto:FireEvent rdf:type owl:Class ;
    rdfs:label "Fire Event" ;
    rdfs:comment "A fire occurrence affecting a forest ecosystem, including both natural and human-induced fires." .

ffonto:ForestFire rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireEvent ;
    skos:altLabel "Wildfire" ;
    rdfs:label "Forest Fire" ;
    rdfs:comment "An uncontrolled fire occurring in natural vegetation, often caused by lightning or human activities." .

ffonto:WildfireScene rdf:type owl:Class ;
    rdfs:label "Wildfire Scene" ;
    rdfs:comment "The environmental context where a wildfire event occurs and observations are made." .

ffonto:ControlledBurn rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireEvent ;
    rdfs:label "Controlled Burn" ;
    rdfs:comment "A deliberately planned and managed fire used to reduce fuel loads, prevent severe forest fires, and promote forest regeneration." .

ffonto:Plant rdf:type owl:Class ;
    rdfs:label "Plant" ;
    rdfs:comment "A living organism belonging to the plant kingdom that performs photosynthesis and forms the biological basis of vegetation in terrestrial ecosystems." .

ffonto:Vegetation rdf:type owl:Class ;
    rdfs:label "Vegetation" ;
    rdfs:comment "Plant life present in a forest ecosystem including trees, shrubs, and grasses." .

ffonto:Tree rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Tree" ;
    rdfs:comment "A woody perennial plant forming the main structural component of forest vegetation." .

ffonto:Shrub rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Shrub" ;
    rdfs:comment "A woody plant smaller than a tree, typically with multiple stems and forming part of forest understory vegetation." .

ffonto:Grass rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Grass" ;
    rdfs:comment "Herbaceous vegetation characterized by narrow leaves and soft stems, commonly forming ground cover in forest and grassland ecosystems." .

ffonto:Snag
    a owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Snag" ;
    rdfs:comment "Standing dead trees (snags)." .

ffonto:Stump
    a owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Stump" ;
    rdfs:comment "Tree stumps that may smolder." .

ffonto:ConiferousTree rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Tree ;
    rdfs:label "Coniferous Tree" ;
    rdfs:comment "A tree species that produces cones and typically has needle-like leaves, often containing resin that increases flammability." .

ffonto:DeciduousTree rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Tree ;
    rdfs:label "Deciduous Tree" ;
    rdfs:comment "A tree species that sheds its leaves seasonally and is generally less flammable than coniferous trees." .

ffonto:EnvironmentalCondition rdf:type owl:Class ;
    rdfs:label "Environmental Condition" ;
    rdfs:comment "A physical environmental factor that influences ecological processes, such as temperature, moisture, or snow cover." .

ffonto:SnowCover rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalCondition ;
    rdfs:label "Snow Cover" ;
    rdfs:comment "Snow present on the ground that can influence fire behavior by reducing vegetation dryness and limiting fire spread." .

ffonto:SoilCondition rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalCondition ;
    rdfs:label "Soil Condition" ;
    rdfs:comment "Physical and chemical characteristics of soil that influence vegetation growth and ecosystem health." .

ffonto:FireImpact rdf:type owl:Class ;
    rdfs:label "Fire Impact" ;
    rdfs:comment "Immediate environmental effects caused by a fire event, such as vegetation loss or carbon release." .

ffonto:EcologicalEffect rdf:type owl:Class ;
    rdfs:label "Ecological Effect" ;
    rdfs:comment "Long-term ecological changes resulting from environmental processes or disturbances." .

ffonto:ForestFireEffect rdf:type owl:Class ;
    rdfs:label "Forest Fire Effect" .

ffonto:ForestRegeneration rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalEffect ;
    rdfs:label "Forest Regeneration" ;
    rdfs:comment "The natural recovery and regrowth of vegetation following a disturbance such as a fire." .

ffonto:HabitatChange rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalEffect ;
    rdfs:label "Habitat Change" ;
    rdfs:comment "Alteration in wildlife habitats due to environmental disturbances or ecological succession." .

ffonto:SpeciesCompositionChange rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalEffect ;
    rdfs:label "Species Composition Change" ;
    rdfs:comment "A shift in the types and proportions of species present in an ecosystem following disturbance." .

ffonto:VegetationDistribution rdf:type owl:Class ;
    rdfs:label "Vegetation distribution" ;
    rdfs:comment "The spatial pattern or arrangement of vegetation within a defined area or ecosystem." .

ffonto:PatchyDistribution rdf:type ffonto:VegetationDistribution ;
    rdfs:label "Patchy distribution" ;
    rdfs:comment "A vegetation distribution pattern where plants occur in irregular, scattered patches separated by areas with little or no vegetation." .

ffonto:ContinuousDistribution rdf:type ffonto:VegetationDistribution ;
    rdfs:label "Continuous distribution" ;
    rdfs:comment "A vegetation distribution pattern where plant cover is relatively uniform and continuous across the landscape with minimal gaps." .

ffonto:FragmentedDistribution rdf:type ffonto:VegetationDistribution ;
    rdfs:label "Fragmented distribution" ;
    rdfs:comment "A vegetation distribution pattern where plant cover is broken into smaller, isolated patches due to natural processes or disturbances such as deforestation or land use change." .

ffonto:SoilQuality rdf:type owl:Class ;
    rdfs:label "Soil quality" ;
    rdfs:comment "Indicators of soil fertility or texture that influence vegetation growth and distribution." .

ffonto:WaterAvailability rdf:type owl:Class ;
    rdfs:label "Water availability" ;
    rdfs:comment "Hydrological conditions (moisture, groundwater) affecting vegetation and fire risk." .

ffonto:DisturbanceHistory rdf:type owl:Class ;
    rdfs:label "Disturbance history" ;
    rdfs:comment "Records of past disturbances (fires, logging, disease) affecting a spatial unit." .

ffonto:Understory rdf:type owl:Class ;
    rdfs:label "Understory" ;
    rdfs:comment "Shrub and herbaceous vegetation and litter layer beneath the forest canopy; important as surface fuel." .

ffonto:FuelLoad rdf:type owl:Class ;
    rdfs:label "Fuel load" ;
    rdfs:comment "Amount and type of combustible organic material present in a spatial unit." .

ffonto:LitterFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelLoad ;
    rdfs:label "Litter fuel" ;
    rdfs:comment "Small, fine fuels such as leaves and small twigs (fast-burning)." .

ffonto:LiveFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelLoad ;
    rdfs:label "Live fuel" ;
    rdfs:comment "Live vegetation that can act as fuel when sufficiently dry." .

ffonto:CoarseWoodyDebris rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelLoad ;
    rdfs:label "Coarse woody debris" ;
    rdfs:comment "Large downed logs and branches contributing to long-duration burns." .

ffonto:IgnitionSource rdf:type owl:Class ;
    rdfs:label "Ignition source" ;
    rdfs:comment "Cause or source of ignition for a fire event." .

ffonto:PlannedIgnition rdf:type owl:Class ;
    rdfs:subClassOf ffonto:IgnitionSource ;
    rdfs:label "Planned ignition" ;
    rdfs:comment "Deliberate ignition (e.g., prescribed burn)." .

ffonto:NaturalIgnition rdf:type owl:Class ;
    rdfs:subClassOf ffonto:IgnitionCause ;
    rdfs:subClassOf ffonto:IgnitionSource ;
    rdfs:label "Natural ignition" ;
    rdfs:comment "Natural causes of ignition such as lightning." .

ffonto:AccidentalIgnition rdf:type owl:Class ;
    rdfs:subClassOf ffonto:IgnitionSource ;
    rdfs:label "Accidental ignition" ;
    rdfs:comment "Human-caused accidental ignition." .

ffonto:FireSeverity rdf:type owl:Class ;
    rdfs:label "Fire severity" ;
    rdfs:comment "Categorical or continuous measure of ecological severity / intensity of a burn." .

ffonto:AirPollution rdf:type owl:Class ;
    rdfs:label "Air pollution" ;
    rdfs:comment "Airborne emissions resulting from fire (smoke, particulates)." .

ffonto:Smoke rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AirPollution ;
    rdfs:label "Smoke" ;
    rdfs:comment "Visible smoke produced by combustion." .

ffonto:ParticulateMatter rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AirPollution ;
    rdfs:label "Particulate matter" ;
    rdfs:comment "PM2.5/PM10 and other airborne particulates from fires." .

ffonto:CarbonRelease rdf:type owl:Class ;
    rdfs:label "Carbon release" ;
    rdfs:comment "Carbon (CO2, CO) emitted during combustion." .

ffonto:ErosionRisk rdf:type owl:Class ;
    rdfs:label "Erosion risk" ;
    rdfs:comment "Likelihood of increased soil erosion after vegetation removal or high-severity fire." .

ffonto:SuccessionStage rdf:type owl:Class ;
    rdfs:label "Succession stage" ;
    rdfs:comment "Post-disturbance vegetation stage (early successional shrubland, grassland, regenerating forest, etc.)." .

ffonto:HabitatType rdf:type owl:Class ;
    rdfs:label "Habitat type" ;
    rdfs:comment "Wildlife habitat categories (mature canopy, shrubland, grassland) relevant to biodiversity." .

ffonto:ManagementAction rdf:type owl:Class ;
    rdfs:label "Management action" ;
    rdfs:comment "Human management activities (prescribed burn, buffer creation, reseeding)." .

ffonto:ManagementPurpose rdf:type owl:Class ;
    rdfs:label "Management purpose" ;
    rdfs:comment "Purpose of a management action (fuel reduction, biodiversity enhancement, hazard reduction)." .

ffonto:ImageObservation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Observation ;
    rdfs:label "Image observation" ;
    rdfs:comment "Observation derived from imagery analysis with provenance and confidence metadata." .

ffonto:SpatialUnit rdf:type owl:Class ;
    rdfs:label "Spatial unit" ;
    rdfs:comment "Spatial unit for measurement and observation (plot, patch, landscape unit)." .

ffonto:VegetationFunctionalGroup rdf:type owl:Class ;
    rdfs:label "Vegetation functional group" ;
    rdfs:comment "Functional grouping such as coniferous, deciduous, shrub, or grass." .

ffonto:ConiferousFunctional rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VegetationFunctionalGroup ;
    rdfs:label "Coniferous functional group" ;
    rdfs:comment "Conifer-dominated functional group." .

ffonto:DeciduousFunctional rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VegetationFunctionalGroup ;
    rdfs:label "Deciduous functional group" ;
    rdfs:comment "Deciduous-dominated functional group." .

ffonto:VegetationPatternObservation a owl:Class ;
    rdfs:subClassOf ffonto:ImageObservation ;
    rdfs:label "Vegetation Pattern Observation" ;
    rdfs:comment "An observation describing spatial patterns of vegetation such as dense clusters, sparse coverage, or uneven distribution detected in an image." .

ffonto:SmokeObservation a owl:Class ;
    rdfs:subClassOf ffonto:ImageObservation ;
    rdfs:label "Smoke Observation" ;
    rdfs:comment "An observation indicating the presence of smoke within an environmental image, which may suggest an ongoing fire or combustion event." .

ffonto:FirePresenceObservation a owl:Class ;
    rdfs:subClassOf ffonto:ImageObservation ;
    rdfs:label "Fire Presence Observation" ;
    rdfs:comment "An observation indicating visible flames, burn marks, or other indicators suggesting that a fire event is occurring." .

ffonto:SnowCoverObservation a owl:Class ;
    rdfs:subClassOf ffonto:ImageObservation ;
    rdfs:label "Snow Cover Observation" ;
    rdfs:comment "An observation indicating the presence of snow cover on the ground or vegetation in an environmental image." .

ffonto:EcosystemService a owl:Class ;
    rdfs:label "Ecosystem Service" ;
    rdfs:comment "A benefit provided by natural ecosystems that supports environmental stability, biodiversity, and ecological processes." .

ffonto:NutrientCycling a owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Nutrient Cycling" ;
    rdfs:comment "An ecosystem process through which nutrients are recycled within the ecosystem, supporting plant growth and soil fertility." .

ffonto:ForestRegeneration a owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Forest Regeneration" ;
    rdfs:comment "The natural or assisted recovery and regrowth of forest vegetation following disturbances such as fire or logging." .

ffonto:BiodiversitySupport a owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Biodiversity Support" ;
    rdfs:comment "An ecosystem service that maintains or enhances species diversity and ecological resilience." .

ffonto:FuelLoadReduction a owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Fuel Load Reduction" ;
    rdfs:comment "The reduction of accumulated combustible vegetation materials that could contribute to the intensity of forest fires." .

ffonto:FireSpreadCondition a owl:Class ;
    rdfs:label "Fire Spread Condition" ;
    rdfs:comment "Environmental or ecological conditions that influence how a fire spreads across a landscape." .

ffonto:FuelMoistureCondition a owl:Class ;
    rdfs:subClassOf ffonto:FireSpreadCondition ;
    rdfs:label "Fuel Moisture Condition" ;
    rdfs:comment "A condition describing the moisture content of vegetation or fuel material that influences fire ignition and spread." .

ffonto:FireContainmentFactor a owl:Class ;
    rdfs:subClassOf ffonto:FireSpreadCondition ;
    rdfs:label "Fire Containment Factor" ;
    rdfs:comment "A natural or artificial factor that limits or prevents the spread of fire." .

ffonto:Ecosystem rdf:type owl:Class ;
    rdfs:label "Ecosystem" ;
    rdfs:comment "A biological community interacting with its physical environment." .

ffonto:ForestEcosystem rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Ecosystem ;
    rdfs:label "Forest Ecosystem" ;
    rdfs:comment "An ecosystem dominated by trees and woody vegetation." .

ffonto:Grassland rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Ecosystem ;
    rdfs:label "Grassland" ;
    rdfs:comment "An ecosystem dominated primarily by grasses and herbaceous plants." .

ffonto:Shrubland rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Ecosystem ;
    rdfs:label "Shrubland" ;
    rdfs:comment "An ecosystem characterized by dense shrub vegetation." .

ffonto:ConiferousForest a owl:Class ;
    rdfs:subClassOf ffonto:ForestEcosystem ;
    rdfs:label "Coniferous Forest" ;
    rdfs:comment "A forest ecosystem dominated by cone-bearing trees such as pines, spruces, and firs." .

ffonto:DeciduousForest a owl:Class ;
    rdfs:subClassOf ffonto:ForestEcosystem ;
    rdfs:label "Deciduous Forest" ;
    rdfs:comment "A forest ecosystem dominated by trees that seasonally shed their leaves." .

ffonto:MixedForest a owl:Class ;
    rdfs:subClassOf ffonto:ForestEcosystem ;
    rdfs:label "Mixed Forest" ;
    rdfs:comment "A forest ecosystem containing both coniferous and deciduous tree species." .

ffonto:PlantFlammabilityTrait a owl:Class ;
    rdfs:label "Plant Flammability Trait" ;
    rdfs:comment "A characteristic of plant species that influences their susceptibility to ignition and contribution to fire intensity." .

ffonto:HighFlammability a owl:Class ;
    rdfs:subClassOf ffonto:PlantFlammabilityTrait ;
    rdfs:label "High Flammability" ;
    rdfs:comment "A trait describing vegetation that ignites easily and burns intensely." .

ffonto:ModerateFlammability a owl:Class ;
    rdfs:subClassOf ffonto:PlantFlammabilityTrait ;
    rdfs:label "Moderate Flammability" ;
    rdfs:comment "A trait describing vegetation with moderate susceptibility to ignition and burning." .

ffonto:LowFlammability a owl:Class ;
    rdfs:subClassOf ffonto:PlantFlammabilityTrait ;
    rdfs:label "Low Flammability" ;
    rdfs:comment "A trait describing vegetation that resists ignition and contributes less to fire intensity." .

ffonto:LandscapeFeature rdf:type owl:Class ;
    rdfs:label "Landscape Feature" ;
    rdfs:comment "A physical natural feature of the landscape." .

ffonto:WaterBody rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandscapeFeature ;
    rdfs:label "Water Body" ;
    rdfs:comment "A natural accumulation of water such as lakes or rivers." .

ffonto:Lake rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WaterBody ;
    rdfs:label "Lake" ;
    rdfs:comment "A large inland body of standing water." .

ffonto:River rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WaterBody ;
    rdfs:label "River" ;
    rdfs:comment "A natural flowing watercourse." .

ffonto:WaterChannel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WaterBody ;
    rdfs:label "Water Channel" ;
    rdfs:comment "A narrow water passage connecting bodies of water." .

ffonto:Island rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandscapeFeature ;
    rdfs:label "Island" ;
    rdfs:comment "A landmass surrounded by water." .

ffonto:FuelType rdf:type owl:Class ;
    rdfs:label "Fuel Type" ;
    rdfs:comment "Combustible vegetation material that contributes to fire spread." .

ffonto:FineFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelType ;
    rdfs:label "Fine Fuel" ;
    rdfs:comment "Small combustible materials like dry grass or leaves that ignite easily." .

ffonto:SurfaceFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelType ;
    rdfs:label "Surface Fuel" ;
    rdfs:comment "Fuel located on the ground surface such as leaf litter." .

ffonto:HeavyFuel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelType ;
    rdfs:label "Heavy Fuel" ;
    rdfs:comment "Large woody materials that burn for long durations." .

ffonto:FireBehavior rdf:type owl:Class ;
    rdfs:label "Fire Behavior" ;
    rdfs:comment "Characteristics describing how a fire behaves and spreads." .

ffonto:FireSpread rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireBehavior ;
    rdfs:label "Fire Spread" ;
    rdfs:comment "The rate and direction in which fire moves." .

ffonto:FlameHeight rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireBehavior ;
    rdfs:label "Flame Height" ;
    rdfs:comment "The vertical height of flames during a fire." .

ffonto:EmberTransport rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireBehavior ;
    rdfs:label "Ember Transport" ;
    rdfs:comment "Movement of burning embers carried by wind." .

ffonto:FireIntensity rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireBehavior ;
    rdfs:label "Fire Intensity" ;
    rdfs:comment "The energy output of a fire." .

ffonto:EnvironmentalFactor rdf:type owl:Class ;
    rdfs:label "Environmental Factor" ;
    rdfs:comment "Environmental conditions affecting fire behavior." .

ffonto:Wind rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WeatherFactor ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:subClassOf ffonto:ForestFireRiskFactor ;
    rdfs:label "Wind" ;
    rdfs:comment "Air movement that influences fire spread and ember transport." .

ffonto:NightConditions rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:label "Nighttime Conditions" ;
    rdfs:comment "Lower visibility, potential downslope winds, and operational hazards." .

ffonto:SoilCondition rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:label "Soil Condition" ;
    rdfs:comment "Characteristics of soil such as moisture and nutrient content." .

ffonto:MoistureLevel rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:label "Moisture Level" ;
    rdfs:comment "Amount of moisture present in the environment." .

ffonto:NaturalBarrier rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:subClassOf ffonto:Topography ;
    rdfs:label "Natural Barrier" ;
    rdfs:comment "Natural features such as rivers or lakes that slow fire spread." .

ffonto:EcologicalImpact rdf:type owl:Class ;
    rdfs:label "Ecological Impact" ;
    rdfs:comment "Environmental consequences resulting from fires." .

ffonto:TreeRegeneration rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:label "Tree Regeneration" ;
    rdfs:comment "The process of tree regrowth following fire disturbance." .

ffonto:SoilNutrientChange rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:label "Soil Nutrient Change" ;
    rdfs:comment "Changes in soil nutrient composition caused by fire." .

ffonto:HabitatLoss rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:label "Habitat Loss" ;
    rdfs:comment "Destruction or reduction of habitats due to fire." .

ffonto:ErosionRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:label "Erosion Risk" ;
    rdfs:comment "Increased risk of soil erosion after vegetation loss." .

ffonto:VegetationRecovery rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalImpact ;
    rdfs:label "Vegetation Recovery" ;
    rdfs:comment "Regrowth of vegetation following fire disturbance." .

ffonto:FireManagementStrategy rdf:type owl:Class ;
    rdfs:label "Fire Management Strategy" ;
    rdfs:comment "Methods used to control or mitigate wildfire spread." .

ffonto:Firebreak rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireManagementStrategy ;
    rdfs:label "Firebreak" ;
    rdfs:comment "A gap in vegetation used to stop or slow fire spread." .

ffonto:Backburn rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireManagementStrategy ;
    rdfs:label "Backburn" ;
    rdfs:comment "A controlled fire set ahead of a wildfire to remove fuel." .

ffonto:ManualSuppression rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireManagementStrategy ;
    rdfs:label "Manual Suppression" ;
    rdfs:comment "Fire suppression performed using tools and human labor." .

ffonto:ControlledBurn rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireManagementStrategy ;
    rdfs:label "Controlled Burn" ;
    rdfs:comment "A planned fire used to reduce fuel loads." .

ffonto:EcosystemService rdf:type owl:Class ;
    rdfs:label "Ecosystem Service" ;
    rdfs:comment "Benefits provided by ecosystems to humans and nature." .

ffonto:BiodiversitySupport rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Biodiversity Support" ;
    rdfs:comment "The role of ecosystems in supporting diverse species." .

ffonto:ErosionControl rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:subClassOf ffonto:PostFireRehabilitation ;
    rdfs:label "Erosion Control" ;
    rdfs:comment "Prevention of soil erosion through vegetation cover." .

ffonto:WaterProtection rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Water Protection" ;
    rdfs:comment "Protection of water quality and regulation of hydrological systems." .

ffonto:HabitatProvision rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Habitat Provision" ;
    rdfs:comment "Provision of living space for organisms." .

ffonto:LandCover rdf:type owl:Class ;
    rdfs:label "Land cover" ;
    rdfs:comment "The physical material covering the surface of the earth such as forest, water, or barren land." .

ffonto:DenseForest rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCover ;
    rdfs:label "Dense forest" ;
    rdfs:comment "Land cover characterized by dense tree canopy and continuous vegetation." .

ffonto:SparseWoodland rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCover ;
    rdfs:label "Sparse woodland" ;
    rdfs:comment "Woodland area with scattered trees and lower canopy density." .

ffonto:DegradedVegetation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCover ;
    rdfs:label "Degraded vegetation" ;
    rdfs:comment "Land cover where vegetation health or density has declined due to disturbance or environmental stress." .

ffonto:BarrenLand rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCover ;
    rdfs:label "Barren land" ;
    rdfs:comment "Land with little or no vegetation cover." .

ffonto:RockyTerrain rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCover ;
    rdfs:label "Rocky terrain" ;
    rdfs:comment "Land cover dominated by exposed rocks or rocky surfaces." .

ffonto:VegetationCondition rdf:type owl:Class ;
    rdfs:label "Vegetation condition" ;
    rdfs:comment "Represents the health or status of vegetation within an ecosystem." .

ffonto:HealthyVegetation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VegetationCondition ;
    rdfs:label "Healthy vegetation" ;
    rdfs:comment "Vegetation with strong growth and normal canopy coverage." .

ffonto:DeadVegetation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VegetationCondition ;
    rdfs:label "Dead vegetation" ;
    rdfs:comment "Vegetation that has died due to fire, pests, drought, or disease." .

ffonto:SparseVegetation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:VegetationCondition ;
    rdfs:label "Sparse vegetation" ;
    rdfs:comment "Vegetation distributed sparsely across the landscape." .

ffonto:Disturbance rdf:type owl:Class ;
    rdfs:label "Disturbance" ;
    rdfs:comment "An event or process that disrupts ecosystem structure or function." .

ffonto:PestInfestation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Disturbance ;
    rdfs:label "Pest infestation" ;
    rdfs:comment "Damage to vegetation caused by insects or pests." .

ffonto:BarkBeetleInfestation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:PestInfestation ;
    rdfs:label "Bark beetle infestation" ;
    rdfs:comment "A specific pest disturbance where bark beetles damage trees." .

ffonto:Drought rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Disturbance ;
    rdfs:subClassOf ffonto:ClimateDriver ;
    rdfs:label "Drought" ;
    rdfs:comment "Extended period of insufficient rainfall causing vegetation stress." .

ffonto:Logging rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Disturbance ;
    rdfs:label "Logging" ;
    rdfs:comment "Human activity involving cutting down trees for timber." .

ffonto:Deforestation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Disturbance ;
    rdfs:label "Deforestation" ;
    rdfs:comment "Large-scale removal of forest cover." .

ffonto:WildfireDamage rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Disturbance ;
    rdfs:label "Wildfire damage" ;
    rdfs:comment "Vegetation damage caused by wildfire events." .

ffonto:EcologicalStress rdf:type owl:Class ;
    rdfs:label "Ecological stress" ;
    rdfs:comment "Environmental pressure affecting ecosystem stability." .

ffonto:VegetationStress rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalStress ;
    rdfs:label "Vegetation stress" ;
    rdfs:comment "Stress affecting plant growth or health." .

ffonto:SoilNutrientLoss rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcologicalStress ;
    rdfs:label "Soil nutrient loss" ;
    rdfs:comment "Reduction in soil fertility due to environmental factors." .

ffonto:DeadBiomass rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ForestFireRiskFactor ;
    rdfs:label "Dead biomass" ;
    rdfs:comment "Accumulated dead plant material acting as fuel for fire." .

ffonto:TerrainType rdf:type owl:Class ;
    rdfs:label "Terrain type" ;
    rdfs:comment "Classification of physical landscape terrain." .

ffonto:BarrenTerrain rdf:type owl:Class ;
    rdfs:subClassOf ffonto:TerrainType ;
    rdfs:label "Barren terrain" ;
    rdfs:comment "Terrain with minimal vegetation cover." .

ffonto:SoilQuality rdf:type owl:Class ;
    rdfs:label "Soil quality" ;
    rdfs:comment "Characteristics describing the fertility and health of soil." .

ffonto:NutrientPoorSoil rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SoilQuality ;
    rdfs:label "Nutrient poor soil" ;
    rdfs:comment "Soil with low nutrient availability limiting vegetation growth." .

ffonto:EcosystemService rdf:type owl:Class ;
    rdfs:label "Ecosystem service" ;
    rdfs:comment "Benefits provided by ecosystems that support environmental health and biodiversity." .

ffonto:SoilMoistureRetention rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Soil moisture retention" ;
    rdfs:comment "Ability of an ecosystem or water body to maintain soil moisture levels." .

ffonto:FireSeverityReduction rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Fire severity reduction" ;
    rdfs:comment "Ecosystem service where water bodies or moist ecosystems reduce wildfire severity." .

ffonto:Pine rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ConiferousTree ;
    rdfs:label "Pine tree" ;
    rdfs:comment "A coniferous tree species belonging to the genus Pinus commonly found in boreal forests." .

ffonto:Spruce rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ConiferousTree ;
    rdfs:label "Spruce tree" ;
    rdfs:comment "A coniferous tree species belonging to the genus Picea commonly found in cold forest ecosystems." .

ffonto:Moss rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Moss" ;
    rdfs:comment "Small non-vascular plants commonly found in moist or nutrient-poor environments." .

ffonto:HardyVegetation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Hardy vegetation" ;
    rdfs:comment "Vegetation adapted to survive harsh environmental conditions such as poor soil or low nutrients." .

ffonto:FireSusceptibility rdf:type owl:Class ;
    rdfs:label "Fire susceptibility" ;
    rdfs:comment "Classification of how vulnerable an ecosystem is to wildfire ignition and spread." .

ffonto:LowFireRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireSusceptibility ;
    rdfs:label "Low fire risk" ;
    rdfs:comment "Indicates low probability of wildfire ignition or spread." .

ffonto:ModerateFireRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireSusceptibility ;
    rdfs:label "Moderate fire risk" ;
    rdfs:comment "Indicates moderate wildfire risk under certain environmental conditions." .

ffonto:HighFireRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireSusceptibility ;
    rdfs:label "High fire risk" ;
    rdfs:comment "Indicates high vulnerability to wildfire ignition and spread." .

ffonto:PoorSoilFertility rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SoilQuality ;
    rdfs:label "Poor soil fertility" ;
    rdfs:comment "Soil condition characterized by low nutrient availability for plant growth." .

ffonto:Biodiversity rdf:type owl:Class ;
    rdfs:label "Biodiversity" ;
    rdfs:comment "The variety and variability of living organisms within an ecosystem." .

ffonto:Habitat rdf:type owl:Class ;
    rdfs:label "Habitat" ;
    rdfs:comment "The natural environment where species live and obtain resources." .

ffonto:TransitionalEcosystem rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Ecosystem ;
    rdfs:label "Transitional ecosystem" ;
    rdfs:comment "An ecosystem occurring between two ecological zones." .

ffonto:Wetland rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Ecosystem ;
    rdfs:label "Wetland" ;
    rdfs:comment "An ecosystem where land is saturated with water." .

ffonto:Tundra rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Ecosystem ;
    rdfs:label "Tundra ecosystem" ;
    rdfs:comment "Cold ecosystem with minimal vegetation and permafrost soils." .

ffonto:ClimateChange rdf:type owl:Class ;
    rdfs:label "Climate change" ;
    rdfs:comment "Long-term changes in global or regional climate patterns." .

ffonto:EnvironmentalRisk rdf:type owl:Class ;
    rdfs:label "Environmental risk" ;
    rdfs:comment "Potential environmental hazards affecting ecosystems." .

ffonto:ExtremeWeather rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalRisk ;
    rdfs:label "Extreme weather" ;
    rdfs:comment "Severe weather events affecting ecosystems." .

ffonto:Infrastructure rdf:type owl:Class ;
    rdfs:label "Infrastructure" ;
    rdfs:comment "Human-built structures within natural landscapes." .

ffonto:Road rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Road" ;
    rdfs:comment "Transportation pathway crossing natural landscapes." .

ffonto:HabitatFragmentation rdf:type owl:Class ;
    rdfs:label "Habitat fragmentation" ;
    rdfs:comment "Division of ecosystems into smaller isolated patches." .

ffonto:ForestStructure rdf:type owl:Class ;
    rdfs:label "Forest structure" ;
    rdfs:comment "Structural characteristics of a forest ecosystem." .

ffonto:Forest
    rdfs:label "Forest"@en ;
    rdfs:comment "A large area dominated by trees and natural vegetation."@en .

ffonto:MatureForest rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Forest ;
    rdfs:label "Mature forest" ;
    rdfs:comment "Forest ecosystem with established canopy and stable vegetation structure." .

ffonto:MixedVegetation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vegetation ;
    rdfs:label "Mixed vegetation" ;
    rdfs:comment "Vegetation composed of multiple plant species." .

ffonto:CarbonSink rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EcosystemService ;
    rdfs:label "Carbon sink" ;
    rdfs:comment "Ecosystem service where carbon dioxide is absorbed and stored." .

#################################################################
# Disjoint classes
#################################################################

ffonto:ForestFire owl:disjointWith ffonto:ControlledBurn .

ffonto:ConiferousTree owl:disjointWith ffonto:DeciduousTree .

ffonto:SnowCover owl:disjointWith ffonto:SoilCondition .

ffonto:PlannedIgnition owl:disjointWith ffonto:NaturalIgnition .
ffonto:PlannedIgnition owl:disjointWith ffonto:AccidentalIgnition .
ffonto:NaturalIgnition owl:disjointWith ffonto:AccidentalIgnition .

ffonto:ConiferousFunctional owl:disjointWith ffonto:DeciduousFunctional .

#################################################################
# Class restrictions
#################################################################

ffonto:ControlledBurn rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:occursIn ;
    owl:someValuesFrom ffonto:ForestEcosystem
] .

# Controlled burns must have a management purpose and occur in a forest ecosystem
ffonto:ControlledBurn rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:hasManagementPurpose ;
    owl:someValuesFrom ffonto:ManagementPurpose
] , [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:occursIn ;
    owl:someValuesFrom ffonto:ForestEcosystem
] .

# Fire events are linked to ignition source and have a burn severity
ffonto:FireEvent rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:hasIgnitionSource ;
    owl:someValuesFrom ffonto:IgnitionSource
] , [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:hasBurnSeverity ;
    owl:someValuesFrom ffonto:FireSeverity
] .

# If a SpatialUnit has a vegetation distribution it should link to vegetation
ffonto:SpatialUnit rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:hasVegetationDistribution ;
    owl:someValuesFrom ffonto:VegetationDistribution
] .

# Example: high burn severity could be defined as a subclass of FireSeverity with a data restriction (optional)
ffonto:HighBurnSeverity rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireSeverity ;
    rdfs:label "High burn severity" ;
    rdfs:comment "High severity class; could be constrained by burnSeverityIndex thresholds in rules." .

#################################################################
# Cardinality restriction
#################################################################

ffonto:FireEvent rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty ffonto:occursIn ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass ffonto:ForestEcosystem
] .

#################################################################
# Property chain
#################################################################

ffonto:affectsEcosystem rdf:type owl:ObjectProperty ;
    rdfs:label "affects ecosystem" ;
    rdfs:comment "Indicates that a fire event affects an ecosystem through vegetation relationships." ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:Ecosystem ;
    owl:propertyChainAxiom (
        ffonto:hasVegetation
        ffonto:influencedBy
    ) .

ffonto:affectsEcosystemOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:Ecosystem ;
    rdfs:label "inverse of affects ecosystem"@en .

ffonto:affectsEcosystemOf owl:inverseOf ffonto:affectsEcosystem .

ffonto:increasesFireRisk rdf:type owl:ObjectProperty ;
    rdfs:label "increases fire risk" ;
    rdfs:comment "Indicates that an environmental factor increases wildfire risk through vegetation distribution and fuel load." ;
    rdfs:domain ffonto:EnvironmentalFactor ;
    rdfs:range ffonto:ForestFireRisk ;
    owl:propertyChainAxiom (
        ffonto:hasVegetationDistribution
        ffonto:hasFuelLoad
    ) .

ffonto:increasesFireRiskOf a owl:ObjectProperty ;
    rdfs:range ffonto:EnvironmentalFactor ;
    rdfs:domain ffonto:ForestFireRisk ;
    rdfs:label "inverse of increases fire risk"@en .

ffonto:increasesFireRiskOf owl:inverseOf ffonto:increasesFireRisk .

ffonto:impliesHighSeverity rdf:type owl:ObjectProperty ;
    rdfs:label "implies high severity" ;
    rdfs:comment "Indicates that fuel load combined with ignition source conditions suggests high fire severity." ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FireSeverity ;
    owl:propertyChainAxiom (
        ffonto:hasFuelLoad
        ffonto:hasIgnitionSource
    ) .

ffonto:impliesHighSeverityOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FireSeverity ;
    rdfs:label "inverse of implies high severity"@en .

ffonto:impliesHighSeverityOf owl:inverseOf ffonto:impliesHighSeverity .

#################################################################
# Union class
#################################################################



#################################################################
# Intersection class
#################################################################

ffonto:FireDrivenEcologicalChange rdf:type owl:Class ;
    owl:intersectionOf (
        ffonto:EcologicalEffect
        ffonto:FireImpact
    ) ;
    rdfs:label "Fire Driven Ecological Change" ;
    rdfs:comment "Ecological change caused directly by fire events." .

#################################################################
# Object Properties
#################################################################

ffonto:hasVegetation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range ffonto:Vegetation ;
    rdfs:label "has vegetation" ;
    rdfs:comment "Relates a forest ecosystem to the vegetation present within it." .

ffonto:occursInEcosystem a owl:ObjectProperty ;
    rdfs:label "occurs in ecosystem"@en ;
    rdfs:comment "Original property (exists in your ontology). Declared inverseOf :hasVegetation."@en .

ffonto:hasVegetation owl:inverseOf ffonto:occursInEcosystem .
ffonto:occursInEcosystem owl:inverseOf ffonto:hasVegetation .

ffonto:hasTreeSpecies rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range ffonto:Tree ;
    rdfs:label "has tree species" ;
    rdfs:comment "Indicates the tree species present in a forest ecosystem." .

ffonto:isTreeSpeciesOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ForestEcosystem ;
    rdfs:domain ffonto:Tree ;
    rdfs:label "is tree species of" ;
    rdfs:comment "Inverse - Indicates the tree species present in a forest ecosystem." .

ffonto:isTreeSpeciesOf owl:inverseOf ffonto:hasTreeSpecies .

ffonto:occursIn rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:WildfireScene ;
    rdfs:label "occurs in" ;
    rdfs:comment "Specifies the forest ecosystem where a fire event takes place." .

ffonto:occurs rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:label "occurs" ;
    rdfs:comment "Inverse - Specifies the forest ecosystem where a fire event takes place." .

ffonto:occurs owl:inverseOf ffonto:occursIn .

ffonto:influencedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireBehavior ;
    rdfs:range ffonto:EnvironmentalCondition ;
    rdfs:label "influenced by" ;
    rdfs:comment "Indicates environmental conditions that affect the behavior of a fire event." .

ffonto:influencedOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireBehavior ;
    rdfs:domain ffonto:EnvironmentalCondition ;
    rdfs:label "influenced of" ;
    rdfs:comment "Inverse - Indicates environmental conditions that affect the behavior of a fire event." .

ffonto:influencedOf owl:inverseOf ffonto:influencedBy .

ffonto:causesImpact rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FireImpact ;
    rdfs:label "causes impact" ;
    rdfs:comment "Links a fire event to its immediate environmental impacts." .

ffonto:causesImpactOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FireImpact ;
    rdfs:label "inverse of causes impact"@en .

ffonto:causesImpactOf owl:inverseOf ffonto:causesImpact .

ffonto:leadsToEffect rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:EcologicalEffect ;
    rdfs:label "leads to ecological effect" ;
    rdfs:comment "Represents long-term ecological effects resulting from a fire event." .

ffonto:leadsToEffectOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:EcologicalEffect ;
    rdfs:label "inverse of leads to effect"@en .

ffonto:leadsToEffectOf owl:inverseOf ffonto:leadsToEffect .

ffonto:affectsHabitat rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:EcologicalEffect ;
    rdfs:range ffonto:HabitatType ;
    rdfs:label "affects habitat" ;
    rdfs:comment "Indicates that an ecological effect alters wildlife habitat type (mature forest, shrub land, grass land)." .

ffonto:affectsHabitatOf a owl:ObjectProperty ;
    rdfs:range ffonto:EcologicalEffect ;
    rdfs:domain ffonto:HabitatType ;
    rdfs:label "inverse of affects habitat"@en .

ffonto:affectsHabitatOf owl:inverseOf ffonto:affectsHabitat .

ffonto:altersSpeciesComposition rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:EcologicalEffect ;
    rdfs:range ffonto:Vegetation ;
    rdfs:label "alters species composition" ;
    rdfs:comment "Fire may change species composition." .

ffonto:altersSpeciesCompositionOf a owl:ObjectProperty ;
    rdfs:range ffonto:EcologicalEffect ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:label "inverse of alters species composition"@en .

ffonto:altersSpeciesCompositionOf owl:inverseOf ffonto:altersSpeciesComposition .

ffonto:promotesRegeneration rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:ForestRegeneration ;
    rdfs:label "promotes regeneration" ;
    rdfs:comment "Fire can stimulate forest regrowth." .

ffonto:promotesRegenerationOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:ForestRegeneration ;
    rdfs:label "promotes regeneration of" ;
    rdfs:comment "Inverse - Fire can stimulate forest regrowth." ;
    owl:inverseOf ffonto:promotesRegeneration .

ffonto:hasFuel rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:Fuel ;
    rdfs:label "has fuel" ;
    rdfs:comment "Relates a fire event to the vegetation that acts as fuel." .

ffonto:isFuelOf a owl:ObjectProperty ;
    rdfs:label "inverse of is fuel"@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:Fuel .

ffonto:isFuelOf owl:inverseOf ffonto:hasFuel .

ffonto:hasSoilCondition rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range ffonto:SoilCondition ;
    rdfs:label "has soil condition" ;
    rdfs:comment "Specifies the soil condition present in a forest ecosystem." .

ffonto:isSoilConditionOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestEcosystem ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:label "inverse of is soil condition"@en .

ffonto:isSoilConditionOf owl:inverseOf ffonto:hasSoilCondition .

ffonto:hasSnowCover rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range ffonto:SnowCover ;
    rdfs:label "has snow cover" ;
