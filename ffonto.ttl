    rdfs:domain ffonto:IntentionalFire ;
    rdfs:range ffonto:LandClearing .

ffonto:occursForPurposeOf a owl:ObjectProperty ;
    rdfs:range ffonto:IntentionalFire ;
    rdfs:domain ffonto:LandClearing ;
    rdfs:label "inverse of occurs for purpose"@en .

ffonto:occursForPurposeOf owl:inverseOf ffonto:occursForPurpose .

ffonto:affectedByAsh
    a owl:ObjectProperty ;
    rdfs:label "affected by ash"@en ;
    rdfs:comment "Relates an AgriculturalProduce instance to one or more AshFall instances that affected it."@en ;
    rdfs:domain ffonto:AgriculturalProduce ;
    rdfs:range  ffonto:AshFall .

ffonto:affectedByAshOf a owl:ObjectProperty ;
    rdfs:range ffonto:AgriculturalProduce ;
    rdfs:domain  ffonto:AshFall ;
    rdfs:label "inverse of affected by ash"@en .

ffonto:affectedByAshOf owl:inverseOf ffonto:affectedByAsh .

ffonto:producedInArea
    a owl:ObjectProperty ;
    rdfs:label "produced in area"@en ;
    rdfs:comment "Relates an AgriculturalProduce instance to the Location in which it was produced."@en ;
    rdfs:domain ffonto:AgriculturalProduce ;
    rdfs:range  ffonto:Location .

ffonto:producedInAreaOf a owl:ObjectProperty ;
    rdfs:range ffonto:AgriculturalProduce ;
    rdfs:domain  ffonto:Location ;
    rdfs:label "inverse of produced in area"@en .

ffonto:producedInAreaOf owl:inverseOf ffonto:producedInArea .

ffonto:generatedByWildfire
    a owl:ObjectProperty ;
    rdfs:label "generated by wildfire"@en ;
    rdfs:comment "Relates an AshFall instance to a Wildfire instance that generated the ash (if known)."@en ;
    rdfs:domain ffonto:AshFall ;
    rdfs:range  ffonto:ForestFire .

ffonto:generatedByWildfireOf a owl:ObjectProperty ;
    rdfs:range ffonto:AshFall ;
    rdfs:domain  ffonto:ForestFire ;
    rdfs:label "inverse of generated by wildfire"@en .

ffonto:generatedByWildfireOf owl:inverseOf ffonto:generatedByWildfire .

ffonto:requiresHandlingGuideline
    a owl:ObjectProperty ;
    rdfs:label "requires handling guideline" ;
    rdfs:comment "Indicates that a hazardous material must be handled according to a specific hazardous waste guideline." ;
    rdfs:domain ffonto:HazardousMaterial ;
