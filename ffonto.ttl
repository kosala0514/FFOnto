    rdfs:label "positioned between" ;
    rdfs:domain ffonto:Responder ;
    rdfs:range ffonto:StructureFire ;
    rdfs:comment "Resources placed between fire and a structure to protect it." .

ffonto:positionedBetweenOf rdf:type owl:ObjectProperty ;
    rdfs:label "positioned between" ;
