ffonto:MeteorologicalObservation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WeatherFactor ;
    rdfs:subClassOf ffonto:WeatherObservation ;
    rdfs:label "Meteorological Observation" .

ffonto:FireLine rdf:type owl:Class ;
    rdfs:label "Fire Line" ;
    rdfs:comment "Constructed control line to stop fire spread." .

ffonto:WeatherCondition rdf:type owl:Class ;
    rdfs:label "Weather Condition" .

ffonto:SmokePlume rdf:type owl:Class ;
    rdfs:label "Smoke Plume" .

ffonto:AirQualityIndex rdf:type owl:Class ;
    rdfs:label "Air Quality Index" .

ffonto:IncidentCommand rdf:type owl:Class ;
    rdfs:label "Incident Command" .

ffonto:OperationsSection rdf:type owl:Class ;
    rdfs:label "Operations Section" .

ffonto:Branch rdf:type owl:Class ;
    rdfs:subClassOf ffonto:OperationsSection ;
    rdfs:label "Operational Branch" .

ffonto:partOfIncidentCommand rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Branch ;
    rdfs:range ffonto:IncidentCommand .

ffonto:partOfIncidentCommandOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Branch ;
    rdfs:domain ffonto:IncidentCommand .

ffonto:partOfIncidentCommandOf owl:inverseOf ffonto:partOfIncidentCommand .

ffonto:SafetyOfficer rdf:type owl:Class ;
    rdfs:label "Safety Officer" .

ffonto:Division rdf:type owl:Class ;
    rdfs:label "Fire Division" .

ffonto:Branch rdf:type owl:Class ;
    rdfs:label "Operational Branch" .

ffonto:Airspace rdf:type owl:Class ;
    rdfs:label "Airspace" .

ffonto:TemporaryFlightRestriction rdf:type owl:Class ;
    rdfs:label "Temporary Flight Restriction (TFR)" ;
    rdfs:comment "Airspace restriction protecting wildfire aircraft operations." .

ffonto:Helispot rdf:type owl:Class ;
    rdfs:label "Helispot" .

ffonto:FlightPath rdf:type owl:Class ;
    rdfs:label "Aircraft Flight Path" .

ffonto:AirAttackSupervisor rdf:type owl:Class ;
    rdfs:label "Air Attack Supervisor" .

ffonto:EvacuationZone rdf:type owl:Class ;
    rdfs:label "Evacuation Zone" ;
     rdfs:comment "A geographic area designated for evacuation procedures during an emergency."@en .

ffonto:FireShelter rdf:type owl:Class ;
    rdfs:label "Fire Shelter" ;
    rdfs:comment "Personal deployable shelters and pre-positioned sheltering options." .

ffonto:VulnerablePopulation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:PopulationGroup ;
    rdfs:label "Vulnerable Population" .

ffonto:HeatStressHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Heat Stress Hazard" .

ffonto:DownedPowerLineHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Downed Power Line Hazard" .

ffonto:DebrisFlowHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Debris Flow Hazard" .

ffonto:AshPitHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Ash Pit Hazard" .

ffonto:Sensor rdf:type owl:Class ;
    rdfs:subClassOf sosa:Sensor ;
    rdfs:label "Sensor" .

ffonto:Camera rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Sensor ;
    rdfs:label "Camera"@en ;
    rdfs:comment "An imaging device used to capture visual data for wildfire monitoring or detection."@en .

ffonto:Radio rdf:type owl:Class ;
    rdfs:label "Handheld Radio" .

ffonto:HandTool rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Tool ;
    rdfs:label "Hand Tool" .

#################################################################
# Object properties
#################################################################

ffonto:hasPerimeterSnapshot rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:PerimeterSnapshot ;
    rdfs:label "has perimeter snapshot" ;
    rdfs:comment "Links an incident to the latest perimeter snapshot used to compute area." .

ffonto:isPerimeterSnapshotOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:PerimeterSnapshot ;
    rdfs:label "inverse of is perimeter snapshot"@en .

ffonto:isPerimeterSnapshotOf owl:inverseOf ffonto:hasPerimeterSnapshot .

ffonto:hasCameraObservation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:hasObservation ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:CameraObservation ;
    rdfs:label "has camera observation" ;
    rdfs:comment "Link from incident to camera-derived frame observations." .

ffonto:isCameraObservationOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:label "inverse of is camera observation"@en .

ffonto:isCameraObservationOf owl:inverseOf ffonto:hasCameraObservation .

ffonto:hasWeatherObservation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:hasObservation ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:WeatherObservation ;
    rdfs:label "has weather observation" ;
    rdfs:comment "Link from incident to weather measurements." .

ffonto:isWeatherObservationOf a owl:ObjectProperty ;
    rdfs:label "inverse of has weather observation"@en ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:WeatherObservation .

ffonto:isWeatherObservationOf owl:inverseOf ffonto:hasWeatherObservation .

ffonto:hasSmokeObservation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:hasObservation ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:SmokeObservation ;
    rdfs:label "has smoke observation" ;
    rdfs:comment "Link from incident to smoke details observed in the frame." .

ffonto:isSmokeObservationOf a owl:ObjectProperty ;
    rdfs:label "inverse of is smoke observation"@en ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:SmokeObservation .

ffonto:isSmokeObservationOf owl:inverseOf ffonto:hasSmokeObservation .

ffonto:hasAudioObservation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf ffonto:hasObservation ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:AudioObservation ;
    rdfs:label "has audio event" ;
    rdfs:comment "Audio detections associated with the incident." .

ffonto:isAudioObservationOf a owl:ObjectProperty ;
    rdfs:label "inverse of is audio observation"@en ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:AudioObservation .

ffonto:isAudioObservationOf owl:inverseOf ffonto:hasAudioObservation .

ffonto:hasFireBehavior rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FireBehavior ;
    rdfs:label "has fire behavior" ;
    rdfs:comment "Describes observed fire behavior (flame fronts, spot fires, torching)." .

ffonto:isFireBehaviorOf a owl:ObjectProperty ;
    rdfs:label "inverse of is fire behavior"@en ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FireBehavior  .

ffonto:isFireBehaviorOf owl:inverseOf ffonto:hasFireBehavior .

ffonto:observedAtLocation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:Location ;
    rdfs:label "observed at location" ;
    rdfs:comment "Location or feature where an observation was recorded (e.g., NE flank ridgeline)." .

ffonto:observedAtLocationOf a owl:ObjectProperty ;
    rdfs:range ffonto:Observation ;
    rdfs:domain ffonto:Location ;
    rdfs:label "inverse of observed at location"@en  .

ffonto:observedAtLocationOf owl:inverseOf ffonto:observedAtLocation .

ffonto:visibleAircraft rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:CameraObservation ;
    rdfs:range ffonto:Aircraft ;
    rdfs:label "visible aircraft" ;
    rdfs:comment "Aircraft visible in camera frames." .

ffonto:visibleAircraftOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:CameraObservation ;
    rdfs:domain ffonto:Aircraft ;
    rdfs:label "visible aircraft of" ;
    rdfs:comment "Inverse - Aircraft visible in camera frames." .

ffonto:visibleAircraftOf owl:inverseOf ffonto:visibleAircraft .

ffonto:relatedWaterSource rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:Location ;
    rdfs:label "related water source" ;
    rdfs:comment "Nearby water body or source useful for suppression." .

ffonto:relatedWaterSourceOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:Location ;
    rdfs:label "related water source of" ;
    rdfs:comment "Inverse - Nearby water body or source useful for suppression." .

ffonto:relatedWaterSourceOf owl:inverseOf ffonto:relatedWaterSource .

ffonto:hasContact rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:Contact ;
    rdfs:label "has contact" ;
    rdfs:comment "Contact information for incident resources." .

ffonto:isContactOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:Contact ;
    rdfs:label "inverse of is contact"@en .

ffonto:isContactOf owl:inverseOf ffonto:hasContact .

ffonto:modeledBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FireProbabilityModel ;
    rdfs:label "modeled by" ;
    rdfs:comment "Link from incident/image to a probability model producing fire probability." .

ffonto:modeledOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FireProbabilityModel ;
    rdfs:label "modeled of" ;
    rdfs:comment "Inverse - Link from incident/image to a probability model producing fire probability." .

ffonto:modeledOf owl:inverseOf ffonto:modeledBy .

ffonto:hasMediaAsset rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:MediaAsset ;
    rdfs:label "has media asset" ;
    rdfs:comment "Connects incident to the captured media file." .

ffonto:isMediaAssetOf a owl:ObjectProperty ;
    rdfs:range ffonto:Observation ;
    rdfs:domain ffonto:MediaAsset ;
    rdfs:label "inverse of has media asset"@en .

ffonto:isMediaAssetOf owl:inverseOf ffonto:hasMediaAsset .

ffonto:hasImageQualityMeta rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ImageAsset ;
    rdfs:range ffonto:ImageQualityMetadata ;
    rdfs:label "has image quality metadata" ;
    rdfs:comment "Links an image to its quality/metadata record." .

ffonto:hasImageQualityMetaInverse a owl:ObjectProperty ;
    rdfs:range ffonto:ImageAsset ;
    rdfs:domain ffonto:ImageQualityMetadata ;
    rdfs:label "inverse of has image quality meta"@en  .

ffonto:hasImageQualityMetaInverse owl:inverseOf ffonto:hasImageQualityMeta .

ffonto:producedCaptionBy rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ImageAsset ;
    rdfs:range ffonto:CaptionModelOutput ;
    rdfs:label "produced caption by" ;
    rdfs:comment "Links image to caption output (model & caption text)." .

ffonto:captionProducedOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ImageAsset ;
    rdfs:domain ffonto:CaptionModelOutput ;
    rdfs:label "caption produced of" ;
    rdfs:comment "Inverse - Links image to caption output (model & caption text)." .

ffonto:captionProducedOf owl:inverseOf ffonto:producedCaptionBy .

ffonto:hasVisionModelScores rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ImageObservation ;
    rdfs:range ffonto:VisionModelScores ;
    rdfs:label "has vision model scores" .

ffonto:isVisionModelScoresOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ImageObservation ;
    rdfs:domain ffonto:VisionModelScores ;
    rdfs:label "has vision model scores" ;
    owl:inverseOf ffonto:hasVisionModelScores .

ffonto:usedModel rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:VisionModelScores ;
    rdfs:range ffonto:MLModel ;
    rdfs:label "used model" .

ffonto:modelOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:VisionModelScores ;
    rdfs:domain ffonto:MLModel ;
    rdfs:label "model of" ;
    rdfs:comment "inverse of use model" ;
    owl:inverseOf ffonto:usedModel .

ffonto:hasSmokeLayers rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SmokeObservation ;
    rdfs:range ffonto:SmokeLayerObservation ;
    rdfs:label "has smoke layers" ;
    rdfs:comment "Links smoke observation to one or more layer descriptions." .

ffonto:isSmokeLayersOf a owl:ObjectProperty ;
    rdfs:range ffonto:SmokeObservation ;
    rdfs:domain ffonto:SmokeLayerObservation ;
    rdfs:label "inverse of is smoke layers"@en .

ffonto:isSmokeLayersOf owl:inverseOf ffonto:hasSmokeLayers .

ffonto:observedBySatellite rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:SatelliteObservation ;
    rdfs:label "observed by satellite" ;
    rdfs:comment "Indicates satellite detection/visibility of smoke plume today." .

ffonto:observedBySatelliteOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:SatelliteObservation ;
    rdfs:label "observed by satellite of" ;
    rdfs:comment "Inverse - Indicates satellite detection/visibility of smoke plume today." .

ffonto:observedBySatelliteOf owl:inverseOf ffonto:observedBySatellite .

ffonto:hasFuelCondition rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FuelCondition ;
    rdfs:label "has fuel condition" ;
    rdfs:comment "Links an incident to observed/predicted fuel conditions." .

ffonto:isFuelConditionOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FuelCondition ;
    rdfs:label "inverse of is fuel condition"@en .

ffonto:isFuelConditionOf owl:inverseOf ffonto:hasFuelCondition .

ffonto:dominantAspect rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:AspectCategory ;
    rdfs:label "dominant aspect" ;
    rdfs:comment "Cardinal aspect dominating the active fire area." .

ffonto:dominantAspectOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:AspectCategory ;
    rdfs:label "inverse of dominant aspect"@en  .

ffonto:dominantAspectOf owl:inverseOf ffonto:dominantAspect .

ffonto:assignedLabel rdf:type owl:ObjectProperty ;
    rdfs:label "assigned label" ;
    rdfs:comment "Links a LabelAssignment to the Label assigned." ;
    rdfs:domain ffonto:LabelAssignment ;
    rdfs:range ffonto:PredictedLabel .

ffonto:assignedLabelOf rdf:type owl:ObjectProperty ;
    rdfs:label "assigned label of" ;
    rdfs:comment "Inverse - Links a LabelAssignment to the Label assigned." ;
    rdfs:range ffonto:LabelAssignment ;
    rdfs:domain ffonto:PredictedLabel .

ffonto:assignedLabelOf owl:inverseOf ffonto:assignedLabel .

ffonto:labelSourceOf rdf:type owl:ObjectProperty ;
    rdfs:label "label source of" ;
    rdfs:comment "Indicates the source (caption/detector/human) that produced the label assignment." ;
    rdfs:domain ffonto:LabelAssignment ;
    rdfs:range ffonto:ModelProvenance .

ffonto:labelSourceOfOf a owl:ObjectProperty ;
    rdfs:range ffonto:LabelAssignment ;
    rdfs:domain ffonto:ModelProvenance ;
    rdfs:label "inverse of label source of"@en  .

ffonto:labelSourceOfOf owl:inverseOf ffonto:labelSourceOf .

ffonto:hasLabelAssignment rdf:type owl:ObjectProperty ;
    rdfs:label "has label assignment"@en ;
    rdfs:comment "Connects an image observation to zero or more LabelAssignment instances."@en ;
    rdfs:domain ffonto:ImageObservation ;
    rdfs:range ffonto:LabelAssignment .

ffonto:isLabelAssignmentOf rdf:type owl:ObjectProperty ;
    rdfs:label "is label assignment of"@en ;
    rdfs:comment "Connects a label assignment back to the original image observation that it annotates."@en ;
    rdfs:domain ffonto:LabelAssignment ;
    rdfs:range ffonto:ImageObservation ;
    owl:inverseOf ffonto:hasLabelAssignment .

ffonto:opacity rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:LabelAssignment ;
    rdfs:range xsd:string ;
    rdfs:label "opacity" .

ffonto:audioAttachedTo rdf:type owl:ObjectProperty ;
    rdfs:label "audio attached to" ;
    rdfs:comment "Relates AudioRecord to an ImageAsset (if attached) or to the incident." ;
    rdfs:domain ffonto:AudioRecord ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf (ffonto:ImageAsset ffonto:FireEvent)
    ] .

ffonto:audioAttachedToInverse a owl:ObjectProperty ;
    rdfs:label "inverse of audio attached to"@en  ;
    rdfs:range ffonto:AudioRecord ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (ffonto:ImageAsset ffonto:FireEvent)
    ] .

ffonto:audioAttachedToInverse owl:inverseOf ffonto:audioAttachedTo .

ffonto:imageEvent rdf:type owl:ObjectProperty ;
    rdfs:label "image event" ;
    rdfs:comment "Event id attached to the image." ;
    rdfs:domain ffonto:ImageAsset ;
    rdfs:range ffonto:ImageObservation .

ffonto:imageEventOf a owl:ObjectProperty ;
    rdfs:range ffonto:ImageAsset ;
    rdfs:domain ffonto:ImageObservation ;
    rdfs:label "inverse of image event"@en  .

ffonto:imageEventOf owl:inverseOf ffonto:imageEvent .

ffonto:audioEvent rdf:type owl:ObjectProperty ;
    rdfs:label "audio event" ;
    rdfs:comment "Event id attached to the audio record." ;
    rdfs:domain ffonto:AudioRecord ;
    rdfs:range ffonto:AudioObservation .

ffonto:audioEventOf a owl:ObjectProperty ;
    rdfs:range ffonto:AudioRecord ;
    rdfs:domain ffonto:AudioObservation ;
    rdfs:label "inverse of audio event"@en .

ffonto:audioEventOf owl:inverseOf ffonto:audioEvent .

ffonto:hasThresholdSet rdf:type owl:ObjectProperty ;
    rdfs:label "has threshold set" ;
    rdfs:comment "Associates predictions or model outputs with ThresholdSet instances." ;
    rdfs:domain ffonto:VisionModelScores ;
    rdfs:range ffonto:ThresholdSet .

ffonto:isThresholdSetOf a owl:ObjectProperty ;
    rdfs:range ffonto:VisionModelScores ;
    rdfs:domain ffonto:ThresholdSet ;
    rdfs:label "inverse of is threshold set"@en .

ffonto:isThresholdSetOf owl:inverseOf ffonto:hasThresholdSet .

ffonto:fireThreshold rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ThresholdSet ;
    rdfs:range xsd:decimal ;
    rdfs:label "fire threshold" .

ffonto:smokeThreshold rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ThresholdSet ;
    rdfs:range xsd:decimal ;
    rdfs:label "smoke threshold" .

ffonto:globalDetectionThreshold rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ThresholdSet ;
    rdfs:range xsd:decimal ;
    rdfs:label "global detection threshold" .

ffonto:frameThreshold rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ThresholdSet ;
    rdfs:range xsd:integer ;
    rdfs:label "frame threshold" .

ffonto:hasModelProvenance rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ModelOutput ;
    rdfs:range ffonto:ModelProvenance ;
    rdfs:label "has model provenance" .

ffonto:isModelProvenanceOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ModelOutput ;
    rdfs:domain ffonto:ModelProvenance ;
    rdfs:label "has model provenance" .

ffonto:hasModelProvenance owl:inverseOf ffonto:isModelProvenanceOf .

ffonto:hasAudit rdf:type owl:ObjectProperty ;
    rdfs:label "has audit record" ;
    rdfs:comment "Links an item to an AuditRecord (checksums, class-map checksum, etc.)." ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (ffonto:ImageAsset ffonto:VisionModelScores ffonto:AudioRecord)
    ] ;
    rdfs:range ffonto:AuditRecord .

ffonto:isAuditOf rdf:type owl:ObjectProperty ;
    rdfs:label "is audit record of" ;
    rdfs:comment "Inverse - Links an item to an AuditRecord (checksums, class-map checksum, etc.)." ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf (ffonto:ImageAsset ffonto:VisionModelScores ffonto:AudioRecord)
    ] ;
    rdfs:domain ffonto:AuditRecord .

ffonto:isAuditOf owl:inverseOf ffonto:hasAudit .

ffonto:hasGridLocation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SpatialExtent ;
    rdfs:range ffonto:GridLocation ;
    rdfs:label "has grid location" .

ffonto:isGridLocationOf a owl:ObjectProperty ;
    rdfs:range ffonto:SpatialExtent ;
    rdfs:domain ffonto:GridLocation ;
    rdfs:label "inverse of is grid location"@en  .

ffonto:isGridLocationOf owl:inverseOf ffonto:hasGridLocation .

ffonto:hasFireSpread rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FireSpread ;
    rdfs:label "has fire spread behavior" .

ffonto:isFireSpreadOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FireSpread ;
    rdfs:label "inverse of is fire spread"@en .

ffonto:isFireSpreadOf owl:inverseOf ffonto:hasFireSpread .

ffonto:hasCluster rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireSpread ;
    rdfs:range ffonto:FireCluster ;
    rdfs:label "has fire cluster" .

ffonto:isClusterOf a owl:ObjectProperty ;
    rdfs:label "inverse of is cluster"@en ;
    rdfs:range ffonto:FireSpread ;
    rdfs:domain ffonto:FireCluster  .

ffonto:isClusterOf owl:inverseOf ffonto:hasCluster .

ffonto:impactsTransportation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:TransportationRoute ;
    rdfs:label "impacts transportation routes" .

ffonto:impactsTransportationOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:TransportationRoute ;
    rdfs:label "impacts transportation routes of" .

ffonto:impactsTransportationOf owl:inverseOf ffonto:impactsTransportation .

ffonto:hasAerialResource rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:AerialResource ;
    rdfs:label "has aerial firefighting resource" .

ffonto:isAerialResourceOf a owl:ObjectProperty ;
    rdfs:label "inverse of is aerial resource"@en ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:AerialResource .

ffonto:isAerialResourceOf owl:inverseOf ffonto:hasAerialResource .

ffonto:hasGroundCrew rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:GroundCrew ;
    rdfs:label "has ground firefighting crew" .

ffonto:isGroundCrewOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:GroundCrew ;
    rdfs:label "is ground crew of" .

ffonto:isGroundCrewOf owl:inverseOf ffonto:hasGroundCrew .

ffonto:burningVegetation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:VegetationType ;
    rdfs:label "burning vegetation type" .

ffonto:burningVegetationOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:VegetationType ;
    rdfs:label "burning vegetation type of" .

ffonto:burningVegetationOf owl:inverseOf ffonto:burningVegetation .

ffonto:hasEnvironment rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:EnvironmentType ;
    rdfs:label "has environment"@en ;
    rdfs:comment "Relates a wildfire incident or observation to its surrounding environmental context."@en .

ffonto:isEnvironmentOf a owl:ObjectProperty ;
    rdfs:label "inverse of has environment"@en ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:EnvironmentType .

ffonto:isEnvironmentOf owl:inverseOf ffonto:hasEnvironment .

ffonto:hasRiskAssessment rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:FireRiskAssessment ;
    rdfs:label "has risk assessment" .

ffonto:isRiskAssessmentOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:FireRiskAssessment ;
    rdfs:label "inverse of is risk assessment"@en  .

ffonto:isRiskAssessmentOf owl:inverseOf ffonto:hasRiskAssessment .

ffonto:detectedBySatellite rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:SatelliteDetection ;
    rdfs:label "detected by satellite"@en ;
    rdfs:comment "Indicates that a wildfire or hotspot was detected using satellite observations."@en .

ffonto:detectedBySatelliteOf a owl:ObjectProperty ;
    rdfs:label "inverse of detected by satellite"@en ;
