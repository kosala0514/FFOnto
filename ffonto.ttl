ffonto:contributesToFireIntensityOf a owl:ObjectProperty ;
    rdfs:label "inverse of contributes to fire intensity"@en ;
    rdfs:range ffonto:Tree ;
    rdfs:domain ffonto:FireEvent .

ffonto:contributesToFireIntensityOf owl:inverseOf ffonto:contributesToFireIntensity .

ffonto:hasVegetationDistribution rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SpatialUnit ;
    rdfs:range ffonto:VegetationDistribution ;
    rdfs:label "has vegetation distribution" ;
    rdfs:comment "Associates a spatial unit with its vegetation distribution pattern." .

ffonto:isVegetationDistributionOf a owl:ObjectProperty ;
    rdfs:range ffonto:SpatialUnit ;
    rdfs:domain ffonto:VegetationDistribution ;
    rdfs:label "inverse of is vegetation distribution"@en .

ffonto:isVegetationDistributionOf owl:inverseOf ffonto:hasVegetationDistribution .

ffonto:influencedBySoilQuality rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:VegetationDistribution ;
    rdfs:range ffonto:SoilQuality ;
    rdfs:label "influenced by soil quality" ;
    rdfs:comment "Indicates soil quality factors influencing vegetation distribution." .

ffonto:influencedBySoilQualityOf a owl:ObjectProperty ;
    rdfs:range ffonto:VegetationDistribution ;
    rdfs:domain ffonto:SoilQuality ;
    rdfs:label "inverse of influenced by soil quality"@en .

ffonto:influencedBySoilQualityOf owl:inverseOf ffonto:influencedBySoilQuality .

ffonto:influencedByWaterAvailability rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:VegetationDistribution ;
    rdfs:range ffonto:WaterAvailability ;
    rdfs:label "influenced by water availability" ;
    rdfs:comment "Indicates water availability effects on vegetation distribution." .

ffonto:influencedByWaterAvailabilityOf a owl:ObjectProperty ;
    rdfs:range ffonto:VegetationDistribution ;
    rdfs:domain ffonto:WaterAvailability ;
    rdfs:label "inverse of influenced by water availability"@en .

ffonto:influencedByWaterAvailabilityOf owl:inverseOf ffonto:influencedByWaterAvailability .

ffonto:hasDisturbanceHistory rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SpatialUnit ;
    rdfs:range ffonto:DisturbanceHistory ;
