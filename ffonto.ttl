    rdfs:domain ffonto:Firefighter ;
    rdfs:range xsd:boolean .

ffonto:spottersVisible
    a owl:DatatypeProperty ;
    rdfs:label "spotters or lookouts visible" ;
    rdfs:comment "Indicates whether spotters are positioned on higher ground." ;
    rdfs:domain ffonto:Responder ;
    rdfs:range xsd:boolean .

ffonto:bulldozerCuttingLine
    a owl:DatatypeProperty ;
    rdfs:label "bulldozer cutting control line" ;
