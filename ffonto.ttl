ffonto:GatedWye rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Gated Wye Valve" .

ffonto:CommandPost rdf:type owl:Class ;
    rdfs:label "Command Post" .

ffonto:UtilityCrew rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Responder ;
    rdfs:label "Utility Crew" ;
    rdfs:comment "Crew from utility companies (power, gas) working on infrastructure." .

ffonto:MediaGroup rdf:type owl:Class ;
    rdfs:label "Media / Observers" ;
    rdfs:comment "Journalists, camera crews, and observers." .

ffonto:AssemblyArea rdf:type owl:Class ;
    rdfs:label "Assembly Area" ;
    rdfs:comment "Pre-designated safe area (parking lot, cleared road) where evacuees gather." .

ffonto:TrafficControlDevice rdf:type owl:Class ;
