ffonto:requiresResource rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:SuppressionResource ;
    rdfs:label "requires suppression resource" ;
    rdfs:comment "Specifies firefighting resources required to manage the wildfire." .

ffonto:requiresResourceOf a owl:ObjectProperty ;
    rdfs:label "inverse of requires resource"@en ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:SuppressionResource .

ffonto:requiresResourceOf owl:inverseOf ffonto:requiresResource .

ffonto:posesHealthRisk rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:HealthRisk ;
    rdfs:label "poses health risk" ;
    rdfs:comment "Indicates health risks caused by wildfire smoke." .

ffonto:posesHealthRiskOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:HealthRisk ;
    rdfs:label "inverse of poses health risk"@en  .

ffonto:posesHealthRiskOf owl:inverseOf ffonto:posesHealthRisk .

ffonto:occursInTerrain rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestFire ;
    rdfs:range ffonto:ForestTerrain ;
    rdfs:label "occurs in terrain" ;
    rdfs:comment "Specifies the terrain where wildfire is occurring." .

ffonto:occursInTerrainOf a owl:ObjectProperty ;
    rdfs:range ffonto:ForestFire ;
    rdfs:domain ffonto:ForestTerrain ;
    rdfs:label "inverse of occurs in terrain"@en .

ffonto:occursInTerrainOf owl:inverseOf ffonto:occursInTerrain .

ffonto:threatens rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( ffonto:Person ffonto:StructureFire ffonto:Animal ffonto:Infrastructure ) ] ;
    rdfs:label "threatens" ;
    rdfs:comment "Who/what is threatened by a given hazard." .

ffonto:threatensOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Hazard ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( ffonto:Person ffonto:StructureFire ffonto:Animal ffonto:Infrastructure ) ] ;
    rdfs:label "threatens of" ;
    rdfs:comment "Inverse - Who/what is threatened by a given hazard." .

ffonto:threatensOf owl:inverseOf ffonto:threatens .

ffonto:usesResource rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:SuppressionResource ;
    rdfs:label "uses resource" ;
    rdfs:comment "Suppression assets assigned to the incident." .

ffonto:usesResourceOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:SuppressionResource ;
    rdfs:label "uses resource of" ;
    rdfs:comment "Inverse - Suppression assets assigned to the incident." .

ffonto:usesResourceOf owl:inverseOf ffonto:usesResource .

ffonto:generatesPyroWeather rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range ffonto:Hazard ;
    rdfs:label "generates pyro-weather" ;
    rdfs:comment "Indicates fire-induced weather (pyrocumulus, fire-generated winds)." .

ffonto:generatesPyroWeatherOf a owl:ObjectProperty ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain ffonto:Hazard ;
    rdfs:label "inverse of generates pyro weather"@en .

ffonto:generatesPyroWeatherOf owl:inverseOf ffonto:generatesPyroWeather .

ffonto:impairsVisibility rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range xsd:boolean ;
    rdfs:label "impairs visibility" ;
    rdfs:comment "Whether the hazard reduces visibility (true/false)." .

ffonto:impairsVisibilityOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:Hazard ;
    rdfs:domain xsd:boolean ;
    rdfs:label "impairs visibility of" ;
    rdfs:comment "Inverse - Whether the hazard reduces visibility (true/false)." .

ffonto:impairsVisibilityOf owl:inverseOf ffonto:impairsVisibility .

ffonto:triggersEvacuationOrder rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range ffonto:EvacuationOrder ;
    rdfs:label "requires evacuation" ;
    rdfs:comment "If the hazard or conditions should prompt evacuation." .

ffonto:isEvacuationOrderFor rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:EvacuationOrder ;
    rdfs:range ffonto:Hazard .

ffonto:triggersEvacuationOrder owl:inverseOf ffonto:isEvacuationOrderFor .

