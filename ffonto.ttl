ffonto:fuelLeakVisible rdf:type owl:DatatypeProperty ;
    rdfs:label "fuel leak visible" ;
    rdfs:domain ffonto:Vehicle ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indicates visible vehicle fuel leaks or spills." .

ffonto:evacuationSirensActive
    a owl:DatatypeProperty ;
    rdfs:domain ffonto:EmergencyActivity ;
    rdfs:range xsd:boolean ;
