    rdfs:range ffonto:WellWater ;
    rdfs:domain ffonto:Groundwater ;
    rdfs:label "extracted of" ;
    rdfs:comment "Inverse - Indicates that well water is extracted from groundwater." .

ffonto:extractedOf owl:inverseOf ffonto:extractedFrom .

ffonto:dependsOnWaterSource rdf:type owl:ObjectProperty ;
