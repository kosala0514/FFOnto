ffonto:PreventionMethod rdf:type owl:Class ;
    rdfs:label "Prevention Method" ;
    rdfs:comment "Strategies or methods used to reduce wildfire risk." .

ffonto:MonitoringSystem rdf:type owl:Class ;
    rdfs:label "Monitoring System" ;
    rdfs:comment "Technological systems used to monitor wildfire risk or detect fires early." .

ffonto:FireRiskMap rdf:type owl:Class ;
    rdfs:label "Fire Risk Map" ;
    rdfs:comment "A map showing wildfire risk levels based on environmental and human factors." .

ffonto:FirefightingResource rdf:type owl:Class ;
    rdfs:label "Firefighting Resource" ;
    rdfs:comment "Personnel, equipment, or vehicles used to combat wildfires." .

ffonto:TrainingProgram rdf:type owl:Class ;
    rdfs:label "Training Program" ;
    rdfs:comment "Educational programs designed to prepare firefighters and communities for wildfire events." .

ffonto:EvacuationProcedure rdf:type owl:Class ;
    rdfs:label "Evacuation Procedure" ;
    rdfs:comment "Guidelines and processes for safely evacuating residents during wildfires." .

ffonto:PreparednessItem rdf:type owl:Class ;
    rdfs:label "Preparedness Item" ;
    rdfs:comment "Items included in emergency preparedness kits." .

ffonto:EvacuationPreparation rdf:type owl:Class ;
    rdfs:label "Evacuation Preparation" ;
    rdfs:comment "High-level plan and actions to prepare before and for evacuation." .

ffonto:BeforeEvacuationAction rdf:type owl:Class ;
    rdfs:label "Before Evacuation Action" ;
    rdfs:comment "Actions to do if wildfire is approaching but evacuation has not been ordered yet." ;
    rdfs:subClassOf ffonto:EvacuationAction .

ffonto:ImmediateEvacuationAction rdf:type owl:Class ;
    rdfs:label "Immediate Evacuation Action" ;
    rdfs:comment "Actions to do when authorities advise or order evacuation." ;
    rdfs:subClassOf ffonto:EvacuationAction .

ffonto:HomeProtectionMeasure rdf:type owl:Class ;
    rdfs:label "Home Protection Measure" ;
    rdfs:comment "Measures to reduce the chance of home ignition from embers, heat, and flame." .

ffonto:VehiclePreparation rdf:type owl:Class ;
    rdfs:label "Vehicle Preparation" ;
    rdfs:comment "Preparations to make vehicles ready for evacuation (fuel, parking orientation, kit stored)." .

ffonto:PetPreparation rdf:type owl:Class ;
    rdfs:label "Pet Preparation" ;
    rdfs:comment "Actions and items to prepare pets for evacuation." .

ffonto:PreparednessKit rdf:type owl:Class ;
    rdfs:label "Preparedness Kit" ;
    rdfs:comment "A disaster or go-kit with supplies for families and pets." .

ffonto:ImportantDocument rdf:type owl:Class ;
    rdfs:label "Important Document" ;
    rdfs:comment "Key legal and personal documents (IDs, insurance, wills) to safeguard and take during evacuation." ;
    rdfs:subClassOf ffonto:PreparednessItem .

ffonto:ClothingRecommendation rdf:type owl:Class ;
    rdfs:label "Clothing Recommendation" ;
    rdfs:comment "Recommended clothing types for safe evacuation and wildfire exposure." .

ffonto:CommunicationPlan rdf:type owl:Class ;
    rdfs:label "Communication Plan" ;
    rdfs:comment "Who to notify, check-in procedures, and contact numbers during evacuation." .

ffonto:EvacuationRoute rdf:type owl:Class ;
    rdfs:label "Evacuation Route" ;
    rdfs:comment "Planned routes out of the danger area; may include alternate routes." .

ffonto:EvacuationShelter rdf:type owl:Class ;
    rdfs:label "Evacuation Shelter" ;
    rdfs:comment "Temporary housing (friend/relative, public shelter) information and rules (pet policies)." .

ffonto:SpecialNeedsPlan rdf:type owl:Class ;
    rdfs:label "Special Needs Plan" ;
    rdfs:comment "Preparedness measures for those with disabilities, medical dependencies, or other special requirements." .

ffonto:GeneratorSafety rdf:type owl:Class ;
    rdfs:label "Generator Safety" ;
    rdfs:comment "Rules and guidance for safe generator use to avoid carbon monoxide and electrical hazards." .

ffonto:NeighborSupportPlan rdf:type owl:Class ;
    rdfs:label "Neighborhood Support Plan" ;
    rdfs:comment "How neighbors coordinate to help those with special needs and to protect neighborhood assets." .

ffonto:EvacuationDrill rdf:type owl:Class ;
    rdfs:label "Evacuation Drill" ;
    rdfs:comment "Organized practice of evacuation procedures." .

ffonto:SmokeComponent rdf:type owl:Class ;
    rdfs:label "Smoke Component" ;
    rdfs:comment "Chemical compounds and particles present in wildfire smoke." .

ffonto:AirToxic rdf:type owl:Class ;
    rdfs:label "Air Toxic Pollutant" ;
    rdfs:comment "Hazardous air pollutants generated during wildfire combustion." .

ffonto:HealthEffect rdf:type owl:Class ;
    rdfs:label "Health Effect" ;
    rdfs:comment "Human health impacts caused by smoke or toxic pollutants." .

ffonto:RemoteSensingMethod rdf:type owl:Class ;
    rdfs:label "Remote Sensing Method" ;
    rdfs:comment "Satellite or radar techniques used to monitor wildfire risk and impacts." .

ffonto:RemoteSensingIndex rdf:type owl:Class ;
    rdfs:label "Remote Sensing Index" ;
    rdfs:comment "Indices derived from satellite imagery used to measure fire severity or vegetation condition." .

ffonto:DataProvider rdf:type owl:Class ;
    rdfs:label "Data Provider Organization" ;
    rdfs:comment "Organizations that provide wildfire, climate, or satellite data." .

ffonto:ContinuityStrategy rdf:type owl:Class ;
    rdfs:label "Business Continuity Strategy" ;
    rdfs:comment "Actions businesses take to maintain operations during wildfire disruptions." .

ffonto:IndoorAirQualityStrategy rdf:type owl:Class ;
    rdfs:label "Indoor Air Quality Strategy" ;
    rdfs:comment "Methods to improve indoor air quality during smoke events." .

ffonto:CombustionProcess rdf:type owl:Class ;
    rdfs:label "Combustion Process" ;
    rdfs:comment "Chemical process of burning fuel that produces smoke, gases, and heat during wildfires." .

ffonto:IncompleteCombustion rdf:type owl:Class ;
    rdfs:subClassOf ffonto:CombustionProcess ;
    rdfs:label "Incomplete Combustion" ;
    rdfs:comment "Combustion that occurs with insufficient oxygen, producing carbon monoxide and other pollutants." .

ffonto:SmolderingPhase rdf:type owl:Class ;
    rdfs:subClassOf ffonto:CombustionProcess ;
    rdfs:label "Smoldering Phase" ;
    rdfs:comment "Low-temperature combustion phase producing high levels of carbon monoxide and smoke." .

ffonto:FlamingPhase rdf:type owl:Class ;
    rdfs:subClassOf ffonto:CombustionProcess ;
    rdfs:label "Flaming Phase" ;
    rdfs:comment "High-temperature combustion phase with visible flames and rapid fuel consumption." .

ffonto:VegetationChemicalComponent rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FuelCharacteristic ;
    rdfs:label "Vegetation Chemical Component" .

ffonto:chemicalComponentAffectsCombustion rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:VegetationChemicalComponent ;
    rdfs:range ffonto:CombustionProcess .

ffonto:isCombustionAffectedByChemicalComponent rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:CombustionProcess ;
    rdfs:range ffonto:VegetationChemicalComponent .

ffonto:chemicalComponentAffectsCombustion owl:inverseOf ffonto:isCombustionAffectedByChemicalComponent .

ffonto:SmokeColor rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SmokePlume ;
    rdfs:label "Smoke Color" .

ffonto:indicatesCombustion rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SmokeColor ;
    rdfs:range ffonto:CombustionProcess .

ffonto:indicatesCombustionOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:SmokeColor ;
    rdfs:domain ffonto:CombustionProcess .

ffonto:indicatesCombustionOf owl:inverseOf ffonto:indicatesCombustion .

ffonto:AirPollutantProperty rdf:type owl:Class ;
    rdfs:label "Air Pollutant Property" ;
    rdfs:comment "Physical or chemical characteristics of airborne pollutants." .

ffonto:ParticleSize rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AirPollutantProperty ;
    rdfs:label "Particle Size" ;
    rdfs:comment "Diameter of particulate matter in smoke, often measured in micrometers." .

ffonto:OpticalScattering rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AirPollutantProperty ;
    rdfs:label "Optical Scattering" ;
    rdfs:comment "Light scattering caused by smoke particles which reduces visibility." .

ffonto:VisibilityReduction rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AirPollutantProperty ;
    rdfs:label "Visibility Reduction" ;
    rdfs:comment "Decreased atmospheric visibility caused by smoke particles." .

ffonto:VegetationChemicalComponent rdf:type owl:Class ;
    rdfs:label "Vegetation Chemical Component" ;
    rdfs:comment "Chemical compounds present in vegetation that influence smoke composition when burned." .

ffonto:Cellulose rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Cellulose" .

ffonto:Lignin rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Lignin" .

ffonto:Tannins rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Tannins" .

ffonto:Resins rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Resins" .

ffonto:Oils rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Plant Oils" .

ffonto:Waxes rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Plant Waxes" .

ffonto:Starch rdf:type ffonto:VegetationChemicalComponent ;
    rdfs:label "Starch" .

ffonto:AnthropogenicFactor rdf:type owl:Class ;
    rdfs:label "Anthropogenic Factor" ;
    rdfs:comment "Human activities that influence wildfire risk and environmental conditions." .

ffonto:LandCoverChange rdf:type owl:Class ;
    rdfs:subClassOf ffonto:AnthropogenicFactor ;
    rdfs:label "Land Cover Change" ;
    rdfs:comment "Changes in land surface due to human activity such as deforestation or agriculture." .

ffonto:AgriculturalExpansion rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCoverChange ;
    rdfs:label "Agricultural Expansion" ;
    rdfs:comment "Conversion of natural landscapes into farmland." .

ffonto:UrbanGrowth rdf:type owl:Class ;
    rdfs:subClassOf ffonto:LandCoverChange ;
    rdfs:label "Urban Growth" ;
    rdfs:comment "Expansion of urban areas into natural landscapes increasing ignition sources." .

ffonto:ForestDisturbance rdf:type owl:Class ;
    rdfs:label "Forest Disturbance" ;
    rdfs:comment "Events that alter forest ecosystems such as pests, disease, or drought." .

ffonto:ForestDisturbance rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EnvironmentalFactor ;
    rdfs:label "Forest Disturbance" .

