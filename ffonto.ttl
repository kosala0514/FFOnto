    rdfs:range [ a owl:Class ; owl:unionOf ( ffonto:Chimney ffonto:MeterBox ) ] ;
    rdfs:domain ffonto:Building ;
    rdfs:label "inverse of part of building"@en .

ffonto:partOfBuildingOf owl:inverseOf ffonto:partOfBuilding .

ffonto:partOfVehicle
    a owl:ObjectProperty ;
    rdfs:label "part of vehicle" ;
    rdfs:comment "Indicates that a window is part of a vehicle." ;
    rdfs:domain ffonto:Window ;
    rdfs:range ffonto:Vehicle .

