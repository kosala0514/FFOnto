#################################################################
# INDIVIDUALS
#################################################################

ffonto:CDC
    a ffonto:ResponseOrganization ;
    rdfs:label "Centers for Disease Control and Prevention" .

ffonto:N95Respirator
    a ffonto:ProtectionMethod ;
    rdfs:label "N95 Respirator" ;
    rdfs:comment "Respirator mask capable of filtering fine particulate smoke." .

ffonto:P2Respirator rdf:type ffonto:ProtectiveEquipment ;
    rdfs:label "P2 Respirator Mask" ;
    rdfs:comment "Equivalent respirator used to protect against wildfire smoke particles." .

ffonto:Children
    a ffonto:PopulationGroup ;
    rdfs:label "Children" .

ffonto:OlderAdults
    a ffonto:PopulationGroup ;
    rdfs:label "Older Adults" .

ffonto:PeopleWithHeartDisease
    a ffonto:PopulationGroup ;
    rdfs:label "People with Heart Disease" .

ffonto:PregnantPeople rdf:type ffonto:PopulationGroup ;
    rdfs:label "Pregnant Individuals" .

ffonto:HeartLungPatients rdf:type ffonto:PopulationGroup ;
    rdfs:label "People with Lung Disease" .
ffonto:Coughing
    a ffonto:HealthSymptom ;
    rdfs:label "Coughing" .

ffonto:ShortnessOfBreath
    a ffonto:HealthSymptom ;
    rdfs:label "Shortness of Breath" .

ffonto:EyeIrritation
    a ffonto:HealthSymptom ;
    rdfs:label "Eye Irritation" .

ffonto:NIOSH
    a ffonto:ResponseOrganization ;
    rdfs:label "National Institute for Occupational Safety and Health" .

ffonto:EPA
    a ffonto:ResponseOrganization ;
    rdfs:label "United States Environmental Protection Agency" .

ffonto:AICC
    a ffonto:ResponseOrganization ;
    rdfs:label "Alaska Interagency Coordination Center" .

ffonto:StayIndoorsAdvice
    a ffonto:HealthAdvice ;
    rdfs:label "Stay indoors health advice" ;
    rdfs:comment "Recommendation to remain indoors and limit physical activity during hazardous smoke conditions." ;
    ffonto:providedBy ffonto:CDC .

ffonto:DrinkWaterAdvice
    a ffonto:HealthAdvice ;
    rdfs:label "Drink water during smoke exposure" ;
    rdfs:comment "Recommendation to drink water to keep airways moist during smoke exposure." .

ffonto:WildfireSmokeExposure rdf:type ffonto:HealthRisk ;
    rdfs:label "Wildfire Smoke Exposure" ;
    rdfs:comment "Exposure to smoke containing gases and fine particulate matter." ;
    ffonto:affectsPopulation ffonto:Children , ffonto:OlderAdults , ffonto:PregnantPeople , ffonto:HeartLungPatients .

ffonto:RespiratoryIrritation rdf:type ffonto:HealthRisk ;
    rdfs:label "Respiratory Irritation" .

ffonto:HeatStress rdf:type ffonto:HealthRisk ;
    rdfs:label "Heat Stress" .

ffonto:SpotFireTriage rdf:type ffonto:EmergencyOperation ;
    rdfs:label "Spot Fire Triage Operation" .

ffonto:TrafficControl rdf:type ffonto:EmergencyOperation ;
    rdfs:label "Traffic Control Deployment" .

ffonto:StructureProtection rdf:type ffonto:EmergencyOperation ;
    rdfs:label "Structure Protection Strategy" .

ffonto:FirefighterTeam rdf:type ffonto:EmergencyResponder ;
    rdfs:label "Wildfire Response Team" ;
    ffonto:performsOperation ffonto:SpotFireTriage , ffonto:TrafficControl .

ffonto:CDCWildfireSmoke rdf:type ffonto:InformationResource ;
    rdfs:label "CDC Wildfire Smoke Resource" ;
    rdfs:comment "Official CDC webpage providing information on wildfire smoke health risks." ;
    ffonto:hasWebsite "https://www.cdc.gov/wildfires/risk-factors/index.html"^^xsd:anyURI .

ffonto:AlaskaPublicHealthResource 
    rdf:type ffonto:InformationResource , ffonto:ResponseOrganization ;
    rdfs:label "Alaska Department of Health and Social Services" ;
    rdfs:comment "Public health organization providing wildfire smoke guidance." ;
    ffonto:hasWebsite "https://health.alaska.gov/en/division-of-public-health/"^^xsd:anyURI .

ffonto:EmergencyFireService rdf:type ffonto:EmergencyContact ;
    rdfs:label "Emergency Fire Department Contact" ;
    rdfs:comment "Emergency phone number for fire response services." ;
    ffonto:hasPhoneNumber "911" .

ffonto:WildfireInformationLine rdf:type ffonto:EmergencyContact ;
    rdfs:label "Wildfire Public Information Hotline" ;
    rdfs:comment "Public hotline providing wildfire information and assistance." ;
    ffonto:hasPhoneNumber "+1-800-237-3633" .

ffonto:StayIndoors rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Stay indoors during heavy smoke" ;
    rdfs:comment "Advises individuals to remain indoors when smoke levels are hazardous." .

ffonto:CloseWindows rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Close windows and doors" ;
    rdfs:comment "Recommended to prevent smoke from entering buildings." .

ffonto:UseHEPAFilter rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Use HEPA air filtration" ;
    rdfs:comment "Using HEPA filters helps reduce smoke particles indoors." .

ffonto:LimitExercise rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Limit outdoor physical activity" ;
    rdfs:comment "Reducing outdoor exercise minimizes inhalation of smoke particles." .

ffonto:SmokeProtectionGuideline rdf:type ffonto:HealthGuideline ;
    rdfs:label "Wildfire Smoke Protection Guideline" ;
    rdfs:comment "Guideline recommending protective actions to reduce health risks from wildfire smoke." ;
    ffonto:recommendsAction ffonto:StayIndoors ,
                      ffonto:CloseWindows ,
                      ffonto:UseHEPAFilter ,
                      ffonto:LimitExercise .

ffonto:DryGrass rdf:type ffonto:Fuel ;
    rdfs:label "Dry Grass" ;
    rdfs:comment "Fine fuels that ignite easily and accelerate wildfire spread." .

ffonto:PineNeedles rdf:type ffonto:Fuel ;
    rdfs:label "Pine Needles" .

ffonto:LeafLitter rdf:type ffonto:Fuel ;
    rdfs:label "Leaf Litter" .

ffonto:DownedLogs rdf:type ffonto:Fuel ;
    rdfs:label "Downed Logs" ;
    rdfs:comment "Large woody debris that may smolder for long periods." .

ffonto:StrongWind rdf:type ffonto:EnvironmentalCondition ;
    rdfs:label "Strong Wind" .

ffonto:LowHumidity rdf:type ffonto:EnvironmentalCondition ;
    rdfs:label "Low Humidity" .

ffonto:SteepTerrain rdf:type ffonto:EnvironmentalCondition ;
    rdfs:label "Steep Terrain" .

ffonto:NighttimeConditions rdf:type ffonto:EnvironmentalCondition ;
    rdfs:label "Nighttime Conditions" .

ffonto:SmokeInhalation rdf:type ffonto:HealthRisk ;
    rdfs:label "Smoke Inhalation Hazard" ;
    rdfs:comment "Fine particulate matter (PM2.5) in wildfire smoke causing respiratory issues." .

ffonto:ReducedVisibility rdf:type ffonto:Hazard ;
    rdfs:label "Reduced Visibility" .

ffonto:EmberSpotting rdf:type ffonto:Hazard ;
    rdfs:label "Ember Spotting Risk" ;
    rdfs:comment "Firebrands carried by wind igniting spot fires ahead of the main fire." .

ffonto:CrownFireRisk rdf:type ffonto:Hazard ;
    rdfs:label "Crown Fire Risk" ;
    rdfs:comment "Risk that ground fire spreads into the tree canopy." .

ffonto:TreeCollapse rdf:type ffonto:Hazard ;
    rdfs:label "Falling Tree Hazard" .

ffonto:WaterSupplyDisruption rdf:type ffonto:InfrastructureRisk ;
    rdfs:label "Water Supply Disruption Risk" .

ffonto:EvacuationBlockage rdf:type ffonto:InfrastructureRisk ;
    rdfs:label "Evacuation Route Blockage" .

ffonto:UseRespirator rdf:type ffonto:SafetyMeasure ;
    rdfs:label "Use Child-Sized Respirator" ;
    rdfs:comment "Respirators may help reduce smoke inhalation for children if tolerated." .

ffonto:CleanRoom rdf:type ffonto:SafetyMeasure ;
    rdfs:label "Clean Air Room" ;
    rdfs:comment "Indoor sealed room with HEPA filtration to reduce PM2.5 exposure." .

ffonto:IndoorShelter rdf:type ffonto:SafetyMeasure ;
    rdfs:label "Stay Indoors" .

ffonto:LimitOutdoorActivity rdf:type ffonto:SafetyMeasure ;
    rdfs:label "Limit Outdoor Activity During Smoke Events" .

ffonto:PetIndoorProtection rdf:type ffonto:SafetyMeasure ;
    rdfs:label "Keep Pets Indoors During Smoke Events" .

ffonto:FireEngine rdf:type ffonto:SuppressionResource ;
    rdfs:comment "Emergency vehicle used by firefighters to combat fires and protect structures." ;
    rdfs:label "Fire Engine" .

ffonto:WaterTanker rdf:type ffonto:SuppressionResource ;
    rdfs:label "Water Tanker" .

ffonto:AerialFirefighting rdf:type ffonto:SuppressionResource ;
    rdfs:label "Aerial Firefighting Aircraft" ;
    rdfs:comment "Aircraft dropping water or fire retardant." .

ffonto:NationalFireProtectionAssociation rdf:type ffonto:ResponseOrganization ;
    rdfs:label "National Fire Protection Association" ;
    ffonto:hasWebsite "https://www.nfpa.org"^^xsd:anyURI ;
    ffonto:hasPhoneNumber "+1-617-770-3000" ;
    rdfs:comment "Standards and guidance relevant to structure and vegetation fire hazards." .

ffonto:USForestService rdf:type ffonto:ResponseOrganization ;
    rdfs:label "US Forest Service" ;
    ffonto:hasWebsite "https://www.fs.usda.gov"^^xsd:anyURI ;
    ffonto:hasPhoneNumber "+1-202-205-8333" .

ffonto:UNOOSA rdf:type owl:NamedIndividual ;
    rdfs:label "United Nations Office for Outer Space Affairs" ;
    ffonto:hasWebsite "https://www.unoosa.org"^^xsd:anyURI .

ffonto:CALFIRE rdf:type owl:NamedIndividual ;
    rdfs:label "California Department of Forestry and Fire Protection" ;
    ffonto:hasWebsite "https://www.fire.ca.gov"^^xsd:anyURI ;
    ffonto:hasPhoneNumber "+1-916-653-7772" .

ffonto:EmergencyServices rdf:type ffonto:ResponseOrganization ;
    rdfs:label "Emergency Services" ;
    ffonto:hasPhoneNumber "911" ;
    ffonto:website "https://www.ready.gov/wildfires" ;
    rdfs:comment "Emergency response contact number." .

ffonto:NationalFireAgency rdf:type ffonto:ResponseOrganization ;
    rdfs:label "National Fire Management Agency" ;
    ffonto:contactNumber "+1-800-555-3473" ;
    ffonto:website "https://www.fire.gov" .

ffonto:ActiveForestFire rdf:type ffonto:ForestFire ;
    rdfs:label "Active Forest Wildfire" ;
    ffonto:hasFuel ffonto:DryGrass , ffonto:PineNeedles , ffonto:LeafLitter , ffonto:DownedLogs ;
    ffonto:createsHazard ffonto:SmokeInhalation , ffonto:ReducedVisibility , ffonto:EmberSpotting , ffonto:CrownFireRisk ;
    ffonto:respondedBy ffonto:FireEngine , ffonto:WaterTanker , ffonto:AerialFirefighting ;
    ffonto:managedBy ffonto:USForestService ;
    ffonto:hasSmokeDensity "High" .

ffonto:SmokeInhalation ffonto:mitigatedBy ffonto:UseRespirator , ffonto:CleanRoom , ffonto:IndoorShelter .
ffonto:ReducedVisibility ffonto:mitigatedBy ffonto:LimitOutdoorActivity .
ffonto:SmokeInhalation ffonto:affects ffonto:Person .
ffonto:SmokeInhalation ffonto:affectsAnimal ffonto:Animal .

ffonto:SmokeInhalationRisk rdf:type ffonto:HealthRisk ;
    rdfs:label "Smoke Inhalation Risk" ;
    rdfs:comment "Health risk caused by breathing wildfire smoke particles." .

ffonto:VisibilityHazard rdf:type ffonto:Hazard ;
    rdfs:label "Reduced Visibility Hazard" ;
    rdfs:comment "Hazard where dense smoke reduces visibility for responders." .

ffonto:RootFireCollapse rdf:type ffonto:Hazard ;
    rdfs:label "Root Fire Collapse Risk" ;
    rdfs:comment "Hazard where underground burning roots weaken ground stability." .

ffonto:SteepHillside rdf:type ffonto:ForestTerrain ;
    rdfs:label "Steep Hillside Terrain" ;
    rdfs:comment "Steep slopes that accelerate wildfire spread uphill." .

ffonto:HelicopterWaterDrop rdf:type ffonto:AerialResource ;
    rdfs:label "Helicopter Water Drop Aircraft" ;
    rdfs:comment "Aircraft used to drop water on wildfires." .

ffonto:RetardantAircraft rdf:type ffonto:AerialResource ;
    rdfs:label "Air Tanker Retardant Aircraft" ;
    rdfs:comment "Aircraft used to drop fire retardant chemicals." .

ffonto:DomesticPets rdf:type ffonto:Animal ;
    rdfs:label "Domestic Pets" ;
    rdfs:comment "Pets such as dogs or cats affected by wildfire smoke exposure." .

ffonto:CDCWildfireSmokeGuide rdf:type ffonto:InformationResource ;
    rdfs:label "CDC ForestFire Smoke Health Guide" ;
    rdfs:comment "Official CDC guidance on wildfire smoke health risks." ;
    ffonto:hasWebsite "https://www.cdc.gov/wildfires/risk-factors/index.html"^^xsd:anyURI .

ffonto:EPAWildfireSmokeGuide rdf:type ffonto:InformationResource ;
    rdfs:label "EPA ForestFire Smoke Guide" ;
    rdfs:comment "EPA resource describing smoke protection and air quality impacts." ;
    ffonto:hasWebsite "https://www.epa.gov/wildfire-smoke-course"^^xsd:anyURI .

ffonto:CountyFireDepartment rdf:type ffonto:ResponseOrganization ;
    rdfs:label "County Fire Department" ;
    ffonto:hasPhoneNumber "911" ;
    ffonto:hasWebsite "https://www.example-countyfire.gov"^^xsd:anyURI ;
    rdfs:comment "Local incident command and structural protection." .

ffonto:DefensibleSpaceAction rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Create defensible space" ;
    rdfs:comment "Remove vegetation and combustibles around structures to reduce ignition risk." .

ffonto:RespiratorChild rdf:type ffonto:PPE ;
    rdfs:label "Child-sized respirator (if tolerated)" .

ffonto:ClearDropZone rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Clear aerial drop zone" ;
    rdfs:comment "Ground personnel clear and mark areas before aerial retardant/water drops to reduce injury/impact risk." .

ffonto:SingleRoadAccess rdf:type ffonto:RoadAccess ;
    rdfs:label "Single visible road" ;
    ffonto:roadWidth "3.2"^^xsd:decimal ;
    rdfs:comment "Single narrow road; potential evacuation bottleneck." .

ffonto:SteepGradeConstraint rdf:type ffonto:VehicleAccess ;
    rdfs:label "Steep grade limiting vehicle access" .

ffonto:DefensibleSpaceSmall rdf:type ffonto:DefensibleSpace ;
    rdfs:label "Small defensible space (limited)" .

ffonto:DropImpactHigh rdf:type ffonto:ImpactHazard ;
    rdfs:label "Drop impact - high force" ;
    ffonto:dropForce "120.5"^^xsd:decimal .

ffonto:ClearDropZoneAction rdf:type ffonto:ProtectiveAction ;
    rdfs:label "Clear drop zone before aerial operations" .

#################################################################
# Sitational Awareness CQ

#################################################################
# Classes
#################################################################

ffonto:PerimeterSnapshot rdf:type owl:Class ;
    rdfs:label "Perimeter Snapshot" ;
    rdfs:comment "Geospatial perimeter capture (time-stamped) used to compute area." .

ffonto:CameraObservation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:ImageObservation ;
    rdfs:label "Camera Observation" ;
    rdfs:comment "Observation produced from a fixed or mobile camera (image/frame-level)." .

ffonto:WeatherObservation rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Observation ;
    rdfs:label "Weather Observation" ;
    rdfs:comment "Meteorological measurements at the incident site." .


ffonto:FireProbabilityModel rdf:type owl:Class ;
    rdfs:label "Fire Probability Model" ;
    rdfs:comment "Model output describing fire probability for an image/frame." .

ffonto:FireWeatherRecord rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WeatherObservation ;
    rdfs:label "Fuel Moisture & Fire Weather Records" ;
    rdfs:comment "FFMC, ISI, DMC, DC, BUI, FWI values used to assess spread potential." .

ffonto:Contact rdf:type owl:Class ;
    rdfs:label "Contact" ;
    rdfs:comment "Contact information (web, phone) for incident resources." .

ffonto:SurfaceFire rdf:type owl:NamedIndividual, ffonto:FireType ;
    rdfs:label "Surface/ground fire" ;
    rdfs:comment "Surface or ground fire (includes intermittent torching)." .

ffonto:CrownFire rdf:type owl:NamedIndividual, ffonto:FireType ;
    rdfs:label "Crown fire" ;
    rdfs:comment "Crown fire (canopy-level)." .

ffonto:SmokeColor rdf:type owl:Class ;
    rdfs:label "Smoke Color (enum)" ;
    rdfs:comment "Smoke color categories." .

ffonto:VisibilityCategory rdf:type owl:Class ;
    rdfs:label "Visibility Category (enum)" ;
    rdfs:comment "Low, Medium, High scene visibility due to smoke." .

ffonto:Trend rdf:type owl:Class ;
    rdfs:label "Trend (enum)" ;
    rdfs:comment "Temporal trend: increasing, decreasing, stable." .

ffonto:MediaAsset rdf:type owl:Class ;
    rdfs:label "Media Asset" ;
    rdfs:comment "Represents an media file (audio/image) and its metadata (resolution, checksum, georef, path, license, etc.)." .


ffonto:ImageAsset rdf:type owl:Class ;
    rdfs:label "Image Asset" ;
    rdfs:comment "Represents an image file and its metadata (resolution, checksum, georef, path, license, etc.)." .

ffonto:ImageQualityMetadata rdf:type owl:Class ;
    rdfs:label "Image Quality Metadata" ;
    rdfs:comment "Quality-related metadata such as blur, cloud_cover quality flags, georeference presence and sensor pose." .

ffonto:CaptionModelOutput rdf:type owl:Class ;
    rdfs:label "Caption Model Output" ;
    owl:subClassOf ffonto:ModelOutput ;
    rdfs:comment "Text caption produced by an image captioning model and related descriptors." .

ffonto:VisionModelScores rdf:type owl:Class ;
    rdfs:label "Vision Model Scores" ;
    owl:subClassOf ffonto:ModelOutput ;
    rdfs:comment "Scores produced by a vision classifier/model (fire/smoke/no-fire etc.) and the producing model name/version." .

ffonto:SmokeLayerObservation rdf:type owl:Class ;
    rdfs:label "Smoke Layer Observation" ;
    rdfs:comment "Observation describing presence of multilayer smoke and qualitative descriptions per layer." .

ffonto:SatelliteObservation rdf:type owl:Class ;
    rdfs:label "Satellite Observation" ;
    rdfs:comment "Represents whether the smoke plume is visible in satellite passes on a given day." .

ffonto:FuelCondition rdf:type owl:Class ;
    rdfs:label "Fuel Condition" ;
    rdfs:comment "Live/dead fuel moisture conditions, curing status, height/continuity of grasses, canopy base height and crown potential." .

ffonto:AspectCategory rdf:type owl:Class ;
    rdfs:label "Aspect Category (enum)" ;
    rdfs:comment "Cardinal aspect(s) active in the scene." .

ffonto:CloudCoverQuality rdf:type owl:Class ;
    rdfs:label "Cloud Cover Quality Metadata" ;
    rdfs:comment "Quality metadata for cloud cover field (presence/absence of quality flag)." .

ffonto:PredictedLabel rdf:type owl:Class ;
    rdfs:label "PredictedLabel" ;
    rdfs:comment "A human or automatic label assigned to an image record (e.g., severity, content label)." .

ffonto:LabelAssignment rdf:type owl:Class ;
    rdfs:label "Label Assignment" ;
    rdfs:subClassOf ffonto:ModelOutput ;
    rdfs:comment "Represents the association of a Label to an ImageAsset, including source and count." .

ffonto:AudioRecord rdf:type owl:Class ;
    rdfs:label "Audio Record" ;
    rdfs:comment "An audio clip and its metadata (path, uuid, source, event ids, model outputs)." .

ffonto:ThresholdSet rdf:type owl:Class ;
    rdfs:label "Threshold Set" ;
    rdfs:comment "A set of configured thresholds (global, smoke, fire, frame_thresh) stored with predictions." .

ffonto:ModelProvenance rdf:type owl:Class ;
    rdfs:label "Model Provenance" ;
    rdfs:comment "Provenance information for a model (repo/URL/name/version) used for audit." .

ffonto:AuditRecord rdf:type owl:Class ;
    rdfs:label "Audit Record" ;
    rdfs:comment "Audit artifacts such as checksums and class-map checksums." .

ffonto:TemporalRecord rdf:type owl:Class ;
    rdfs:label "Temporal Record" ;
    rdfs:comment "Represents whether timestamp metadata is available for pairing events." .

ffonto:GridLocation rdf:type owl:Class ;
    rdfs:label "Grid Location" ;
    rdfs:comment "Spatial grid reference for the monitored site." .

ffonto:FireDangerAssessment rdf:type owl:Class ;
    rdfs:label "Fire Danger Assessment" ;
    rdfs:comment "Assessment of wildfire danger based on FWI system values." .

ffonto:ModalityConsistency rdf:type owl:Class ;
    rdfs:label "Modality Consistency Check" ;
    rdfs:comment "Evaluation of consistency between modalities (image, audio, caption, weather)." .

ffonto:FireSpread rdf:type owl:Class ;
    rdfs:label "Fire Spread Behavior" ;
    rdfs:comment "Represents spread characteristics of the wildfire." .

ffonto:FireCluster rdf:type owl:Class ;
    rdfs:label "Fire Cluster" ;
    rdfs:comment "A distinct group or cluster of flames detected in the scene." .

ffonto:TransportationRoute rdf:type owl:Class ;
    rdfs:label "Transportation Route" ;
    rdfs:comment "Roads or travel corridors affected by wildfire." .

ffonto:GroundCrew rdf:type owl:Class ;
    rdfs:label "Ground Fire Crew" ;
    rdfs:comment "Firefighters operating on the ground." .

ffonto:VegetationType rdf:type owl:Class ;
    rdfs:label "Vegetation Type" ;
    rdfs:comment "Type of vegetation burning in the wildfire." .

ffonto:EnvironmentType rdf:type owl:Class ;
    rdfs:label "Environment Type" ;
    rdfs:comment "General environmental setting (forested, grassland, agricultural)." .

ffonto:FireRiskAssessment rdf:type owl:Class ;
    rdfs:label "Fire Risk Assessment" ;
    rdfs:comment "Assessment of risk to infrastructure, people, and environment." .

ffonto:ForestFireRisk rdf:type owl:Class ;
    rdfs:label "Forest fire risk"@en ;
    skos:altLabel "Wildfire risk"@en ;
    rdfs:comment "The likelihood or probability that a wildfire may start and spread in a forested area based on environmental, climatic, and human factors."@en ;
    skos:definition "A risk assessment concept representing the potential for wildfire ignition and propagation in forest ecosystems."@en ;
    rdfs:subClassOf ffonto:RiskAssessment .

ffonto:SatelliteDetection rdf:type owl:Class ;
    rdfs:subClassOf ffonto:DetectionMethod ;
    rdfs:label "Satellite Detection" ;
    rdfs:comment "Thermal or spectral satellite detection of wildfire signatures." .

ffonto:SuppressionDifficulty rdf:type owl:Class ;
    rdfs:label "Suppression Difficulty" ;
    rdfs:comment "Assessment of wildfire suppression difficulty." .

ffonto:UrbanWildlandInterface rdf:type owl:Class ;
    rdfs:label "Urban Wildland Interface" ;
    rdfs:comment "Area where human infrastructure meets wildland vegetation." .

ffonto:AgriculturalLand rdf:type owl:Class ;
    rdfs:label "Agricultural Land" ;
    rdfs:comment "Farms, crop fields, or managed grasslands impacted by wildfire." .

ffonto:AviationRoute rdf:type owl:Class ;
    rdfs:label "Aviation Route" ;
    rdfs:comment "Air traffic corridor affected by smoke or wildfire plume." .

ffonto:SpottingEvent rdf:type owl:Class ;
    rdfs:label "Spotting / Ember Cast Event" ;
    rdfs:comment "Transport of embers causing spot fires ahead of main front." .

ffonto:FireTruck rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EmergencyVehicle ;
    rdfs:label "Fire Truck" ;
    rdfs:comment "Ground firefighting vehicle." .

ffonto:AlertSystemStatus rdf:type owl:Class ;
    rdfs:label "Alert System Status" ;
    rdfs:comment "Represents completeness of required fields for automated alert generation." .

ffonto:BrushEngine rdf:type owl:Class ;
    rdfs:subClassOf ffonto:FireEngine ;
    rdfs:label "Brush Engine (Type 6)" .

ffonto:WaterTender rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "Water Tender" .

ffonto:PoliceCar rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Vehicle ;
    rdfs:label "Police Car" .

ffonto:Helicopter rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Aircraft ;
    rdfs:label "Helicopter" .

ffonto:HoseLine rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Fire Hose Line" .

ffonto:Chainsaw rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Chainsaw" .

ffonto:DripTorch rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Drip Torch" .

ffonto:PortableWaterTank rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
