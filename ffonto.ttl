ffonto:Hydrant
    a owl:Class ;
    rdfs:subClassOf ffonto:UtilityInfrastructure ;
    rdfs:label "Hydrant" ;
    rdfs:comment "Fire hydrants." .

ffonto:CommunicationTower
    a owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Communication Tower" ;
