    rdfs:range ffonto:CarbonSink .

ffonto:providesCarbonStorageOf a owl:ObjectProperty ;
    rdfs:range ffonto:Forest ;
    rdfs:domain ffonto:CarbonSink ;
    rdfs:label "inverse of provides carbon storage"@en .

ffonto:providesCarbonStorageOf owl:inverseOf ffonto:providesCarbonStorage .

ffonto:contributesToFireRisk rdf:type owl:ObjectProperty ;
    rdfs:label "contributes to fire risk" ;
    rdfs:comment "Relates environmental conditions to increased wildfire risk." ;
    rdfs:domain ffonto:EnvironmentalCondition ;
    rdfs:range ffonto:FireBehavior .

ffonto:influencedByEnvironmentalCondiction a owl:ObjectProperty ;
    rdfs:label "influenced by"@en ;
    rdfs:range ffonto:EnvironmentalCondition ;
    rdfs:domain ffonto:FireBehavior .

ffonto:influencedByEnvironmentalCondiction owl:inverseOf ffonto:contributesToFireRisk .

ffonto:hasFireEvent rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range ffonto:FireEvent ;
    rdfs:label "has fire event" ;
    rdfs:comment "Indicates that a forest ecosystem experienced a fire event." .

ffonto:isFireEventOf rdf:type owl:ObjectProperty ;
    rdfs:range ffonto:ForestEcosystem ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:label "is fire event of" ;
    owl:inverseOf ffonto:hasFireEvent ;
    rdfs:comment "Inverse of has fire event" .

ffonto:isComponentOfVegetation rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Plant ;
    rdfs:range ffonto:Vegetation ;
    rdfs:label "is component of vegetation" ;
    rdfs:comment "Indicates that a plant is part of a vegetation community." ;
    owl:inverseOf ffonto:hasPlantComponent .

#################################################################
# Data Properties
#################################################################

ffonto:canopyDensity rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range xsd:decimal ;
    rdfs:label "canopy density" ;
    rdfs:comment "Represents the density of the forest canopy in a forest ecosystem." .

ffonto:vegetationDensity rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:string ;
    rdfs:label "vegetation density" ;
    rdfs:comment "Describes the density of vegetation such as sparse, moderate, or dense." .

ffonto:treeSpacing rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestEcosystem ;
    rdfs:range xsd:string ;
    rdfs:label "tree spacing" ;
    rdfs:comment "Represents the spacing between trees within a forest ecosystem." .

ffonto:flammabilityLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Tree ;
    rdfs:range xsd:string ;
    rdfs:label "flammability level" ;
    rdfs:comment "Indicates how flammable a tree species is (e.g., high, medium, low)." .

ffonto:resinContent rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Tree ;
    rdfs:range xsd:decimal ;
    rdfs:label "resin content" ;
    rdfs:comment "Represents the amount of resin in a tree species which contributes to flammability." .

ffonto:burnedAreaSize rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range xsd:decimal ;
    rdfs:label "burned area size" ;
    rdfs:comment "Represents the size of the area affected by the fire event, typically measured in hectares." .

ffonto:carbonReleased rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireImpact ;
    rdfs:range xsd:decimal ;
    rdfs:label "carbon released" ;
    rdfs:comment "Amount of carbon released into the atmosphere due to a fire event." .

ffonto:soilNutrientLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:decimal ;
    rdfs:label "soil nutrient level" ;
    rdfs:comment "Represents the level of nutrients present in the soil." .

ffonto:snowDepth rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SnowCover ;
    rdfs:range xsd:decimal ;
    rdfs:label "snow depth" ;
    rdfs:comment "Represents the depth of snow cover in the forest ecosystem." .

ffonto:vegetationPatchArea rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:VegetationDistribution ;
    rdfs:range xsd:decimal ;
    rdfs:label "vegetation patch area (ha)" ;
    rdfs:comment "Area of the vegetation patch in hectares." .

ffonto:canopyClosurePercent rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SpatialUnit ;
    rdfs:range xsd:decimal ;
    rdfs:label "canopy closure percent" ;
    rdfs:comment "Percent canopy closure for the spatial unit (0-100)." .

ffonto:understoryDensity rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:Understory ;
    rdfs:range xsd:decimal ;
    rdfs:label "understory density" ;
    rdfs:comment "Density metric for understory vegetation (e.g., stems per m2 or qualitative index)." .

ffonto:fuelLoadTonsPerHa rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FuelLoad ;
    rdfs:range xsd:decimal ;
    rdfs:label "fuel load (tons/ha)" ;
    rdfs:comment "Quantitative fuel load expressed in tonnes per hectare." .

ffonto:soilNutrientIndex rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SoilQuality ;
    rdfs:range xsd:decimal ;
    rdfs:label "soil nutrient index" ;
    rdfs:comment "Index indicating soil nutrient availability." .

ffonto:soilMoisturePercent rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:SoilQuality ;
    rdfs:range xsd:decimal ;
    rdfs:label "soil moisture percent" ;
    rdfs:comment "Soil moisture percentage (volumetric or gravimetric as specified)." .

ffonto:waterTableDepth rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:WaterAvailability ;
    rdfs:range xsd:decimal ;
    rdfs:label "water table depth (m)" ;
    rdfs:comment "Depth to groundwater table in meters." .

ffonto:burnDurationHours rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range xsd:decimal ;
    rdfs:label "burn duration (hours)" ;
    rdfs:comment "Duration of the fire event measured in hours." .

ffonto:smokePM25 rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ParticulateMatter ;
    rdfs:range xsd:decimal ;
    rdfs:label "smoke PM2.5 (ug/m3)" ;
    rdfs:comment "Measured PM2.5 concentration in micrograms per cubic meter from smoke." .

ffonto:carbonReleasedKg rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:CarbonRelease ;
    rdfs:range xsd:decimal ;
    rdfs:label "carbon released (kg)" ;
    rdfs:comment "Estimated carbon mass released by the fire event in kilograms." .

ffonto:regenerationRate rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ForestRegeneration ;
    rdfs:range xsd:decimal ;
    rdfs:label "regeneration rate (seedlings/ha/yr)" ;
    rdfs:comment "Rate of seedling establishment per hectare per year after disturbance." .

ffonto:speciesRichness rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:HabitatType ;
    rdfs:range xsd:decimal ;
    rdfs:label "species richness" ;
    rdfs:comment "Count of species observed in the habitat (richness metric)." .

ffonto:burnSeverityIndex rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:FireSeverity ;
    rdfs:range xsd:decimal ;
    rdfs:label "burn severity index" ;
    rdfs:comment "Numeric index representing burn severity (higher values = more severe)." .

ffonto:observationConfidence rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ImageObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "observation confidence" ;
    rdfs:comment "Confidence (0-1) in the image-derived observation or classification." .

ffonto:observedAt rdf:type owl:DatatypeProperty ;
    rdfs:domain ffonto:ImageObservation ;
    rdfs:range xsd:dateTime ;
    rdfs:label "observed at" ;
    rdfs:comment "Timestamp for the image observation." .

ffonto:hasAverageTreeHeight rdf:type owl:DatatypeProperty ;
    rdfs:label "has average tree height" ;
    rdfs:comment "Relates a coniferous forest ecosystem to the average height of trees present within it." ;
    rdfs:domain ffonto:ConiferousForest ;
    rdfs:range xsd:float .

ffonto:hasSeasonalLeafDropRate rdf:type owl:DatatypeProperty ;
    rdfs:label "has seasonal leaf drop rate" ;
    rdfs:comment "Relates a deciduous forest to the rate at which trees shed their leaves during seasonal cycles." ;
    rdfs:domain ffonto:DeciduousForest ;
    rdfs:range xsd:float .

ffonto:hasSpeciesDiversityIndex rdf:type owl:DatatypeProperty ;
    rdfs:label "has species diversity index" ;
    rdfs:comment "Relates a mixed forest ecosystem to a biodiversity index representing species diversity." ;
    rdfs:domain ffonto:MixedForest ;
    rdfs:range xsd:float .

ffonto:hasGrassCoveragePercentage rdf:type owl:DatatypeProperty ;
    rdfs:label "has grass coverage percentage" ;
    rdfs:comment "Relates a grassland ecosystem to the percentage of land surface covered by grass vegetation." ;
    rdfs:domain ffonto:Grassland ;
    rdfs:range xsd:float .

ffonto:hasShrubDensity rdf:type owl:DatatypeProperty ;
    rdfs:label "has shrub density" ;
    rdfs:comment "Relates a shrubland ecosystem to the density of shrubs within the area." ;
    rdfs:domain ffonto:Shrubland ;
    rdfs:range xsd:float .

ffonto:hasNeedleLength rdf:type owl:DatatypeProperty ;
    rdfs:label "has needle length" ;
    rdfs:comment "Relates a coniferous tree to the average length of its needles." ;
    rdfs:domain ffonto:ConiferousTree ;
    rdfs:range xsd:float .

ffonto:hasLeafAreaIndex rdf:type owl:DatatypeProperty ;
    rdfs:label "has leaf area index" ;
    rdfs:comment "Relates a deciduous tree to its leaf area index representing canopy density." ;
    rdfs:domain ffonto:DeciduousTree ;
    rdfs:range xsd:float .

ffonto:hasGrassHeight rdf:type owl:DatatypeProperty ;
    rdfs:label "has grass height" ;
    rdfs:comment "Relates grass vegetation to its average height." ;
    rdfs:domain ffonto:Grass ;
    rdfs:range xsd:float .

ffonto:hasShrubHeight rdf:type owl:DatatypeProperty ;
    rdfs:label "has shrub height" ;
    rdfs:comment "Relates a shrub to its typical height." ;
    rdfs:domain ffonto:Shrub ;
    rdfs:range xsd:float .

ffonto:hasSurfaceArea rdf:type owl:DatatypeProperty ;
    rdfs:label "has surface area" ;
    rdfs:comment "Relates a lake to its surface area measurement." ;
    rdfs:domain ffonto:Lake ;
    rdfs:range xsd:float .

ffonto:hasFlowRate rdf:type owl:DatatypeProperty ;
    rdfs:label "has flow rate" ;
    rdfs:comment "Relates a river to the rate of water flow within it." ;
    rdfs:domain ffonto:River ;
    rdfs:range xsd:float .

ffonto:hasChannelWidth rdf:type owl:DatatypeProperty ;
    rdfs:label "has channel width" ;
    rdfs:comment "Relates a water channel to its width measurement." ;
    rdfs:domain ffonto:WaterChannel ;
    rdfs:range xsd:float .

ffonto:hasIslandArea rdf:type owl:DatatypeProperty ;
    rdfs:label "has island area" ;
    rdfs:comment "Relates an island to its total land area." ;
    rdfs:domain ffonto:Island ;
    rdfs:range xsd:float .

ffonto:hasFuelMoistureContent rdf:type owl:DatatypeProperty ;
    rdfs:label "has fuel moisture content" ;
    rdfs:comment "Relates a fine fuel type to its moisture content level influencing ignition probability." ;
    rdfs:domain ffonto:FineFuel ;
    rdfs:range xsd:float .

ffonto:hasFuelDepth rdf:type owl:DatatypeProperty ;
    rdfs:label "has fuel depth" ;
    rdfs:comment "Relates surface fuel to the depth of the fuel layer on the ground." ;
    rdfs:domain ffonto:SurfaceFuel ;
    rdfs:range xsd:float .

ffonto:hasHeavyFuel rdf:type owl:DatatypeProperty ;
    rdfs:label "has heavy fuel" ;
    rdfs:comment "Relates heavy fuel to the quantity of combustible material present." ;
    rdfs:domain ffonto:HeavyFuel ;
    rdfs:range xsd:float .

ffonto:hasSpreadRate rdf:type owl:DatatypeProperty ;
    rdfs:label "has fire spread rate" ;
    rdfs:comment "Relates fire spread behavior to the rate at which fire propagates across a landscape." ;
    rdfs:domain ffonto:FireSpread ;
    rdfs:range xsd:float .

ffonto:hasFlameHeightValue rdf:type owl:DatatypeProperty ;
    rdfs:label "has flame height" ;
    rdfs:comment "Relates fire behavior to the vertical height of flames produced during combustion." ;
    rdfs:domain ffonto:FlameHeight ;
    rdfs:range xsd:float .

ffonto:hasEmberTravelDistance rdf:type owl:DatatypeProperty ;
    rdfs:label "has ember travel distance" ;
    rdfs:comment "Relates ember transport behavior to the distance embers can travel through wind." ;
    rdfs:domain ffonto:EmberTransport ;
    rdfs:range xsd:float .

ffonto:hasHeatReleaseRate rdf:type owl:DatatypeProperty ;
    rdfs:label "has heat release rate" ;
    rdfs:comment "Relates fire intensity to the amount of heat energy released per unit time." ;
    rdfs:domain ffonto:FireIntensity ;
    rdfs:range xsd:float .

ffonto:hasWindSpeed rdf:type owl:DatatypeProperty ;
    rdfs:label "has wind speed" ;
    rdfs:comment "Relates a wind environmental factor to its speed measurement." ;
    rdfs:domain ffonto:Wind ;
    rdfs:range xsd:float .

ffonto:hasSoilMoisture rdf:type owl:DatatypeProperty ;
    rdfs:label "has soil moisture" ;
    rdfs:comment "Relates soil condition to the amount of moisture present in soil." ;
    rdfs:domain ffonto:SoilCondition ;
    rdfs:range xsd:float .

ffonto:hasRelativeHumidity rdf:type owl:DatatypeProperty ;
    rdfs:label "has relative humidity" ;
    rdfs:comment "Relates moisture level to the relative humidity in the environment." ;
    rdfs:domain ffonto:MoistureLevel ;
    rdfs:range xsd:float .

ffonto:hasBarrierWidth rdf:type owl:DatatypeProperty ;
    rdfs:label "has barrier width" ;
    rdfs:comment "Relates a natural barrier to its width which may influence fire spread." ;
    rdfs:domain ffonto:NaturalBarrier ;
    rdfs:range xsd:float .

ffonto:hasSeedSurvivalRate rdf:type owl:DatatypeProperty ;
    rdfs:label "has seed survival rate" ;
    rdfs:comment "Relates tree regeneration processes to the proportion of seeds that survive after fire." ;
    rdfs:domain ffonto:TreeRegeneration ;
    rdfs:range xsd:float .

ffonto:hasNutrientLevelChange rdf:type owl:DatatypeProperty ;
    rdfs:label "has nutrient level change" ;
    rdfs:comment "Relates soil nutrient change to variations in nutrient levels following fire disturbance." ;
    rdfs:domain ffonto:SoilNutrientChange ;
    rdfs:range xsd:float .

ffonto:hasHabitatLossPercentage rdf:type owl:DatatypeProperty ;
    rdfs:label "has habitat loss percentage" ;
    rdfs:comment "Relates habitat loss to the percentage of habitat area destroyed by fire." ;
    rdfs:domain ffonto:HabitatLoss ;
    rdfs:range xsd:float .

ffonto:hasErosionProbability rdf:type owl:DatatypeProperty ;
    rdfs:label "has erosion probability" ;
    rdfs:comment "Relates erosion risk to the probability of soil erosion occurring after fire." ;
    rdfs:domain ffonto:ErosionRisk ;
    rdfs:range xsd:float .

ffonto:hasRecoveryTimeYears rdf:type owl:DatatypeProperty ;
    rdfs:label "has recovery time in years" ;
    rdfs:comment "Relates vegetation recovery to the estimated time required for vegetation to regenerate." ;
    rdfs:domain ffonto:VegetationRecovery ;
    rdfs:range xsd:float .

ffonto:hasFirebreakWidth rdf:type owl:DatatypeProperty ;
    rdfs:label "has firebreak width" ;
    rdfs:comment "Relates a firebreak to the width of the vegetation gap used to slow fire spread." ;
    rdfs:domain ffonto:Firebreak ;
    rdfs:range xsd:float .

ffonto:hasBackburnArea rdf:type owl:DatatypeProperty ;
    rdfs:label "has backburn area" ;
    rdfs:comment "Relates a backburn strategy to the area intentionally burned to remove fuel." ;
    rdfs:domain ffonto:Backburn ;
    rdfs:range xsd:float .

ffonto:hasPersonnelCount rdf:type owl:DatatypeProperty ;
    rdfs:label "has personnel count" ;
    rdfs:comment "Relates manual suppression operations to the number of personnel involved." ;
    rdfs:domain ffonto:ManualSuppression ;
    rdfs:range xsd:integer .

ffonto:hasBurnTemperature rdf:type owl:DatatypeProperty ;
    rdfs:label "has burn temperature" ;
    rdfs:comment "Relates a controlled burn to the temperature reached during the burning process." ;
    rdfs:domain ffonto:ControlledBurn ;
    rdfs:range xsd:float .

ffonto:hasSpeciesRichness rdf:type owl:DatatypeProperty ;
    rdfs:label "has species richness" ;
    rdfs:comment "Relates biodiversity support to the number of species present in an ecosystem." ;
    rdfs:domain ffonto:BiodiversitySupport ;
    rdfs:range xsd:integer .

ffonto:hasSoilRetentionRate rdf:type owl:DatatypeProperty ;
    rdfs:label "has soil retention rate" ;
    rdfs:comment "Relates erosion control services to the rate at which soil is retained." ;
    rdfs:domain ffonto:ErosionControl ;
    rdfs:range xsd:float .

ffonto:hasWaterQualityIndex rdf:type owl:DatatypeProperty ;
    rdfs:label "has water quality index" ;
    rdfs:comment "Relates water protection services to a water quality measurement index." ;
    rdfs:domain ffonto:WaterProtection ;
    rdfs:range xsd:float .

ffonto:hasHabitatCapacity rdf:type owl:DatatypeProperty ;
    rdfs:label "has habitat capacity" ;
    rdfs:comment "Relates habitat provision to the capacity of an ecosystem to support living organisms." ;
    rdfs:domain ffonto:HabitatProvision ;
    rdfs:range xsd:integer .

ffonto:hasVegetationDensity rdf:type owl:DatatypeProperty ;
    rdfs:label "has vegetation density" ;
    rdfs:comment "Relates vegetation to its density within a given area." ;
    rdfs:domain ffonto:Vegetation ;
    rdfs:range xsd:float .

ffonto:hasCanopyCoverage rdf:type owl:DatatypeProperty ;
    rdfs:label "has canopy coverage" ;
    rdfs:comment "Represents the proportion of land covered by tree canopy." ;
    rdfs:domain ffonto:Forest ;
    rdfs:range xsd:float .

ffonto:hasDegradedAreaPercentage rdf:type owl:DatatypeProperty ;
    rdfs:label "has degraded area percentage" ;
    rdfs:comment "Percentage of ecosystem area that is degraded or damaged." ;
    rdfs:domain ffonto:Ecosystem ;
    rdfs:range xsd:float .

ffonto:hasDeadBiomassVolume rdf:type owl:DatatypeProperty ;
    rdfs:label "has dead biomass volume" ;
    rdfs:comment "Volume of dead vegetation biomass present in an area." ;
    rdfs:domain ffonto:DeadVegetation ;
    rdfs:range xsd:float .

ffonto:hasSoilFertilityIndex rdf:type owl:DatatypeProperty ;
    rdfs:label "has soil fertility index" ;
    rdfs:comment "Numerical indicator representing soil fertility." ;
    rdfs:domain ffonto:SoilQuality ;
    rdfs:range xsd:float .

ffonto:hasRockCoveragePercentage rdf:type owl:DatatypeProperty ;
    rdfs:label "has rock coverage percentage" ;
    rdfs:comment "Percentage of terrain covered by rocks." ;
    rdfs:domain ffonto:RockyTerrain ;
    rdfs:range xsd:float .

#################################################################
# Incident Analysis and Restoration CQ

#################################################################
# Class
#################################################################

ffonto:Firefighter
    a owl:Class ;
    rdfs:subClassOf ffonto:Responder ;
    rdfs:label "Firefighter" ;
    rdfs:comment "Wildland or structural firefighters engaged in suppression operations." .

ffonto:FirefightingOperation rdf:type owl:Class ;
    rdfs:label "Firefighting Operation" ;
    rdfs:comment "An operational activity conducted to control or suppress wildfire." .

ffonto:Equipment rdf:type owl:Class ;
    rdfs:label "Equipment" ;
    rdfs:comment "Tools or devices used during firefighting operations." .

ffonto:Vehicle rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Vehicle" ;
    rdfs:comment "Ground vehicles used in wildfire operations." .

ffonto:Aircraft rdf:type owl:Class ;
    rdfs:label "Aircraft" ;
    rdfs:comment "Aircraft used in wildfire suppression." .

ffonto:AirTanker rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Aircraft ;
    rdfs:label "Air Tanker" ;
    rdfs:comment "Aircraft used to drop fire retardant." .

ffonto:WaterSource rdf:type owl:Class ;
    rdfs:label "Water Source" ;
    rdfs:comment "A natural or artificial water source used for firefighting." .

ffonto:Stream rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WaterBody ;
    rdfs:label "Stream" ;
    rdfs:comment "A natural flowing water source that may be used for drafting water." .

ffonto:Infrastructure rdf:type owl:Class ;
    rdfs:label "Infrastructure" ;
    rdfs:comment "Temporary or permanent structures used during wildfire response." .

ffonto:IncidentCommandPost rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Incident Command Post" ;
    rdfs:comment "The central command location for managing wildfire response." .

ffonto:RehabArea rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Rehabilitation Area" ;
    rdfs:comment "A rest area where firefighters recover and hydrate." .

ffonto:BriefingArea rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Briefing Area" ;
    rdfs:comment "Location where firefighters receive operational briefings." .

ffonto:House rdf:type owl:Class ;
    rdfs:label "House" ;
    rdfs:comment "Residential structure potentially threatened by wildfire." .

ffonto:Hazard rdf:type owl:Class ;
    rdfs:label "Hazard" ;
    rdfs:comment "A dangerous condition present during wildfire operations." .

ffonto:SmokeHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Smoke Hazard" ;
    rdfs:comment "Respiratory and visibility impacts from PM2.5 and toxic smoke." .

ffonto:ToxicSmoke rdf:type owl:Class ;
    rdfs:subClassOf ffonto:SmokeHazard ;
    rdfs:label "Toxic Smoke" ;
    rdfs:comment "Smoke from structures or hazardous materials containing toxic combustion products (plastics, treated wood)." .

ffonto:EmberHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Ember / Firebrand Hazard" ;
    rdfs:comment "Flying embers that generate spot fires or ignite structures/vegetation." .

ffonto:RadiantHeatHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Radiant Heat Hazard" ;
    rdfs:comment "Heat flux from burning structures or vegetation that can ignite nearby fuels." .

ffonto:StructuralCollapse rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Structural Collapse Hazard" ;
    rdfs:comment "Risk of building collapse endangering personnel." .

ffonto:RetardantHazard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Retardant Deployment Hazard" ;
    rdfs:comment "Slip, contamination, and impact hazards from aerial retardant or water drops." .

ffonto:EntrapmentRisk rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Hazard ;
    rdfs:label "Entrapment Risk" ;
    rdfs:comment "Risk a crew or individual may be cut off from escape routes by rapid fire behavior." .

ffonto:EmergencyActivity rdf:type owl:Class ;
    rdfs:label "Emergency Activity" ;
    rdfs:comment "Activities indicating emergency conditions such as evacuations or escalations." .

ffonto:RecoveryGuideline rdf:type owl:Class ;
    rdfs:label "Recovery Guideline" ;
    rdfs:comment "Guidelines provided to residents after a wildfire event." .

ffonto:UtilitySystem rdf:type owl:Class ;
    rdfs:label "Utility System" ;
    rdfs:comment "Infrastructure systems such as water or gas supply." .

ffonto:FoodSafetyProcedure rdf:type owl:Class ;
    rdfs:label "Food Safety Procedure" ;
    rdfs:comment "Food safety measures recommended after power outages." .

ffonto:FireHose rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Fire Hose" ;
    rdfs:comment "A flexible hose used to deliver water to extinguish fire." .

ffonto:WaterTank rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Water Tank" ;
    rdfs:comment "A storage container or reservoir used to store water for firefighting, domestic supply, or emergency use." .

ffonto:Cistern rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WaterSource ;
    rdfs:label "Cistern" ;
    rdfs:comment "A container for storing water, typically used as an emergency water source." .

ffonto:PortableTank rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Portable Water Tank" ;
    rdfs:comment "Portable tanks (pumpkins) used to store water near structures during firefighting operations." .

ffonto:MapBoard rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Equipment ;
    rdfs:label "Map Board" ;
    rdfs:comment "A board used during briefings to display maps and operational information." .

ffonto:PropaneTank rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Infrastructure ;
    rdfs:label "Propane Tank" ;
    rdfs:comment "A tank used to store propane gas near residential structures." .

ffonto:AshCleanupGuideline rdf:type owl:Class ;
    rdfs:subClassOf ffonto:RecoveryGuideline ;
    rdfs:label "Ash Cleanup Guideline" ;
    rdfs:comment "Guidelines for safely cleaning wildfire ash from homes." .

ffonto:WaterSafetyAdvisory rdf:type owl:Class ;
    rdfs:subClassOf ffonto:RecoveryGuideline ;
    rdfs:label "Water Safety Advisory" ;
    rdfs:comment "Advisories regarding drinking water safety after wildfire events." .

ffonto:InsuranceDocumentationGuideline rdf:type owl:Class ;
    rdfs:subClassOf ffonto:RecoveryGuideline ;
    rdfs:label "Insurance Documentation Guideline" ;
    rdfs:comment "Guidelines for documenting wildfire damage for insurance claims." .

ffonto:PowerOutageEvent rdf:type owl:Class ;
    rdfs:subClassOf ffonto:EmergencyActivity ;
    rdfs:label "Power Outage Event" ;
    rdfs:comment "An interruption of electricity supply affecting households after wildfire." .

ffonto:WellWater rdf:type owl:Class ;
    rdfs:subClassOf ffonto:WaterSource ;
    rdfs:label "Well Water" ;
    rdfs:comment "Groundwater extracted from a well used for drinking or household use." .

ffonto:AgriculturalProduce rdf:type owl:Class ;
    rdfs:label "Agricultural Produce" ;
    rdfs:comment "Food crops grown at home or on farms that may be affected by wildfire ash." .

ffonto:HazardousMaterial rdf:type owl:Class ;
    rdfs:label "Hazardous Material" ;
    rdfs:comment "Dangerous household or industrial substances that require special handling after wildfire." .

ffonto:WildfireSmoke rdf:type owl:Class ;
    rdfs:subClassOf ffonto:Smoke ;
