    rdfs:domain ffonto:AirToxic ;
    rdfs:range ffonto:HealthEffect .

ffonto:causesHealthEffectOf a owl:ObjectProperty ;
    rdfs:label "inverse of causes health effect"@en ;
    rdfs:range ffonto:AirToxic ;
    rdfs:domain ffonto:HealthEffect .

ffonto:causesHealthEffectOf owl:inverseOf ffonto:causesHealthEffect .

ffonto:hasFuelType rdf:type owl:ObjectProperty ;
    rdfs:label "has fuel type" ;
    rdfs:comment "Links fuel materials to fuel categories." ;
    rdfs:domain ffonto:Fuel ;
    rdfs:range ffonto:FuelType .

ffonto:isFuelTypeOf rdf:type owl:ObjectProperty ;
    rdfs:label "is fuel type of" ;
    rdfs:comment "Inverse - Links fuel materials to fuel categories." ;
    rdfs:range ffonto:Fuel ;
    rdfs:domain ffonto:FuelType .

ffonto:isFuelTypeOf owl:inverseOf ffonto:hasFuelType .

# Flammability → Risk Assessment
ffonto:flammabilityInfluencesRiskAssessment rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:SeasonalFlammability ;
    rdfs:range ffonto:RiskAssessment ;
    owl:inverseOf ffonto:isRiskAssessmentInfluencedByFlammability .

ffonto:isRiskAssessmentInfluencedByFlammability rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:RiskAssessment ;
    rdfs:range ffonto:SeasonalFlammability .


# Climate → Fire Weather Index
ffonto:climateDriverInfluencesFireWeatherIndex rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:ClimateDriver ;
    rdfs:range ffonto:FireWeatherIndex ;
    owl:inverseOf ffonto:isFireWeatherIndexInfluencedByClimateDriver .

ffonto:isFireWeatherIndexInfluencedByClimateDriver rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:FireWeatherIndex ;
    rdfs:range ffonto:ClimateDriver .

ffonto:derivedRemoteSensingIndexFrom rdf:type owl:ObjectProperty ;
    rdfs:label "derived from" ;
    rdfs:comment "Links remote sensing indices to methods or satellite data." ;
    rdfs:domain ffonto:RemoteSensingIndex ;
    rdfs:range ffonto:RemoteSensingMethod .

ffonto:derivedRemoteSensingIndexOf rdf:type owl:ObjectProperty ;
    rdfs:label "derived of" ;
    rdfs:comment "Inverse - Links remote sensing indices to methods or satellite data." ;
    rdfs:range ffonto:RemoteSensingIndex ;
    rdfs:domain ffonto:RemoteSensingMethod .

ffonto:derivedRemoteSensingIndexOf owl:inverseOf ffonto:derivedRemoteSensingIndexFrom .

ffonto:dataProvidedBy rdf:type owl:ObjectProperty ;
    rdfs:label "provided by" ;
    rdfs:comment "Indicates organizations providing wildfire datasets." ;
    rdfs:domain ffonto:MonitoringSystem ;
    rdfs:range ffonto:DataProvider .

ffonto:dataProvidedOf a owl:ObjectProperty ;
    rdfs:label "inverse of data provided by"@en ;
    rdfs:range ffonto:MonitoringSystem ;
    rdfs:domain ffonto:DataProvider  .

ffonto:dataProvidedOf owl:inverseOf ffonto:dataProvidedBy .

