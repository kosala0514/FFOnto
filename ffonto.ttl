#################################################################
# DATA PROPERTIES 
#################################################################

ffonto:civilianVehiclesPresent
    a owl:DatatypeProperty ;
    rdfs:label "civilian vehicles present in danger zone" ;
    rdfs:comment "Indicates whether civilian vehicles are present near the wildfire hazard area." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean .

ffonto:visibilityForDriversCompromised
    a owl:DatatypeProperty ;
    rdfs:label "visibility for drivers compromised" ;
    rdfs:comment "Indicates whether smoke or flames reduce visibility for drivers." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean .

ffonto:respondersVisible
    a owl:DatatypeProperty ;
    rdfs:label "firefighter or responder presence visible" ;
    rdfs:comment "Indicates whether responders are visible in the scene." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean .

ffonto:lifeThreateningForVehicles
    a owl:DatatypeProperty ;
    rdfs:label "situation life-threatening for vehicle occupants" ;
    rdfs:comment "Indicates whether vehicles are exposed to immediate life-threatening wildfire hazards." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean .

ffonto:protectiveEquipmentDescription
    a owl:DatatypeProperty ;
    rdfs:label "protective equipment description" ;
    rdfs:comment "Text describing protective equipment worn by responders." ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range xsd:string .

ffonto:activeFireSuppression
    a owl:DatatypeProperty ;
    rdfs:label "active fire suppression occurring" ;
    rdfs:comment "Indicates whether firefighters are actively suppressing fire." ;
    rdfs:domain ffonto:FireSuppressionAction ;
    rdfs:range xsd:boolean .

ffonto:firefightersCloseToFlames
    a owl:DatatypeProperty ;
    rdfs:label "firefighters close to flames" ;
    rdfs:comment "Indicates whether firefighters are operating within close proximity to flames." ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range xsd:boolean .

ffonto:firefighterSafetyRisk
    a owl:DatatypeProperty ;
    rdfs:label "firefighter safety risk present" ;
    rdfs:comment "Indicates whether hazards threaten firefighter safety." ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range xsd:boolean .

ffonto:teamworkObserved
    a owl:DatatypeProperty ;
    rdfs:label "teamwork evident" ;
    rdfs:comment "Indicates whether coordinated teamwork among firefighters is visible." ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range xsd:boolean .

ffonto:defensibleSpacePresent
    a owl:DatatypeProperty ;
    rdfs:label "defensible space around homes" ;
    rdfs:comment "Indicates whether defensible space exists around structures." ;
    rdfs:domain ffonto:StructureFire ;
    rdfs:range xsd:boolean .

ffonto:emergencyVehiclesStaged
    a owl:DatatypeProperty ;
    rdfs:label "emergency vehicles staged for evacuation" ;
    rdfs:comment "Indicates whether emergency vehicles are positioned for evacuation." ;
    rdfs:domain ffonto:EmergencyVehicle ;
    rdfs:range xsd:boolean .

ffonto:visibilityImpairedBySmoke
    a owl:DatatypeProperty ;
    rdfs:label "visibility impaired by smoke" ;
    rdfs:comment "Indicates whether smoke impairs visibility for responders or residents." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean .

ffonto:escapeRoutesViable
    a owl:DatatypeProperty ;
    rdfs:label "escape routes viable" ;
    rdfs:comment "Indicates whether evacuation routes remain open and usable." ;
    rdfs:domain ffonto:EvacuationStatus ;
    rdfs:range xsd:boolean .

ffonto:structureIgnitionRisk
    a owl:DatatypeProperty ;
    rdfs:label "structural ignition risk from radiant heat" ;
    rdfs:comment "Indicates whether structures are likely to ignite due to radiant heat." ;
    rdfs:domain ffonto:StructureFire ;
    rdfs:range xsd:boolean .

ffonto:evacuationRecommended
    a owl:DatatypeProperty ;
    rdfs:label "immediate evacuation recommended" ;
    rdfs:comment "Indicates whether residents should evacuate immediately." ;
    rdfs:domain ffonto:EvacuationStatus ;
    rdfs:range xsd:boolean .

ffonto:helicopterDropAffectedBySmoke
    a owl:DatatypeProperty ;
    rdfs:label "helicopter water drop effectiveness compromised" ;
    rdfs:comment "Indicates whether smoke or wind affects aerial firefighting accuracy." ;
    rdfs:domain ffonto:AerialVehicle ;
    rdfs:range xsd:boolean .

ffonto:pilotNavigationRisk
    a owl:DatatypeProperty ;
    rdfs:label "smoke risk for pilot navigation" ;
    rdfs:comment "Indicates whether smoke affects pilot navigation and visibility." ;
    rdfs:domain ffonto:AerialVehicle ;
    rdfs:range xsd:boolean .

ffonto:aircraftStabilityAffected
    a owl:DatatypeProperty ;
    rdfs:label "aircraft stability affected by updrafts" ;
    rdfs:comment "Indicates whether strong fire convection affects aircraft stability." ;
    rdfs:domain ffonto:AerialVehicle ;
    rdfs:range xsd:boolean .

ffonto:groundCrewRiskFromAerialDrops
    a owl:DatatypeProperty ;
    rdfs:label "ground crews at risk from aerial drops" ;
    rdfs:comment "Indicates whether aerial drops may endanger ground crews." ;
    rdfs:domain ffonto:Responder ;
    rdfs:range xsd:boolean .

ffonto:structureCollapseRisk
    a owl:DatatypeProperty ;
    rdfs:label "structure collapse risk" ;
    rdfs:comment "Indicates whether a burning structure is likely to collapse." ;
    rdfs:domain ffonto:StructureFire ;
    rdfs:range xsd:boolean .

ffonto:explosionRiskPresent
    a owl:DatatypeProperty ;
    rdfs:label "explosion risk present" ;
    rdfs:comment "Indicates whether materials may explode under heat." ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range xsd:boolean .

ffonto:environmentSafeForAnimals
    a owl:DatatypeProperty ;
    rdfs:label "environment safe for animals or civilians" ;
    rdfs:comment "Indicates whether the environment is safe for animals or civilians." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range xsd:boolean .

ffonto:radiantHeatIgnitionRisk
    a owl:DatatypeProperty ;
    rdfs:label "radiant heat can ignite secondary fuels" ;
    rdfs:comment "Indicates whether radiant heat may ignite nearby fuels." ;
    rdfs:domain ffonto:Hazard ;
    rdfs:range xsd:boolean .

ffonto:defensiveStrategyRequired
    a owl:DatatypeProperty ;
    rdfs:label "defensive firefighting strategy required" ;
    rdfs:comment "Indicates whether defensive strategy is recommended instead of interior attack." ;
    rdfs:domain ffonto:FireSuppressionAction ;
    rdfs:range xsd:boolean .

ffonto:firefightersWearingPPE
    a owl:DatatypeProperty ;
    rdfs:label "firefighters wearing protective gear" ;
    rdfs:comment "Indicates whether firefighters appear equipped with PPE." ;
    rdfs:domain ffonto:Firefighter ;
    rdfs:range xsd:boolean .

ffonto:firefightersCommunicating
    a owl:DatatypeProperty ;
    rdfs:label "firefighters communicating via radio" ;
    rdfs:comment "Indicates whether firefighters are communicating through radios." ;
    rdfs:domain ffonto:Communication ;
    rdfs:range xsd:boolean .

ffonto:firefightersMovingTowardFire
    a owl:DatatypeProperty ;
