    a owl:ObjectProperty ;
    rdfs:label "vehicle part of" ;
    rdfs:comment "Inverse - Indicates that a window is part of a vehicle." ;
    rdfs:range ffonto:Window ;
    rdfs:domain ffonto:Vehicle .

ffonto:vehiclePartOf owl:inverseOf ffonto:partOfVehicle .

ffonto:observedAtScene rdf:type owl:ObjectProperty ;
    rdfs:label "observed at scene" ;
    rdfs:comment "Links an observation or object to the WildfireScene where it was observed." ;
    rdfs:domain ffonto:Observation ;
    rdfs:range ffonto:WildfireScene .

ffonto:observedAtSceneOf rdf:type owl:ObjectProperty ;
    rdfs:label "observed at scene of" ;
    rdfs:comment "Inverse - Links an observation or object to the WildfireScene where it was observed." ;
    rdfs:range ffonto:Observation ;
    rdfs:domain ffonto:WildfireScene .

ffonto:observedAtSceneOf owl:inverseOf ffonto:observedAtScene .

ffonto:sceneLocatedIn
    rdfs:subPropertyOf ffonto:locatedAt ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            ffonto:Infrastructure
            ffonto:Vegetation
            ffonto:BurnEvidence
            ffonto:OutdoorItems
        )
    ] ;
    rdfs:range ffonto:WildfireScene .

ffonto:sceneLocatedOf a owl:ObjectProperty ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf (
            ffonto:Infrastructure
            ffonto:Vegetation
            ffonto:BurnEvidence
            ffonto:OutdoorItems
        )
    ] ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:label "inverse of scene located in"@en  .

ffonto:sceneLocatedOf owl:inverseOf ffonto:sceneLocatedIn .

ffonto:fireLocatedAt
    rdfs:subPropertyOf ffonto:hasLocation ;
    rdfs:domain ffonto:FireEvent ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf (
            ffonto:FireEvent
            ffonto:StructureFire
            ffonto:NaturalFeature
        )
    ] .

ffonto:locatedfireOf
    rdfs:subPropertyOf ffonto:hasLocation ;
    rdfs:range ffonto:FireEvent ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            ffonto:FireEvent
            ffonto:StructureFire
            ffonto:NaturalFeature
        )
    ] .

ffonto:locatedfireOf owl:inverseOf ffonto:fireLocatedAt .

ffonto:affectsWaterBody
    a owl:ObjectProperty ;
    rdfs:label "affects water body" ;
    rdfs:comment "Indicates that wildfire impacts affect a nearby water body." ;
    rdfs:domain ffonto:WildfireScene ;
    rdfs:range ffonto:WaterBody .

ffonto:affectsWaterBodyOf
    a owl:ObjectProperty ;
