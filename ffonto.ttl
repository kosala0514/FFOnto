ffonto:isSnowCoverOf owl:inverseOf ffonto:hasSnowCover .

ffonto:contributesToFireIntensity rdf:type owl:ObjectProperty ;
    rdfs:domain ffonto:Tree ;
    rdfs:range ffonto:FireEvent ;
    rdfs:label "contributes to fire intensity" ;
